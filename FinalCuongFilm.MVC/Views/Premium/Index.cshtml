@model IEnumerable<FinalCuongFilm.ApplicationCore.Entities.VipPackage>
@{
    Layout = "_LayoutUser";
    ViewData["Title"] = "CuongFilm Premium";
}

<style>
    .pricing-header {
        text-align: center;
        padding: 50px 0;
        color: #fff;
    }

    .pricing-title {
        font-size: 2.5rem;
        font-weight: 700;
        margin-bottom: 15px;
    }

    .pricing-subtitle {
        color: #a3a3a3;
        font-size: 1.1rem;
    }

    .vip-card {
        background: #1f1f1f;
        border: 1px solid #333;
        border-radius: 12px;
        padding: 30px;
        text-align: center;
        transition: transform 0.3s, border-color 0.3s;
        height: 100%;
        display: flex;
        flex-direction: column;
    }

        .vip-card:hover {
            transform: translateY(-10px);
            border-color: #e50914;
            box-shadow: 0 10px 20px rgba(229, 9, 20, 0.2);
        }

        .vip-card.popular {
            border-color: #e50914;
            position: relative;
        }

    .vip-badge {
        position: absolute;
        top: -12px;
        left: 50%;
        transform: translateX(-50%);
        background: #e50914;
        color: white;
        padding: 4px 12px;
        border-radius: 20px;
        font-size: 0.8rem;
        font-weight: bold;
        text-transform: uppercase;
    }

    .package-name {
        color: #fff;
        font-size: 1.5rem;
        font-weight: 600;
        margin-bottom: 15px;
    }

    .package-price {
        font-size: 2.5rem;
        font-weight: 700;
        color: #fff;
        margin-bottom: 5px;
    }

    .package-duration {
        color: #8c8c8c;
        margin-bottom: 25px;
    }

    .package-desc {
        color: #ccc;
        margin-bottom: 30px;
        flex-grow: 1;
    }

    /* Fixed btn-buy to work perfectly as an <a> tag */
    .btn-buy {
        background: #e50914;
        color: #fff;
        border: none;
        padding: 12px 0;
        width: 100%;
        border-radius: 4px;
        font-weight: 600;
        font-size: 1.1rem;
        transition: background 0.2s;
        display: block;
        text-decoration: none;
    }

        .btn-buy:hover {
            background: #b20710;
            color: #fff;
            text-decoration: none;
        }

    .current-vip-alert {
        background: rgba(46, 204, 113, 0.1);
        border: 1px solid #2ecc71;
        color: #2ecc71;
        padding: 15px;
        border-radius: 8px;
        text-align: center;
        margin-bottom: 30px;
    }
</style>

<div class="container" style="margin-bottom: 80px;">
    <div class="pricing-header">
        <h1 class="pricing-title">Ultimate Cinematic Experience</h1>
        <p class="pricing-subtitle">Unlock the entire premium movie library. Ad-free. Ultra HD 4K Quality.</p>
    </div>

    @if (TempData["Success"] != null)
    {
        <div class="alert alert-success text-center">@TempData["Success"]</div>
    }

    @if (TempData["Error"] != null)
    {
        <div class="alert alert-danger text-center">@TempData["Error"]</div>
    }

    @if (ViewBag.CurrentVipEndDate != null)
    {
        <div class="current-vip-alert">
            <i class="zmdi zmdi-star"></i> You are currently a Premium member. Valid until: <strong>@(((DateTime)ViewBag.CurrentVipEndDate).ToString("MM/dd/yyyy"))</strong>.
            <br />(If you purchase a new plan, the days will be added to your current balance).
        </div>
    }

    <div class="row justify-content-center g-4">
        @if (Model != null && Model.Any())
        {
            int count = 0;
            foreach (var pkg in Model)
            {
                count++;
                <div class="col-12 col-md-4">
                    <div class="vip-card @(count == 2 ? "popular" : "")">
                        @if (count == 2)
                        {
                            <div class="vip-badge">Most Popular</div>
                        }

                        <div class="package-name">@pkg.Name</div>
                        <div class="package-price">@pkg.Price.ToString("N0") VNĐ</div>
                        <div class="package-duration">Valid for @pkg.DurationInDays days</div>

                        <div class="package-desc">
                            @if (!string.IsNullOrEmpty(pkg.Description))
                            {
                                @pkg.Description
                            }
                            else
                            {
                                <ul style="list-style: none; padding: 0; text-align: left;">
                                    <li style="margin-bottom: 10px;"><i class="zmdi zmdi-check" style="color: #e50914; margin-right: 8px;"></i>Exclusive Premium Movies</li>
                                    <li style="margin-bottom: 10px;"><i class="zmdi zmdi-check" style="color: #e50914; margin-right: 8px;"></i>Ultra HD 4K Resolution</li>
                                    <li><i class="zmdi zmdi-check" style="color: #e50914; margin-right: 8px;"></i>No Annoying Ads</li>
                                </ul>
                            }
                        </div>

                        <a asp-action="Checkout" asp-route-packageId="@pkg.Id" class="btn-buy">
                            BUY THIS PLAN
                        </a>
                    </div>
                </div>
            }
        }
        else
        {
            <div class="col-12 text-center" style="color: #8c8c8c;">
                <h4>The system is currently updating pricing plans. Please come back later!</h4>
            </div>
        }
    </div>
</div>