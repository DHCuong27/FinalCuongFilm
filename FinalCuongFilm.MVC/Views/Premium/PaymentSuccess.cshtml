@{
    ViewData["Title"] = "Thanh toán thành công";
    Layout = "_LayoutUser";
}

<style>
    .success-icon {
        animation: popIn 0.6s cubic-bezier(0.175, 0.885, 0.32, 1.275) forwards;
        transform: scale(0);
    }

    @@keyframes popIn {
        0% {
            transform: scale(0);
            opacity: 0;
        }

        100% {
            transform: scale(1);
            opacity: 1;
        }
    }

    .receipt-box {
        background: #f8f9fa;
        border: 1px dashed #dee2e6;
        border-radius: 10px;
    }
</style>

<div class="container d-flex justify-content-center align-items-center" style="min-height: 75vh; margin-top: 50px; margin-bottom: 50px;">
    <div class="card shadow-lg border-0" style="max-width: 550px; width: 100%; border-radius: 20px; overflow: hidden;">

        <div class="bg-success text-white text-center py-5">
            <i class="fa fa-check-circle success-icon" style="font-size: 85px;"></i>
            <h2 class="mt-3 fw-bold mb-0">Payment Successful!</h2>
        </div>

        <div class="card-body p-4 p-md-5">
            <p class="text-center text-muted fs-6 mb-4">Your transaction has been completed via ZaloPay.</p>

            @if (ViewBag.IsPending == false)
            {
                <div class="receipt-box p-4 mb-4" style="background: #f8f9fa; border: 1px dashed #dee2e6; border-radius: 10px;">
                    <h5 class="fw-bold border-bottom pb-2 mb-3 text-center">Transaction Details</h5>

                    <div class="d-flex justify-content-between align-items-center mb-3">
                        <span class="text-muted"><i class="fa fa-box me-2"></i>Package:</span>
                        <span class="fw-bold text-dark fs-5">@ViewBag.PackageName</span>
                    </div>

                    <div class="d-flex justify-content-between align-items-center mb-3">
                        <span class="text-muted"><i class="fa fa-info-circle me-2"></i>Status:</span>
                        <span class="badge bg-success px-3 py-2 rounded-pill">Active</span>
                    </div>

                    <div class="d-flex justify-content-between align-items-center">
                        <span class="text-muted"><i class="fa fa-calendar-alt me-2"></i>Valid Until:</span>
                        <span class="fw-bold text-danger fs-5">@ViewBag.ExpiryDate</span>
                    </div>
                </div>
            }
            else
            {
                <div class="alert alert-warning border-0 shadow-sm rounded-3 p-4 text-center mb-4">
                    <div class="spinner-border text-warning mb-3" role="status"></div>
                    <h5 class="fw-bold text-dark">Processing...</h5>
                    <p class="mb-0 text-muted small">
                        Your transaction is being verified. Your Premium benefits will be activated in 1-2 minutes.
                    </p>
                </div>
            }

            <hr class="my-4" style="border-color: #eee;">

            <div class="d-grid gap-3">
                <a href="/Movie" class="btn btn-danger btn-lg rounded-pill fw-bold py-3">
                    <i class="fa fa-play me-2"></i> Watch Premium Movies
                </a>
                <a href="/" class="btn btn-light btn-lg rounded-pill fw-bold text-muted border py-2">
                    <i class="fa fa-home me-1"></i> Back to Home
                </a>
            </div>
        </div>
    </div>
</div>