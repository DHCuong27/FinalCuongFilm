@model FinalCuongFilm.ApplicationCore.Entities.VipPackage
@{
    Layout = "_LayoutUser";
    ViewData["Title"] = "Premium Package Checkout";
}

<style>
    .checkout-container {
        max-width: 800px;
        margin: 50px auto 100px;
        background: #1f1f1f;
        border-radius: 12px;
        padding: 40px;
        color: #fff;
        box-shadow: 0 10px 30px rgba(0,0,0,0.5);
    }

    .order-summary {
        background: #141414;
        border: 1px solid #333;
        border-radius: 8px;
        padding: 25px;
        margin-bottom: 30px;
    }

    .summary-row {
        display: flex;
        justify-content: space-between;
        margin-bottom: 15px;
        font-size: 1.1rem;
    }

        .summary-row.total {
            border-top: 1px dashed #444;
            padding-top: 15px;
            font-size: 1.5rem;
            font-weight: bold;
            color: #e50914;
        }

    .payment-methods {
        margin-bottom: 30px;
    }

    .payment-option {
        display: flex;
        align-items: center;
        background: #2b2b2b;
        border: 2px solid #e50914;
        border-radius: 8px;
        padding: 15px 20px;
        cursor: pointer;
    }

        .payment-option img {
            height: 30px;
            margin-right: 15px;
        }

        .payment-option span {
            font-size: 1.2rem;
            font-weight: 600;
        }

    .btn-pay {
        background: #e50914;
        color: #fff;
        border: none;
        padding: 15px;
        width: 100%;
        border-radius: 6px;
        font-size: 1.3rem;
        font-weight: bold;
        transition: background 0.3s;
    }

        .btn-pay:hover {
            background: #b20710;
        }

    .security-badge {
        text-align: center;
        margin-top: 15px;
        color: #888;
        font-size: 0.9rem;
    }
</style>

<div class="container">
    <div class="checkout-container">
        <h2 class="mb-4 text-center">Confirm Payment</h2>

        <div class="order-summary">
            <h4 class="mb-3 text-white">Order Details</h4>
            <div class="summary-row">
                <span style="color: #ccc;">Package:</span>
                <span>@Model.Name</span>
            </div>
            <div class="summary-row">
                <span style="color: #ccc;">Account:</span>
                <span>@User.Identity?.Name</span>
            </div>
            <div class="summary-row">
                <span style="color: #ccc;">Duration:</span>
                <span>@Model.DurationInDays days</span>
            </div>
            <div class="summary-row total">
                <span>Total Amount:</span>
                <span>@Model.Price.ToString("N0") VND</span>
            </div>
        </div>

        <div class="payment-methods">
            <h4 class="mb-3 text-white">Payment Method</h4>
            <div class="payment-option">
                <img src="https://media.loveitopcdn.com/3807/thumb/logo-zalopay1-compressed.jpg" alt="ZALOPAY" />
                <span>Pay via ZaloPay Gateway</span>
            </div>
        </div>

        <form asp-action="ProcessPayment" method="post">
            <input type="hidden" name="packageId" value="@Model.Id" />
            <button type="submit" class="btn-pay">
                <i class="zmdi zmdi-lock"></i> SECURE CHECKOUT
            </button>
        </form>

        <div class="security-badge">
            <i class="zmdi zmdi-shield-security"></i> All transactions are encrypted with 256-bit SSL.
        </div>
    </div>
</div>