@model FinalCuongFilm.MVC.Models.ViewModels.MovieFilterViewModel
@{
    ViewData["Title"] = Model.PageTitle ?? "Movie Genre";
    Layout = "_LayoutUser";
    var genreSlug = ViewBag.GenreSlug as string;
}

<style>
    :root {
        --netflix-red: #e50914;
        --netflix-dark: #0f0f0f;
        --netflix-dark-bg: #1a1a1a;
        --netflix-gray: #2d2d2d;
        --netflix-light-gray: #b3b3b3;
    }

    body {
        background-color: var(--netflix-dark);
        color: white;
        font-family: 'Segoe UI', sans-serif;
    }

    .page-container {
        max-width: 1400px;
        margin: 0 auto;
        padding: 100px 2rem 3rem;
    }

    .page-hero {
        margin-bottom: 2rem;
        padding-bottom: 1.5rem;
        border-bottom: 2px solid var(--netflix-gray);
        position: relative;
    }

        .page-hero::after {
            content: '';
            position: absolute;
            bottom: -2px;
            left: 0;
            width: 120px;
            height: 2px;
            background: var(--netflix-red);
        }

        .page-hero h1 {
            font-size: 2.5rem;
            font-weight: 800;
            display: flex;
            align-items: center;
            gap: 1rem;
        }

            .page-hero h1 i {
                color: var(--netflix-red);
            }

        .page-hero p {
            color: var(--netflix-light-gray);
            margin-top: 0.5rem;
        }

    /* Sort Bar */
    .sort-bar {
        display: flex;
        align-items: center;
        justify-content: space-between;
        margin-bottom: 1.5rem;
        flex-wrap: wrap;
        gap: 1rem;
    }

    .sort-bar-left {
        color: var(--netflix-light-gray);
        font-size: 0.9rem;
    }

        .sort-bar-left span {
            color: var(--netflix-red);
            font-weight: 700;
        }

    .sort-group {
        display: flex;
        align-items: center;
        gap: 0.5rem;
    }

        .sort-group label {
            color: var(--netflix-light-gray);
            font-size: 0.85rem;
            white-space: nowrap;
        }

    .filter-select {
        background: var(--netflix-gray);
        border: 1px solid rgba(255,255,255,0.15);
        color: white;
        border-radius: 8px;
        padding: 0.5rem 1rem;
        font-size: 0.85rem;
        cursor: pointer;
    }

        .filter-select:focus {
            outline: none;
            border-color: var(--netflix-red);
        }

        .filter-select option {
            background: var(--netflix-gray);
        }

    /* Movies Grid */
    .movies-grid {
        display: grid;
        grid-template-columns: repeat(auto-fill, minmax(180px, 1fr));
        gap: 1.2rem;
        margin-bottom: 3rem;
    }

    .grid-card {
        position: relative;
        border-radius: 8px;
        overflow: hidden;
        background: var(--netflix-dark-bg);
        border: 1px solid var(--netflix-gray);
        transition: transform 0.3s, box-shadow 0.3s;
    }

        .grid-card:hover {
            transform: translateY(-6px);
            box-shadow: 0 12px 30px rgba(0,0,0,0.7);
        }

    .grid-card-poster {
        position: relative;
        aspect-ratio: 2/3;
        overflow: hidden;
    }

        .grid-card-poster img {
            width: 100%;
            height: 100%;
            object-fit: cover;
            transition: transform 0.4s;
        }

    .grid-card:hover .grid-card-poster img {
        transform: scale(1.05);
    }

    .grid-card-overlay {
        position: absolute;
        inset: 0;
        background: linear-gradient(180deg, transparent 50%, rgba(0,0,0,0.95) 100%);
        opacity: 0;
        transition: opacity 0.3s;
        display: flex;
        align-items: flex-end;
        padding: 1rem;
    }

    .grid-card:hover .grid-card-overlay {
        opacity: 1;
    }

    .btn-play-card {
        display: inline-flex;
        align-items: center;
        gap: 0.4rem;
        background: var(--netflix-red);
        color: white;
        padding: 0.5rem 1rem;
        border-radius: 6px;
        text-decoration: none;
        font-size: 0.85rem;
        font-weight: 600;
    }

        .btn-play-card:hover {
            background: #f40612;
            color: white;
        }

    .grid-card-info {
        padding: 0.8rem;
    }

    .grid-card-title {
        font-size: 0.9rem;
        font-weight: 600;
        margin-bottom: 0.3rem;
        white-space: nowrap;
        overflow: hidden;
        text-overflow: ellipsis;
    }

        .grid-card-title a {
            color: white;
            text-decoration: none;
        }

            .grid-card-title a:hover {
                color: var(--netflix-red);
            }

    .grid-card-meta {
        font-size: 0.78rem;
        color: var(--netflix-light-gray);
        display: flex;
        gap: 0.5rem;
    }

    .badge-type {
        position: absolute;
        top: 8px;
        left: 8px;
        background: rgba(229,9,20,0.85);
        color: white;
        padding: 0.2rem 0.6rem;
        border-radius: 4px;
        font-size: 0.7rem;
        font-weight: 700;
        z-index: 3;
    }

    /* Pagination */
    .pagination-wrapper {
        display: flex;
        justify-content: center;
        align-items: center;
        gap: 0.5rem;
        margin: 2rem 0;
        flex-wrap: wrap;
    }

    .page-btn {
        background: var(--netflix-gray);
        color: white;
        border: 1px solid rgba(255,255,255,0.1);
        padding: 0.5rem 0.9rem;
        border-radius: 6px;
        text-decoration: none;
        font-size: 0.9rem;
        transition: all 0.2s;
    }

        .page-btn:hover {
            background: var(--netflix-red);
            border-color: var(--netflix-red);
            color: white;
        }

        .page-btn.active {
            background: var(--netflix-red);
            border-color: var(--netflix-red);
            font-weight: 700;
        }

        .page-btn.disabled {
            opacity: 0.4;
            pointer-events: none;
        }

    .netflix-alert {
        background: var(--netflix-dark-bg);
        border: 1px solid var(--netflix-gray);
        border-radius: 8px;
        padding: 3rem;
        text-align: center;
    }

        .netflix-alert i {
            color: var(--netflix-red);
            font-size: 2rem;
            margin-bottom: 1rem;
            display: block;
        }

    @@media (max-width: 768px) {
        .page-container {
            padding: 80px 1rem 2rem;
        }

        .sort-bar {
            flex-direction: column;
            align-items: flex-start;
        }

        .movies-grid {
            grid-template-columns: repeat(auto-fill, minmax(140px, 1fr));
        }
    }
</style>

<div class="page-container">
    <div class="page-hero">
        <h1><i class="fas fa-theater-masks"></i> @Model.PageTitle</h1>
        <p>@Model.PageSubTitle</p>
    </div>

    <div class="sort-bar">
        <div class="sort-bar-left">
            Showing <span>@Model.Movies.Count</span> / <span>@Model.TotalItems</span> movies
            — Page <span>@Model.PageNumber</span> / <span>@(Model.TotalPages == 0 ? 1 : Model.TotalPages)</span>
        </div>
        <form method="get" asp-action="Index" asp-controller="Genre" class="sort-group">
            <input type="hidden" name="slug" value="@genreSlug" />
            <label for="sortBy"><i class="fas fa-sort"></i> Sort by:</label>
            <select name="sortBy" id="sortBy" class="filter-select" onchange="this.form.submit()">
                <option value="latest" selected="@(Model.SortBy == "latest" ? "selected" : null)">Latest</option>
                <option value="popular" selected="@(Model.SortBy == "popular" ? "selected" : null)">Most Popular</option>
                <option value="title" selected="@(Model.SortBy == "title" ? "selected" : null)">Name A-Z</option>
            </select>
        </form>
    </div>

    @if (Model.Movies.Any())
    {
        <div class="movies-grid">
            @foreach (var movie in Model.Movies)
            {
                <div class="grid-card">
                    <div class="grid-card-poster">
                        <a asp-controller="Movie" asp-action="Detail" asp-route-slug="@movie.Slug">
                            <img src="@(movie.PosterUrl ?? "https://via.placeholder.com/300x450/2d2d2d/fff?text=No+Poster")" alt="@movie.Title" loading="lazy" />
                        </a>
                        <span class="badge-type">@(movie.Type.ToString() == "Series" ? "Series" : "Movie")</span>
                        <div class="grid-card-overlay">
                            <a asp-controller="Movie" asp-action="Watch" asp-route-slug="@movie.Slug" class="btn-play-card">
                                <i class="fas fa-play"></i> Watch Now
                            </a>
                        </div>
                    </div>
                    <div class="grid-card-info">
                        <div class="grid-card-title">
                            <a asp-controller="Movie" asp-action="Detail" asp-route-slug="@movie.Slug">@movie.Title</a>
                        </div>
                        <div class="grid-card-meta">
                            @if (movie.ReleaseYear.HasValue)
                            {
                                <span><i class="fas fa-calendar"></i> @movie.ReleaseYear</span>
                            }
                            @if (!string.IsNullOrEmpty(movie.CountryName))
                            {
                                <span>@movie.CountryName</span>
                            }
                        </div>
                    </div>
                </div>
            }
        </div>

        @if (Model.TotalPages > 1)
        {
            <div class="pagination-wrapper">
                <a asp-action="Index" asp-controller="Genre"
                   asp-route-slug="@genreSlug" asp-route-sortBy="@Model.SortBy" asp-route-pageNumber="@(Model.PageNumber - 1)"
                   class="page-btn @(!Model.HasPreviousPage ? "disabled" : "")">
                    <i class="fas fa-chevron-left"></i> Prev
                </a>

                @for (int i = Math.Max(1, Model.PageNumber - 2); i <= Math.Min(Model.TotalPages, Model.PageNumber + 2); i++)
                {
                    <a asp-action="Index" asp-controller="Genre"
                       asp-route-slug="@genreSlug" asp-route-sortBy="@Model.SortBy" asp-route-pageNumber="@i"
                       class="page-btn @(i == Model.PageNumber ? "active" : "")">@i</a>
                }

                <a asp-action="Index" asp-controller="Genre"
                   asp-route-slug="@genreSlug" asp-route-sortBy="@Model.SortBy" asp-route-pageNumber="@(Model.PageNumber + 1)"
                   class="page-btn @(!Model.HasNextPage ? "disabled" : "")">
                    Next <i class="fas fa-chevron-right"></i>
                </a>
            </div>
        }
    }
    else
    {
        <div class="netflix-alert">
            <i class="fas fa-film"></i>
            <h3>No movies found in this genre</h3>
            <p><a asp-controller="Movie" asp-action="Index" style="color:var(--netflix-red);">View all movies</a></p>
        </div>
    }
</div>