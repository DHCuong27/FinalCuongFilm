@{
    ViewData["Title"] = ViewBag.Movie.Title + " - Watch";
    Layout = "_LayoutUser";
    var movie = ViewBag.Movie as FinalCuongFilm.Common.DTOs.MovieDto;
    var mediaFile = ViewBag.MediaFile as FinalCuongFilm.Common.DTOs.MediaFileDto;
    var currentEpisode = ViewBag.CurrentEpisode as FinalCuongFilm.Common.DTOs.EpisodeDto;
    var episodes = ViewBag.Episodes as IEnumerable<FinalCuongFilm.Common.DTOs.EpisodeDto>;
}

<style>
    :root {
        --player-bg: #000000;
        --player-controls: rgba(0, 0, 0, 0.7);
        --netflix-red: #e50914;
    }

    body {
        background-color: var(--player-bg);
        overflow-x: hidden;
    }

    .watch-container {
        min-height: 100vh;
        background: var(--player-bg);
    }

    /* Video Player */
    .video-player-wrapper {
        position: relative;
        width: 100%;
        background: #000;
    }

    .video-player {
        width: 100%;
        height: auto;
        max-height: 80vh;
        background: #000;
    }

    video {
        width: 100%;
        height: 100%;
        outline: none;
    }

    /* Custom Controls */
    .player-controls {
        position: absolute;
        bottom: 0;
        left: 0;
        right: 0;
        background: linear-gradient(to top, rgba(0,0,0,0.9), transparent);
        padding: 20px;
        opacity: 0;
        transition: opacity 0.3s;
    }

        .video-player-wrapper:hover .player-controls,
        .player-controls.show {
            opacity: 1;
        }

    .progress-bar {
        width: 100%;
        height: 5px;
        background: rgba(255,255,255,0.3);
        cursor: pointer;
        margin-bottom: 15px;
        position: relative;
    }

    .progress-filled {
        height: 100%;
        background: var(--netflix-red);
        width: 0%;
        transition: width 0.1s;
    }

    .progress-buffered {
        position: absolute;
        top: 0;
        left: 0;
        height: 100%;
        background: rgba(255,255,255,0.5);
        width: 0%;
    }

    .controls-row {
        display: flex;
        align-items: center;
        justify-content: space-between;
        color: white;
    }

    .controls-left,
    .controls-right {
        display: flex;
        align-items: center;
        gap: 15px;
    }

    .control-btn {
        background: none;
        border: none;
        color: white;
        font-size: 1.5rem;
        cursor: pointer;
        padding: 5px;
        transition: transform 0.2s;
    }

        .control-btn:hover {
            transform: scale(1.2);
        }

    .time-display {
        font-size: 0.9rem;
        font-weight: 500;
    }

    .volume-control {
        display: flex;
        align-items: center;
        gap: 10px;
    }

    .volume-slider {
        width: 80px;
        height: 5px;
    }

    /* Loading Spinner */
    .loading-spinner {
        position: absolute;
        top: 50%;
        left: 50%;
        transform: translate(-50%, -50%);
        display: none;
    }

    .spinner {
        width: 50px;
        height: 50px;
        border: 4px solid rgba(255,255,255,0.3);
        border-top: 4px solid var(--netflix-red);
        border-radius: 50%;
        animation: spin 1s linear infinite;
    }

    @@keyframes spin {
        to

    {
        transform: rotate(360deg);
    }

    }

    /* Movie Info */
    .movie-info {
        max-width: 1400px;
        margin: 0 auto;
        padding: 30px 20px;
        color: white;
    }

    .movie-title {
        font-size: 2rem;
        font-weight: 700;
        margin-bottom: 10px;
    }

    .movie-meta {
        color: #999;
        margin-bottom: 20px;
    }

    /* Episodes List */
    .episodes-section {
        margin-top: 30px;
    }

    .section-title {
        font-size: 1.5rem;
        font-weight: 700;
        margin-bottom: 20px;
        display: flex;
        align-items: center;
        gap: 10px;
    }

    .episodes-grid {
        display: grid;
        grid-template-columns: repeat(auto-fill, minmax(250px, 1fr));
        gap: 15px;
    }

    .episode-card {
        background: rgba(255,255,255,0.1);
        border-radius: 8px;
        overflow: hidden;
        cursor: pointer;
        transition: all 0.3s;
        text-decoration: none;
        color: white;
        border: 2px solid transparent;
    }

        .episode-card:hover {
            transform: scale(1.05);
            border-color: var(--netflix-red);
            color: white;
        }

        .episode-card.active {
            border-color: var(--netflix-red);
            background: rgba(229, 9, 20, 0.2);
        }

    .episode-thumb {
        aspect-ratio: 16/9;
        background: #333;
        display: flex;
        align-items: center;
        justify-content: center;
        font-size: 2rem;
        color: #666;
    }

    .episode-info {
        padding: 15px;
    }

    .episode-number {
        font-size: 0.85rem;
        color: #999;
        margin-bottom: 5px;
    }

    .episode-title {
        font-size: 1rem;
        font-weight: 600;
        margin-bottom: 8px;
    }

    .episode-duration {
        font-size: 0.85rem;
        color: #999;
    }

    /* Quality Selector */
    .quality-selector {
        position: relative;
    }

    .quality-menu {
        position: absolute;
        bottom: 100%;
        right: 0;
        background: rgba(0,0,0,0.9);
        border-radius: 4px;
        padding: 10px;
        display: none;
        min-width: 120px;
    }

        .quality-menu.show {
            display: block;
        }

    .quality-option {
        padding: 8px 12px;
        cursor: pointer;
        border-radius: 4px;
        transition: background 0.2s;
    }

        .quality-option:hover {
            background: rgba(255,255,255,0.1);
        }

        .quality-option.active {
            color: var(--netflix-red);
            font-weight: 600;
        }
</style>

<div class="watch-container">
    <!-- Video Player -->
    <div class="video-player-wrapper" id="videoWrapper">
        <video id="videoPlayer" class="video-player" preload="metadata">
            <source src="" type="video/mp4">
            Your browser does not support the video tag.
        </video>

        <!-- Loading Spinner -->
        <div class="loading-spinner" id="loadingSpinner">
            <div class="spinner"></div>
        </div>

        <!-- Custom Controls -->
        <div class="player-controls" id="playerControls">
            <!-- Progress Bar -->
            <div class="progress-bar" id="progressBar">
                <div class="progress-buffered" id="progressBuffered"></div>
                <div class="progress-filled" id="progressFilled"></div>
            </div>

            <!-- Controls Row -->
            <div class="controls-row">
                <div class="controls-left">
                    <button class="control-btn" id="playPauseBtn" title="Play/Pause">
                        <i class="fas fa-play"></i>
                    </button>

                    <button class="control-btn" id="rewindBtn" title="Rewind 10s">
                        <i class="fas fa-backward"></i>
                    </button>

                    <button class="control-btn" id="forwardBtn" title="Forward 10s">
                        <i class="fas fa-forward"></i>
                    </button>

                    <div class="volume-control">
                        <button class="control-btn" id="volumeBtn" title="Mute/Unmute">
                            <i class="fas fa-volume-up"></i>
                        </button>
                        <input type="range" id="volumeSlider" class="volume-slider" min="0" max="100" value="100">
                    </div>

                    <span class="time-display">
                        <span id="currentTime">0:00</span> / <span id="duration">0:00</span>
                    </span>
                </div>

                <div class="controls-right">
                    <button class="control-btn" id="subtitleBtn" title="Subtitles">
                        <i class="fas fa-closed-captioning"></i>
                    </button>

                    <div class="quality-selector">
                        <button class="control-btn" id="qualityBtn" title="Quality">
                            <i class="fas fa-cog"></i>
                        </button>
                        <div class="quality-menu" id="qualityMenu">
                            <div class="quality-option active" data-quality="auto">Auto</div>
                            <div class="quality-option" data-quality="1080p">1080p</div>
                            <div class="quality-option" data-quality="720p">720p</div>
                            <div class="quality-option" data-quality="480p">480p</div>
                        </div>
                    </div>

                    <button class="control-btn" id="fullscreenBtn" title="Fullscreen">
                        <i class="fas fa-expand"></i>
                    </button>
                </div>
            </div>
        </div>
    </div>

    <!-- Movie Info -->
    <div class="movie-info">
        <h1 class="movie-title">
            @movie.Title
            @if (currentEpisode != null)
            {
                <span style="font-weight: 400; color: #999;"> - Tập @currentEpisode.EpisodeNumber</span>
            }
        </h1>

        <div class="movie-meta">
            @if (movie.ReleaseYear.HasValue)
            {
                <span>@movie.ReleaseYear</span>
                <span> • </span>
            }
            <span>@movie.Type</span>
            @if (mediaFile.Quality != null)
            {
                <span> • </span>
                <span>@mediaFile.Quality</span>
            }
        </div>

        @if (!string.IsNullOrEmpty(movie.Description))
        {
            <p style="color: #ccc; line-height: 1.6; max-width: 800px;">@movie.Description</p>
        }

        <!-- Episodes List -->
        @if (episodes != null && episodes.Any())
        {
            <div class="episodes-section">
                <h2 class="section-title">
                    <i class="fas fa-list"></i>
                    Episodes (@episodes.Count())
                </h2>

                <div class="episodes-grid">
                    @foreach (var episode in episodes.OrderBy(e => e.EpisodeNumber))
                    {
                        <a href="@Url.Action("Watch", "Movie", new { slug = movie.Slug, ep = episode.EpisodeNumber })"
                           class="episode-card @(currentEpisode?.Id == episode.Id ? "active" : "")">
                            <div class="episode-thumb">
                                <i class="fas fa-play-circle"></i>
                            </div>
                            <div class="episode-info">
                                <div class="episode-number">Tập @episode.EpisodeNumber</div>
                                <div class="episode-title">@episode.Title</div>
                                @if (episode.DurationMinutes.HasValue)
                                {
                                    <div class="episode-duration">@episode.DurationMinutes phút</div>
                                }
                            </div>
                        </a>
                    }
                </div>
            </div>
        }
    </div>
</div>

@section Scripts {
    <script>
        const mediaFileId = '@mediaFile.Id';
        const movieId = '@movie.Id';
        const episodeId = '@(currentEpisode?.Id ?? Guid.Empty)';

        let video;
        let isPlaying = false;
        let controlsTimeout;

        $(document).ready(function() {
            video = document.getElementById('videoPlayer');
            initializePlayer();
        });

        async function initializePlayer() {
            try {
                showLoading(true);

                // Get streaming URL from server
                const response = await fetch(`/Stream/Video/${mediaFileId}`);
                const data = await response.json();

                if (data.success) {
                    video.src = data.url;

                    // Load saved progress
                    await loadProgress();

                    setupEventListeners();
                    showLoading(false);
                } else {
                    alert('Không thể tải video');
                }
            } catch (error) {
                console.error('Error initializing player:', error);
                alert('Lỗi khi tải video');
                showLoading(false);
            }
        }

        function setupEventListeners() {
            // Video events
            video.addEventListener('loadedmetadata', updateDuration);
            video.addEventListener('timeupdate', updateProgress);
            video.addEventListener('progress', updateBuffered);
            video.addEventListener('play', () => updatePlayPauseIcon(true));
            video.addEventListener('pause', () => updatePlayPauseIcon(false));
            video.addEventListener('waiting', () => showLoading(true));
            video.addEventListener('canplay', () => showLoading(false));

            // Controls
            $('#playPauseBtn').click(togglePlay);
            $('#rewindBtn').click(() => skip(-10));
            $('#forwardBtn').click(() => skip(10));
            $('#volumeBtn').click(toggleMute);
            $('#volumeSlider').on('input', changeVolume);
            $('#fullscreenBtn').click(toggleFullscreen);
            $('#progressBar').click(seek);
            $('#qualityBtn').click(toggleQualityMenu);

            // Keyboard shortcuts
            $(document).keydown(handleKeyboard);

            // Hide controls on mouse idle
            $('#videoWrapper').mousemove(showControls);
            $('#videoWrapper').click(togglePlay);

            // Save progress every 10 seconds
            setInterval(saveProgress, 10000);
        }

        function togglePlay() {
            if (video.paused) {
                video.play();
            } else {
                video.pause();
            }
        }

        function updatePlayPauseIcon(playing) {
            const icon = $('#playPauseBtn i');
            icon.removeClass('fa-play fa-pause');
            icon.addClass(playing ? 'fa-pause' : 'fa-play');
            isPlaying = playing;
        }

        function skip(seconds) {
            video.currentTime = Math.max(0, Math.min(video.duration, video.currentTime + seconds));
        }

        function toggleMute() {
            video.muted = !video.muted;
            const icon = $('#volumeBtn i');
            icon.removeClass('fa-volume-up fa-volume-mute');
            icon.addClass(video.muted ? 'fa-volume-mute' : 'fa-volume-up');
            $('#volumeSlider').val(video.muted ? 0 : video.volume * 100);
        }

        function changeVolume() {
            const volume = $('#volumeSlider').val() / 100;
            video.volume = volume;
            video.muted = volume === 0;
            updateVolumeIcon(volume);
        }

        function updateVolumeIcon(volume) {
            const icon = $('#volumeBtn i');
            icon.removeClass('fa-volume-up fa-volume-down fa-volume-mute');
            if (volume === 0) {
                icon.addClass('fa-volume-mute');
            } else if (volume < 0.5) {
                icon.addClass('fa-volume-down');
            } else {
                icon.addClass('fa-volume-up');
            }
        }

        function updateProgress() {
            const percentage = (video.currentTime / video.duration) * 100;
            $('#progressFilled').css('width', percentage + '%');
            $('#currentTime').text(formatTime(video.currentTime));
        }

        function updateBuffered() {
            if (video.buffered.length > 0) {
                const bufferedEnd = video.buffered.end(video.buffered.length - 1);
                const percentage = (bufferedEnd / video.duration) * 100;
                $('#progressBuffered').css('width', percentage + '%');
            }
        }

        function updateDuration() {
            $('#duration').text(formatTime(video.duration));
        }

        function seek(e) {
            const progressBar = $('#progressBar');
            const clickX = e.pageX - progressBar.offset().left;
            const width = progressBar.width();
            const percentage = clickX / width;
            video.currentTime = percentage * video.duration;
        }

        function toggleFullscreen() {
            const wrapper = document.getElementById('videoWrapper');
            if (!document.fullscreenElement) {
                wrapper.requestFullscreen();
                $('#fullscreenBtn i').removeClass('fa-expand').addClass('fa-compress');
            } else {
                document.exitFullscreen();
                $('#fullscreenBtn i').removeClass('fa-compress').addClass('fa-expand');
            }
        }

        function toggleQualityMenu() {
            $('#qualityMenu').toggleClass('show');
        }

        function showControls() {
            $('#playerControls').addClass('show');
            clearTimeout(controlsTimeout);
            controlsTimeout = setTimeout(() => {
                if (isPlaying) {
                    $('#playerControls').removeClass('show');
                }
            }, 3000);
        }

        function handleKeyboard(e) {
            switch(e.key) {
                case ' ':
                case 'k':
                    e.preventDefault();
                    togglePlay();
                    break;
                case 'ArrowLeft':
                    e.preventDefault();
                    skip(-5);
                    break;
                case 'ArrowRight':
                    e.preventDefault();
                    skip(5);
                    break;
                case 'f':
                    toggleFullscreen();
                    break;
                case 'm':
                    toggleMute();
                    break;
            }
        }

        function formatTime(seconds) {
            const h = Math.floor(seconds / 3600);
            const m = Math.floor((seconds % 3600) / 60);
            const s = Math.floor(seconds % 60);

            if (h > 0) {
                return `${h}:${m.toString().padStart(2, '0')}:${s.toString().padStart(2, '0')}`;
            }
            return `${m}:${s.toString().padStart(2, '0')}`;
        }

        function showLoading(show) {
            $('#loadingSpinner').css('display', show ? 'block' : 'none');
        }

        async function saveProgress() {
            if (!video || video.paused || video.ended) return;

            try {
                await fetch('/Stream/UpdateProgress', {
                    method: 'POST',
                    headers: {
                        'Content-Type': 'application/json',
                        'RequestVerificationToken': $('input[name="__RequestVerificationToken"]').val()
                    },
                    body: JSON.stringify({
                        movieId: movieId,
                        episodeId: episodeId !== '@Guid.Empty' ? episodeId : null,
                        currentTime: video.currentTime,
                        duration: video.duration
                    })
                });
            } catch (error) {
                console.error('Error saving progress:', error);
            }
        }

        async function loadProgress() {
            try {
                const url = `/Stream/Progress/${movieId}` + (episodeId !== '@Guid.Empty' ? `?episodeId=${episodeId}` : '');
                const response = await fetch(url);
                const data = await response.json();

                if (data.success && data.currentTime > 0) {
                    video.currentTime = data.currentTime;
                }
            } catch (error) {
                console.error('Error loading progress:', error);
            }
        }

        // Cleanup on page unload
        window.addEventListener('beforeunload', saveProgress);
    </script>
}

@Html.AntiForgeryToken()