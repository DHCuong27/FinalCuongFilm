@using FinalCuongFilm.ApplicationCore.Entities
@model FinalCuongFilm.MVC.Models.ViewModels.MovieFilterViewModel
@{
    ViewData["Title"] = Model.PageTitle ?? "All Movies";
    Layout = "_LayoutUser";

    // DYNAMIC ACTION ROUTING
    var currentAction = ViewContext.RouteData.Values["action"]?.ToString() ?? "Index";
}

<style>
    :root {
        --netflix-red: #e50914;
        --netflix-dark: #0f0f0f;
        --netflix-dark-bg: #1a1a1a;
        --netflix-gray: #2d2d2d;
        --netflix-light-gray: #b3b3b3;
        --netflix-white: #ffffff;
    }

    body {
        background-color: var(--netflix-dark);
        color: var(--netflix-white);
        font-family: 'Segoe UI', sans-serif;
    }

    .page-container {
        max-width: 1400px;
        margin: 0 auto;
        padding: 100px 2rem 3rem;
    }

    /* Page Header */
    .page-hero {
        margin-bottom: 2rem;
    }

        .page-hero h1 {
            font-size: 2.5rem;
            font-weight: 800;
            margin-bottom: 0.5rem;
        }

        .page-hero p {
            color: var(--netflix-light-gray);
            font-size: 1rem;
        }

    /* Filter Bar */
    .filter-bar {
        background: var(--netflix-dark-bg);
        border: 1px solid var(--netflix-gray);
        border-radius: 12px;
        padding: 1.5rem;
        margin-bottom: 2rem;
    }

    .filter-row {
        display: flex;
        flex-wrap: wrap;
        gap: 1rem;
        align-items: flex-end;
    }

    .filter-group {
        display: flex;
        flex-direction: column;
        gap: 0.4rem;
        flex: 1;
        min-width: 140px;
    }

        .filter-group label {
            font-size: 0.78rem;
            font-weight: 600;
            color: var(--netflix-light-gray);
            text-transform: uppercase;
            letter-spacing: 0.5px;
        }

    .filter-select {
        background: var(--netflix-gray);
        border: 1px solid rgba(255,255,255,0.15);
        color: white;
        border-radius: 8px;
        padding: 0.6rem 1rem;
        font-size: 0.9rem;
        cursor: pointer;
        transition: border-color 0.2s;
    }

        .filter-select:focus {
            outline: none;
            border-color: var(--netflix-red);
        }

        .filter-select option {
            background: var(--netflix-gray);
        }

    .filter-input {
        background: var(--netflix-gray);
        border: 1px solid rgba(255,255,255,0.15);
        color: white;
        border-radius: 8px;
        padding: 0.6rem 1rem;
        font-size: 0.9rem;
    }

        .filter-input:focus {
            outline: none;
            border-color: var(--netflix-red);
        }

        .filter-input::placeholder {
            color: var(--netflix-light-gray);
        }

    .search-input-wrapper {
        display: flex;
        background: var(--netflix-gray);
        border: 1px solid rgba(255,255,255,0.15);
        border-radius: 8px;
        overflow: hidden;
        transition: border-color 0.2s;
    }

        .search-input-wrapper:focus-within {
            border-color: var(--netflix-red);
        }

        .search-input-wrapper input {
            flex: 1;
            background: transparent;
            border: none;
            color: white;
            font-size: 0.9rem;
            padding: 0.6rem 1rem;
            outline: none;
        }

            .search-input-wrapper input::placeholder {
                color: var(--netflix-light-gray);
            }

        .search-input-wrapper .btn-search {
            background: var(--netflix-red);
            color: white;
            border: none;
            padding: 0.6rem 1rem;
            cursor: pointer;
            font-size: 0.85rem;
            transition: background 0.2s;
        }

            .search-input-wrapper .btn-search:hover {
                background: #f40612;
            }

    .btn-filter {
        background: var(--netflix-red);
        color: white;
        border: none;
        border-radius: 8px;
        padding: 0.65rem 1.5rem;
        font-weight: 600;
        cursor: pointer;
        transition: all 0.2s;
        white-space: nowrap;
    }

        .btn-filter:hover {
            background: #f40612;
            transform: translateY(-1px);
        }

    .btn-reset {
        background: transparent;
        color: var(--netflix-light-gray);
        border: 1px solid rgba(255,255,255,0.2);
        border-radius: 8px;
        padding: 0.65rem 1.2rem;
        font-size: 0.9rem;
        cursor: pointer;
        transition: all 0.2s;
        white-space: nowrap;
        text-decoration: none;
        display: inline-flex;
        align-items: center;
        gap: 0.3rem;
    }

        .btn-reset:hover {
            border-color: var(--netflix-red);
            color: var(--netflix-red);
        }

    .filter-result-count {
        font-size: 0.9rem;
        color: var(--netflix-light-gray);
        margin-top: 0.8rem;
    }

        .filter-result-count span {
            color: var(--netflix-red);
            font-weight: 700;
        }

    /* Active Filters Tags */
    .active-filters {
        display: flex;
        flex-wrap: wrap;
        gap: 0.5rem;
        margin-top: 1rem;
        padding-top: 1rem;
        border-top: 1px solid rgba(255,255,255,0.05);
    }

    .filter-tag {
        display: inline-flex;
        align-items: center;
        gap: 0.4rem;
        background: rgba(229,9,20,0.15);
        border: 1px solid rgba(229,9,20,0.4);
        color: white;
        padding: 0.3rem 0.8rem;
        border-radius: 20px;
        font-size: 0.82rem;
    }

        .filter-tag a {
            color: var(--netflix-light-gray);
            text-decoration: none;
            margin-left: 0.3rem;
        }

            .filter-tag a:hover {
                color: var(--netflix-red);
            }

    /* Movie Card Styles */
    .movies-grid {
        display: grid;
        grid-template-columns: repeat(auto-fill, minmax(180px, 1fr));
        gap: 1.2rem;
        margin-bottom: 3rem;
    }

    .nf-movie-card {
        position: relative;
        transition: transform 0.3s cubic-bezier(0.4, 0, 0.2, 1);
        cursor: pointer;
        border-radius: 4px;
        overflow: hidden;
        background: var(--netflix-dark-bg);
        border: 1px solid var(--netflix-gray);
    }

        .nf-movie-card:hover {
            transform: scale(1.08);
            z-index: 10;
            box-shadow: 0 10px 20px rgba(0,0,0,0.8);
        }

    .grid-card-poster {
        position: relative;
        aspect-ratio: 2/3;
        overflow: hidden;
    }

    .nf-poster {
        width: 100%;
        height: 100%;
        object-fit: cover;
        border-radius: 4px 4px 0 0;
        transition: transform 0.4s;
    }

    .nf-movie-card:hover .nf-poster {
        transform: scale(1.05);
    }

    /* Badges */
    .badge-type {
        position: absolute;
        top: 8px;
        left: 8px;
        background: var(--netflix-red);
        color: white;
        padding: 0.2rem 0.6rem;
        border-radius: 4px;
        font-size: 0.75rem;
        font-weight: 700;
        z-index: 10;
    }

    .premium-movie-badge {
        position: absolute;
        top: 8px;
        right: 8px;
        background: #ffc107; /* Gold */
        color: #000;
        font-size: 0.75rem;
        font-weight: 800;
        padding: 0.2rem 0.6rem;
        border-radius: 4px;
        z-index: 10;
        box-shadow: 0 2px 5px rgba(0,0,0,0.5);
    }

    /* Hover Overlay & Play Button */
    .grid-card-overlay {
        position: absolute;
        inset: 0;
        background: linear-gradient(180deg, transparent 50%, rgba(0,0,0,0.95) 100%);
        opacity: 0;
        transition: opacity 0.3s;
        display: flex;
        align-items: flex-end;
        padding: 1rem;
    }

    .nf-movie-card:hover .grid-card-overlay {
        opacity: 1;
    }

    .btn-play-card {
        display: flex;
        justify-content: center;
        align-items: center;
        width: 100%;
        gap: 0.4rem;
        background: var(--netflix-red);
        color: white;
        padding: 0.6rem;
        border-radius: 4px;
        text-decoration: none;
        font-size: 0.95rem;
        font-weight: 700;
    }

        .btn-play-card:hover {
            background: #f40612;
            color: white;
        }

    /* Movie Info */
    .nf-movie-info {
        padding: 0.8rem;
    }

    .nf-movie-title {
        color: #fff;
        font-size: 0.95rem;
        font-weight: 600;
        margin-bottom: 0.3rem;
        text-decoration: none;
        white-space: nowrap;
        overflow: hidden;
        text-overflow: ellipsis;
        display: block;
    }

        .nf-movie-title:hover {
            color: var(--netflix-red);
        }

    .nf-movie-meta {
        font-size: 0.8rem;
        color: var(--netflix-light-gray);
        display: flex;
        align-items: center;
        gap: 0.5rem;
        flex-wrap: wrap;
    }

    /* Pagination */
    .pagination-wrapper {
        display: flex;
        justify-content: center;
        align-items: center;
        gap: 0.5rem;
        margin: 2rem 0;
        flex-wrap: wrap;
    }

    .page-btn {
        background: var(--netflix-gray);
        color: white;
        border: 1px solid rgba(255,255,255,0.1);
        padding: 0.5rem 0.9rem;
        border-radius: 6px;
        cursor: pointer;
        text-decoration: none;
        font-size: 0.9rem;
        transition: all 0.2s;
    }

        .page-btn:hover {
            background: var(--netflix-red);
            border-color: var(--netflix-red);
            color: white;
        }

        .page-btn.active {
            background: var(--netflix-red);
            border-color: var(--netflix-red);
            font-weight: 700;
        }

        .page-btn.disabled {
            opacity: 0.4;
            pointer-events: none;
        }

    .pagination-info {
        color: var(--netflix-light-gray);
        font-size: 0.85rem;
        margin: 0 0.5rem;
    }

    /* No results */
    .netflix-alert {
        background: var(--netflix-dark-bg);
        border: 1px solid var(--netflix-gray);
        border-radius: 8px;
        padding: 3rem 2rem;
        margin: 2rem 0;
        text-align: center;
    }

        .netflix-alert i {
            color: var(--netflix-red);
            font-size: 3rem;
            margin-bottom: 1rem;
            display: block;
        }

        .netflix-alert h3 {
            font-size: 1.5rem;
            margin-bottom: 0.5rem;
        }

        .netflix-alert p {
            color: var(--netflix-light-gray);
        }

    @@media (max-width: 768px) {
        .page-container {
            padding: 80px 1rem 2rem;
        }

        .page-hero h1 {
            font-size: 1.8rem;
        }

        .filter-row {
            flex-direction: column;
        }

        .movies-grid {
            grid-template-columns: repeat(auto-fill, minmax(140px, 1fr));
        }
    }
</style>

<div class="page-container">
    <div class="page-hero">
        <h1><i class="fas fa-film" style="color:var(--netflix-red); margin-right:0.5rem;"></i>@(Model.PageTitle ?? "All Movies")</h1>
        @if (!string.IsNullOrEmpty(Model.PageSubTitle))
        {
            <p>@Model.PageSubTitle</p>
        }
    </div>

    <div class="filter-bar">
        <form method="get" asp-action="@currentAction" asp-controller="Movie" id="filterForm">
            <div class="filter-row">
                <div class="filter-group" style="flex:2; min-width:200px;">
                    <label><i class="fas fa-search"></i> Search</label>
                    <div class="search-input-wrapper">
                        <input type="text" name="search" value="@Model.Search" placeholder="Movie title..." />
                        <button type="submit" class="btn-search"><i class="fas fa-search"></i></button>
                    </div>
                </div>

                <div class="filter-group">
                    <label><i class="fas fa-theater-masks"></i> Genre</label>
                    <select name="genreId" class="filter-select" onchange="this.form.submit()">
                        <option value="">All Genres</option>
                        @foreach (var g in Model.Genres)
                        {
                            <option value="@g.Id" selected="@(Model.GenreId == g.Id ? "selected" : null)">@g.Name</option>
                        }
                    </select>
                </div>

                <div class="filter-group">
                    <label><i class="fas fa-globe"></i> Country</label>
                    <select name="countryId" class="filter-select" onchange="this.form.submit()">
                        <option value="">All Countries</option>
                        @foreach (var c in Model.Countries)
                        {
                            <option value="@c.Id" selected="@(Model.CountryId == c.Id ? "selected" : null)">@c.Name</option>
                        }
                    </select>
                </div>

                <div class="filter-group">
                    <label><i class="fas fa-tv"></i> Type</label>
                    <select name="type" class="filter-select" onchange="this.form.submit()">
                        <option value="">All Types</option>
                        <option value="1" selected="@(Model.Type == 1 ? "selected" : null)">Movie</option>
                        <option value="2" selected="@(Model.Type == 2 ? "selected" : null)">TV Series</option>
                    </select>
                </div>

                <div class="filter-group">
                    <label><i class="fas fa-sort"></i> Sort by</label>
                    <select name="sortBy" class="filter-select" onchange="this.form.submit()">
                        <option value="latest" selected="@(Model.SortBy == "latest" ? "selected" : null)">Latest</option>
                        <option value="popular" selected="@(Model.SortBy == "popular" ? "selected" : null)">Most Popular</option>
                        <option value="title" selected="@(Model.SortBy == "title" ? "selected" : null)">Name A-Z</option>
                    </select>
                </div>

                <div class="filter-group" style="justify-content:flex-end; flex-direction:row; gap:0.5rem; min-width:auto;">
                    <a asp-action="@currentAction" asp-controller="Movie" class="btn-reset"><i class="fas fa-times"></i> Reset</a>
                </div>
            </div>

            @{
                bool hasFilter = !string.IsNullOrEmpty(Model.Search) || Model.GenreId.HasValue || Model.CountryId.HasValue || Model.Type.HasValue;
            }

            @if (hasFilter)
            {
                <div class="active-filters">
                    @if (!string.IsNullOrEmpty(Model.Search))
                    {
                        <span class="filter-tag"><i class="fas fa-search"></i> "@Model.Search"</span>
                    }
                    @if (Model.GenreId.HasValue)
                    {
                        var gName = Model.Genres.FirstOrDefault(g => g.Id == Model.GenreId)?.Name;
                        <span class="filter-tag"><i class="fas fa-theater-masks"></i> @gName</span>
                    }
                    @if (Model.CountryId.HasValue)
                    {
                        var cName = Model.Countries.FirstOrDefault(c => c.Id == Model.CountryId)?.Name;
                        <span class="filter-tag"><i class="fas fa-globe"></i> @cName</span>
                    }
                    @if (Model.Type.HasValue)
                    {
                        <span class="filter-tag"><i class="fas fa-tv"></i> @(Model.Type == 1 ? "Movie" : "TV Series")</span>
                    }
                </div>
            }

            <div class="filter-result-count">
                Showing <span>@Model.Movies.Count</span> / <span>@Model.TotalItems</span> movies
                @if (hasFilter)
                {
                    <span style="margin-left:0.5rem; color:var(--netflix-light-gray); font-weight: normal;">(filtered)</span>
                }
            </div>
        </form>
    </div>

    <div class="row g-3 g-md-4">
        @if (Model.Movies != null && Model.Movies.Any())
        {
            foreach (var item in Model.Movies)
            {
                <div class="col-6 col-sm-4 col-md-3 col-lg-2-4" style="width: 20%; flex: 0 0 auto; min-width: 150px;">
                    <div class="nf-movie-card">

                        <div class="grid-card-poster">
                            <span class="badge-type">@(item.Type.ToString() == "Series" ? "Series" : "Movie")</span>

                            @if (item.IsVipOnly)
                            {
                                <div class="premium-movie-badge">
                                    <i class="fa-solid fa-crown"></i> VIP
                                </div>
                            }

                            <a asp-controller="Movie" asp-action="Detail" asp-route-slug="@item.Slug" class="d-block">
                                <img src="@(item.PosterUrl ?? "https://via.placeholder.com/300x450/2d2d2d/fff?text=No+Poster")" alt="@item.Title" class="nf-poster" loading="lazy" />
                            </a>

                            <div class="grid-card-overlay">
                                <a asp-controller="Movie" asp-action="Watch" asp-route-slug="@item.Slug" class="btn-play-card">
                                    <i class="fas fa-play"></i> Watch Now
                                </a>
                            </div>
                        </div>

                        <div class="nf-movie-info">
                            <a asp-controller="Movie" asp-action="Detail" asp-route-slug="@item.Slug" class="nf-movie-title">
                                @item.Title
                            </a>
                            <div class="nf-movie-meta">
                                @if (item.ReleaseYear.HasValue)
                                {
                                    <span><i class="far fa-calendar-alt"></i> @item.ReleaseYear</span>
                                }
                                @if (!string.IsNullOrEmpty(item.CountryName))
                                {
                                    <span>@item.CountryName</span>
                                }
                            </div>
                        </div>

                    </div>
                </div>
            }
        }
        else
        {
            <div class="col-12">
                <div class="netflix-alert">
                    <i class="fas fa-search"></i>
                    <h3>No content matches your filters</h3>
                    <p>Try adjusting your search or filter categories, or <a asp-action="@currentAction" asp-controller="Movie" style="color:var(--netflix-red);">reset all filters</a>.</p>
                </div>
            </div>
        }
    </div>

    @if (Model.TotalPages > 1)
    {
        <div class="pagination-wrapper">
            <a asp-action="@currentAction" asp-controller="Movie"
               asp-route-search="@Model.Search" asp-route-genreId="@Model.GenreId" asp-route-countryId="@Model.CountryId"
               asp-route-type="@Model.Type" asp-route-sortBy="@Model.SortBy" asp-route-pageNumber="@(Model.PageNumber - 1)"
               class="page-btn @(!Model.HasPreviousPage ? "disabled" : "")">
                <i class="fas fa-chevron-left"></i> Previous
            </a>

            @if (Model.PageNumber > 3)
            {
                <span class="pagination-info">...</span>
            }

            @for (int i = Math.Max(1, Model.PageNumber - 2); i <= Math.Min(Model.TotalPages, Model.PageNumber + 2); i++)
            {
                <a asp-action="@currentAction" asp-controller="Movie"
                   asp-route-search="@Model.Search" asp-route-genreId="@Model.GenreId" asp-route-countryId="@Model.CountryId"
                   asp-route-type="@Model.Type" asp-route-sortBy="@Model.SortBy" asp-route-pageNumber="@i"
                   class="page-btn @(i == Model.PageNumber ? "active" : "")">@i</a>
            }

            @if (Model.PageNumber < Model.TotalPages - 2)
            {
                <span class="pagination-info">...</span>
            }

            <a asp-action="@currentAction" asp-controller="Movie"
               asp-route-search="@Model.Search" asp-route-genreId="@Model.GenreId" asp-route-countryId="@Model.CountryId"
               asp-route-type="@Model.Type" asp-route-sortBy="@Model.SortBy" asp-route-pageNumber="@(Model.PageNumber + 1)"
               class="page-btn @(!Model.HasNextPage ? "disabled" : "")">
                Next <i class="fas fa-chevron-right"></i>
            </a>
        </div>
        <div style="text-align:center; color:var(--netflix-light-gray); font-size:0.85rem; margin-top:-1rem; margin-bottom:2rem;">
            Page @Model.PageNumber of @Model.TotalPages — @Model.TotalItems movies total
        </div>
    }
</div>

@section Scripts {
    <script>
        $(document).ready(function () {
            // Filter is always visible in this design
            if (window.location.search.length > 1) {
                var params = new URLSearchParams(window.location.search);
            }
        });
    </script>
}