@model FinalCuongFilm.Common.DTOs.MovieDto
@using static FinalCuongFilm.ApplicationCore.Entities.Enum

@{
    ViewData["Title"] = Model.Title;
    var isFavorited = ViewBag.IsFavorited as bool? ?? false;
    var rating = ViewBag.Rating as FinalCuongFilm.Common.DTOs.MovieRatingDto;
    var reviews = ViewBag.Reviews as IEnumerable<FinalCuongFilm.Common.DTOs.ReviewDto>;
    var userReview = ViewBag.UserReview as FinalCuongFilm.Common.DTOs.ReviewDto;
    var episodes = ViewBag.Episodes as IEnumerable<FinalCuongFilm.Common.DTOs.EpisodeDto>;
}

<!-- Movie Header -->
<div class="movie-header" style="background: linear-gradient(to bottom, rgba(0,0,0,0.7), rgba(0,0,0,0.9)), url('@(Model.PosterUrl ?? "/images/default-bg.jpg")'); background-size: cover; background-position: center;">
    <div class="container py-5">
        <div class="row">
            <!-- Poster -->
            <div class="col-md-3">
                <img src="@(Model.PosterUrl ?? "/images/no-poster.jpg")"
                     alt="@Model.Title"
                     class="img-fluid rounded shadow-lg"
                     style="max-height: 500px; width: 100%; object-fit: cover;">
            </div>

            <!-- Movie Info -->
            <div class="col-md-9 text-white">
                <h1 class="display-4 fw-bold mb-3">@Model.Title</h1>

                <!-- Rating & Stats -->
                <div class="d-flex align-items-center mb-3">
                    @if (rating != null && rating.TotalReviews > 0)
                    {
                        <div class="me-4">
                            <div class="d-flex align-items-center">
                                @for (int i = 1; i <= 5; i++)
                                {
                                    if (i <= Math.Round(rating.AverageRating))
                                    {
                                        <i class="fas fa-star text-warning"></i>
                                    }
                                    else if (i - 0.5 <= rating.AverageRating)
                                    {
                                        <i class="fas fa-star-half-alt text-warning"></i>
                                    }
                                    else
                                    {
                                        <i class="far fa-star text-warning"></i>
                                    }
                                }
                                <span class="ms-2 fs-5 fw-bold">@rating.AverageRating.ToString("F1")</span>
                                <span class="ms-2 text-muted">(@rating.TotalReviews đánh giá)</span>
                            </div>
                        </div>
                    }

                    @if (rating != null)
                    {
                        <div class="me-4">
                            <i class="fas fa-heart text-danger"></i>
                            <span>@rating.TotalFavorites yêu thích</span>
                        </div>
                    }

                    <div>
                        <i class="fas fa-eye"></i>
                        <span>@Model.ViewCount.ToString("N0") lượt xem</span>
                    </div>
                </div>

                <!-- Metadata -->
                <div class="mb-3">
                    <span class="badge bg-primary me-2">@Model.Type.ToString()</span>
                    <span class="badge bg-success me-2">@Model.Status.ToString()</span>
                    @if (Model.ReleaseYear.HasValue)
                    {
                        <span class="badge bg-info me-2">@Model.ReleaseYear</span>
                    }
                    @if (Model.DurationMinutes.HasValue)
                    {
                        <span class="badge bg-warning text-dark me-2">@Model.DurationMinutes phút</span>
                    }
                </div>

                <!-- Description -->
                @if (!string.IsNullOrEmpty(Model.Description))
                {
                    <p class="lead">@Model.Description</p>
                }

                <!-- ✅ ACTION BUTTONS -->
                <div class="mt-4">
                    <div class="btn-group" role="group">
                        <!-- Watch Button -->
                        <a href="@Url.Action("Watch", "Movies", new { id = Model.Id })"
                           class="btn btn-danger btn-lg">
                            <i class="fas fa-play"></i> Xem phim
                        </a>

                        <!-- Trailer Button -->
                        @if (!string.IsNullOrEmpty(Model.TrailerUrl))
                        {
                            <a href="@Model.TrailerUrl"
                               target="_blank"
                               class="btn btn-outline-light btn-lg">
                                <i class="fab fa-youtube"></i> Trailer
                            </a>
                        }

                        <!-- ✅ FAVORITE BUTTON -->
                        @if (User.Identity?.IsAuthenticated == true)
                        {
                            <button type="button"
                                    class="btn btn-outline-light btn-lg favorite-toggle-btn"
                                    data-movie-id="@Model.Id"
                                    data-is-favorited="@isFavorited.ToString().ToLower()">
                                <i class="@(isFavorited ? "fas" : "far") fa-heart"></i>
                                <span class="favorite-text">@(isFavorited ? "Đã yêu thích" : "Yêu thích")</span>
                            </button>
                        }
                        else
                        {
                            <a href="@Url.Action("Login", "Account", new { area = "Identity", returnUrl = Context.Request.Path })"
                               class="btn btn-outline-light btn-lg">
                                <i class="far fa-heart"></i> Yêu thích
                            </a>
                        }

                        <!--  REVIEW BUTTON -->
                        @if (User.Identity?.IsAuthenticated == true)
                        {
                            if (userReview != null)
                            {
                                <a href="@Url.Action("Edit", "Reviews", new { id = userReview.Id })"
                                   class="btn btn-outline-warning btn-lg">
                                    <i class="fas fa-edit"></i> Sửa đánh giá
                                </a>
                            }
                            else
                            {
                                <a href="@Url.Action("Create", "Reviews", new { movieId = Model.Id })"
                                   class="btn btn-outline-warning btn-lg">
                                    <i class="fas fa-star"></i> Đánh giá
                                </a>
                            }
                        }
                        else
                        {
                            <a href="@Url.Action("Login", "Account", new { area = "Identity", returnUrl = Context.Request.Path })"
                               class="btn btn-outline-warning btn-lg">
                                <i class="fas fa-star"></i> Đánh giá
                            </a>
                        }
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>

<!-- Main Content -->
<div class="container my-5">
    <div class="row">
        <!-- Main Column -->
        <div class="col-lg-8">
            <!-- ✅ RATING OVERVIEW -->
            @if (rating != null && rating.TotalReviews > 0)
            {
                <div class="card mb-4 shadow-sm">
                    <div class="card-header bg-primary text-white">
                        <h5 class="mb-0">
                            <i class="fas fa-chart-bar"></i> Đánh giá tổng quan
                        </h5>
                    </div>
                    <div class="card-body">
                        <div class="row align-items-center">
                            <div class="col-md-4 text-center">
                                <div class="display-3 text-warning fw-bold">@rating.AverageRating.ToString("F1")</div>
                                <div class="mb-2">
                                    @for (int i = 1; i <= 5; i++)
                                    {
                                        if (i <= Math.Round(rating.AverageRating))
                                        {
                                            <i class="fas fa-star text-warning"></i>
                                        }
                                        else
                                        {
                                            <i class="far fa-star text-warning"></i>
                                        }
                                    }
                                </div>
                                <p class="text-muted">@rating.TotalReviews đánh giá</p>
                            </div>
                            <div class="col-md-8">
                                @foreach (var star in new[] { 5, 4, 3, 2, 1 })
                                {
                                    var count = rating.RatingDistribution.ContainsKey(star) ? rating.RatingDistribution[star] : 0;
                                    var percentage = rating.TotalReviews > 0 ? (count * 100.0 / rating.TotalReviews) : 0;

                                    <div class="d-flex align-items-center mb-2">
                                        <span class="me-2" style="width: 60px;">@star sao</span>
                                        <div class="progress flex-grow-1" style="height: 20px;">
                                            <div class="progress-bar bg-warning"
                                                 role="progressbar"
                                                 style="width: @(percentage)%"
                                                 aria-valuenow="@count"
                                                 aria-valuemin="0"
                                                 aria-valuemax="@rating.TotalReviews">
                                            </div>
                                        </div>
                                        <span class="ms-2 text-muted" style="width: 50px;">@count</span>
                                    </div>
                                }
                            </div>
                        </div>
                    </div>
                </div>
            }

            <!-- ✅ REVIEWS SECTION -->
            @if (reviews != null && reviews.Any())
            {
                <div class="card mb-4 shadow-sm">
                    <div class="card-header bg-success text-white d-flex justify-content-between align-items-center">
                        <h5 class="mb-0">
                            <i class="fas fa-comments"></i> Đánh giá từ người xem
                        </h5>
                        <a href="@Url.Action("Movie", "Reviews", new { movieId = Model.Id })"
                           class="btn btn-sm btn-light">
                            Xem tất cả
                        </a>
                    </div>
                    <div class="card-body">
                        @foreach (var review in reviews)
                        {
                            <div class="review-item mb-4 pb-4 @(review != reviews.Last() ? "border-bottom" : "")">
                                <div class="d-flex justify-content-between align-items-start mb-2">
                                    <div>
                                        <strong>@review.UserName</strong>
                                        <div class="mt-1">
                                            @for (int i = 1; i <= 5; i++)
                                            {
                                                if (i <= review.Rating)
                                                {
                                                    <i class="fas fa-star text-warning"></i>
                                                }
                                                else
                                                {
                                                    <i class="far fa-star text-warning"></i>
                                                }
                                            }
                                        </div>
                                    </div>
                                    <small class="text-muted">
                                        @review.CreatedAt.ToString("dd/MM/yyyy")
                                    </small>
                                </div>
                                @if (!string.IsNullOrEmpty(review.Comment))
                                {
                                    <p class="mb-0">@review.Comment</p>
                                }
                            </div>
                        }
                    </div>
                </div>
            }

            <!-- Episodes (if series) -->
            @if (Model.Type == MovieType.Series && episodes != null && episodes.Any())
            {
                <div class="card mb-4 shadow-sm">
                    <div class="card-header bg-info text-white">
                        <h5 class="mb-0">
                            <i class="fas fa-list-ol"></i> Danh sách tập phim
                        </h5>
                    </div>
                    <div class="card-body">
                        <div class="row">
                            @foreach (var episode in episodes)
                            {
                                <div class="col-md-6 mb-3">
                                    <div class="card h-100">
                                        <div class="card-body">
                                            <h6 class="card-title">Tập @episode.EpisodeNumber: @episode.Title</h6>
                                            @if (!string.IsNullOrEmpty(episode.Description))
                                            {
                                                <p class="card-text text-muted small">@episode.Description</p>
                                            }
                                            <a href="@Url.Action("WatchEpisode", "Movies", new { id = Model.Id, episodeNumber = episode.EpisodeNumber })"
                                               class="btn btn-sm btn-primary">
                                                <i class="fas fa-play"></i> Xem
                                            </a>
                                        </div>
                                    </div>
                                </div>
                            }
                        </div>
                    </div>
                </div>
            }
        </div>

        <!-- Sidebar -->
        <div class="col-lg-4">
            <!-- Movie Info -->
            <div class="card mb-4 shadow-sm">
                <div class="card-header bg-dark text-white">
                    <h5 class="mb-0">
                        <i class="fas fa-info-circle"></i> Thông tin phim
                    </h5>
                </div>
                <div class="card-body">
                    <table class="table table-sm">
                        <tbody>
                            @if (Model.ReleaseYear.HasValue)
                            {
                                <tr>
                                    <th style="width: 40%;">Năm phát hành:</th>
                                    <td>@Model.ReleaseYear</td>
                                </tr>
                            }
                            @if (Model.DurationMinutes.HasValue)
                            {
                                <tr>
                                    <th>Thời lượng:</th>
                                    <td>@Model.DurationMinutes phút</td>
                                </tr>
                            }
                            @if (!string.IsNullOrEmpty(Model.LanguageName))
                            {
                                <tr>
                                    <th>Ngôn ngữ:</th>
                                    <td>@Model.LanguageName</td>
                                </tr>
                            }
                            @if (!string.IsNullOrEmpty(Model.CountryName))
                            {
                                <tr>
                                    <th>Quốc gia:</th>
                                    <td>@Model.CountryName</td>
                                </tr>
                            }
                            <tr>
                                <th>Loại phim:</th>
                                <td>@Model.Type.ToString()</td>
                            </tr>
                            <tr>
                                <th>Trạng thái:</th>
                                <td>
                                    <span class="badge bg-@(Model.Status == MovieStatus.Completed ? "success" : Model.Status == MovieStatus.Ongoing ? "primary" : "warning")">
                                        @Model.Status.ToString()
                                    </span>
                                </td>
                            </tr>
                        </tbody>
                    </table>
                </div>
            </div>

            <!-- Similar Movies (TODO) -->
            <div class="card shadow-sm">
                <div class="card-header bg-secondary text-white">
                    <h5 class="mb-0">
                        <i class="fas fa-film"></i> Phim liên quan
                    </h5>
                </div>
                <div class="card-body">
                    <p class="text-muted">Đang cập nhật...</p>
                </div>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <script>
        $(document).ready(function() {
            // ✅ FAVORITE TOGGLE
            $('.favorite-toggle-btn').click(function() {
                const btn = $(this);
                const movieId = btn.data('movie-id');
                const isFavorited = btn.data('is-favorited');

                $.ajax({
                    url: '@Url.Action("Toggle", "Favorites")',
                    type: 'POST',
                    data: {
                        movieId: movieId,
                        __RequestVerificationToken: $('input[name="__RequestVerificationToken"]').val()
                    },
                    success: function(response) {
                        if (response.success) {
                            // Update button state
                            const icon = btn.find('i');
                            const text = btn.find('.favorite-text');

                            if (response.isFavorite) {
                                icon.removeClass('far').addClass('fas');
                                text.text('Đã yêu thích');
                                btn.data('is-favorited', true);
                            } else {
                                icon.removeClass('fas').addClass('far');
                                text.text('Yêu thích');
                                btn.data('is-favorited', false);
                            }

                            // Show toast
                            showToast('success', response.message);
                        } else {
                            showToast('error', response.message);
                        }
                    },
                    error: function() {
                        showToast('error', 'Có lỗi xảy ra!');
                    }
                });
            });
        });

        function showToast(type, message) {
            const toast = $(`
                <div class="alert alert-${type === 'success' ? 'success' : 'danger'} alert-dismissible fade show position-fixed"
                     style="top: 20px; right: 20px; z-index: 9999; min-width: 300px;"
                     role="alert">
                    <i class="fas fa-${type === 'success' ? 'check-circle' : 'exclamation-circle'}"></i>
                    ${message}
                    <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
                </div>
            `);

            $('body').append(toast);

            setTimeout(() => {
                toast.fadeOut(300, function() { $(this).remove(); });
            }, 3000);
        }
    </script>
}

<style>
    .movie-header {
        min-height: 500px;
        color: white;
    }

    .favorite-toggle-btn.active {
        background-color: #dc3545 !important;
        border-color: #dc3545 !important;
        color: white !important;
    }

    .review-item {
        transition: background-color 0.2s;
    }

        .review-item:hover {
            background-color: #f8f9fa;
            border-radius: 8px;
            padding: 10px;
        }
</style>

@* Anti-forgery token for AJAX *@
@Html.AntiForgeryToken()