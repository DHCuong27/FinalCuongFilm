@using FinalCuongFilm.ApplicationCore.Entities
@using FinalCuongFilm.ApplicationCore.Entities.Identity
@using Microsoft.AspNetCore.Identity
@using System.Security.Claims
@model FinalCuongFilm.MVC.Models.ViewModels.MovieDetailsViewModel
@using static FinalCuongFilm.ApplicationCore.Entities.Enum
@inject FinalCuongFilm.Service.Interfaces.IVipService VipService
@inject UserManager<CuongFilmUser> UserManager

@{
    ViewData["Title"] = Model.Movie.Title;
    Layout = "_LayoutUser";

    var userId = User.FindFirstValue(ClaimTypes.NameIdentifier);
    bool isVip = userId != null && await VipService.HasActiveVipAsync(userId);

    string currentUserName = User.Identity?.Name ?? "Unknown";
    string currentUserAvatar = "";

    if (User.Identity?.IsAuthenticated == true)
    {
        var currentUser = await UserManager.GetUserAsync(User);
        if (currentUser != null)
        {
            string rawName = !string.IsNullOrEmpty(currentUser.FullName) ? currentUser.FullName : currentUser.UserName;
            currentUserName = rawName.Contains("@") ? rawName.Split('@')[0] : rawName;
            currentUserAvatar = currentUser.AvatarUrl ?? "";
        }
    }

    var isFavorited = ViewBag.IsFavorited as bool? ?? false;
    var rating = ViewBag.Rating as FinalCuongFilm.Common.DTOs.MovieRatingDto;
    var rawReviews = ViewBag.Reviews as IEnumerable<FinalCuongFilm.Common.DTOs.ReviewDto> ?? new List<FinalCuongFilm.Common.DTOs.ReviewDto>();
    var textReviews = rawReviews.Where(r => !string.IsNullOrWhiteSpace(r.Comment)).ToList();
    var currentUrl = Url.Action("Detail", "Movie", new { slug = Model.Movie.Slug });
}

<style>
    :root {
        --netflix-red: #e50914;
        --bg-dark: #0f0f0f;
        --bg-card: #1a1a1a;
        --bg-hover: #2a2a2a;
        --text-primary: #ffffff;
        --text-secondary: #a8a8a8;
        --border-color: #303030;
        --accent-yellow: #f5c518;
        --transition-speed: 0.3s;
    }

    body {
        background-color: var(--bg-dark);
        color: var(--text-primary);
        font-family: -apple-system, BlinkMacSystemFont, 'Segoe UI', Roboto, Arial, sans-serif;
    }

    .hero-banner {
        position: relative;
        height: 550px;
        background-color: #000;
        margin-top: -70px;
        margin-bottom: 0;
        overflow: hidden;
    }

    .hero-backdrop {
        position: absolute;
        top: 0;
        left: 0;
        width: 100%;
        height: 100%;
        object-fit: cover;
        object-position: center 20%;
        opacity: 0.4;
        filter: blur(4px);
        transform: scale(1.05);
    }

    .hero-gradient {
        position: absolute;
        top: 0;
        left: 0;
        width: 100%;
        height: 100%;
        background: linear-gradient(to bottom, rgba(15,15,15,0) 0%, rgba(15,15,15,0.6) 60%, var(--bg-dark) 100%), linear-gradient(to right, var(--bg-dark) 0%, rgba(15,15,15,0.4) 50%, rgba(15,15,15,0) 100%);
    }

    .hero-content {
        position: absolute;
        bottom: 0;
        left: 0;
        right: 0;
        padding: 0 40px 40px;
        z-index: 10;
    }

    .hero-inner {
        max-width: 1400px;
        margin: 0 auto;
        display: flex;
        align-items: flex-end;
        gap: 40px;
        z-index: 11;
    }

    .hero-poster {
        width: 260px;
        flex-shrink: 0;
        border-radius: 12px;
        overflow: hidden;
        box-shadow: 0 20px 50px rgba(0,0,0,0.9);
        border: 1px solid rgba(255,255,255,0.1);
    }

        .hero-poster img {
            width: 100%;
            display: block;
            transition: transform var(--transition-speed);
        }

        .hero-poster:hover img {
            transform: scale(1.03);
        }

    .hero-info {
        flex: 1;
        padding-bottom: 10px;
    }

    .hero-title {
        font-size: 3.5rem;
        font-weight: 800;
        margin-bottom: 1rem;
        text-shadow: 2px 4px 10px rgba(0,0,0,0.9);
        line-height: 1.1;
        letter-spacing: -0.5px;
    }

    .hero-meta {
        display: flex;
        align-items: center;
        gap: 1.2rem;
        flex-wrap: wrap;
        font-size: 1.1rem;
        color: #d2d2d2;
        margin-bottom: 1.5rem;
        font-weight: 500;
    }

        .hero-meta > * {
            display: flex;
            align-items: center;
            gap: 0.4rem;
        }

    .meta-separator {
        color: rgba(255,255,255,0.3);
        font-size: 0.8rem;
    }

    .hero-description {
        font-size: 1.05rem;
        line-height: 1.7;
        color: #e0e0e0;
        max-width: 850px;
        margin-bottom: 2rem;
        text-shadow: 1px 1px 4px rgba(0,0,0,0.8);
        display: -webkit-box;
        -webkit-line-clamp: 3;
        -webkit-box-orient: vertical;
        overflow: hidden;
    }

    .hero-actions {
        display: flex;
        gap: 1rem;
        flex-wrap: wrap;
        position: relative;
        z-index: 100;
    }

    .btn-hero {
        padding: 0.9rem 2.2rem;
        border-radius: 8px;
        font-weight: 600;
        font-size: 1.05rem;
        cursor: pointer;
        transition: all var(--transition-speed);
        display: inline-flex;
        align-items: center;
        gap: 0.8rem;
        text-decoration: none;
        border: none;
        position: relative;
        z-index: 100;
    }

    .btn-hero-primary {
        background: var(--netflix-red);
        color: white;
        box-shadow: 0 4px 15px rgba(229, 9, 20, 0.4);
    }

        .btn-hero-primary:hover {
            background: #f40612;
            color: white;
            transform: translateY(-2px);
            box-shadow: 0 6px 20px rgba(229, 9, 20, 0.6);
        }

    .btn-hero-secondary {
        background: rgba(42, 42, 42, 0.6);
        backdrop-filter: blur(10px);
        color: white;
        border: 1px solid rgba(255,255,255,0.1);
    }

        .btn-hero-secondary:hover {
            background: rgba(255,255,255,0.2);
            color: white;
            border-color: rgba(255,255,255,0.4);
            transform: translateY(-2px);
        }

        .btn-hero-secondary.active {
            color: var(--netflix-red);
            border-color: var(--netflix-red);
            background: rgba(229, 9, 20, 0.1);
        }

    /* Gọn gàng nút Download ở Details */
    .btn-download-vip {
        color: #f5c518;
        border-color: rgba(245, 197, 24, 0.5);
    }

        .btn-download-vip:hover {
            background: rgba(245, 197, 24, 0.1) !important;
            color: #f5c518 !important;
            border-color: #f5c518 !important;
        }

    .btn-download-free {
        color: #46d369;
        border-color: rgba(70, 211, 105, 0.5);
    }

        .btn-download-free:hover {
            background: rgba(70, 211, 105, 0.1) !important;
            color: #46d369 !important;
            border-color: #46d369 !important;
        }

    .movie-container {
        max-width: 1400px;
        margin: 0 auto;
        padding: 0 40px;
    }

    .movie-layout {
        display: grid;
        grid-template-columns: 300px 1fr;
        gap: 40px;
        margin-top: 2.5rem;
    }

    .sidebar-column {
        position: sticky;
        top: 90px;
        align-self: start;
    }

    .sidebar-section {
        background: var(--bg-card);
        border: 1px solid var(--border-color);
        border-radius: 12px;
        padding: 1.5rem;
        margin-bottom: 1.5rem;
        box-shadow: 0 4px 20px rgba(0,0,0,0.3);
    }

    .sidebar-title {
        font-size: 1.1rem;
        font-weight: 700;
        margin-bottom: 1.2rem;
        padding-bottom: 0.8rem;
        border-bottom: 1px solid var(--border-color);
        display: flex;
        align-items: center;
        gap: 0.6rem;
        color: var(--text-primary);
    }

    .info-grid {
        display: grid;
        gap: 1rem;
    }

    .info-row {
        display: flex;
        flex-direction: column;
        gap: 0.3rem;
        font-size: 0.95rem;
    }

    .info-label {
        color: var(--text-secondary);
        font-weight: 600;
        font-size: 0.85rem;
        text-transform: uppercase;
        letter-spacing: 0.5px;
    }

    .info-value {
        color: #e0e0e0;
        font-weight: 500;
    }

    .top-movies-compact {
        list-style: none;
        padding: 0;
        margin: 0;
    }

    .top-movie-compact {
        display: flex;
        gap: 1rem;
        padding: 0.8rem;
        border-radius: 8px;
        margin-bottom: 0.5rem;
        transition: all var(--transition-speed);
        cursor: pointer;
        text-decoration: none;
        color: var(--text-primary);
        align-items: center;
    }

        .top-movie-compact:hover {
            background: var(--bg-hover);
            transform: translateX(5px);
        }

    .top-rank-compact {
        font-size: 1.4rem;
        font-weight: 900;
        color: var(--netflix-red);
        min-width: 25px;
        text-align: center;
    }

    .top-thumb-compact {
        width: 50px;
        height: 75px;
        border-radius: 6px;
        object-fit: cover;
        box-shadow: 0 2px 8px rgba(0,0,0,0.5);
    }

    .top-info-compact {
        flex: 1;
        min-width: 0;
    }

        .top-info-compact h5 {
            font-size: 0.95rem;
            font-weight: 600;
            margin-bottom: 0.3rem;
            white-space: nowrap;
            overflow: hidden;
            text-overflow: ellipsis;
        }

    .top-meta-compact {
        font-size: 0.8rem;
        color: var(--text-secondary);
    }

    .content-column {
        min-width: 0;
    }

    .stats-cards {
        display: grid;
        grid-template-columns: repeat(auto-fit, minmax(150px, 1fr));
        gap: 1.5rem;
        margin-bottom: 2rem;
    }

    .stat-card {
        background: var(--bg-card);
        border: 1px solid var(--border-color);
        border-radius: 12px;
        padding: 1.5rem;
        text-align: center;
        transition: all var(--transition-speed);
        box-shadow: 0 4px 15px rgba(0,0,0,0.2);
    }

        .stat-card:hover {
            background: var(--bg-hover);
            border-color: rgba(255,255,255,0.2);
            transform: translateY(-5px);
        }

    .stat-number {
        font-size: 2rem;
        font-weight: 800;
        color: var(--text-primary);
        margin-bottom: 0.5rem;
    }

    .stat-card:first-child .stat-number {
        color: var(--accent-yellow);
    }

    .stat-card:nth-child(2) .stat-number {
        color: #3498db;
    }

    .stat-card:nth-child(3) .stat-number {
        color: #2ecc71;
    }

    .stat-card:nth-child(4) .stat-number {
        color: var(--netflix-red);
    }

    .stat-label {
        font-size: 0.85rem;
        color: var(--text-secondary);
        text-transform: uppercase;
        letter-spacing: 1px;
        font-weight: 600;
    }

    /* Interactive Rating Section */
    .interactive-rating {
        display: flex;
        flex-direction: row-reverse;
        gap: 5px;
        font-size: 2rem;
    }

        .interactive-rating input {
            display: none;
        }

        .interactive-rating label {
            color: #444;
            cursor: pointer;
            transition: color 0.2s;
            margin: 0;
        }

            .interactive-rating label:hover, .interactive-rating label:hover ~ label, .interactive-rating input:checked ~ label {
                color: var(--accent-yellow);
            }

    .rate-prompt-text {
        font-size: 0.9rem;
        color: var(--text-secondary);
        margin-bottom: 5px;
        font-weight: 500;
        text-align: right;
    }

    .review-box {
        background: var(--bg-card);
        border: 1px solid var(--border-color);
        border-radius: 12px;
        padding: 2rem;
        margin-bottom: 2rem;
        box-shadow: 0 4px 20px rgba(0,0,0,0.2);
    }

    .rating-overview {
        display: grid;
        grid-template-columns: 200px 1fr;
        gap: 3rem;
        align-items: center;
    }

    .rating-score {
        text-align: center;
    }

    .rating-number {
        font-size: 4.5rem;
        font-weight: 800;
        color: var(--accent-yellow);
        line-height: 1;
        margin-bottom: 0.5rem;
    }

    .rating-stars {
        font-size: 1.5rem;
        color: var(--accent-yellow);
        margin-bottom: 0.8rem;
    }

    .rating-count {
        font-size: 0.95rem;
        color: var(--text-secondary);
        font-weight: 500;
    }

    .rating-bars {
        display: flex;
        flex-direction: column;
        gap: 0.8rem;
    }

    .rating-bar-row {
        display: flex;
        align-items: center;
        gap: 1rem;
    }

    .bar-label {
        min-width: 60px;
        font-size: 0.95rem;
        color: var(--text-secondary);
        font-weight: 500;
    }

    .bar-container {
        flex: 1;
        height: 10px;
        background: rgba(255,255,255,0.05);
        border-radius: 5px;
        overflow: hidden;
    }

    .bar-fill {
        height: 100%;
        background: linear-gradient(90deg, #f5c518, #ffda44);
        border-radius: 5px;
        transition: width 1s cubic-bezier(0.4, 0, 0.2, 1);
    }

    .bar-count {
        min-width: 40px;
        text-align: right;
        font-size: 0.9rem;
        color: var(--text-secondary);
    }

    .section-title {
        font-size: 1.4rem;
        font-weight: 600;
        margin-bottom: 20px;
        display: flex;
        align-items: center;
        gap: 10px;
    }

    .review-textarea {
        width: 100%;
        background: rgba(255,255,255,0.03);
        border: 1px solid var(--border-color);
        border-radius: 8px;
        color: var(--text-primary);
        padding: 1.2rem;
        font-size: 1rem;
        resize: vertical;
        margin-bottom: 0.5rem;
        transition: all 0.3s;
    }

        .review-textarea:focus {
            outline: none;
            border-color: var(--netflix-red);
        }

    .btn-submit-review {
        background: var(--netflix-red);
        color: white;
        padding: 0.6rem 1.5rem;
        border: none;
        border-radius: 6px;
        font-weight: 600;
        cursor: pointer;
        display: inline-flex;
        align-items: center;
        gap: 0.5rem;
    }

        .btn-submit-review:hover {
            background: #f40612;
        }

    .reviews-list {
        display: flex;
        flex-direction: column;
        gap: 1.2rem;
    }

    .review-item {
        background: rgba(255,255,255,0.02);
        border: 1px solid var(--border-color);
        border-radius: 12px;
        padding: 1.5rem;
        margin-bottom: 1rem;
        transition: all 0.3s;
    }

    .review-header {
        display: flex;
        justify-content: space-between;
        align-items: flex-start;
        margin-bottom: 0.8rem;
    }

    .review-author {
        display: flex;
        align-items: center;
        gap: 1rem;
    }

    .author-avatar {
        width: 45px;
        height: 45px;
        border-radius: 50%;
        background: linear-gradient(135deg, var(--netflix-red), #ff4b4b);
        display: flex;
        align-items: center;
        justify-content: center;
        font-weight: 700;
        font-size: 1.2rem;
        color: #fff;
        overflow: hidden;
        border: 1px solid rgba(255,255,255,0.1);
    }

        .author-avatar img {
            width: 100%;
            height: 100%;
            object-fit: cover;
        }

    .author-info h4 {
        font-size: 1.05rem;
        font-weight: 700;
        margin-bottom: 0.1rem;
        display: flex;
        align-items: center;
    }

    .review-date {
        font-size: 0.9rem;
        color: var(--text-secondary);
    }

    .review-content {
        color: #e0e0e0;
        line-height: 1.6;
        font-size: 1rem;
        margin-top: 5px;
    }

    .review-actions {
        display: flex;
        gap: 1.2rem;
        margin-top: 0.8rem;
        padding-top: 0.8rem;
        border-top: 1px solid rgba(255,255,255,0.05);
    }

    .review-action-btn {
        background: none;
        border: none;
        color: var(--text-secondary);
        font-size: 0.9rem;
        font-weight: 500;
        cursor: pointer;
        transition: all 0.2s;
        display: inline-flex;
        align-items: center;
        gap: 0.3rem;
    }

        .review-action-btn:hover {
            color: var(--text-primary);
        }

    .login-prompt {
        text-align: center;
        padding: 2rem 1rem;
        border: 1px dashed var(--border-color);
        border-radius: 12px;
    }

    .cast-grid {
        display: grid;
        grid-template-columns: repeat(auto-fill, minmax(120px, 1fr));
        gap: 1.5rem;
    }

    .cast-card {
        text-align: center;
        transition: transform var(--transition-speed);
    }

        .cast-card:hover {
            transform: translateY(-5px);
        }

    .cast-avatar {
        width: 110px;
        height: 110px;
        border-radius: 50%;
        background: var(--bg-hover);
        display: flex;
        align-items: center;
        justify-content: center;
        margin: 0 auto 0.8rem;
        border: 3px solid var(--border-color);
        overflow: hidden;
        box-shadow: 0 4px 10px rgba(0,0,0,0.5);
    }

        .cast-avatar img {
            width: 100%;
            height: 100%;
            object-fit: cover;
        }

        .cast-avatar i {
            font-size: 3rem;
            color: var(--text-secondary);
        }

    .cast-name {
        font-size: 0.95rem;
        font-weight: 600;
        margin-bottom: 0.3rem;
        color: var(--text-primary);
    }

    .cast-role {
        font-size: 0.8rem;
        color: var(--text-secondary);
    }

    .episodes-list {
        display: flex;
        flex-direction: column;
        gap: 1rem;
    }

    .episode-item {
        background: rgba(255,255,255,0.02);
        border: 1px solid var(--border-color);
        border-radius: 10px;
        padding: 1.2rem;
        display: grid;
        grid-template-columns: 50px 140px 1fr auto;
        gap: 1.5rem;
        align-items: center;
        transition: all var(--transition-speed);
        text-decoration: none;
        color: var(--text-primary);
    }

        .episode-item:hover {
            background: var(--bg-hover);
            border-color: rgba(255,255,255,0.2);
            transform: translateX(5px);
        }

    .episode-number {
        font-size: 1.5rem;
        font-weight: 800;
        color: var(--text-secondary);
        text-align: center;
    }

    .episode-thumb {
        width: 140px;
        height: 80px;
        border-radius: 6px;
        background: var(--bg-hover);
        display: flex;
        align-items: center;
        justify-content: center;
        overflow: hidden;
        position: relative;
    }

        .episode-thumb i {
            font-size: 2rem;
            color: rgba(255,255,255,0.8);
            position: absolute;
        }

    .episode-info {
        flex: 1;
        min-width: 0;
    }

    .episode-title {
        font-weight: 700;
        font-size: 1.1rem;
        margin-bottom: 0.4rem;
    }

    .episode-desc {
        font-size: 0.9rem;
        color: var(--text-secondary);
        display: -webkit-box;
        -webkit-line-clamp: 2;
        -webkit-box-orient: vertical;
        overflow: hidden;
    }

    .episode-duration {
        font-size: 0.9rem;
        color: var(--text-secondary);
        font-weight: 500;
    }

    .btn-play-ep {
        width: 45px;
        height: 45px;
        border-radius: 50%;
        background: rgba(255,255,255,0.1);
        border: 1px solid rgba(255,255,255,0.2);
        color: white;
        display: flex;
        align-items: center;
        justify-content: center;
        transition: all var(--transition-speed);
    }

    .episode-item:hover .btn-play-ep {
        background: var(--netflix-red);
        border-color: var(--netflix-red);
        transform: scale(1.1);
    }

    .toast-notification {
        position: fixed;
        top: 90px;
        right: 20px;
        background: var(--bg-card);
        padding: 1rem 1.5rem;
        border-radius: 6px;
        box-shadow: 0 10px 30px rgba(0,0,0,0.5);
        z-index: 9999;
        display: flex;
        align-items: center;
        gap: 1rem;
        border-left: 4px solid var(--netflix-red);
        animation: slideInRight 0.3s ease;
    }

    @@keyframes slideInRight {
        from {
            opacity: 0;
            transform: translateX(120%);
        }

        to {
            opacity: 1;
            transform: translateX(0);
        }
    }

    @@media (max-width: 1024px) {
        .movie-layout {
            grid-template-columns: 1fr;
        }

        .sidebar-column {
            position: relative;
            top: 0;
            display: grid;
            grid-template-columns: repeat(2, 1fr);
            gap: 1.5rem;
        }
    }

    @@media (max-width: 768px) {
        .hero-banner {
            height: auto;
            min-height: 500px;
            padding-top: 80px;
        }

        .hero-inner {
            flex-direction: column;
            align-items: center;
            text-align: center;
            gap: 20px;
        }

        .hero-title {
            font-size: 2.5rem;
        }

        .hero-meta, .hero-actions {
            justify-content: center;
        }

        .sidebar-column {
            grid-template-columns: 1fr;
        }

        .stats-cards {
            grid-template-columns: repeat(2, 1fr);
        }

        .rating-overview {
            grid-template-columns: 1fr;
            gap: 2rem;
        }

        .episode-item {
            grid-template-columns: 40px 1fr auto;
        }

        .episode-thumb {
            display: none;
        }
    }
</style>

<div class="hero-banner">
    @if (TempData["Error"] != null)
    {
        <div class="alert alert-danger" style="margin: 20px; z-index: 999; position: relative; border-radius: 8px;">
            <strong>Error:</strong> @TempData["Error"]
        </div>
    }
    <img src="@(Model.Movie.PosterUrl ?? "/images/default-bg.jpg")" alt="@Model.Movie.Title" class="hero-backdrop">
    <div class="hero-gradient"></div>

    <div class="hero-content">
        <div class="hero-inner">
            <div class="hero-poster">
                <img src="@(Model.Movie.PosterUrl ?? "/images/no-poster.jpg")" alt="@Model.Movie.Title">
            </div>

            <div class="hero-info">
                <h1 class="hero-title">@Model.Movie.Title</h1>

                <div class="hero-meta">
                    @if (Model.Movie.ReleaseYear.HasValue)
                    {
                        <span>@Model.Movie.ReleaseYear</span>
                        <span class="meta-separator">•</span>
 }
                    @if (Model.Movie.DurationMinutes.HasValue)
                    {
                        <span><i class="far fa-clock"></i> @Model.Movie.DurationMinutes min</span>
                        <span class="meta-separator">•</span>
 }
                    <span>@Model.Movie.Type</span>
                    @if (!string.IsNullOrEmpty(Model.Movie.CountryName))
                    {
                        <span class="meta-separator">•</span>
                        <span>@Model.Movie.CountryName</span>
 }
                </div>

                @if (!string.IsNullOrEmpty(Model.Movie.Description))
                {
                    <p class="hero-description">@Model.Movie.Description</p>
                }

                <div class="hero-actions">
                    <a href="/Movie/Watch/@Model.Movie.Slug" class="btn-hero btn-hero-primary"><i class="fas fa-play"></i> Watch Now</a>

                    @if (isVip)
                    {
                        <a asp-controller="Movie" asp-action="Download" asp-route-id="@Model.Movie.Id" class="btn-hero btn-hero-secondary btn-download-free text-success">
                            <i class="fa-solid fa-download"></i> Download
                        </a>
                    }
                    else
                    {
                        <a asp-controller="Premium" asp-action="Index" class="btn-hero btn-hero-secondary btn-download-vip text-warning" title="Upgrade to VIP to download this movie">
                            <i class="fa-solid fa-crown"></i> VIP Download
                        </a>
                    }

                    @if (!string.IsNullOrEmpty(Model.Movie.TrailerUrl))
                    {
                        <a href="@Model.Movie.TrailerUrl" target="_blank" class="btn-hero btn-hero-secondary">
                            <i class="fab fa-youtube"></i> Trailer
                        </a>
                    }

                    @if (User.Identity?.IsAuthenticated == true)
                    {
                        <button type="button" class="btn-hero btn-hero-secondary favorite-toggle-btn @(isFavorited ? "active" : "")" data-movie-id="@Model.Movie.Id">
                            <i class="@(isFavorited ? "fas fa-check" : "fas fa-plus")"></i>
                            <span>@(isFavorited ? "In My List" : "My List")</span>
                        </button>
                    }
                    else
                    {
                        <a href="/Identity/Account/Login?returnUrl=@Uri.EscapeDataString(currentUrl)" class="btn-hero btn-hero-secondary">
                            <i class="far fa-heart"></i> Favorite
                        </a>
                    }
                </div>
            </div>
        </div>
    </div>
</div>

<div class="movie-container">
    <div class="movie-layout">
        <div class="sidebar-column">
            <div class="sidebar-section">
                <h3 class="sidebar-title"><i class="fas fa-info-circle"></i> Information</h3>
                <div class="info-grid">
                    @if (Model.Movie.ReleaseYear.HasValue)
                    {
                        <div class="info-row"><span class="info-label">Year</span><span class="info-value">@Model.Movie.ReleaseYear</span></div>
                    }
                    @if (Model.Movie.DurationMinutes.HasValue)
                    {
                        <div class="info-row"><span class="info-label">Duration</span><span class="info-value">@Model.Movie.DurationMinutes min</span></div>
                    }
                    @if (!string.IsNullOrEmpty(Model.Movie.CountryName))
                    {
                        <div class="info-row"><span class="info-label">Country</span><span class="info-value">@Model.Movie.CountryName</span></div>
                    }
                    <div class="info-row"><span class="info-label">Type</span><span class="info-value">@Model.Movie.Type</span></div>
                    <div class="info-row"><span class="info-label">Status</span><span class="info-value">@Model.Movie.Status</span></div>
                </div>
            </div>

            @if (Model.RelatedMovies != null && Model.RelatedMovies.Any())
            {
                <div class="sidebar-section">
                    <h3 class="sidebar-title"><i class="fas fa-fire"></i> Trending This Week</h3>
                    <ul class="top-movies-compact">
                        @for (int i = 0; i < Math.Min(5, Model.RelatedMovies.Count()); i++)
                        {
                            var movie = Model.RelatedMovies.ElementAt(i);
                            <li>
                                <a href="@Url.Action("Detail", "Movie", new { slug = movie.Slug })" class="top-movie-compact">
                                    <div class="top-rank-compact">@(i + 1)</div>
                                    <img src="@(movie.PosterUrl ?? "/images/no-poster.jpg")" alt="@movie.Title" class="top-thumb-compact">
                                    <div class="top-info-compact">
                                        <h5>@movie.Title</h5>
                                        <div class="top-meta-compact">
                                            @if (movie.ReleaseYear.HasValue)
                                            {
                                                <span>@movie.ReleaseYear • </span>
                                            }
         <span>@movie.Type</span>
                                        </div>
                                    </div>
                                </a>
                            </li>
                        }
                    </ul>
                </div>
            }
        </div>

        <div class="content-column">
            <div class="stats-cards">
                <div class="stat-card"><div class="stat-number">@(rating != null && rating.TotalReviews > 0 ? rating.AverageRating.ToString("F1") : "--")</div><div class="stat-label">Rating</div></div>
                <div class="stat-card"><div class="stat-number">@Model.Movie.ViewCount.ToString("N0")</div><div class="stat-label">Views</div></div>
                <div class="stat-card"><div class="stat-number">@textReviews.Count</div><div class="stat-label">Comments</div></div>
                <div class="stat-card"><div class="stat-number">@(rating != null ? rating.TotalFavorites.ToString() : "0")</div><div class="stat-label">Favorites</div></div>
            </div>

            @if (Model.Actors != null && Model.Actors.Any())
            {
                <div class="review-box">
                    <h2 class="section-title"><i class="fas fa-users text-danger"></i> Cast & Crew</h2>
                    <div class="cast-grid">
                        @foreach (var actor in Model.Actors)
                        {
                            <a href="/Actor/Dashboard/@actor.Id" style="text-decoration: none; color: inherit; display: block;">
                                <div class="cast-card">
                                    <div class="cast-avatar">
                                        @if (!string.IsNullOrEmpty(actor.AvartUrl))
                                        {
                                            <img src="@actor.AvartUrl" alt="@actor.Name">
                                        }
                                        else
                                        {

                                            <i class="fas fa-user"></i>
                                        }
                                    </div>
                                    <div class="cast-name">@actor.Name</div>
                                    <div class="cast-role">@(string.IsNullOrEmpty(actor.Gender) ? "Actor" : actor.Gender)</div>
                                </div>
                            </a>
                        }
                    </div>
                </div>
            }

            @if (Model.Episodes != null && Model.Episodes.Any() && Model.Movie.Type == MovieType.Series)
            {
                <div class="review-box">
                    <h2 class="section-title"><i class="fas fa-list text-danger"></i> Episodes List (@Model.Episodes.Count())</h2>
                    <div class="episodes-list">
                        @foreach (var episode in Model.Episodes)
                        {
                            <a href="/Movie/Watch/@Model.Movie.Slug?ep=@episode.EpisodeNumber" class="episode-item">
                                <div class="episode-number">@episode.EpisodeNumber</div>
                                <div class="episode-thumb"><i class="fas fa-play-circle"></i></div>
                                <div class="episode-info">
                                    <div class="episode-title">@episode.Title</div>
                                    @if (!string.IsNullOrEmpty(episode.Description))
                                    {
                                        <div class="episode-desc">@episode.Description</div>
                                    }
                                </div>
                                @if (episode.DurationMinutes.HasValue)
                                {
                                    <div class="episode-duration">@episode.DurationMinutes min</div>
                                }
                                <div class="btn-play-ep"><i class="fas fa-play"></i></div>
                            </a>
                        }
                    </div>
                </div>
            }

            @if (rating != null)
            {
                <div class="review-box">
                    <div class="d-flex justify-content-between align-items-start mb-4 flex-wrap gap-3">
                        <h2 class="section-title m-0"><i class="fas fa-star text-danger"></i> Rating Overview</h2>

                        @if (User.Identity?.IsAuthenticated == true)
                        {
                            var myRatingRecord = rawReviews.FirstOrDefault(r => r.UserName == User.Identity.Name && r.Rating > 0);
                            int myCurrentStar = myRatingRecord != null ? myRatingRecord.Rating : 0;

                            <div>
                                <div class="rate-prompt-text">@(myCurrentStar > 0 ? "Your Rating:" : "Rate this movie:")</div>
                                <form id="ratingForm" class="interactive-rating">
                                    <input type="hidden" name="MovieId" value="@Model.Movie.Id" />
                                    @for (int i = 5; i >= 1; i--)
                                    {
                                        string isChecked = (i == myCurrentStar) ? "checked" : "";
                                        <input type="radio" id="voteStar@(i)" name="Rating" value="@i" class="vote-star-btn" @isChecked />
                                        <label for="voteStar@(i)" title="@i stars"><i class="fas fa-star"></i></label>
                                    }
                                </form>
                            </div>
                        }
                    </div>

                    <div class="rating-overview">
                        <div class="rating-score">
                            <div class="rating-number">@(rating.TotalReviews > 0 ? rating.AverageRating.ToString("F1") : "0.0")</div>
                            <div class="rating-stars">
                                @for (int i = 1; i <= 5; i++)
                                {
                                    if (i <= Math.Round(rating.AverageRating))
                                    {
                                        <i class="fas fa-star"></i>
                                    }
                                    else if (i - 0.5 <= rating.AverageRating)
                                    {

                                        <i class="fas fa-star-half-alt"></i>
                                    }
                                    else
                                    {

                                        <i class="far fa-star"></i>
                                    }
                                }
                            </div>
                            <div class="rating-count">@rating.TotalReviews ratings</div>
                        </div>
                        <div class="rating-bars">
                            @foreach (var star in new[] { 5, 4, 3, 2, 1 })
                            {
                                var count = rating.RatingDistribution.ContainsKey(star) ? rating.RatingDistribution[star] : 0;
                                var percentage = rating.TotalReviews > 0 ? (count * 100.0 / rating.TotalReviews) : 0;
                                <div class="rating-bar-row">
                                    <span class="bar-label">@star stars</span>
                                    <div class="bar-container"><div class="bar-fill" style="width: @(percentage)%"></div></div>
                                    <span class="bar-count">@count</span>
                                </div>
                            }
                        </div>
                    </div>
                </div>
            }

            <div class="review-box" id="create-review-section">
                @if (User.Identity?.IsAuthenticated == true)
                {
                    <h2 class="section-title"><i class="fas fa-comment-dots text-danger"></i> Leave a Comment</h2>
                    <form id="mainCommentForm" method="post">
                        @Html.AntiForgeryToken()
                        <input type="hidden" name="MovieId" value="@Model.Movie.Id" />

                        <div class="d-flex gap-3 mb-3">
                            <div class="author-avatar" style="width: 50px; height: 50px; flex-shrink: 0; background: linear-gradient(135deg, #e50914, #ff4b4b);">
                                @if (!string.IsNullOrEmpty(currentUserAvatar))
                                {
                                    <img src="@currentUserAvatar" alt="Avatar" />
                                }
                                else
                                {
                                    @currentUserName.Substring(0, 1).ToUpper()
                                }
                            </div>
                            <div class="flex-grow-1">
                                <textarea name="Comment" class="review-textarea m-0" rows="3" placeholder="Share your thoughts about this movie..." required></textarea>
                            </div>
                        </div>
                        <div class="text-end">
                            <button type="submit" class="btn-submit-review btn-main-submit"><i class="fas fa-paper-plane"></i> Post Comment</button>
                        </div>
                    </form>
                }
                else
                {
                    <div class="login-prompt">
                        <i class="fas fa-user-lock mb-3 d-block" style="font-size: 3rem;"></i>
                        <p class="mb-3">Sign in to join the discussion.</p>
                        <a href="/Identity/Account/Login?returnUrl=@Uri.EscapeDataString(currentUrl)" class="btn-submit-review text-decoration-none">Sign In</a>
                    </div>
                }
            </div>

            <div class="review-box" id="all-reviews-section">
                <h2 class="section-title"><i class="fas fa-comments text-danger"></i> Discussion (<span id="reviewCount">@textReviews.Count</span>)</h2>

                <div class="reviews-list" id="reviewsListContainer">
                    @if (textReviews.Any())
                    {
                        @foreach (var comment in textReviews)
                        {
                            // 1. Ưu tiên lấy FullName mới nhất từ DTO, nếu không có thì lấy UserName
                            var rawName = !string.IsNullOrEmpty(comment.FullName) && comment.FullName != "Unknown"
                            ? comment.FullName
                            : (comment.UserName ?? "User");

                            // Cắt bỏ phần @gmail.com nếu là email
                            string displayName = rawName.Contains("@") ? rawName.Split('@')[0] : rawName;

                            // 2. Kiểm tra xem có phải comment của user hiện tại không dựa vào UserId (chính xác hơn)
                            bool isMyComment = User.Identity?.IsAuthenticated == true && comment.UserId == userId;

                            // 3. Lấy AvatarUrl trực tiếp từ DTO vì ReviewService đã join với Identity
                            string displayAvatar = isMyComment && !string.IsNullOrEmpty(currentUserAvatar)
                            ? currentUserAvatar
                            : (comment.AvatarUrl ?? "");

                            string[] colors = { "#e50914", "#f5c518", "#3498db", "#2ecc71", "#9b59b6" };
                            string avatarBg = colors[Math.Abs(displayName.GetHashCode()) % colors.Length];

                            <div class="review-item" id="review-@comment.Id" style="@(isMyComment ? "border-color: var(--netflix-red); background: rgba(229, 9, 20, 0.02);" : "")">
                                <div id="display-mode-@comment.Id">
                                    <div class="review-header">
                                        <div class="review-author">
                                            <!-- Gắn Avatar -->
                                            <div class="author-avatar" style="background: @avatarBg;">
                                                @if (!string.IsNullOrEmpty(displayAvatar))
                                                {
                                                    <img src="@displayAvatar" alt="@displayName" />
                                                }
                                                else
                                                {
                                                    @displayName.Substring(0, 1).ToUpper()
                                                }
                                            </div>
                                            <div class="author-info">
                                                <!-- Hiển thị Display Name mới nhất -->
                                                <h4>
                                                    @displayName
                                                    @if (isMyComment)
                                                    {
                                                        <span class="badge bg-danger ms-2" style="font-size: 0.7rem;">You</span>
                                                    }
                                                </h4>
                                                <span class="review-date">@comment.CreatedAt.ToString("MMM dd, yyyy")</span>
                                            </div>
                                        </div>                               
                                    </div>
                                    <div class="review-content">@comment.Comment</div>

                                    <div class="review-actions">
                                        @if (isMyComment)
                                        {
                                            <button class="review-action-btn text-primary" onclick="showEditForm('@comment.Id')"><i class="fas fa-edit"></i> Edit</button>
                                            <button class="review-action-btn text-danger ms-3" onclick="deleteReview('@comment.Id')"><i class="fas fa-trash"></i> Delete</button>
                                        }

                                    </div>
                                </div>

                                @if (isMyComment)
                                {
                                    <div id="edit-mode-@comment.Id" style="display: none; margin-top: 15px;">
                                        <form class="form-edit-review" method="post">
                                            @Html.AntiForgeryToken()
                                            <input type="hidden" name="Id" value="@comment.Id" />
                                            <input type="hidden" name="MovieId" value="@Model.Movie.Id" />
                                            <textarea name="Comment" class="review-textarea" rows="2" required>@comment.Comment</textarea>
                                            <div class="d-flex gap-2 mt-2">
                                                <button type="submit" class="btn btn-danger btn-sm px-3 fw-bold">Save</button>
                                                <button type="button" class="btn btn-secondary btn-sm px-3 fw-bold" onclick="hideEditForm('@comment.Id')">Cancel</button>
                                            </div>
                                        </form>
                                    </div>
                                }
                            </div>
                        }
                    }
                    else
                    {
                        <div id="no-reviews-msg" class="text-center text-secondary py-4">
                            <i class="fas fa-comment-slash fs-1 mb-3"></i>
                            <p>No comments yet. Be the first to share your thoughts!</p>
                        </div>
                    }
                </div>
            </div>

        </div>
    </div>
</div>

@section Scripts {
    <script>
        $(document).ready(function() {
            // Favorite Button
            $('.favorite-toggle-btn').click(function() {
                const btn = $(this);
                fetch('@Url.Action("Toggle", "Favorites")', {
                    method: 'POST',
                    headers: { 'Content-Type': 'application/x-www-form-urlencoded', 'RequestVerificationToken': $('input[name="__RequestVerificationToken"]').val() },
                    body: `movieId=${btn.data('movie-id')}`
                }).then(r => r.json()).then(data => {
                    if (data.success) {
                        if (data.isFavorite) { btn.addClass('active').find('span').text('In My List'); btn.find('i').attr('class', 'fas fa-check'); }
                        else { btn.removeClass('active').find('span').text('My List'); btn.find('i').attr('class', 'fas fa-plus'); }
                        showToast(data.isFavorite ? 'Added to List' : 'Removed from List', 'success');
                    }
                });
            });

            // 1. AJAX RATING SAO ĐỘC LẬP
            $('.vote-star-btn').on('change', function() {
                const form = $('#ratingForm');
                $.ajax({
                    url: '@Url.Action("RateMovie", "Reviews")',
                    type: 'POST',
                    data: form.serialize(),
                    success: function(response) {
                        if(response.success) {
                            showToast(response.message, 'success');
                            setTimeout(() => location.reload(), 1000);
                        } else {
                            showToast(response.message, 'error');
                        }
                    }
                });
            });

            // 2. AJAX COMMENT TEXT
            $('#mainCommentForm').on('submit', function(e) {
                e.preventDefault();
                const submitBtn = $(this).find('.btn-main-submit');
                submitBtn.prop('disabled', true).html('<i class="fas fa-spinner fa-spin"></i> Posting...');

                $.ajax({
                    url: '@Url.Action("Create", "Reviews")', type: 'POST', data: $(this).serialize(),
                    success: function(response) {
                        if (response.success) {
                            showToast('Comment posted!', 'success');
                            setTimeout(() => location.reload(), 800);
                        } else { showToast(response.message, 'error'); }
                    },
                    complete: function() { submitBtn.prop('disabled', false).html('<i class="fas fa-paper-plane"></i> Post Comment'); }
                });
            });

            // 3. EDIT COMMENT
            $(document).on('submit', '.form-edit-review', function(e) {
                e.preventDefault();
                const form = $(this);
                const reviewId = form.find('input[name="Id"]').val();

                $.ajax({
                    url: '@Url.Action("Edit", "Reviews")', type: 'POST', data: form.serialize(),
                    success: function(response) {
                        if (response.success) {
                            showToast('Saved!', 'success');
                            setTimeout(() => location.reload(), 800);
                        }
                    }
                });
            });
        });

        function showEditForm(reviewId) { $('#display-mode-' + reviewId).hide(); $('#edit-mode-' + reviewId).fadeIn(200); }
        function hideEditForm(reviewId) { $('#edit-mode-' + reviewId).hide(); $('#display-mode-' + reviewId).fadeIn(200); }

        function deleteReview(reviewId) {
            if (!confirm('Are you sure you want to delete this comment?')) return;
            $.ajax({
                url: '@Url.Action("Delete", "Reviews")', type: 'POST',
                data: { id: reviewId, __RequestVerificationToken: $('input[name="__RequestVerificationToken"]').val() },
                success: function(response) {
                    if (response.success) {
                        showToast('Deleted successfully!', 'success');
                        setTimeout(() => location.reload(), 800);
                    }
                }
            });
        }

        function showToast(message, type) {
            $('.toast-notification').remove();
            const borderColor = type === 'success' ? '#46d369' : '#e50914';
            const icon = type === 'success' ? 'check-circle' : 'exclamation-circle';
            const toast = $(`<div class="toast-notification" style="border-left-color: ${borderColor};"><i class="fas fa-${icon}" style="color: ${borderColor};"></i><span>${message}</span></div>`);
            $('body').append(toast);
            setTimeout(() => toast.fadeOut(300, function() { $(this).remove(); }), 3000);
        }
    </script>
}