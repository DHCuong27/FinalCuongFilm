@using FinalCuongFilm.ApplicationCore.Entities
@using FinalCuongFilm.ApplicationCore.Entities.Identity
@using Microsoft.AspNetCore.Identity
@using System.Security.Claims
@model FinalCuongFilm.MVC.Models.ViewModels.MovieDetailsViewModel
@using static FinalCuongFilm.ApplicationCore.Entities.Enum
@inject FinalCuongFilm.Service.Interfaces.IVipService VipService
@inject UserManager<CuongFilmUser> UserManager

@{
    ViewData["Title"] = Model.Movie.Title;
    Layout = "_LayoutUser";

    var userId = User.FindFirstValue(ClaimTypes.NameIdentifier);
    bool isVip = userId != null && await VipService.HasActiveVipAsync(userId);

    // BẮT CHÍNH XÁC TÊN VÀ AVATAR TỪ DATABASE (Giống hệt Navbar)
    string currentUserName = User.Identity?.Name ?? "Unknown";
    string currentUserAvatar = "";

    if (User.Identity?.IsAuthenticated == true)
    {
        var currentUser = await UserManager.GetUserAsync(User);
        if (currentUser != null)
        {
            // Lấy FullName, nếu không có thì lấy UserName, có @ thì cắt đuôi
            string rawName = !string.IsNullOrEmpty(currentUser.FullName) ? currentUser.FullName : currentUser.UserName;
            currentUserName = rawName.Contains("@") ? rawName.Split('@')[0] : rawName;
            currentUserAvatar = currentUser.AvatarUrl ?? "";
        }
    }

    var isFavorited = ViewBag.IsFavorited as bool? ?? false;
    var rating = ViewBag.Rating as FinalCuongFilm.Common.DTOs.MovieRatingDto;
    var reviews = ViewBag.Reviews as IEnumerable<FinalCuongFilm.Common.DTOs.ReviewDto> ?? new List<FinalCuongFilm.Common.DTOs.ReviewDto>();

    var currentUrl = Url.Action("Detail", "Movie", new { slug = Model.Movie.Slug });
}

<style>
    :root {
        --netflix-red: #e50914;
        --bg-dark: #0f0f0f;
        --bg-card: #1a1a1a;
        --bg-hover: #2a2a2a;
        --text-primary: #ffffff;
        --text-secondary: #a8a8a8;
        --border-color: #303030;
        --accent-yellow: #f5c518;
        --transition-speed: 0.3s;
    }

    body {
        background-color: var(--bg-dark);
        color: var(--text-primary);
        font-family: -apple-system, BlinkMacSystemFont, 'Segoe UI', Roboto, Arial, sans-serif;
    }

    /* Hero Banner */
    .hero-banner {
        position: relative;
        height: 550px;
        background-color: #000;
        margin-top: -70px;
        margin-bottom: 0;
        overflow: hidden;
    }

    .hero-backdrop {
        position: absolute;
        top: 0;
        left: 0;
        width: 100%;
        height: 100%;
        object-fit: cover;
        object-position: center 20%;
        opacity: 0.4;
        filter: blur(4px);
        transform: scale(1.05);
    }

    .hero-gradient {
        position: absolute;
        top: 0;
        left: 0;
        width: 100%;
        height: 100%;
        background: linear-gradient(to bottom, rgba(15,15,15,0) 0%, rgba(15,15,15,0.6) 60%, var(--bg-dark) 100%), linear-gradient(to right, var(--bg-dark) 0%, rgba(15,15,15,0.4) 50%, rgba(15,15,15,0) 100%);
    }

    .hero-content {
        position: absolute;
        bottom: 0;
        left: 0;
        right: 0;
        padding: 0 40px 40px;
        z-index: 10;
    }

    .hero-inner {
        max-width: 1400px;
        margin: 0 auto;
        display: flex;
        align-items: flex-end;
        gap: 40px;
        z-index: 11;
    }

    .hero-poster {
        width: 260px;
        flex-shrink: 0;
        border-radius: 12px;
        overflow: hidden;
        box-shadow: 0 20px 50px rgba(0,0,0,0.9);
        border: 1px solid rgba(255,255,255,0.1);
    }

        .hero-poster img {
            width: 100%;
            display: block;
            transition: transform var(--transition-speed);
        }

        .hero-poster:hover img {
            transform: scale(1.03);
        }

    .hero-info {
        flex: 1;
        padding-bottom: 10px;
    }

    .hero-title {
        font-size: 3.5rem;
        font-weight: 800;
        margin-bottom: 1rem;
        text-shadow: 2px 4px 10px rgba(0,0,0,0.9);
        line-height: 1.1;
        letter-spacing: -0.5px;
    }

    .hero-meta {
        display: flex;
        align-items: center;
        gap: 1.2rem;
        flex-wrap: wrap;
        font-size: 1.1rem;
        color: #d2d2d2;
        margin-bottom: 1.5rem;
        font-weight: 500;
    }

        .hero-meta > * {
            display: flex;
            align-items: center;
            gap: 0.4rem;
        }

    .meta-separator {
        color: rgba(255,255,255,0.3);
        font-size: 0.8rem;
    }

    .hero-description {
        font-size: 1.05rem;
        line-height: 1.7;
        color: #e0e0e0;
        max-width: 850px;
        margin-bottom: 2rem;
        text-shadow: 1px 1px 4px rgba(0,0,0,0.8);
        display: -webkit-box;
        -webkit-line-clamp: 3;
        -webkit-box-orient: vertical;
        overflow: hidden;
    }

    .hero-actions {
        display: flex;
        gap: 1rem;
        flex-wrap: wrap;
        position: relative;
        z-index: 100;
    }

    .btn-hero {
        padding: 0.9rem 2.2rem;
        border-radius: 8px;
        font-weight: 600;
        font-size: 1.05rem;
        cursor: pointer;
        transition: all var(--transition-speed);
        display: inline-flex;
        align-items: center;
        gap: 0.8rem;
        text-decoration: none;
        border: none;
        pointer-events: auto !important;
        position: relative;
        z-index: 100;
    }

    .btn-hero-primary {
        background: var(--netflix-red);
        color: white;
        box-shadow: 0 4px 15px rgba(229, 9, 20, 0.4);
    }

        .btn-hero-primary:hover {
            background: #f40612;
            color: white;
            transform: translateY(-2px);
            box-shadow: 0 6px 20px rgba(229, 9, 20, 0.6);
        }

    .btn-hero-secondary {
        background: rgba(42, 42, 42, 0.6);
        backdrop-filter: blur(10px);
        color: white;
        border: 1px solid rgba(255,255,255,0.1);
    }

        .btn-hero-secondary:hover {
            background: rgba(255,255,255,0.2);
            color: white;
            border-color: rgba(255,255,255,0.4);
            transform: translateY(-2px);
        }

        .btn-hero-secondary.active {
            color: var(--netflix-red);
            border-color: var(--netflix-red);
            background: rgba(229, 9, 20, 0.1);
        }

    /* Layout & Sidebar */
    .movie-container {
        max-width: 1400px;
        margin: 0 auto;
        padding: 0 40px;
    }

    .movie-layout {
        display: grid;
        grid-template-columns: 300px 1fr;
        gap: 40px;
        margin-top: 2.5rem;
    }

    .sidebar-column {
        position: sticky;
        top: 90px;
        align-self: start;
    }

    .sidebar-section {
        background: var(--bg-card);
        border: 1px solid var(--border-color);
        border-radius: 12px;
        padding: 1.5rem;
        margin-bottom: 1.5rem;
        box-shadow: 0 4px 20px rgba(0,0,0,0.3);
    }

    .sidebar-title {
        font-size: 1.1rem;
        font-weight: 700;
        margin-bottom: 1.2rem;
        padding-bottom: 0.8rem;
        border-bottom: 1px solid var(--border-color);
        display: flex;
        align-items: center;
        gap: 0.6rem;
        color: var(--text-primary);
    }

    .info-grid {
        display: grid;
        gap: 1rem;
    }

    .info-row {
        display: flex;
        flex-direction: column;
        gap: 0.3rem;
        font-size: 0.95rem;
    }

    .info-label {
        color: var(--text-secondary);
        font-weight: 600;
        font-size: 0.85rem;
        text-transform: uppercase;
        letter-spacing: 0.5px;
    }

    .info-value {
        color: #e0e0e0;
        font-weight: 500;
    }

    .top-movies-compact {
        list-style: none;
        padding: 0;
        margin: 0;
    }

    .top-movie-compact {
        display: flex;
        gap: 1rem;
        padding: 0.8rem;
        border-radius: 8px;
        margin-bottom: 0.5rem;
        transition: all var(--transition-speed);
        cursor: pointer;
        text-decoration: none;
        color: var(--text-primary);
        align-items: center;
    }

        .top-movie-compact:hover {
            background: var(--bg-hover);
            transform: translateX(5px);
        }

    .top-rank-compact {
        font-size: 1.4rem;
        font-weight: 900;
        color: var(--netflix-red);
        min-width: 25px;
        text-align: center;
    }

    .top-thumb-compact {
        width: 50px;
        height: 75px;
        border-radius: 6px;
        object-fit: cover;
        box-shadow: 0 2px 8px rgba(0,0,0,0.5);
    }

    .top-info-compact {
        flex: 1;
        min-width: 0;
    }

        .top-info-compact h5 {
            font-size: 0.95rem;
            font-weight: 600;
            margin-bottom: 0.3rem;
            white-space: nowrap;
            overflow: hidden;
            text-overflow: ellipsis;
        }

    .top-meta-compact {
        font-size: 0.8rem;
        color: var(--text-secondary);
    }

    /* Main Content */
    .content-column {
        min-width: 0;
    }

    .stats-cards {
        display: grid;
        grid-template-columns: repeat(auto-fit, minmax(150px, 1fr));
        gap: 1.5rem;
        margin-bottom: 2rem;
    }

    .stat-card {
        background: var(--bg-card);
        border: 1px solid var(--border-color);
        border-radius: 12px;
        padding: 1.5rem;
        text-align: center;
        transition: all var(--transition-speed);
        box-shadow: 0 4px 15px rgba(0,0,0,0.2);
    }

        .stat-card:hover {
            background: var(--bg-hover);
            border-color: rgba(255,255,255,0.2);
            transform: translateY(-5px);
        }

    .stat-number {
        font-size: 2rem;
        font-weight: 800;
        color: var(--text-primary);
        margin-bottom: 0.5rem;
    }

    .stat-card:first-child .stat-number {
        color: var(--accent-yellow);
    }

    .stat-card:nth-child(2) .stat-number {
        color: #3498db;
    }

    .stat-card:nth-child(3) .stat-number {
        color: #2ecc71;
    }

    .stat-card:nth-child(4) .stat-number {
        color: var(--netflix-red);
    }

    .stat-label {
        font-size: 0.85rem;
        color: var(--text-secondary);
        text-transform: uppercase;
        letter-spacing: 1px;
        font-weight: 600;
    }

    /* ---------------- GIAO DIỆN BÌNH LUẬN ---------------- */
    .review-box {
        background: var(--bg-card);
        border: 1px solid var(--border-color);
        border-radius: 12px;
        padding: 2rem;
        margin-bottom: 2rem;
    }

    .section-title {
        font-size: 1.4rem;
        font-weight: 600;
        margin-bottom: 20px;
        display: flex;
        align-items: center;
        gap: 10px;
    }

    .review-textarea {
        width: 100%;
        background: rgba(255,255,255,0.03);
        border: 1px solid var(--border-color);
        border-radius: 8px;
        color: var(--text-primary);
        padding: 1.2rem;
        font-size: 1rem;
        resize: vertical;
        margin-bottom: 0.5rem;
        transition: all 0.3s;
    }

        .review-textarea:focus {
            outline: none;
            border-color: var(--netflix-red);
        }

    .btn-submit-review {
        background: var(--netflix-red);
        color: white;
        padding: 0.6rem 1.5rem;
        border: none;
        border-radius: 6px;
        font-weight: 600;
        cursor: pointer;
        transition: all 0.2s;
        display: inline-flex;
        align-items: center;
        gap: 0.5rem;
    }

        .btn-submit-review:hover {
            background: #f40612;
        }

    .reviews-list {
        display: flex;
        flex-direction: column;
        gap: 1.2rem;
    }

    .review-item {
        background: rgba(255,255,255,0.02);
        border: 1px solid var(--border-color);
        border-radius: 12px;
        padding: 1.5rem;
        transition: all 0.3s;
        margin-bottom: 1rem;
    }

    .review-header {
        display: flex;
        justify-content: space-between;
        align-items: flex-start;
        margin-bottom: 0.8rem;
    }

    .review-author {
        display: flex;
        align-items: center;
        gap: 1rem;
    }

    /* Avatar chuẩn */
    .author-avatar {
        width: 45px;
        height: 45px;
        border-radius: 50%;
        background: linear-gradient(135deg, #667eea, #764ba2);
        display: flex;
        align-items: center;
        justify-content: center;
        font-weight: 700;
        font-size: 1.2rem;
        color: #fff;
        overflow: hidden;
        border: 2px solid rgba(255,255,255,0.1);
    }

        .author-avatar img {
            width: 100%;
            height: 100%;
            object-fit: cover;
        }

    .author-info h4 {
        font-size: 1.05rem;
        font-weight: 700;
        margin-bottom: 0.1rem;
        display: flex;
        align-items: center;
    }

    .review-date {
        font-size: 0.9rem;
        color: var(--text-secondary);
    }

    .review-content {
        color: #e0e0e0;
        line-height: 1.6;
        font-size: 1rem;
        margin-top: 5px;
    }

    .review-actions {
        display: flex;
        gap: 1.2rem;
        margin-top: 0.8rem;
        padding-top: 0.8rem;
        border-top: 1px solid rgba(255,255,255,0.05);
    }

    .review-action-btn {
        background: none;
        border: none;
        color: var(--text-secondary);
        font-size: 0.9rem;
        font-weight: 500;
        cursor: pointer;
        transition: all 0.2s;
        display: inline-flex;
        align-items: center;
        gap: 0.3rem;
    }

        .review-action-btn:hover {
            color: var(--text-primary);
        }

    .login-prompt {
        text-align: center;
        padding: 2rem 1rem;
        background: rgba(255,255,255,0.02);
        border-radius: 12px;
        border: 1px dashed var(--border-color);
    }

    /* Toast */
    .toast-notification {
        position: fixed;
        top: 90px;
        right: 20px;
        background: var(--bg-card);
        padding: 1rem 1.5rem;
        border-radius: 6px;
        box-shadow: 0 10px 30px rgba(0,0,0,0.5);
        z-index: 9999;
        display: flex;
        align-items: center;
        gap: 1rem;
        border-left: 4px solid var(--netflix-red);
        animation: slideInRight 0.3s ease;
    }

    @@keyframes slideInRight {
        from {
            opacity: 0;
            transform: translateX(120%);
        }

        to {
            opacity: 1;
            transform: translateX(0);
        }
    }

    /* Cast/Episodes Grid */
    .cast-grid {
        display: grid;
        grid-template-columns: repeat(auto-fill, minmax(120px, 1fr));
        gap: 1.5rem;
    }

    .cast-card {
        text-align: center;
        transition: transform var(--transition-speed);
    }

        .cast-card:hover {
            transform: translateY(-5px);
        }

    .cast-avatar {
        width: 110px;
        height: 110px;
        border-radius: 50%;
        background: var(--bg-hover);
        display: flex;
        align-items: center;
        justify-content: center;
        margin: 0 auto 0.8rem;
        border: 3px solid var(--border-color);
        overflow: hidden;
        box-shadow: 0 4px 10px rgba(0,0,0,0.5);
    }

        .cast-avatar img {
            width: 100%;
            height: 100%;
            object-fit: cover;
        }

        .cast-avatar i {
            font-size: 3rem;
            color: var(--text-secondary);
        }

    .cast-name {
        font-size: 0.95rem;
        font-weight: 600;
        margin-bottom: 0.3rem;
        color: var(--text-primary);
    }

    .cast-role {
        font-size: 0.8rem;
        color: var(--text-secondary);
    }

    @@media (max-width: 1024px) {
        .movie-layout {
            grid-template-columns: 1fr;
        }

        .sidebar-column {
            position: relative;
            top: 0;
            display: grid;
            grid-template-columns: repeat(2, 1fr);
            gap: 1.5rem;
        }
    }

    @@media (max-width: 768px) {
        .hero-banner {
            height: auto;
            min-height: 500px;
            padding-top: 80px;
        }

        .hero-inner {
            flex-direction: column;
            align-items: center;
            text-align: center;
            gap: 20px;
        }

        .hero-title {
            font-size: 2.5rem;
        }

        .hero-meta, .hero-actions {
            justify-content: center;
        }

        .sidebar-column {
            grid-template-columns: 1fr;
        }

        .stats-cards {
            grid-template-columns: repeat(2, 1fr);
        }
    }
</style>

<div class="hero-banner">
    @if (TempData["Error"] != null)
    {
        <div class="alert alert-danger" style="margin: 20px; z-index: 999; position: relative; border-radius: 8px;">
            <strong>Error:</strong> @TempData["Error"]
        </div>
    }
    <img src="@(Model.Movie.PosterUrl ?? "/images/default-bg.jpg")" alt="@Model.Movie.Title" class="hero-backdrop">
    <div class="hero-gradient"></div>

    <div class="hero-content">
        <div class="hero-inner">
            <div class="hero-poster">
                <img src="@(Model.Movie.PosterUrl ?? "/images/no-poster.jpg")" alt="@Model.Movie.Title">
            </div>

            <div class="hero-info">
                <h1 class="hero-title">@Model.Movie.Title</h1>

                <div class="hero-meta">
                    @if (Model.Movie.ReleaseYear.HasValue)
                    {
                        <span>@Model.Movie.ReleaseYear</span>
                        <span class="meta-separator">•</span>
 }
                    @if (Model.Movie.DurationMinutes.HasValue)
                    {
                        <span><i class="far fa-clock"></i> @Model.Movie.DurationMinutes min</span>
                        <span class="meta-separator">•</span>
 }
                    <span>@Model.Movie.Type</span>
                    @if (!string.IsNullOrEmpty(Model.Movie.CountryName))
                    {
                        <span class="meta-separator">•</span>
                        <span>@Model.Movie.CountryName</span>
 }
                </div>

                @if (!string.IsNullOrEmpty(Model.Movie.Description))
                {
                    <p class="hero-description">@Model.Movie.Description</p>
                }

                <div class="hero-actions">
                    <a href="/Movie/Watch/@Model.Movie.Slug" class="btn-hero btn-hero-primary"><i class="fas fa-play"></i> Watch Now</a>
                    @if (Model.IsVipOnly)
                    {
                        <a asp-controller="Movie" asp-action="Download" asp-route-id="@Model.Movie.Id" class="btn btn-warning text-dark"><i class="fa-solid fa-lock"></i> Premium Download</a>
                    }
                    else
                    {
                        <a asp-controller="Movie" asp-action="Download" asp-route-id="@Model.Movie.Id" class="btn btn-success"><i class="fa-solid fa-download"></i> Free Download</a>
                    }

                    @if (!string.IsNullOrEmpty(Model.Movie.TrailerUrl))
                    {
                        <a href="@Model.Movie.TrailerUrl" target="_blank" class="btn-hero btn-hero-secondary"><i class="fab fa-youtube"></i> Trailer</a>
                    }

                    @if (User.Identity?.IsAuthenticated == true)
                    {
                        <button type="button" class="btn-hero btn-hero-secondary favorite-toggle-btn @(isFavorited ? "active" : "")" data-movie-id="@Model.Movie.Id">
                            <i class="@(isFavorited ? "fas fa-check" : "fas fa-plus")"></i> <span>@(isFavorited ? "In My List" : "My List")</span>
                        </button>
                    }
                    else
                    {
                        <a href="/Identity/Account/Login?returnUrl=@Uri.EscapeDataString(currentUrl)" class="btn-hero btn-hero-secondary"><i class="far fa-heart"></i> Favorite</a>
                    }
                </div>
            </div>
        </div>
    </div>
</div>

<div class="movie-container">
    <div class="movie-layout">
        <div class="sidebar-column">
            <div class="sidebar-section">
                <h3 class="sidebar-title"><i class="fas fa-info-circle"></i> Information</h3>
                <div class="info-grid">
                    @if (Model.Movie.ReleaseYear.HasValue)
                    {
                        <div class="info-row"><span class="info-label">Year</span><span class="info-value">@Model.Movie.ReleaseYear</span></div>
                    }
                    @if (Model.Movie.DurationMinutes.HasValue)
                    {
                        <div class="info-row"><span class="info-label">Duration</span><span class="info-value">@Model.Movie.DurationMinutes min</span></div>
                    }
                    @if (!string.IsNullOrEmpty(Model.Movie.CountryName))
                    {
                        <div class="info-row"><span class="info-label">Country</span><span class="info-value">@Model.Movie.CountryName</span></div>
                    }
                    <div class="info-row"><span class="info-label">Type</span><span class="info-value">@Model.Movie.Type</span></div>
                    <div class="info-row"><span class="info-label">Status</span><span class="info-value">@Model.Movie.Status</span></div>
                </div>
            </div>

            @if (Model.RelatedMovies != null && Model.RelatedMovies.Any())
            {
                <div class="sidebar-section">
                    <h3 class="sidebar-title"><i class="fas fa-fire"></i> Trending This Week</h3>
                    <ul class="top-movies-compact">
                        @for (int i = 0; i < Math.Min(5, Model.RelatedMovies.Count()); i++)
                        {
                            var movie = Model.RelatedMovies.ElementAt(i);
                            <li>
                                <a href="@Url.Action("Detail", "Movie", new { slug = movie.Slug })" class="top-movie-compact">
                                    <div class="top-rank-compact">@(i + 1)</div>
                                    <img src="@(movie.PosterUrl ?? "/images/no-poster.jpg")" alt="@movie.Title" class="top-thumb-compact">
                                    <div class="top-info-compact">
                                        <h5>@movie.Title</h5>
                                        <div class="top-meta-compact">
                                            @if (movie.ReleaseYear.HasValue)
                                            {
                                                <span>@movie.ReleaseYear • </span>
                                            }
         <span>@movie.Type</span>
                                        </div>
                                    </div>
                                </a>
                            </li>
                        }
                    </ul>
                </div>
            }
        </div>

        <div class="content-column">
            <div class="stats-cards">
                <div class="stat-card"><div class="stat-number">@(rating != null && rating.TotalReviews > 0 ? rating.AverageRating.ToString("F1") : "--")</div><div class="stat-label">Average Rating</div></div>
                <div class="stat-card"><div class="stat-number">@Model.Movie.ViewCount.ToString("N0")</div><div class="stat-label">Views</div></div>
                <div class="stat-card"><div class="stat-number">@(rating != null ? rating.TotalReviews.ToString() : "0")</div><div class="stat-label">Comments</div></div>
                <div class="stat-card"><div class="stat-number">@(rating != null ? rating.TotalFavorites.ToString() : "0")</div><div class="stat-label">Favorites</div></div>
            </div>

            @if (Model.Actors != null && Model.Actors.Any())
            {
                <div class="review-box">
                    <h2 class="section-title"><i class="fas fa-users text-danger"></i> Cast & Crew</h2>
                    <div class="cast-grid">
                        @foreach (var actor in Model.Actors)
                        {
                            <a href="/Actor/Dashboard/@actor.Id" style="text-decoration: none; color: inherit; display: block;">
                                <div class="cast-card">
                                    <div class="cast-avatar">
                                        @if (!string.IsNullOrEmpty(actor.AvartUrl))
                                        {
                                            <img src="@actor.AvartUrl" alt="@actor.Name">
                                        }
                                        else
                                        {

                                            <i class="fas fa-user"></i>
                                        }
                                    </div>
                                    <div class="cast-name">@actor.Name</div>
                                    <div class="cast-role">@(string.IsNullOrEmpty(actor.Gender) ? "Actor" : actor.Gender)</div>
                                </div>
                            </a>
                        }
                    </div>
                </div>
            }

            <div class="review-box" id="create-review-section">
                @if (User.Identity?.IsAuthenticated == true)
                {
                    <h2 class="section-title"><i class="fas fa-comment-dots text-danger"></i> Leave a Comment</h2>

                    <form id="mainCommentForm" method="post">
                        @Html.AntiForgeryToken()
                        <input type="hidden" name="MovieId" value="@Model.Movie.Id" />
                        <input type="hidden" name="Rating" value="5" /> <div class="d-flex gap-3 mb-3">
                            <div class="author-avatar" style="width: 50px; height: 50px; flex-shrink: 0; background: linear-gradient(135deg, #e50914, #ff4b4b);">
                                @if (!string.IsNullOrEmpty(currentUserAvatar))
                                {
                                    <img src="@currentUserAvatar" alt="Avatar" />
                                }
                                else
                                {
                                    @currentUserName.Substring(0, 1).ToUpper()
                                }
                            </div>
                            <div class="flex-grow-1">
                                <textarea name="Comment" class="review-textarea m-0" rows="3" placeholder="Share your thoughts about this movie..." required></textarea>
                            </div>
                        </div>
                        <div class="text-end">
                            <button type="submit" class="btn-submit-review btn-main-submit"><i class="fas fa-paper-plane"></i> Post Comment</button>
                        </div>
                    </form>
                }
                else
                {
                    <div class="login-prompt">
                        <i class="fas fa-user-lock mb-3 d-block" style="font-size: 3rem;"></i>
                        <p class="mb-3">Sign in to join the discussion.</p>
                        <a href="/Identity/Account/Login?returnUrl=@Uri.EscapeDataString(currentUrl)" class="btn-submit-review text-decoration-none">Sign In</a>
                    </div>
                }
            </div>

            <div class="review-box" id="all-reviews-section">
                <h2 class="section-title"><i class="fas fa-comments text-danger"></i> Discussion (<span id="reviewCount">@(reviews?.Count() ?? 0)</span>)</h2>

                <div class="reviews-list" id="reviewsListContainer">
                    @if (reviews != null && reviews.Any())
                    {
                        @foreach (var comment in reviews)
                        {
                            // Dò tên người dùng
                            var rawName = comment.UserName ?? "User";
                            var baseName = rawName.Contains("@") ? rawName.Split('@')[0] : rawName;

                            // Kiểm tra comment của chính user
                            bool isMyComment = (rawName == User.Identity?.Name || baseName == currentUserName);
                            string displayName = isMyComment ? currentUserName : baseName;

                            // Dò Avatar từ DTO (Hoặc ép dùng Avatar của chính chủ nếu là comment của mình)
                            var avatarProp = comment.GetType().GetProperty("AvatarUrl") ?? comment.GetType().GetProperty("Avatar");
                            string dbAvatar = avatarProp?.GetValue(comment, null)?.ToString();
                            string displayAvatar = isMyComment && !string.IsNullOrEmpty(currentUserAvatar) ? currentUserAvatar : dbAvatar;

                            // Random màu nền cho user không có ảnh
                            string[] colors = { "#e50914", "#f5c518", "#3498db", "#2ecc71", "#9b59b6" };
                            string avatarBg = colors[Math.Abs(displayName.GetHashCode()) % colors.Length];

                            <div class="review-item" id="review-@comment.Id" style="@(isMyComment ? "border-color: var(--netflix-red); background: rgba(229, 9, 20, 0.02);" : "")">
                                <div id="display-mode-@comment.Id">
                                    <div class="review-header">
                                        <div class="review-author">
                                            <div class="author-avatar" style="background: @avatarBg;">
                                                @if (!string.IsNullOrEmpty(displayAvatar))
                                                {
                                                    <img src="@displayAvatar" alt="Avatar" />
                                                }
                                                else
                                                {
                                                    @displayName.Substring(0, 1).ToUpper()
                                                }
                                            </div>
                                            <div class="author-info">
                                                <h4 class="mb-0">
                                                    @displayName
                                                    @if (isMyComment)
                                                    {
                                                        <span class="badge bg-danger ms-2" style="font-size: 0.7rem; padding: 0.3em 0.5em;">You</span>
                                                    }
                                                </h4>
                                            </div>
                                        </div>
                                        <div class="review-date">@comment.CreatedAt.ToString("MMM dd, yyyy")</div>
                                    </div>
                                    <div class="review-content">@comment.Comment</div>

                                    <div class="review-actions">
                                        @if (isMyComment)
                                        {
                                            <button class="review-action-btn text-primary" onclick="showEditForm('@comment.Id')"><i class="fas fa-edit"></i> Edit</button>
                                            <button class="review-action-btn text-danger ms-3" onclick="deleteReview('@comment.Id')"><i class="fas fa-trash"></i> Delete</button>
                                        }
                                        else
                                        {
                                            <button class="review-action-btn"><i class="far fa-thumbs-up"></i> Helpful</button>
                                            <button class="review-action-btn ms-3"><i class="far fa-flag"></i> Report</button>
                                        }
                                    </div>
                                </div>

                                @if (isMyComment)
                                {
                                    <div id="edit-mode-@comment.Id" style="display: none; margin-top: 15px;">
                                        <form class="form-edit-review" method="post">
                                            @Html.AntiForgeryToken()
                                            <input type="hidden" name="Id" value="@comment.Id" />
                                            <input type="hidden" name="MovieId" value="@Model.Movie.Id" />
                                            <input type="hidden" name="Rating" value="5" />
                                            <textarea name="Comment" class="review-textarea" rows="2" required>@comment.Comment</textarea>
                                            <div class="d-flex gap-2 mt-2">
                                                <button type="submit" class="btn btn-danger btn-sm px-3 fw-bold">Save</button>
                                                <button type="button" class="btn btn-secondary btn-sm px-3 fw-bold" onclick="hideEditForm('@comment.Id')">Cancel</button>
                                            </div>
                                        </form>
                                    </div>
                                }
                            </div>
                        }
                    }
                    else
                    {
                        <div id="no-reviews-msg" class="text-center text-secondary py-4">
                            <i class="fas fa-comment-slash fs-1 mb-3"></i>
                            <p>No comments yet. Be the first to share your thoughts!</p>
                        </div>
                    }
                </div>
            </div>

        </div>
    </div>
</div>

@section Scripts {
    <script>
        const currentUserName = '@Html.Raw(currentUserName)';
        const currentUserAvatar = '@Html.Raw(currentUserAvatar)';

        $(document).ready(function() {
            // Xử lý Favorite
            $('.favorite-toggle-btn').click(function() {
                const btn = $(this);
                fetch('@Url.Action("Toggle", "Favorites")', {
                    method: 'POST',
                    headers: { 'Content-Type': 'application/x-www-form-urlencoded', 'RequestVerificationToken': document.querySelector('input[name="__RequestVerificationToken"]').value },
                    body: `movieId=${btn.data('movie-id')}`
                }).then(r => r.json()).then(data => {
                    if (data.success) {
                        if (data.isFavorite) { btn.addClass('active').find('span').text('In My List'); btn.find('i').attr('class', 'fas fa-check'); }
                        else { btn.removeClass('active').find('span').text('My List'); btn.find('i').attr('class', 'fas fa-plus'); }
                        showToast(data.isFavorite ? 'Added to List' : 'Removed from List', 'success');
                    }
                });
            });
        });

        // --- HỆ THỐNG AJAX BÌNH LUẬN ---

        function showEditForm(reviewId) { $('#display-mode-' + reviewId).hide(); $('#edit-mode-' + reviewId).fadeIn(200); }
        function hideEditForm(reviewId) { $('#edit-mode-' + reviewId).hide(); $('#display-mode-' + reviewId).fadeIn(200); }

        function deleteReview(reviewId) {
            if (!confirm('Are you sure you want to delete this comment?')) return;
            $.ajax({
                url: '@Url.Action("Delete", "Reviews")', type: 'POST',
                data: { id: reviewId, __RequestVerificationToken: $('input[name="__RequestVerificationToken"]').val() },
                success: function(response) {
                    if (response.success) {
                        showToast('Deleted successfully!', 'success');
                        $('#review-' + reviewId).fadeOut(300, function() {
                            $(this).remove();
                            let count = parseInt($('#reviewCount').text()) - 1;
                            $('#reviewCount').text(count > 0 ? count : 0);
                            if (count <= 0) $('#reviewsListContainer').html(`<div id="no-reviews-msg" class="text-center text-secondary py-4"><i class="fas fa-comment-slash fs-1 mb-3"></i><p>No comments yet. Be the first to share your thoughts!</p></div>`);
                        });
                    }
                }
            });
        }

        $(document).ready(function() {

            // 1. TẠO COMMENT MỚI (AJAX - KHÔNG SAO)
            $('#mainCommentForm').on('submit', function(e) {
                e.preventDefault();
                const form = $(this);
                const submitBtn = form.find('.btn-main-submit');

                submitBtn.prop('disabled', true).html('<i class="fas fa-spinner fa-spin"></i> Posting...');
                $.ajax({
                    url: '@Url.Action("Create", "Reviews")', type: 'POST', data: form.serialize(),
                    success: function(response) {
                        if (response.success) {
                            showToast('Comment posted!', 'success');
                            form[0].reset();

                            const newId = response.review ? response.review.id : 'temp-' + Date.now();
                            const commentText = form.find('textarea[name="Comment"]').val();
                            const firstLetter = currentUserName.charAt(0).toUpperCase();

                            // Render Ảnh Avatar hoặc Chữ
                            let avatarContent = currentUserAvatar
                                ? `<img src="${currentUserAvatar}" alt="Avatar" />`
                                : `${firstLetter}`;

                            const token = $('input[name="__RequestVerificationToken"]').val();

                            const reviewHtml = `
                                <div class="review-item" id="review-${newId}" style="border: 1px solid var(--netflix-red); background: rgba(229, 9, 20, 0.05); opacity: 0; animation: fadeIn 0.5s ease forwards; margin-bottom: 1rem;">
                                    <div id="display-mode-${newId}">
                                        <div class="review-header">
                                            <div class="review-author">
                                                <div class="author-avatar" style="background: linear-gradient(135deg, #e50914, #ff4b4b); color: #000;">
                                                    ${avatarContent}
                                                </div>
                                                <div class="author-info">
                                                    <h4 class="mb-0">${currentUserName} <span class="badge bg-danger ms-2" style="font-size: 0.7rem; padding: 0.3em 0.5em;">You</span></h4>
                                                </div>
                                            </div>
                                            <div class="review-date">Just now</div>
                                        </div>
                                        <div class="review-content mt-2">${commentText}</div>
                                        <div class="review-actions mt-3 pt-3" style="border-top: 1px solid rgba(255,255,255,0.05);">
                                            <button class="review-action-btn text-primary" onclick="showEditForm('${newId}')"><i class="fas fa-edit"></i> Edit</button>
                                            <button class="review-action-btn text-danger ms-3" onclick="deleteReview('${newId}')"><i class="fas fa-trash"></i> Delete</button>
                                        </div>
                                    </div>
                                    <div id="edit-mode-${newId}" style="display: none; margin-top: 15px;">
                                        <form class="form-edit-review" method="post">
                                            <input type="hidden" name="__RequestVerificationToken" value="${token}" />
                                            <input type="hidden" name="Id" value="${newId}" />
                                            <input type="hidden" name="MovieId" value="@Model.Movie.Id" />
                                            <input type="hidden" name="Rating" value="5" />
                                            <textarea name="Comment" class="review-textarea" rows="2" required>${commentText}</textarea>
                                            <div class="d-flex gap-2 mt-2">
                                                <button type="submit" class="btn btn-danger btn-sm px-3 fw-bold">Save</button>
                                                <button type="button" class="btn btn-secondary btn-sm px-3 fw-bold" onclick="hideEditForm('${newId}')">Cancel</button>
                                            </div>
                                        </form>
                                    </div>
                                </div>`;

                            $('#no-reviews-msg').remove();
                            $('#reviewsListContainer').prepend(reviewHtml);

                            let count = parseInt($('#reviewCount').text()) + 1;
                            $('#reviewCount').text(count);

                        } else { showToast(response.message, 'error'); }
                    },
                    complete: function() { submitBtn.prop('disabled', false).html('<i class="fas fa-paper-plane"></i> Post Comment'); }
                });
            });

            // 2. SỬA COMMENT (In-place)
            $(document).on('submit', '.form-edit-review', function(e) {
                e.preventDefault();
                const form = $(this);
                const reviewId = form.find('input[name="Id"]').val();
                const newComment = form.find('textarea[name="Comment"]').val();

                $.ajax({
                    url: '@Url.Action("Edit", "Reviews")', type: 'POST', data: form.serialize(),
                    success: function(response) {
                        if (response.success) {
                            showToast('Saved!', 'success');
                            const displayMode = $('#display-mode-' + reviewId);
                            displayMode.find('.review-content').text(newComment);
                            hideEditForm(reviewId);
                        }
                    }
                });
            });
        });

        // UI Toast
        function showToast(message, type) {
            $('.toast-notification').remove();
            const borderColor = type === 'success' ? '#46d369' : '#e50914';
            const icon = type === 'success' ? 'check-circle' : 'exclamation-circle';
            const toast = $(`<div class="toast-notification" style="border-left-color: ${borderColor};"><i class="fas fa-${icon}" style="color: ${borderColor};"></i><span>${message}</span></div>`);
            $('body').append(toast);
            setTimeout(() => toast.fadeOut(300, function() { $(this).remove(); }), 3000);
        }
    </script>
}