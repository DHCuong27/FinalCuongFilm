@model FinalCuongFilm.MVC.Models.ViewModels.MovieDetailsViewModel
@using static FinalCuongFilm.ApplicationCore.Entities.Enum

@{
    ViewData["Title"] = Model.Movie.Title;
    Layout = "_LayoutUser";
    var isFavorited = ViewBag.IsFavorited as bool? ?? false;
    var rating = ViewBag.Rating as FinalCuongFilm.Common.DTOs.MovieRatingDto;
    var reviews = ViewBag.Reviews as IEnumerable<FinalCuongFilm.Common.DTOs.ReviewDto>;
    var userReview = ViewBag.UserReview as FinalCuongFilm.Common.DTOs.ReviewDto;

    //  FIX: Tạo returnUrl đúng - encode để tránh lỗi
    var currentUrl = Url.Action("Detail", "Movie", new { slug = Model.Movie.Slug });
}

<style>
    :root {
        --netflix-red: #e50914;
        --bg-dark: #0f0f0f;
        --bg-card: #1a1a1a;
        --bg-hover: #2a2a2a;
        --text-primary: #ffffff;
        --text-secondary: #a8a8a8;
        --border-color: #303030;
        --accent-yellow: #f5c518;
    }

    body {
        background-color: var(--bg-dark);
        color: var(--text-primary);
        font-family: -apple-system, BlinkMacSystemFont, 'Segoe UI', Roboto, Arial, sans-serif;
    }

    /* Hero Banner */
    .hero-banner {
        position: relative;
        height: 500px;
        background-color: #000;
        margin-top: -70px;
        margin-bottom: 0;
        overflow: hidden;
    }

    .hero-backdrop {
        position: absolute;
        top: 0;
        left: 0;
        width: 100%;
        height: 100%;
        object-fit: cover;
        object-position: center top;
        opacity: 0.5;
    }

    .hero-gradient {
        position: absolute;
        top: 0;
        left: 0;
        width: 100%;
        height: 100%;
        background: linear-gradient( to bottom, rgba(0,0,0,0.2) 0%, rgba(0,0,0,0.5) 50%, rgba(15,15,15,0.9) 85%, #0f0f0f 100% );
    }

    .hero-content {
        position: absolute;
        bottom: 0;
        left: 0;
        right: 0;
        padding: 0 20px 30px;
        z-index: 2;
    }

    .hero-inner {
        max-width: 1400px;
        margin: 0 auto;
        display: flex;
        align-items: flex-end;
        gap: 30px;
    }

    .hero-poster {
        width: 220px;
        flex-shrink: 0;
        margin-bottom: 20px;
    }

        .hero-poster img {
            width: 100%;
            border-radius: 8px;
            box-shadow: 0 10px 40px rgba(0,0,0,0.8);
        }

    .hero-info {
        flex: 1;
        padding-bottom: 20px;
    }

    .hero-title {
        font-size: 3rem;
        font-weight: 700;
        margin-bottom: 1rem;
        text-shadow: 2px 2px 8px rgba(0,0,0,0.9);
        line-height: 1.1;
    }

    .hero-meta {
        display: flex;
        align-items: center;
        gap: 1rem;
        flex-wrap: wrap;
        font-size: 1.1rem;
        color: var(--text-secondary);
        margin-bottom: 1.5rem;
    }

        .hero-meta > * {
            display: flex;
            align-items: center;
            gap: 0.3rem;
        }

    .meta-separator {
        color: var(--border-color);
    }

    .hero-description {
        font-size: 1rem;
        line-height: 1.6;
        color: var(--text-primary);
        max-width: 800px;
        margin-bottom: 1.5rem;
        text-shadow: 1px 1px 3px rgba(0,0,0,0.8);
        display: -webkit-box;
        -webkit-line-clamp: 3;
        -webkit-box-orient: vertical;
        overflow: hidden;
    }

    .hero-actions {
        display: flex;
        gap: 1rem;
        flex-wrap: wrap;
    }

    .btn-hero {
        padding: 0.8rem 2rem;
        border-radius: 6px;
        font-weight: 600;
        font-size: 1rem;
        cursor: pointer;
        transition: all 0.2s;
        display: inline-flex;
        align-items: center;
        gap: 0.7rem;
        text-decoration: none;
        border: none;
    }

    .btn-hero-primary {
        background: var(--netflix-red);
        color: white;
    }

        .btn-hero-primary:hover {
            background: #b8070f;
            color: white;
            transform: scale(1.05);
        }

    .btn-hero-secondary {
        background: rgba(255,255,255,0.2);
        color: white;
        border: 1px solid rgba(255,255,255,0.4);
    }

        .btn-hero-secondary:hover {
            background: rgba(255,255,255,0.3);
            color: white;
            border-color: rgba(255,255,255,0.6);
        }

        .btn-hero-secondary.active {
            color: var(--netflix-red);
            border-color: var(--netflix-red);
        }

    /* Main Container */
    .movie-container {
        max-width: 1400px;
        margin: 0 auto;
        padding: 0 20px;
    }

    .movie-layout {
        display: grid;
        grid-template-columns: 250px 1fr;
        gap: 30px;
        margin-top: 2rem;
    }

    /* Left Sidebar */
    .sidebar-column {
        position: sticky;
        top: 90px;
        align-self: start;
    }

    .sidebar-section {
        background: var(--bg-card);
        border: 1px solid var(--border-color);
        border-radius: 8px;
        padding: 1.2rem;
        margin-bottom: 1.5rem;
    }

    .sidebar-title {
        font-size: 1rem;
        font-weight: 700;
        margin-bottom: 1rem;
        padding-bottom: 0.5rem;
        border-bottom: 1px solid var(--border-color);
        display: flex;
        align-items: center;
        gap: 0.5rem;
    }

    /* Quick Actions */
    .quick-actions {
        display: flex;
        flex-direction: column;
        gap: 0.5rem;
    }

    .btn-action {
        padding: 0.7rem;
        border-radius: 6px;
        font-size: 0.9rem;
        font-weight: 600;
        cursor: pointer;
        transition: all 0.2s;
        display: flex;
        align-items: center;
        justify-content: center;
        gap: 0.5rem;
        text-decoration: none;
        border: none;
    }

    .btn-watch {
        background: var(--netflix-red);
        color: white;
    }

        .btn-watch:hover {
            background: #b8070f;
            color: white;
        }

    .btn-outline {
        background: transparent;
        color: var(--text-primary);
        border: 1px solid var(--border-color);
    }

        .btn-outline:hover {
            background: var(--bg-hover);
            color: var(--text-primary);
            border-color: var(--text-secondary);
        }

        .btn-outline.active {
            color: var(--netflix-red);
            border-color: var(--netflix-red);
        }

    /* Top Movies Compact */
    .top-movies-compact {
        list-style: none;
        padding: 0;
        margin: 0;
    }

    .top-movie-compact {
        display: flex;
        gap: 0.8rem;
        padding: 0.8rem;
        border-radius: 6px;
        margin-bottom: 0.8rem;
        transition: all 0.2s;
        cursor: pointer;
        text-decoration: none;
        color: var(--text-primary);
    }

        .top-movie-compact:hover {
            background: var(--bg-hover);
            color: var(--text-primary);
        }

    .top-rank-compact {
        font-size: 1.2rem;
        font-weight: 900;
        color: var(--accent-yellow);
        min-width: 25px;
    }

    .top-thumb-compact {
        width: 45px;
        height: 65px;
        border-radius: 4px;
        object-fit: cover;
    }

    .top-info-compact {
        flex: 1;
        min-width: 0;
    }

        .top-info-compact h5 {
            font-size: 0.85rem;
            font-weight: 600;
            margin-bottom: 0.2rem;
            white-space: nowrap;
            overflow: hidden;
            text-overflow: ellipsis;
        }

    .top-meta-compact {
        font-size: 0.7rem;
        color: var(--text-secondary);
    }

    /* Main Content Column */
    .content-column {
        min-width: 0;
    }

    /* Stats Cards */
    .stats-cards {
        display: grid;
        grid-template-columns: repeat(auto-fit, minmax(140px, 1fr));
        gap: 1rem;
        margin-bottom: 1.5rem;
    }

    .stat-card {
        background: var(--bg-card);
        border: 1px solid var(--border-color);
        border-radius: 8px;
        padding: 1rem;
        text-align: center;
        transition: all 0.2s;
    }

        .stat-card:hover {
            background: var(--bg-hover);
            border-color: var(--text-secondary);
        }

    .stat-number {
        font-size: 1.8rem;
        font-weight: 700;
        color: var(--accent-yellow);
        margin-bottom: 0.3rem;
    }

    .stat-label {
        font-size: 0.85rem;
        color: var(--text-secondary);
        text-transform: uppercase;
        letter-spacing: 0.5px;
    }

    /* Info Section */
    .info-section {
        background: var(--bg-card);
        border: 1px solid var(--border-color);
        border-radius: 8px;
        padding: 1.5rem;
        margin-bottom: 1.5rem;
    }

    .section-title {
        font-size: 1.2rem;
        font-weight: 700;
        margin-bottom: 1rem;
        padding-bottom: 0.5rem;
        border-bottom: 1px solid var(--border-color);
        display: flex;
        align-items: center;
        gap: 0.5rem;
    }

    /* Info Grid */
    .info-grid {
        display: grid;
        gap: 0.8rem;
    }

    .info-row {
        display: grid;
        grid-template-columns: 120px 1fr;
        gap: 1rem;
        font-size: 0.9rem;
    }

    .info-label {
        color: var(--text-secondary);
        font-weight: 500;
    }

    .info-value {
        color: var(--text-primary);
    }

    /* Rating Overview */
    .rating-overview {
        display: grid;
        grid-template-columns: 200px 1fr;
        gap: 2rem;
        margin-bottom: 2rem;
    }

    .rating-score {
        text-align: center;
    }

    .rating-number {
        font-size: 4rem;
        font-weight: 700;
        color: var(--accent-yellow);
        line-height: 1;
        margin-bottom: 0.5rem;
    }

    .rating-stars {
        font-size: 1.5rem;
        color: var(--accent-yellow);
        margin-bottom: 0.5rem;
    }

    .rating-count {
        font-size: 0.9rem;
        color: var(--text-secondary);
    }

    .rating-bars {
        display: flex;
        flex-direction: column;
        gap: 0.8rem;
    }

    .rating-bar-row {
        display: flex;
        align-items: center;
        gap: 1rem;
    }

    .bar-label {
        min-width: 60px;
        font-size: 0.9rem;
        color: var(--text-secondary);
    }

    .bar-container {
        flex: 1;
        height: 8px;
        background: rgba(255,255,255,0.1);
        border-radius: 4px;
        overflow: hidden;
    }

    .bar-fill {
        height: 100%;
        background: linear-gradient(90deg, var(--accent-yellow), #ffd700);
        transition: width 0.5s ease;
    }

    .bar-count {
        min-width: 40px;
        text-align: right;
        font-size: 0.85rem;
        color: var(--text-secondary);
    }

    /* Review Form */
    .review-form-section {
        background: var(--bg-card);
        border: 1px solid var(--border-color);
        border-radius: 8px;
        padding: 1.5rem;
        margin-bottom: 1.5rem;
    }

    .star-rating-input {
        display: flex;
        gap: 0.5rem;
        margin-bottom: 1rem;
        flex-direction: row-reverse;
        justify-content: flex-end;
    }

        .star-rating-input input {
            display: none;
        }

        .star-rating-input label {
            font-size: 2rem;
            color: rgba(255,255,255,0.2);
            cursor: pointer;
            transition: all 0.2s;
        }

            .star-rating-input input:checked ~ label,
            .star-rating-input label:hover,
            .star-rating-input label:hover ~ label {
                color: var(--accent-yellow);
            }

    .review-textarea {
        width: 100%;
        background: rgba(255,255,255,0.05);
        border: 1px solid var(--border-color);
        border-radius: 6px;
        color: var(--text-primary);
        padding: 1rem;
        font-size: 0.95rem;
        resize: vertical;
        min-height: 100px;
        font-family: inherit;
        margin-bottom: 0.5rem;
    }

        .review-textarea:focus {
            outline: none;
            border-color: var(--netflix-red);
            background: rgba(255,255,255,0.08);
        }

        .review-textarea::placeholder {
            color: var(--text-secondary);
        }

    .char-counter {
        text-align: right;
        font-size: 0.8rem;
        color: var(--text-secondary);
        margin-bottom: 1rem;
    }

    .btn-submit-review {
        background: var(--netflix-red);
        color: white;
        padding: 0.8rem 2rem;
        border: none;
        border-radius: 6px;
        font-weight: 600;
        cursor: pointer;
        transition: all 0.2s;
    }

        .btn-submit-review:hover {
            background: #b8070f;
            transform: scale(1.02);
        }

        .btn-submit-review:disabled {
            background: var(--text-secondary);
            cursor: not-allowed;
            transform: none;
        }

    /* Login Prompt */
    .login-prompt {
        text-align: center;
        padding: 2rem;
    }

        .login-prompt i {
            font-size: 3rem;
            color: var(--text-secondary);
            margin-bottom: 1rem;
        }

        .login-prompt p {
            color: var(--text-secondary);
            margin-bottom: 1.5rem;
        }

    /* Reviews List */
    .reviews-list {
        display: flex;
        flex-direction: column;
        gap: 1rem;
    }

    .review-item {
        background: rgba(255,255,255,0.03);
        border: 1px solid var(--border-color);
        border-radius: 8px;
        padding: 1.2rem;
        transition: all 0.2s;
    }

        .review-item:hover {
            background: rgba(255,255,255,0.05);
            border-color: var(--text-secondary);
        }

    .review-header {
        display: flex;
        justify-content: space-between;
        align-items: flex-start;
        margin-bottom: 0.8rem;
    }

    .review-author {
        display: flex;
        align-items: center;
        gap: 0.8rem;
    }

    .author-avatar {
        width: 40px;
        height: 40px;
        border-radius: 50%;
        background: linear-gradient(135deg, var(--netflix-red), #ff6b6b);
        display: flex;
        align-items: center;
        justify-content: center;
        font-weight: 700;
        font-size: 1.1rem;
    }

    .author-info h4 {
        font-size: 1rem;
        font-weight: 600;
        margin-bottom: 0.2rem;
    }

    .review-rating {
        color: var(--accent-yellow);
        font-size: 0.9rem;
    }

    .review-date {
        font-size: 0.85rem;
        color: var(--text-secondary);
    }

    .review-content {
        color: var(--text-secondary);
        line-height: 1.6;
        font-size: 0.95rem;
    }

    .review-actions {
        display: flex;
        gap: 1rem;
        margin-top: 0.8rem;
        padding-top: 0.8rem;
        border-top: 1px solid var(--border-color);
    }

    .review-action-btn {
        background: none;
        border: none;
        color: var(--text-secondary);
        font-size: 0.85rem;
        cursor: pointer;
        transition: all 0.2s;
        display: flex;
        align-items: center;
        gap: 0.3rem;
    }

        .review-action-btn:hover {
            color: var(--text-primary);
        }

    /* Episodes Section */
    .episodes-section {
        margin-top: 2rem;
    }

    .episodes-list {
        display: flex;
        flex-direction: column;
        gap: 1rem;
    }

    .episode-item {
        background: var(--bg-card);
        border: 1px solid var(--border-color);
        border-radius: 8px;
        padding: 1rem;
        display: grid;
        grid-template-columns: 60px 120px 1fr auto;
        gap: 1rem;
        align-items: center;
        transition: all 0.2s;
        text-decoration: none;
        color: var(--text-primary);
    }

        .episode-item:hover {
            background: var(--bg-hover);
            border-color: var(--text-secondary);
            color: var(--text-primary);
        }

    .episode-number {
        font-size: 1.2rem;
        font-weight: 700;
        color: var(--text-secondary);
    }

    .episode-thumb {
        width: 120px;
        height: 68px;
        border-radius: 4px;
        background: var(--bg-hover);
        display: flex;
        align-items: center;
        justify-content: center;
    }

        .episode-thumb i {
            font-size: 1.5rem;
            color: var(--text-secondary);
        }

    .episode-info {
        flex: 1;
        min-width: 0;
    }

    .episode-title {
        font-weight: 600;
        font-size: 0.95rem;
        margin-bottom: 0.3rem;
    }

    .episode-desc {
        font-size: 0.85rem;
        color: var(--text-secondary);
        display: -webkit-box;
        -webkit-line-clamp: 2;
        -webkit-box-orient: vertical;
        overflow: hidden;
    }

    .episode-duration {
        font-size: 0.85rem;
        color: var(--text-secondary);
    }

    .btn-play-ep {
        width: 40px;
        height: 40px;
        border-radius: 50%;
        background: var(--netflix-red);
        border: none;
        color: white;
        cursor: pointer;
        display: flex;
        align-items: center;
        justify-content: center;
        transition: all 0.2s;
    }

        .btn-play-ep:hover {
            transform: scale(1.1);
        }

    /* Cast Grid */
    .cast-grid {
        display: grid;
        grid-template-columns: repeat(auto-fill, minmax(100px, 1fr));
        gap: 1rem;
    }

    .cast-card {
        text-align: center;
        transition: all 0.2s;
    }

        .cast-card:hover {
            transform: translateY(-5px);
        }

    .cast-avatar {
        width: 100px;
        height: 100px;
        border-radius: 50%;
        background: var(--bg-hover);
        display: flex;
        align-items: center;
        justify-content: center;
        margin: 0 auto 0.5rem;
        border: 2px solid var(--border-color);
    }

        .cast-avatar i {
            font-size: 2.5rem;
            color: var(--text-secondary);
        }

    .cast-name {
        font-size: 0.85rem;
        font-weight: 600;
        margin-bottom: 0.2rem;
    }

    .cast-role {
        font-size: 0.75rem;
        color: var(--text-secondary);
    }

    /* Responsive */
    @@media (max-width: 992px) {
        .hero-inner {
            flex-direction: column;
            align-items: flex-start;
        }

        .movie-layout {
            grid-template-columns: 1fr;
        }

        .sidebar-column {
            position: relative;
            top: 0;
            display: grid;
            grid-template-columns: repeat(2, 1fr);
            gap: 1rem;
        }

        .rating-overview {
            grid-template-columns: 1fr;
        }

        .episode-item {
            grid-template-columns: 50px 1fr auto;
        }

        .episode-thumb {
            display: none;
        }
    }

    @@media (max-width: 768px) {
        .hero-title {
            font-size: 2rem;
        }

        .sidebar-column {
            grid-template-columns: 1fr;
        }

        .stats-cards {
            grid-template-columns: repeat(2, 1fr);
        }
    }

    /* Toast Notification */
    .toast-notification {
        position: fixed;
        top: 80px;
        right: 20px;
        background: var(--bg-card);
        border: 1px solid var(--border-color);
        border-left: 4px solid var(--netflix-red);
        padding: 1rem 1.5rem;
        border-radius: 6px;
        box-shadow: 0 10px 30px rgba(0,0,0,0.7);
        z-index: 9999;
        animation: slideIn 0.3s ease;
        display: flex;
        align-items: center;
        gap: 1rem;
        min-width: 300px;
    }

    @@keyframes slideIn {
        from {
            transform: translateX(400px);
            opacity: 0;
        }

        to {
            transform: translateX(0);
            opacity: 1;
        }
    }

    .alert-info {
        background: rgba(52, 152, 219, 0.1);
        border: 1px solid rgba(52, 152, 219, 0.3);
        border-radius: 6px;
        padding: 1rem;
        color: var(--text-primary);
        margin-bottom: 1rem;
    }

        .alert-info i {
            color: #3498db;
        }

    /*  FIX: Ensure buttons are clickable */
    .btn-hero, .btn-action {
        pointer-events: auto !important;
        cursor: pointer !important;
        position: relative;
        z-index: 100;
    }

    .btn-hero-primary, .btn-watch {
        pointer-events: auto !important;
        cursor: pointer !important;
    }

    /*  FIX: Prevent layout issues */
    .hero-actions {
        position: relative;
        z-index: 100;
    }

    .quick-actions {
        position: relative;
        z-index: 100;
    }

    /*  FIX: Ensure hero content is on top */
    .hero-content {
        z-index: 10 !important;
    }

    .hero-inner {
        z-index: 11 !important;
    }
</style>

<!-- Hero Banner -->
<div class="hero-banner">
    <img src="@(Model.Movie.PosterUrl ?? "/images/default-bg.jpg")"
         alt="@Model.Movie.Title"
         class="hero-backdrop">
    <div class="hero-gradient"></div>

    <div class="hero-content">
        <div class="hero-inner">
            <div class="hero-poster">
                <img src="@(Model.Movie.PosterUrl ?? "/images/no-poster.jpg")"
                     alt="@Model.Movie.Title">
            </div>

            <div class="hero-info">
                <h1 class="hero-title">@Model.Movie.Title</h1>

                <div class="hero-meta">
                    @if (Model.Movie.ReleaseYear.HasValue)
                    {
                        <span>@Model.Movie.ReleaseYear</span>
                        <span class="meta-separator">•</span>
                    }
                    @if (Model.Movie.DurationMinutes.HasValue)
                    {
                        <span><i class="far fa-clock"></i> @Model.Movie.DurationMinutes phút</span>
                        <span class="meta-separator">•</span>
                    }
                    <span>@Model.Movie.Type</span>
                    @if (!string.IsNullOrEmpty(Model.Movie.CountryName))
                    {
                        <span class="meta-separator">•</span>
                        <span>@Model.Movie.CountryName</span>
                    }
                </div>

                @if (!string.IsNullOrEmpty(Model.Movie.Description))
                {
                    <p class="hero-description">@Model.Movie.Description</p>
                }

                <div class="hero-actions">
                    <a href="/Movie/Watch/@Model.Movie.Slug" 
                       class="btn-hero btn-hero-primary">
                        <i class="fas fa-play"></i>
                        Xem Ngay
                    </a>

                    @if (!string.IsNullOrEmpty(Model.Movie.TrailerUrl))
                    {
                        <a href="@Model.Movie.TrailerUrl" target="_blank" class="btn-hero btn-hero-secondary">
                            <i class="fab fa-youtube"></i>
                            Trailer
                        </a>
                    }

                    @if (User.Identity?.IsAuthenticated == true)
                    {
                        <button type="button"
                                class="btn-hero btn-hero-secondary favorite-toggle-btn @(isFavorited ? "active" : "")"
                                data-movie-id="@Model.Movie.Id"
                                data-is-favorited="@isFavorited.ToString().ToLower()">
                            <i class="@(isFavorited ? "fas" : "far") fa-heart"></i>
                            <span>@(isFavorited ? "Đã yêu thích" : "Yêu thích")</span>
                        </button>
                    }
                    else
                    {
                        <!--  FIX: Sử dụng currentUrl đã encode -->
                        <a href="/Identity/Account/Login?returnUrl=@Uri.EscapeDataString(currentUrl)"
                           class="btn-hero btn-hero-secondary">
                            <i class="far fa-heart"></i>
                            Yêu thích
                        </a>
                    }
                </div>
            </div>
        </div>
    </div>
</div>

<!-- Main Container -->
<div class="movie-container">
    <div class="movie-layout">
        <!-- Left Sidebar -->
        <div class="sidebar-column">
            <!-- Quick Actions -->
            <div class="sidebar-section">
                <h3 class="sidebar-title">
                    <i class="fas fa-bolt"></i>
                    Thao tác nhanh
                </h3>
                <div class="quick-actions">
                    <a href="@Url.Action("Watch", "Movie", new { slug = Model.Movie.Slug })" 
                       class="btn-action btn-watch"
                       onclick="console.log('Sidebar watch button clicked'); return true;">
                        <i class="fas fa-play"></i>
                        Xem Ngay
                    </a>

                    @if (!string.IsNullOrEmpty(Model.Movie.TrailerUrl))
                    {
                        <a href="@Model.Movie.TrailerUrl" target="_blank" class="btn-action btn-outline">
                            <i class="fab fa-youtube"></i>
                            Trailer
                        </a>
                    }

                    @if (User.Identity?.IsAuthenticated == true)
                    {
                        <button type="button"
                                class="btn-action btn-outline favorite-toggle-btn-sidebar @(isFavorited ? "active" : "")"
                                data-movie-id="@Model.Movie.Id"
                                data-is-favorited="@isFavorited.ToString().ToLower()">
                            <i class="@(isFavorited ? "fas" : "far") fa-heart"></i>
                            <span>@(isFavorited ? "Đã yêu thích" : "Yêu thích")</span>
                        </button>
                    }
                    else
                    {
                        <!--  FIX: Sử dụng currentUrl đã encode -->
                        <a href="/Identity/Account/Login?returnUrl=@Uri.EscapeDataString(currentUrl)"
                           class="btn-action btn-outline">
                            <i class="far fa-heart"></i>
                            Yêu thích
                        </a>
                    }
                </div>
            </div>

            <!-- Movie Info -->
            <div class="sidebar-section">
                <h3 class="sidebar-title">
                    <i class="fas fa-info-circle"></i>
                    Thông tin
                </h3>
                <div class="info-grid">
                    @if (Model.Movie.ReleaseYear.HasValue)
                    {
                        <div class="info-row">
                            <span class="info-label">Năm:</span>
                            <span class="info-value">@Model.Movie.ReleaseYear</span>
                        </div>
                    }
                    @if (Model.Movie.DurationMinutes.HasValue)
                    {
                        <div class="info-row">
                            <span class="info-label">Thời lượng:</span>
                            <span class="info-value">@Model.Movie.DurationMinutes phút</span>
                        </div>
                    }
                    @if (!string.IsNullOrEmpty(Model.Movie.CountryName))
                    {
                        <div class="info-row">
                            <span class="info-label">Quốc gia:</span>
                            <span class="info-value">@Model.Movie.CountryName</span>
                        </div>
                    }
                    @if (!string.IsNullOrEmpty(Model.Movie.LanguageName))
                    {
                        <div class="info-row">
                            <span class="info-label">Ngôn ngữ:</span>
                            <span class="info-value">@Model.Movie.LanguageName</span>
                        </div>
                    }
                    <div class="info-row">
                        <span class="info-label">Loại:</span>
                        <span class="info-value">@Model.Movie.Type</span>
                    </div>
                    <div class="info-row">
                        <span class="info-label">Trạng thái:</span>
                        <span class="info-value">@Model.Movie.Status</span>
                    </div>
                </div>
            </div>

            <!-- Top Movies This Week -->
            @if (Model.RelatedMovies != null && Model.RelatedMovies.Any())
            {
                <div class="sidebar-section">
                    <h3 class="sidebar-title">
                        <i class="fas fa-fire"></i>
                        Top tuần này
                    </h3>
                    <ul class="top-movies-compact">
                        @for (int i = 0; i < Math.Min(5, Model.RelatedMovies.Count()); i++)
                        {
                            var movie = Model.RelatedMovies.ElementAt(i);
                            <li>
                                <a href="@Url.Action("Detail", "Movie", new { slug = movie.Slug })" class="top-movie-compact">
                                    <div class="top-rank-compact">@(i + 1)</div>
                                    <img src="@(movie.PosterUrl ?? "/images/no-poster.jpg")"
                                         alt="@movie.Title"
                                         class="top-thumb-compact">
                                    <div class="top-info-compact">
                                        <h5>@movie.Title</h5>
                                        <div class="top-meta-compact">
                                            @if (movie.ReleaseYear.HasValue)
                                            {
                                                <span>@movie.ReleaseYear</span>
                                                <span> • </span>
                                            }
                                            <span>@movie.Type</span>
                                        </div>
                                    </div>
                                </a>
                            </li>
                        }
                    </ul>
                </div>
            }
        </div>

        <!-- Main Content Column -->
        <div class="content-column">
            <!-- Stats Cards -->
            <div class="stats-cards">
                <div class="stat-card">
                    <div class="stat-number">
                        @if (rating != null && rating.TotalReviews > 0)
                        {
                            @rating.AverageRating.ToString("F1")
                        }
                        else
                        {
                            @:--
                        }
                    </div>
                    <div class="stat-label">Đánh giá</div>
                </div>

                <div class="stat-card">
                    <div class="stat-number">@Model.Movie.ViewCount.ToString("N0")</div>
                    <div class="stat-label">Lượt xem</div>
                </div>

                <div class="stat-card">
                    <div class="stat-number">
                        @if (rating != null)
                        {
                            @rating.TotalReviews
                        }
                        else
                        {
                            @:0
                        }
                    </div>
                    <div class="stat-label">Reviews</div>
                </div>

                <div class="stat-card">
                    <div class="stat-number">
                        @if (rating != null)
                        {
                            @rating.TotalFavorites
                        }
                        else
                        {
                            @:0
                        }
                    </div>
                    <div class="stat-label">Yêu thích</div>
                </div>
            </div>

            <!-- Cast -->
            <div class="info-section">
                <h2 class="section-title">
                    <i class="fas fa-users"></i>
                    Diễn viên
                </h2>
                <div class="cast-grid">
                    @for (int i = 0; i < 6; i++)
                    {
                        <div class="cast-card">
                            <div class="cast-avatar">
                                <i class="fas fa-user"></i>
                            </div>
                            <div class="cast-name">Diễn viên @(i + 1)</div>
                            <div class="cast-role">Vai chính</div>
                        </div>
                    }
                </div>
            </div>

            <!-- Episodes -->
            @if (Model.Movie.Type == MovieType.Series && Model.Episodes != null && Model.Episodes.Any())
            {
                <div class="episodes-section">
                    <div class="info-section">
                        <h2 class="section-title">
                            <i class="fas fa-list"></i>
                            Danh sách tập (@Model.Episodes.Count())
                        </h2>

                        <div class="episodes-list">
                            @foreach (var episode in Model.Episodes)
                            {
                                <a href="/Movie/Watch/@Model.Movie.Slug?ep=@episode.EpisodeNumber"
                                   class="episode-item">
                                    <div class="episode-number">@episode.EpisodeNumber</div>

                                    <div class="episode-thumb">
                                        <i class="fas fa-play-circle"></i>
                                    </div>

                                    <div class="episode-info">
                                        <div class="episode-title">@episode.Title</div>
                                        @if (!string.IsNullOrEmpty(episode.Description))
                                        {
                                            <div class="episode-desc">@episode.Description</div>
                                        }
                                    </div>

                                    @if (episode.DurationMinutes.HasValue)
                                    {
                                        <div class="episode-duration">@episode.DurationMinutes phút</div>
                                    }

                                    <button class="btn-play-ep" type="button">
                                        <i class="fas fa-play"></i>
                                    </button>
                                </a>
                            }
                        </div>
                    </div>
                </div>
            }

            <!-- Rating Overview -->
            @if (rating != null && rating.TotalReviews > 0)
            {
                <div class="info-section">
                    <h2 class="section-title">
                        <i class="fas fa-star"></i>
                        Tổng quan đánh giá
                    </h2>

                    <div class="rating-overview">
                        <div class="rating-score">
                            <div class="rating-number">@rating.AverageRating.ToString("F1")</div>
                            <div class="rating-stars">
                                @for (int i = 1; i <= 5; i++)
                                {
                                    if (i <= Math.Round(rating.AverageRating))
                                    {
                                        <i class="fas fa-star"></i>
                                    }
                                    else if (i - 0.5 <= rating.AverageRating)
                                    {
                                        <i class="fas fa-star-half-alt"></i>
                                    }
                                    else
                                    {
                                        <i class="far fa-star"></i>
                                    }
                                }
                            </div>
                            <div class="rating-count">@rating.TotalReviews đánh giá</div>
                        </div>

                        <div class="rating-bars">
                            @foreach (var star in new[] { 5, 4, 3, 2, 1 })
                            {
                                var count = rating.RatingDistribution.ContainsKey(star) ? rating.RatingDistribution[star] : 0;
                                var percentage = rating.TotalReviews > 0 ? (count * 100.0 / rating.TotalReviews) : 0;

                                <div class="rating-bar-row">
                                    <span class="bar-label">@star sao</span>
                                    <div class="bar-container">
                                        <div class="bar-fill" style="width: @(percentage)%"></div>
                                    </div>
                                    <span class="bar-count">@count</span>
                                </div>
                            }
                        </div>
                    </div>
                </div>
            }

            <!-- Review Form -->
            <div class="review-form-section" id="review-section">
                <h2 class="section-title">
                    <i class="fas fa-comment-dots"></i>
                    Đánh giá của bạn
                </h2>

                @if (User.Identity?.IsAuthenticated == true)
                {
                    @if (userReview != null)
                    {
                        <div class="alert-info">
                            <i class="fas fa-check-circle"></i> Bạn đã đánh giá phim này.
                            <a href="@Url.Action("Edit", "Reviews", new { id = userReview.Id })" style="color: var(--netflix-red); margin-left: 1rem;">
                                <i class="fas fa-edit"></i> Chỉnh sửa
                            </a>
                        </div>
                    }
                    else
                    {
                        <form id="reviewForm" asp-controller="Reviews" asp-action="Create" method="post">
                            @Html.AntiForgeryToken()
                            <input type="hidden" name="MovieId" value="@Model.Movie.Id" />

                            <div class="mb-3">
                                <label class="form-label fw-bold">Đánh giá của bạn</label>
                                <div class="star-rating-input">
                                    @for (int i = 5; i >= 1; i--)
                                    {
                                        <input type="radio" id="star@(i)" name="Rating" value="@i" required />
                                        <label for="star@(i)"><i class="fas fa-star"></i></label>
                                    }
                                </div>
                                <span id="ratingError" class="text-danger" style="display: none;">Vui lòng chọn số sao</span>
                            </div>

                            <div class="mb-3">
                                <label class="form-label fw-bold">Nhận xét</label>
                                <textarea name="Comment"
                                  id="commentText"
                                  class="review-textarea"
                                  placeholder="Chia sẻ suy nghĩ của bạn về bộ phim này..."
                                  maxlength="1000"></textarea>
                                <div class="char-counter">
                                    <span id="charCount">0</span>/1000 ký tự
                                </div>
                            </div>

                            <button type="submit" class="btn-submit-review">
                                <i class="fas fa-paper-plane"></i> Gửi đánh giá
                            </button>
                        </form>
                    }
                }
                else
                {
                    <div class="login-prompt">
                        <i class="fas fa-user-lock"></i>
                        <p>Đăng nhập để đánh giá phim này</p>
                        <!--  FIX: Sử dụng currentUrl đã encode -->
                        <a href="/Identity/Account/Login?returnUrl=@Uri.EscapeDataString(currentUrl)"
                           class="btn-submit-review" style="text-decoration: none; display: inline-block;">
                            <i class="fas fa-sign-in-alt"></i> Đăng nhập
                        </a>
                    </div>
                }
            </div>

            <!-- Reviews List -->
            @if (reviews != null && reviews.Any())
            {
                <div class="info-section">
                    <h2 class="section-title">
                        <i class="fas fa-comments"></i>
                        Nhận xét từ người xem (<span id="reviewCount">@reviews.Count()</span>)
                    </h2>

                    <div class="reviews-list">
                        @foreach (var review in reviews)
                        {
                            <div class="review-item" id="review-@review.Id">
                                <div class="review-header">
                                    <div class="review-author">
                                        <div class="author-avatar">
                                            @review.UserName.Substring(0, 1).ToUpper()
                                        </div>
                                        <div class="author-info">
                                            <h4>@review.UserName</h4>
                                            <div class="review-rating">
                                                @for (int i = 1; i <= 5; i++)
                                                {
                                                    if (i <= review.Rating)
                                                    {
                                                        <i class="fas fa-star"></i>
                                                    }
                                                    else
                                                    {
                                                        <i class="far fa-star"></i>
                                                    }
                                                }
                                            </div>
                                        </div>
                                    </div>
                                    <div class="review-date">
                                        @review.CreatedAt.ToString("dd/MM/yyyy")
                                    </div>
                                </div>

                                @if (!string.IsNullOrEmpty(review.Comment))
                                {
                                    <div class="review-content">@review.Comment</div>
                                }

                                <div class="review-actions">
                                    <button class="review-action-btn" type="button">
                                        <i class="far fa-thumbs-up"></i>
                                        <span>Hữu ích</span>
                                    </button>
                                    <button class="review-action-btn" type="button">
                                        <i class="far fa-flag"></i>
                                        <span>Báo cáo</span>
                                    </button>
                                </div>
                            </div>
                        }
                    </div>

                    @if (reviews.Count() >= 5)
                    {
                        <div class="text-center mt-3">
                            <a href="@Url.Action("Movie", "Reviews", new { movieId = Model.Movie.Id })"
                               class="btn-action btn-outline" style="display: inline-flex; text-decoration: none;">
                                Xem tất cả đánh giá
                                <i class="fas fa-arrow-right"></i>
                            </a>
                        </div>
                    }
                </div>
            }
            else
            {
                <!-- Empty reviews placeholder -->
                <div class="info-section" id="emptyReviewsSection">
                    <h2 class="section-title">
                        <i class="fas fa-comments"></i>
                        Nhận xét từ người xem (0)
                    </h2>
                    <div class="reviews-list" style="display: none;">
                        <!-- Reviews will be added here dynamically -->
                    </div>
                </div>
            }
        </div>
    </div>
</div>

@section Scripts {
    <script>
        $(document).ready(function() {
            console.log('Detail page loaded - AJAX review enabled');

            //  DEBUG: Log when page loads
            console.log(' Detail page fully loaded');

            // Check if watch buttons exist
            const watchButtons = $('a[href*="Watch"]');
            console.log('Found watch buttons:', watchButtons.length);

            watchButtons.each(function(index) {
                console.log(`Button ${index + 1}:`, {
                    href: $(this).attr('href'),
                    text: $(this).text().trim(),
                    visible: $(this).is(':visible')
                });
            });

            // Character counter
            $('#commentText').on('input', function() {
                const count = $(this).val().length;
                $('#charCount').text(count);
            });

            // Favorite toggle
            $('.favorite-toggle-btn, .favorite-toggle-btn-sidebar').click(function() {
                const btn = $(this);
                const movieId = btn.data('movie-id');

                $.ajax({
                    url: '@Url.Action("Toggle", "Favorites")',
                    type: 'POST',
                    data: {
                        movieId: movieId,
                        __RequestVerificationToken: $('input[name="__RequestVerificationToken"]').val()
                    },
                    success: function(response) {
                        if (response.success) {
                            // Update all favorite buttons
                            $('.favorite-toggle-btn, .favorite-toggle-btn-sidebar').each(function() {
                                const icon = $(this).find('i');
                                const text = $(this).find('span');

                                if (response.isFavorite) {
                                    icon.removeClass('far').addClass('fas');
                                    if (text.length) text.text('Đã yêu thích');
                                    $(this).addClass('active');
                                } else {
                                    icon.removeClass('fas').addClass('far');
                                    if (text.length) text.text('Yêu thích');
                                    $(this).removeClass('active');
                                }
                            });

                            showToast(response.message, 'success');
                        } else {
                            showToast(response.message, 'error');
                        }
                    },
                    error: function() {
                        showToast('Có lỗi xảy ra!', 'error');
                    }
                });
            });

            //  AJAX Review Form Submit
            $('#reviewForm').on('submit', function(e) {
                e.preventDefault(); 

                console.log('Form submitted via AJAX');

                const rating = $('input[name="Rating"]:checked').val();
                if (!rating) {
                    $('#ratingError').show();
                    showToast('Vui lòng chọn số sao đánh giá', 'error');
                    return false;
                } else {
                    $('#ratingError').hide();
                }

                const formData = $(this).serialize();
                const submitBtn = $(this).find('.btn-submit-review');

                console.log('Sending data:', formData);

                // Disable button
                submitBtn.prop('disabled', true).html('<i class="fas fa-spinner fa-spin"></i> Đang gửi...');

                $.ajax({
                    url: '@Url.Action("Create", "Reviews")',
                    type: 'POST',
                    data: formData,
                    dataType: 'json',
                    success: function(response) {
                        console.log('Response received:', response);

                        if (response.success) {
                            showToast(response.message, 'success');

                            //  Thêm review mới vào đầu danh sách
                            addReviewToList(response.review);

                            //  Reset form
                            $('#reviewForm')[0].reset();
                            $('#charCount').text('0');

                            //  Cập nhật số lượng reviews
                            updateReviewCount();

                            //  Ẩn form và hiện thông báo đã review
                            $('#reviewForm').parent().html(`
                                <div class="alert-info">
                                    <i class="fas fa-check-circle"></i> Bạn đã đánh giá phim này.
                                    <button class="btn btn-link text-danger" style="padding: 0; border: none; background: none; cursor: pointer;" onclick="deleteReview('${response.review.id}'); return false;">
                                        <i class="fas fa-trash"></i> Xóa đánh giá
                                    </button>
                                </div>
                            `);
                        } else {
                            showToast(response.message, 'error');
                        }
                    },
                    error: function(xhr, status, error) {
                        console.error('AJAX Error:', xhr.responseText);
                        showToast('Có lỗi xảy ra khi gửi đánh giá!', 'error');
                    },
                    complete: function() {
                        submitBtn.prop('disabled', false).html('<i class="fas fa-paper-plane"></i> Gửi đánh giá');
                    }
                });
            });

            // Star rating click
            $('.star-rating-input input').on('change', function() {
                $('#ratingError').hide();
            });
        });

        //  Function thêm review vào danh sách
        function addReviewToList(review) {
            console.log('Adding review to list:', review);

            const firstLetter = review.userName.charAt(0).toUpperCase();
            const stars = generateStars(review.rating);

            const reviewHtml = `
                <div class="review-item" id="review-${review.id}" style="opacity: 0; animation: fadeIn 0.5s ease forwards;">
                    <div class="review-header">
                        <div class="review-author">
                            <div class="author-avatar">
                                ${firstLetter}
                            </div>
                            <div class="author-info">
                                <h4>${review.userName}</h4>
                                <div class="review-rating">
                                    ${stars}
                                </div>
                            </div>
                        </div>
                        <div class="review-date">
                            ${review.createdAt}
                        </div>
                    </div>
                    ${review.comment ? `<div class="review-content">${escapeHtml(review.comment)}</div>` : ''}
                    <div class="review-actions">
                        <button class="review-action-btn" type="button">
                            <i class="far fa-thumbs-up"></i>
                            <span>Hữu ích</span>
                        </button>
                        <button class="review-action-btn" type="button">
                            <i class="far fa-flag"></i>
                            <span>Báo cáo</span>
                        </button>
                    </div>
                </div>
            `;

            // Kiểm tra xem có danh sách reviews không
            let reviewsList = $('.reviews-list');
            if (reviewsList.length > 0 && reviewsList.is(':visible')) {
                reviewsList.prepend(reviewHtml);
                console.log('Review added to existing list');
            } else {
                // Nếu chưa có reviews, tạo section mới
                const newSection = `
                    <div class="info-section" id="reviews-section">
                        <h2 class="section-title">
                            <i class="fas fa-comments"></i>
                            Nhận xét từ người xem (<span id="reviewCount">1</span>)
                        </h2>
                        <div class="reviews-list">
                            ${reviewHtml}
                        </div>
                    </div>
                `;

                // Thêm sau phần review form
                $('#review-section').after(newSection);
                console.log('New reviews section created');
            }
        }

        //  Generate star HTML
        function generateStars(rating) {
            let stars = '';
            for (let i = 1; i <= 5; i++) {
                if (i <= rating) {
                    stars += '<i class="fas fa-star"></i>';
                } else {
                    stars += '<i class="far fa-star"></i>';
                }
            }
            return stars;
        }

        //  Escape HTML để tránh XSS
        function escapeHtml(text) {
            const div = document.createElement('div');
            div.textContent = text;
            return div.innerHTML;
        }

        //  Update review count
        function updateReviewCount() {
            const currentCount = $('.reviews-list .review-item').length;
            $('#reviewCount').text(currentCount);

            // Update stat card
            const reviewStatCard = $('.stat-card').eq(2);
            if (reviewStatCard.length) {
                reviewStatCard.find('.stat-number').text(currentCount);
            }

            console.log('Review count updated:', currentCount);
        }

        //  Delete review function
        function deleteReview(reviewId) {
            if (!confirm('Bạn có chắc muốn xóa đánh giá này?')) {
                return;
            }

            $.ajax({
                url: '@Url.Action("Delete", "Reviews")',
                type: 'POST',
                data: {
                    id: reviewId,
                    __RequestVerificationToken: $('input[name="__RequestVerificationToken"]').val()
                },
                success: function(response) {
                    if (response.success) {
                        showToast(response.message, 'success');

                        // Reload để hiện lại form
                        setTimeout(() => {
                            location.reload();
                        }, 1000);
                    } else {
                        showToast(response.message, 'error');
                    }
                },
                error: function() {
                    showToast('Có lỗi xảy ra khi xóa đánh giá!', 'error');
                }
            });
        }

        function showToast(message, type) {
            $('.toast-notification').remove();

            const borderColor = type === 'success' ? '#46d369' : '#e50914';
            const icon = type === 'success' ? 'check-circle' : 'exclamation-circle';

            const toast = $(`
                <div class="toast-notification" style="border-left-color: ${borderColor};">
                    <i class="fas fa-${icon}" style="color: ${borderColor}; font-size: 1.3rem;"></i>
                    <span style="color: var(--text-primary);">${message}</span>
                </div>
            `);

            $('body').append(toast);

            setTimeout(() => {
                toast.fadeOut(300, function() { $(this).remove(); });
            }, 3000);
        }

        //  Thêm CSS animation
        const style = document.createElement('style');
        style.textContent = `
            @@keyframes fadeIn {
                from {
                    opacity: 0;
                    transform: translateY(-20px);
                }
                to {
                    opacity: 1;
                    transform: translateY(0);
                }
            }
        `;
        document.head.appendChild(style);
    </script>
}

