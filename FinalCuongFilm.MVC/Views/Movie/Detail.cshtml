@using FinalCuongFilm.ApplicationCore.Entities
@using System.Security.Claims
@model FinalCuongFilm.MVC.Models.ViewModels.MovieDetailsViewModel
@using static FinalCuongFilm.ApplicationCore.Entities.Enum
@inject FinalCuongFilm.Service.Interfaces.IVipService VipService
@{
    var userId = User.FindFirstValue(ClaimTypes.NameIdentifier);
    var currentUserName = User.Identity?.Name ?? "";
    bool isVip = userId != null && await VipService.HasActiveVipAsync(userId);

    ViewData["Title"] = Model.Movie.Title;
    Layout = "_LayoutUser";

    var isFavorited = ViewBag.IsFavorited as bool? ?? false;
    var rating = ViewBag.Rating as FinalCuongFilm.Common.DTOs.MovieRatingDto;
    var reviews = ViewBag.Reviews as IEnumerable<FinalCuongFilm.Common.DTOs.ReviewDto>;
    var userReview = ViewBag.UserReview as FinalCuongFilm.Common.DTOs.ReviewDto;
    var currentUrl = Url.Action("Detail", "Movie", new { slug = Model.Movie.Slug });
}

<style>
    :root {
        --netflix-red: #e50914;
        --bg-dark: #0f0f0f;
        --bg-card: #1a1a1a;
        --bg-hover: #2a2a2a;
        --text-primary: #ffffff;
        --text-secondary: #a8a8a8;
        --border-color: #303030;
        --accent-yellow: #f5c518;
        --transition-speed: 0.3s;
    }

    body {
        background-color: var(--bg-dark);
        color: var(--text-primary);
        font-family: -apple-system, BlinkMacSystemFont, 'Segoe UI', Roboto, Arial, sans-serif;
    }

    /* Hero Banner */
    .hero-banner {
        position: relative;
        height: 550px;
        background-color: #000;
        margin-top: -70px;
        margin-bottom: 0;
        overflow: hidden;
    }

    .hero-backdrop {
        position: absolute;
        top: 0;
        left: 0;
        width: 100%;
        height: 100%;
        object-fit: cover;
        object-position: center 20%;
        opacity: 0.4;
        filter: blur(4px);
        transform: scale(1.05);
    }

    .hero-gradient {
        position: absolute;
        top: 0;
        left: 0;
        width: 100%;
        height: 100%;
        background: linear-gradient(to bottom, rgba(15,15,15,0) 0%, rgba(15,15,15,0.6) 60%, var(--bg-dark) 100%), linear-gradient(to right, var(--bg-dark) 0%, rgba(15,15,15,0.4) 50%, rgba(15,15,15,0) 100%);
    }

    .hero-content {
        position: absolute;
        bottom: 0;
        left: 0;
        right: 0;
        padding: 0 40px 40px;
        z-index: 10;
    }

    .hero-inner {
        max-width: 1400px;
        margin: 0 auto;
        display: flex;
        align-items: flex-end;
        gap: 40px;
        z-index: 11;
    }

    .hero-poster {
        width: 260px;
        flex-shrink: 0;
        border-radius: 12px;
        overflow: hidden;
        box-shadow: 0 20px 50px rgba(0,0,0,0.9);
        border: 1px solid rgba(255,255,255,0.1);
    }

    .hero-poster img {
        width: 100%;
        display: block;
        transition: transform var(--transition-speed);
    }

    .hero-poster:hover img {
        transform: scale(1.03);
    }

    .hero-info {
        flex: 1;
        padding-bottom: 10px;
    }

    .hero-title {
        font-size: 3.5rem;
        font-weight: 800;
        margin-bottom: 1rem;
        text-shadow: 2px 4px 10px rgba(0,0,0,0.9);
        line-height: 1.1;
        letter-spacing: -0.5px;
    }

    .hero-meta {
        display: flex;
        align-items: center;
        gap: 1.2rem;
        flex-wrap: wrap;
        font-size: 1.1rem;
        color: #d2d2d2;
        margin-bottom: 1.5rem;
        font-weight: 500;
    }

    .hero-meta > * {
        display: flex;
        align-items: center;
        gap: 0.4rem;
    }

    .meta-separator {
        color: rgba(255,255,255,0.3);
        font-size: 0.8rem;
    }

    .hero-description {
        font-size: 1.05rem;
        line-height: 1.7;
        color: #e0e0e0;
        max-width: 850px;
        margin-bottom: 2rem;
        text-shadow: 1px 1px 4px rgba(0,0,0,0.8);
        display: -webkit-box;
        -webkit-line-clamp: 3;
        -webkit-box-orient: vertical;
        overflow: hidden;
    }

    .hero-actions {
        display: flex;
        gap: 1rem;
        flex-wrap: wrap;
        position: relative;
        z-index: 100;
    }

    .btn-hero {
        padding: 0.9rem 2.2rem;
        border-radius: 8px;
        font-weight: 600;
        font-size: 1.05rem;
        cursor: pointer;
        transition: all var(--transition-speed);
        display: inline-flex;
        align-items: center;
        gap: 0.8rem;
        text-decoration: none;
        border: none;
        pointer-events: auto !important;
        position: relative;
        z-index: 100;
    }

    .btn-hero-primary {
        background: var(--netflix-red);
        color: white;
        box-shadow: 0 4px 15px rgba(229, 9, 20, 0.4);
    }

    .btn-hero-primary:hover {
        background: #f40612;
        color: white;
        transform: translateY(-2px);
        box-shadow: 0 6px 20px rgba(229, 9, 20, 0.6);
    }

    .btn-hero-secondary {
        background: rgba(42, 42, 42, 0.6);
        backdrop-filter: blur(10px);
        color: white;
        border: 1px solid rgba(255,255,255,0.1);
    }

    .btn-hero-secondary:hover {
        background: rgba(255,255,255,0.2);
        color: white;
        border-color: rgba(255,255,255,0.4);
        transform: translateY(-2px);
    }

    .btn-hero-secondary.active {
        color: var(--netflix-red);
        border-color: var(--netflix-red);
        background: rgba(229, 9, 20, 0.1);
    }

    /* Layout & Sidebar */
    .movie-container {
        max-width: 1400px;
        margin: 0 auto;
        padding: 0 40px;
    }

    .movie-layout {
        display: grid;
        grid-template-columns: 300px 1fr;
        gap: 40px;
        margin-top: 2.5rem;
    }

    .sidebar-column {
        position: sticky;
        top: 90px;
        align-self: start;
    }

    .sidebar-section {
        background: var(--bg-card);
        border: 1px solid var(--border-color);
        border-radius: 12px;
        padding: 1.5rem;
        margin-bottom: 1.5rem;
        box-shadow: 0 4px 20px rgba(0,0,0,0.3);
    }

    .sidebar-title {
        font-size: 1.1rem;
        font-weight: 700;
        margin-bottom: 1.2rem;
        padding-bottom: 0.8rem;
        border-bottom: 1px solid var(--border-color);
        display: flex;
        align-items: center;
        gap: 0.6rem;
        color: var(--text-primary);
    }

    /* Info Grid */
    .info-grid {
        display: grid;
        gap: 1rem;
    }

    .info-row {
        display: flex;
        flex-direction: column;
        gap: 0.3rem;
        font-size: 0.95rem;
    }

    .info-label {
        color: var(--text-secondary);
        font-weight: 600;
        font-size: 0.85rem;
        text-transform: uppercase;
        letter-spacing: 0.5px;
    }

    .info-value {
        color: #e0e0e0;
        font-weight: 500;
    }

    /* Trending List */
    .top-movies-compact {
        list-style: none;
        padding: 0;
        margin: 0;
    }

    .top-movie-compact {
        display: flex;
        gap: 1rem;
        padding: 0.8rem;
        border-radius: 8px;
        margin-bottom: 0.5rem;
        transition: all var(--transition-speed);
        cursor: pointer;
        text-decoration: none;
        color: var(--text-primary);
        align-items: center;
    }

    .top-movie-compact:hover {
        background: var(--bg-hover);
        transform: translateX(5px);
    }

    .top-rank-compact {
        font-size: 1.4rem;
        font-weight: 900;
        color: var(--netflix-red);
        min-width: 25px;
        text-align: center;
    }

    .top-thumb-compact {
        width: 50px;
        height: 75px;
        border-radius: 6px;
        object-fit: cover;
        box-shadow: 0 2px 8px rgba(0,0,0,0.5);
    }

    .top-info-compact {
        flex: 1;
        min-width: 0;
    }

    .top-info-compact h5 {
        font-size: 0.95rem;
        font-weight: 600;
        margin-bottom: 0.3rem;
        white-space: nowrap;
        overflow: hidden;
        text-overflow: ellipsis;
    }

    .top-meta-compact {
        font-size: 0.8rem;
        color: var(--text-secondary);
    }

    /* Main Content */
    .content-column {
        min-width: 0;
    }

    .stats-cards {
        display: grid;
        grid-template-columns: repeat(auto-fit, minmax(150px, 1fr));
        gap: 1.5rem;
        margin-bottom: 2rem;
    }

    .stat-card {
        background: var(--bg-card);
        border: 1px solid var(--border-color);
        border-radius: 12px;
        padding: 1.5rem;
        text-align: center;
        transition: all var(--transition-speed);
        box-shadow: 0 4px 15px rgba(0,0,0,0.2);
    }

    .stat-card:hover {
        background: var(--bg-hover);
        border-color: rgba(255,255,255,0.2);
        transform: translateY(-5px);
    }

    .stat-number {
        font-size: 2rem;
        font-weight: 800;
        color: var(--text-primary);
        margin-bottom: 0.5rem;
    }

    .stat-card:first-child .stat-number { color: var(--accent-yellow); }
    .stat-card:nth-child(2) .stat-number { color: #3498db; }
    .stat-card:nth-child(3) .stat-number { color: #2ecc71; }
    .stat-card:nth-child(4) .stat-number { color: var(--netflix-red); }

    .stat-label {
        font-size: 0.85rem;
        color: var(--text-secondary);
        text-transform: uppercase;
        letter-spacing: 1px;
        font-weight: 600;
    }

    .info-section {
        background: var(--bg-card);
        border: 1px solid var(--border-color);
        border-radius: 12px;
        padding: 2rem;
        margin-bottom: 2rem;
        box-shadow: 0 4px 20px rgba(0,0,0,0.2);
    }

    .section-title {
        font-size: 1.4rem;
        font-weight: 700;
        margin-bottom: 1.5rem;
        padding-bottom: 0.8rem;
        border-bottom: 1px solid var(--border-color);
        display: flex;
        align-items: center;
        gap: 0.8rem;
    }

    /* Cast Grid */
    .cast-grid {
        display: grid;
        grid-template-columns: repeat(auto-fill, minmax(120px, 1fr));
        gap: 1.5rem;
    }

    .cast-card {
        text-align: center;
        transition: transform var(--transition-speed);
    }

    .cast-card:hover {
        transform: translateY(-5px);
    }

    .cast-avatar {
        width: 110px;
        height: 110px;
        border-radius: 50%;
        background: var(--bg-hover);
        display: flex;
        align-items: center;
        justify-content: center;
        margin: 0 auto 0.8rem;
        border: 3px solid var(--border-color);
        overflow: hidden;
        box-shadow: 0 4px 10px rgba(0,0,0,0.5);
    }

    .cast-avatar img {
        width: 100%;
        height: 100%;
        object-fit: cover;
    }

    .cast-avatar i {
        font-size: 3rem;
        color: var(--text-secondary);
    }

    .cast-name {
        font-size: 0.95rem;
        font-weight: 600;
        margin-bottom: 0.3rem;
        color: var(--text-primary);
    }

    .cast-role {
        font-size: 0.8rem;
        color: var(--text-secondary);
    }

    /* Episodes Section */
    .episodes-list {
        display: flex;
        flex-direction: column;
        gap: 1rem;
    }

    .episode-item {
        background: rgba(255,255,255,0.02);
        border: 1px solid var(--border-color);
        border-radius: 10px;
        padding: 1.2rem;
        display: grid;
        grid-template-columns: 50px 140px 1fr auto;
        gap: 1.5rem;
        align-items: center;
        transition: all var(--transition-speed);
        text-decoration: none;
        color: var(--text-primary);
    }

    .episode-item:hover {
        background: var(--bg-hover);
        border-color: rgba(255,255,255,0.2);
        transform: translateX(5px);
    }

    .episode-number {
        font-size: 1.5rem;
        font-weight: 800;
        color: var(--text-secondary);
        text-align: center;
    }

    .episode-thumb {
        width: 140px;
        height: 80px;
        border-radius: 6px;
        background: var(--bg-hover);
        display: flex;
        align-items: center;
        justify-content: center;
        overflow: hidden;
        position: relative;
    }

    .episode-thumb img {
        width: 100%;
        height: 100%;
        object-fit: cover;
        opacity: 0.7;
    }

    .episode-thumb i {
        font-size: 2rem;
        color: rgba(255,255,255,0.8);
        position: absolute;
    }

    .episode-info {
        flex: 1;
        min-width: 0;
    }

    .episode-title {
        font-weight: 700;
        font-size: 1.1rem;
        margin-bottom: 0.4rem;
    }

    .episode-desc {
        font-size: 0.9rem;
        color: var(--text-secondary);
        display: -webkit-box;
        -webkit-line-clamp: 2;
        -webkit-box-orient: vertical;
        overflow: hidden;
    }

    .episode-duration {
        font-size: 0.9rem;
        color: var(--text-secondary);
        font-weight: 500;
    }

    .btn-play-ep {
        width: 45px;
        height: 45px;
        border-radius: 50%;
        background: rgba(255,255,255,0.1);
        border: 1px solid rgba(255,255,255,0.2);
        color: white;
        cursor: pointer;
        display: flex;
        align-items: center;
        justify-content: center;
        transition: all var(--transition-speed);
    }

    .episode-item:hover .btn-play-ep {
        background: var(--netflix-red);
        border-color: var(--netflix-red);
        transform: scale(1.1);
    }

    /* Rating Overview */
    .rating-overview {
        display: grid;
        grid-template-columns: 200px 1fr;
        gap: 3rem;
        align-items: center;
    }

    .rating-score {
        text-align: center;
    }

    .rating-number {
        font-size: 4.5rem;
        font-weight: 800;
        color: var(--accent-yellow);
        line-height: 1;
        margin-bottom: 0.5rem;
    }

    .rating-stars {
        font-size: 1.5rem;
        color: var(--accent-yellow);
        margin-bottom: 0.8rem;
    }

    .rating-count {
        font-size: 0.95rem;
        color: var(--text-secondary);
        font-weight: 500;
    }

    .rating-bars {
        display: flex;
        flex-direction: column;
        gap: 0.8rem;
    }

    .rating-bar-row {
        display: flex;
        align-items: center;
        gap: 1rem;
    }

    .bar-label {
        min-width: 60px;
        font-size: 0.95rem;
        color: var(--text-secondary);
        font-weight: 500;
    }

    .bar-container {
        flex: 1;
        height: 10px;
        background: rgba(255,255,255,0.05);
        border-radius: 5px;
        overflow: hidden;
    }

    .bar-fill {
        height: 100%;
        background: linear-gradient(90deg, #f5c518, #ffda44);
        border-radius: 5px;
        transition: width 1s cubic-bezier(0.4, 0, 0.2, 1);
    }

    .bar-count {
        min-width: 40px;
        text-align: right;
        font-size: 0.9rem;
        color: var(--text-secondary);
    }

    /* Review Form */
    .star-rating-input {
        display: flex;
        gap: 0.5rem;
        margin-bottom: 1rem;
        flex-direction: row-reverse;
        justify-content: flex-end;
    }

    .star-rating-input input {
        display: none;
    }

    .star-rating-input label {
        font-size: 2.2rem;
        color: rgba(255,255,255,0.1);
        cursor: pointer;
        transition: all 0.2s;
    }

    .star-rating-input input:checked ~ label,
    .star-rating-input label:hover,
    .star-rating-input label:hover ~ label {
        color: var(--accent-yellow);
    }

    .review-textarea {
        width: 100%;
        background: rgba(255,255,255,0.03);
        border: 1px solid var(--border-color);
        border-radius: 8px;
        color: var(--text-primary);
        padding: 1.2rem;
        font-size: 1rem;
        resize: vertical;
        min-height: 120px;
        font-family: inherit;
        margin-bottom: 0.5rem;
        transition: all 0.3s;
    }

    .review-textarea:focus {
        outline: none;
        border-color: var(--netflix-red);
        background: rgba(255,255,255,0.06);
        box-shadow: 0 0 0 3px rgba(229, 9, 20, 0.15);
    }

    .char-counter {
        text-align: right;
        font-size: 0.85rem;
        color: var(--text-secondary);
        margin-bottom: 1.5rem;
    }

    .btn-submit-review {
        background: var(--netflix-red);
        color: white;
        padding: 0.9rem 2.5rem;
        border: none;
        border-radius: 8px;
        font-weight: 600;
        font-size: 1rem;
        cursor: pointer;
        transition: all 0.2s;
        display: inline-flex;
        align-items: center;
        gap: 0.6rem;
    }

    .btn-submit-review:hover {
        background: #f40612;
        transform: translateY(-2px);
        box-shadow: 0 4px 15px rgba(229, 9, 20, 0.4);
    }

    .btn-submit-review:disabled {
        background: #555;
        cursor: not-allowed;
        transform: none;
        box-shadow: none;
    }

    /* Reviews List */
    .reviews-list {
        display: flex;
        flex-direction: column;
        gap: 1.2rem;
    }

    .review-item {
        background: rgba(255,255,255,0.02);
        border: 1px solid var(--border-color);
        border-radius: 12px;
        padding: 1.5rem;
        transition: all 0.3s;
    }

    .review-item:hover {
        background: rgba(255,255,255,0.04);
        border-color: rgba(255,255,255,0.1);
    }

    .review-header {
        display: flex;
        justify-content: space-between;
        align-items: flex-start;
        margin-bottom: 1rem;
    }

    .review-author {
        display: flex;
        align-items: center;
        gap: 1rem;
    }

    .author-avatar {
        width: 45px;
        height: 45px;
        border-radius: 50%;
        background: linear-gradient(135deg, var(--netflix-red), #ff4b4b);
        display: flex;
        align-items: center;
        justify-content: center;
        font-weight: 700;
        font-size: 1.2rem;
        box-shadow: 0 2px 8px rgba(229, 9, 20, 0.3);
    }

    .author-info h4 {
        font-size: 1.05rem;
        font-weight: 700;
        margin-bottom: 0.2rem;
    }

    .review-rating {
        color: var(--accent-yellow);
        font-size: 0.9rem;
    }

    .review-date {
        font-size: 0.9rem;
        color: var(--text-secondary);
    }

    .review-content {
        color: #e0e0e0;
        line-height: 1.6;
        font-size: 1rem;
    }

    .review-actions {
        display: flex;
        gap: 1.2rem;
        margin-top: 1rem;
        padding-top: 1rem;
        border-top: 1px solid rgba(255,255,255,0.05);
    }

    .review-action-btn {
        background: none;
        border: none;
        color: var(--text-secondary);
        font-size: 0.9rem;
        font-weight: 500;
        cursor: pointer;
        transition: all 0.2s;
        display: flex;
        align-items: center;
        gap: 0.4rem;
    }

    .review-action-btn:hover {
        color: var(--text-primary);
    }

    /* Login Prompt */
    .login-prompt {
        text-align: center;
        padding: 3rem 1rem;
        background: rgba(255,255,255,0.02);
        border-radius: 12px;
        border: 1px dashed var(--border-color);
    }

    .login-prompt i {
        font-size: 3.5rem;
        color: var(--text-secondary);
        margin-bottom: 1.2rem;
    }

    .login-prompt p {
        color: var(--text-primary);
        font-size: 1.1rem;
        margin-bottom: 1.5rem;
    }

    /* Responsive */
    @@media (max-width: 1024px) {
        .movie-layout {
            grid-template-columns: 1fr;
        }

        .sidebar-column {
            position: relative;
            top: 0;
            display: grid;
            grid-template-columns: repeat(2, 1fr);
            gap: 1.5rem;
        }
    }

    @@media (max-width: 768px) {
        .hero-banner {
            height: auto;
            min-height: 500px;
            padding-top: 80px;
        }

        .hero-inner {
            flex-direction: column;
            align-items: center;
            text-align: center;
            gap: 20px;
        }

        .hero-title {
            font-size: 2.5rem;
        }

        .hero-meta, .hero-actions {
            justify-content: center;
        }

        .sidebar-column {
            grid-template-columns: 1fr;
        }

        .stats-cards {
            grid-template-columns: repeat(2, 1fr);
        }

        .rating-overview {
            grid-template-columns: 1fr;
            gap: 2rem;
        }

        .episode-item {
            grid-template-columns: 40px 1fr auto;
        }

        .episode-thumb {
            display: none;
        }
    }
</style>

<div class="hero-banner">
    @if (TempData["Error"] != null)
    {
        <div class="alert alert-danger" style="margin: 20px; z-index: 999; position: relative; border-radius: 8px;">
            <strong>Error:</strong> @TempData["Error"]
        </div>
    }
    <img src="@(Model.Movie.PosterUrl ?? "/images/default-bg.jpg")" alt="@Model.Movie.Title" class="hero-backdrop">
    <div class="hero-gradient"></div>

    <div class="hero-content">
        <div class="hero-inner">
            <div class="hero-poster">
                <img src="@(Model.Movie.PosterUrl ?? "/images/no-poster.jpg")" alt="@Model.Movie.Title">
            </div>

            <div class="hero-info">
                <h1 class="hero-title">@Model.Movie.Title</h1>

                <div class="hero-meta">
                    @if (Model.Movie.ReleaseYear.HasValue)
                    {
                        <span>@Model.Movie.ReleaseYear</span>
                        <span class="meta-separator">•</span>
                    }
                    @if (Model.Movie.DurationMinutes.HasValue)
                    {
                        <span><i class="far fa-clock"></i> @Model.Movie.DurationMinutes min</span>
                        <span class="meta-separator">•</span>
                    }
                    <span>@Model.Movie.Type</span>
                    @if (!string.IsNullOrEmpty(Model.Movie.CountryName))
                    {
                        <span class="meta-separator">•</span>
                        <span>@Model.Movie.CountryName</span>
                    }
                </div>

                @if (!string.IsNullOrEmpty(Model.Movie.Description))
                {
                    <p class="hero-description">@Model.Movie.Description</p>
                }

                <div class="hero-actions">
                    <a href="/Movie/Watch/@Model.Movie.Slug" class="btn-hero btn-hero-primary">
                        <i class="fas fa-play"></i> Watch Now
                    </a>

                    @if (Model.IsVipOnly)
                    {
                        <a asp-controller="Movie" asp-action="Download" asp-route-id="@Model.Movie.Id" class="btn btn-warning text-dark">
                            <i class="fa-solid fa-lock"></i> Premium Download
                        </a>
                    }
                    else
                    {
                        <a asp-controller="Movie" asp-action="Download" asp-route-id="@Model.Movie.Id" class="btn btn-success">
                            <i class="fa-solid fa-download"></i> Free Download
                        </a>
                    }

                    @if (!string.IsNullOrEmpty(Model.Movie.TrailerUrl))
                    {
                        <a href="@Model.Movie.TrailerUrl" target="_blank" class="btn-hero btn-hero-secondary">
                            <i class="fab fa-youtube"></i> Trailer
                        </a>
                    }

                    @if (User.Identity?.IsAuthenticated == true)
                    {
                        <button type="button"
                                class="btn-hero btn-hero-secondary favorite-toggle-btn @(isFavorited ? "active" : "")"
                                data-movie-id="@Model.Movie.Id"
                                data-is-favorited="@isFavorited.ToString().ToLower()">
                            <i class="@(isFavorited ? "fas" : "far") fa-heart"></i>
                            <span>@(isFavorited ? "Favorited" : "Favorite")</span>
                        </button>
                    }
                    else
                    {
                        <a href="/Identity/Account/Login?returnUrl=@Uri.EscapeDataString(currentUrl)" class="btn-hero btn-hero-secondary">
                            <i class="far fa-heart"></i> Favorite
                        </a>
                    }
                </div>
            </div>
        </div>
    </div>
</div>

<div class="movie-container">
    <div class="movie-layout">

        <div class="sidebar-column">
            <div class="sidebar-section">
                <h3 class="sidebar-title">
                    <i class="fas fa-info-circle"></i> Information
                </h3>
                <div class="info-grid">
                    @if (Model.Movie.ReleaseYear.HasValue)
                    {
                        <div class="info-row">
                            <span class="info-label">Year</span>
                            <span class="info-value">@Model.Movie.ReleaseYear</span>
                        </div>
                    }
                    @if (Model.Movie.DurationMinutes.HasValue)
                    {
                        <div class="info-row">
                            <span class="info-label">Duration</span>
                            <span class="info-value">@Model.Movie.DurationMinutes min</span>
                        </div>
                    }
                    @if (!string.IsNullOrEmpty(Model.Movie.CountryName))
                    {
                        <div class="info-row">
                            <span class="info-label">Country</span>
                            <span class="info-value">@Model.Movie.CountryName</span>
                        </div>
                    }
                    <div class="info-row">
                        <span class="info-label">Type</span>
                        <span class="info-value">@Model.Movie.Type</span>
                    </div>
                    <div class="info-row">
                        <span class="info-label">Status</span>
                        <span class="info-value">@Model.Movie.Status</span>
                    </div>
                </div>
            </div>

            @if (Model.RelatedMovies != null && Model.RelatedMovies.Any())
            {
                <div class="sidebar-section">
                    <h3 class="sidebar-title">
                        <i class="fas fa-fire"></i> Trending This Week
                    </h3>
                    <ul class="top-movies-compact">
                        @for (int i = 0; i < Math.Min(5, Model.RelatedMovies.Count()); i++)
                        {
                            var movie = Model.RelatedMovies.ElementAt(i);
                            <li>
                                <a href="@Url.Action("Detail", "Movie", new { slug = movie.Slug })" class="top-movie-compact">
                                    <div class="top-rank-compact">@(i + 1)</div>
                                    <img src="@(movie.PosterUrl ?? "/images/no-poster.jpg")" alt="@movie.Title" class="top-thumb-compact">
                                    <div class="top-info-compact">
                                        <h5>@movie.Title</h5>
                                        <div class="top-meta-compact">
                                            @if (movie.ReleaseYear.HasValue)
                                            {
                                                <span>@movie.ReleaseYear</span>
                                                <span> • </span>
                                            }
                                            <span>@movie.Type</span>
                                        </div>
                                    </div>
                                </a>
                            </li>
                        }
                    </ul>
                </div>
            }
        </div>

        <div class="content-column">

            <div class="stats-cards">
                <div class="stat-card">
                    <div class="stat-number">
                        @(rating != null && rating.TotalReviews > 0 ? rating.AverageRating.ToString("F1") : "--")
                    </div>
                    <div class="stat-label">Average Rating</div>
                </div>
                <div class="stat-card">
                    <div class="stat-number">@Model.Movie.ViewCount.ToString("N0")</div>
                    <div class="stat-label">Views</div>
                </div>
                <div class="stat-card">
                    <div class="stat-number">@(rating != null ? rating.TotalReviews.ToString() : "0")</div>
                    <div class="stat-label">Reviews</div>
                </div>
                <div class="stat-card">
                    <div class="stat-number">@(rating != null ? rating.TotalFavorites.ToString() : "0")</div>
                    <div class="stat-label">Favorites</div>
                </div>
            </div>

            @if (Model.Actors != null && Model.Actors.Any())
            {
                <div class="info-section">
                    <h2 class="section-title">
                        <i class="fas fa-users"></i> Cast & Crew
                    </h2>
                    <div class="cast-grid">
                        @foreach (var actor in Model.Actors)
                        {
                            <a href="/Actor/Dashboard/@actor.Id" style="text-decoration: none; color: inherit; display: block;">
                                <div class="cast-card">
                                    <div class="cast-avatar">
                                        @if (!string.IsNullOrEmpty(actor.AvartUrl))
                                        {
                                            <img src="@actor.AvartUrl" alt="@actor.Name">
                                        }
                                        else
                                        {
                                            <i class="fas fa-user"></i>
                                        }
                                    </div>
                                    <div class="cast-name">@actor.Name</div>
                                    <div class="cast-role">
                                        @(string.IsNullOrEmpty(actor.Gender) ? "Actor" : actor.Gender)
                                    </div>
                                </div>
                            </a>
                        }
                    </div>
                </div>
            }

            @if (Model.Movie.Type == MovieType.Series && Model.Episodes != null && Model.Episodes.Any())
            {
                <div class="info-section">
                    <h2 class="section-title">
                        <i class="fas fa-list"></i> Episodes List (@Model.Episodes.Count())
                    </h2>
                    <div class="episodes-list">
                        @foreach (var episode in Model.Episodes)
                        {
                            <a href="/Movie/Watch/@Model.Movie.Slug?ep=@episode.EpisodeNumber" class="episode-item">
                                <div class="episode-number">@episode.EpisodeNumber</div>
                                <div class="episode-thumb">
                                    <i class="fas fa-play-circle"></i>
                                </div>
                                <div class="episode-info">
                                    <div class="episode-title">@episode.Title</div>
                                    @if (!string.IsNullOrEmpty(episode.Description))
                                    {
                                        <div class="episode-desc">@episode.Description</div>
                                    }
                                </div>
                                @if (episode.DurationMinutes.HasValue)
                                {
                                    <div class="episode-duration">@episode.DurationMinutes min</div>
                                }
                                <div class="btn-play-ep"><i class="fas fa-play"></i></div>
                            </a>
                        }
                    </div>
                </div>
            }

            @if (rating != null && rating.TotalReviews > 0)
            {
                <div class="info-section">
                    <h2 class="section-title">
                        <i class="fas fa-star"></i> Rating Overview
                    </h2>

                    <div class="rating-overview">
                        <div class="rating-score">
                            <div class="rating-number">@rating.AverageRating.ToString("F1")</div>
                            <div class="rating-stars">
                                @for (int i = 1; i <= 5; i++)
                                {
                                    if (i <= Math.Round(rating.AverageRating))
                                    {
                                        <i class="fas fa-star"></i>
                                    }
                                    else if (i - 0.5 <= rating.AverageRating)
                                    {
                                        <i class="fas fa-star-half-alt"></i>
                                    }
                                    else
                                    {
                                        <i class="far fa-star"></i>
                                    }
                                }
                            </div>
                            <div class="rating-count">@rating.TotalReviews reviews</div>
                        </div>

                        <div class="rating-bars">
                            @foreach (var star in new[] { 5, 4, 3, 2, 1 })
                            {
                                var count = rating.RatingDistribution.ContainsKey(star) ? rating.RatingDistribution[star] : 0;
                                var percentage = rating.TotalReviews > 0 ? (count * 100.0 / rating.TotalReviews) : 0;

                                <div class="rating-bar-row">
                                    <span class="bar-label">@star stars</span>
                                    <div class="bar-container">
                                        <div class="bar-fill" style="width: @(percentage)%"></div>
                                    </div>
                                    <span class="bar-count">@count</span>
                                </div>
                            }
                        </div>
                    </div>
                </div>
            }

            <div id="create-review-section" style="display: @(userReview == null ? "block" : "none");">
                @if (User.Identity?.IsAuthenticated == true)
                {
                    <div class="info-section">
                        <h2 class="section-title">
                            <i class="fas fa-pen"></i> Write a Review
                        </h2>
                        <form id="reviewForm" asp-controller="Reviews" asp-action="Create" method="post">
                            @Html.AntiForgeryToken()
                            <input type="hidden" name="MovieId" value="@Model.Movie.Id" />

                            <div class="mb-3">
                                <div class="star-rating-input">
                                    @for (int i = 5; i >= 1; i--)
                                    {
                                        <input type="radio" id="star@(i)" name="Rating" value="@i" required />
                                        <label for="star@(i)" title="@i stars"><i class="fas fa-star"></i></label>
                                    }
                                </div>
                                <span id="ratingError" class="text-danger" style="display: none; font-size: 0.9rem;">Please select a star rating</span>
                            </div>

                            <div class="mb-3">
                                <textarea name="Comment" id="commentText" class="review-textarea" placeholder="Share your thoughts about this movie..." maxlength="1000"></textarea>
                                <div class="char-counter">
                                    <span id="charCount">0</span>/1000 characters
                                </div>
                            </div>

                            <button type="submit" class="btn-submit-review">
                                <i class="fas fa-paper-plane"></i> Submit Review
                            </button>
                        </form>
                    </div>
                }
                else
                {
                    <div class="info-section">
                        <div class="login-prompt">
                            <i class="fas fa-user-lock"></i>
                            <p>Sign in to review this movie</p>
                            <a href="/Identity/Account/Login?returnUrl=@Uri.EscapeDataString(currentUrl)" class="btn-submit-review" style="text-decoration: none;">
                                <i class="fas fa-sign-in-alt"></i> Sign In
                            </a>
                        </div>
                    </div>
                }
            </div>

            <div class="info-section" id="all-reviews-section">
                <h2 class="section-title">
                    <i class="fas fa-comments"></i> User Reviews (<span id="reviewCount">@(reviews?.Count() ?? 0)</span>)
                </h2>

                <div class="reviews-list" id="reviewsListContainer">
                    @if (reviews != null && reviews.Any())
                    {
                        @foreach (var review in reviews)
                        {
                            bool isMyReview = (userReview != null && review.Id == userReview.Id);
                            // Ưu tiên hiển thị tên mới nhất mà user đã đổi, nếu có @ thì chặt đuôi đi
                            var displayName = review.UserName.Contains("@") ? review.UserName.Split('@')[0] : review.UserName;

                            <div class="review-item" id="review-@review.Id" style="@(isMyReview ? "border: 1px solid var(--netflix-red); background: rgba(229, 9, 20, 0.05);" : "")">
                                
                                <div id="display-mode-@review.Id">
                                    <div class="review-header">
                                        <div class="review-author">
                                            <div class="author-avatar" style="@(isMyReview ? "background: linear-gradient(135deg, #f5c518, #ffda44); color: #000;" : "")">
                                                @review.UserName.Substring(0, 1).ToUpper()
                                            </div>
                                            <div class="author-info">
                                                <h4>
                                                    @displayName 
                                                    @if(isMyReview) { <span class="badge bg-danger ms-2" style="font-size: 0.7rem;">You</span> }
                                                </h4>
                                                <div class="review-rating">
                                                    @for (int i = 1; i <= 5; i++)
                                                    {
                                                        if (i <= review.Rating) { <i class="fas fa-star"></i> }
                                                        else { <i class="far fa-star"></i> }
                                                    }
                                                </div>
                                            </div>
                                        </div>
                                        <div class="review-date">@review.CreatedAt.ToString("MMM dd, yyyy")</div>
                                    </div>

                                    @if (!string.IsNullOrEmpty(review.Comment))
                                    {
                                        <div class="review-content" style="font-size: 1.05rem;">@review.Comment</div>
                                    }

                                    <div class="review-actions mt-3 pt-3" style="border-top: 1px solid rgba(255,255,255,0.05);">
                                        @if (isMyReview)
                                        {
                                            <button class="review-action-btn text-primary" onclick="showEditForm('@review.Id')"><i class="fas fa-edit"></i> Edit</button>
                                            <button class="review-action-btn text-danger ms-3" onclick="deleteReview('@review.Id')"><i class="fas fa-trash"></i> Delete</button>
                                        }
                                        else
                                        {
                                            <button class="review-action-btn"><i class="far fa-thumbs-up"></i> Helpful</button>
                                            <button class="review-action-btn ms-3"><i class="far fa-flag"></i> Report</button>
                                        }
                                    </div>
                                </div>

                                @if (isMyReview)
                                {
                                    <div id="edit-mode-@review.Id" style="display: none;">
                                        <form class="form-edit-review" method="post">
                                            @Html.AntiForgeryToken()
                                            <input type="hidden" name="Id" value="@review.Id" />
                                            <input type="hidden" name="MovieId" value="@Model.Movie.Id" />

                                            <div class="mb-3">
                                                <label class="text-light mb-2 fw-bold">Update your rating:</label>
                                                <div class="star-rating-input">
                                                    @for (int i = 5; i >= 1; i--)
                                                    {
                                                        var isChecked = (i == review.Rating) ? "checked" : "";
                                                        <input type="radio" id="editStar-@review.Id-@i" name="Rating" value="@i" required @isChecked />
                                                        <label for="editStar-@review.Id-@i" title="@i stars"><i class="fas fa-star"></i></label>
                                                    }
                                                </div>
                                            </div>

                                            <div class="mb-3">
                                                <textarea name="Comment" class="review-textarea" rows="3" required>@review.Comment</textarea>
                                            </div>

                                            <div class="d-flex gap-2">
                                                <button type="submit" class="btn btn-danger px-4 fw-bold">
                                                    <i class="fas fa-save"></i> Save
                                                </button>
                                                <button type="button" class="btn btn-secondary px-4 fw-bold" onclick="hideEditForm('@review.Id')">
                                                    Cancel
                                                </button>
                                            </div>
                                        </form>
                                    </div>
                                }
                            </div>
                        }
                    }
                    else
                    {
                        <div id="no-reviews-msg" class="text-center text-secondary py-4">
                            <i class="fas fa-comment-slash fs-1 mb-3"></i>
                            <p>No reviews yet. Be the first to review this movie!</p>
                        </div>
                    }
                </div>
            </div>

        </div>
    </div>
</div>

@section Scripts {
    <script>
        const currentUserName = '@User.Identity?.Name'; // Lấy đúng tên user đang login
        
        // --------------------------------------------------------
        // 1. DOM MANIPULATION CHO FORM EDIT
        // --------------------------------------------------------
        function showEditForm(reviewId) {
            $('#display-mode-' + reviewId).hide();
            $('#edit-mode-' + reviewId).fadeIn(200);
        }

        function hideEditForm(reviewId) {
            $('#edit-mode-' + reviewId).hide();
            $('#display-mode-' + reviewId).fadeIn(200);
        }

        // --------------------------------------------------------
        // 2. AJAX XÓA REVIEW
        // --------------------------------------------------------
        function deleteReview(reviewId) {
            if (!confirm('Are you sure you want to delete your review?')) return;

            $.ajax({
                url: '@Url.Action("Delete", "Reviews")',
                type: 'POST',
                data: {
                    id: reviewId,
                    __RequestVerificationToken: $('input[name="__RequestVerificationToken"]').val()
                },
                success: function(response) {
                    if (response.success) {
                        showToast(response.message || 'Review deleted successfully!', 'success');
                        
                        $('#review-' + reviewId).fadeOut(300, function() {
                            $(this).remove();
                            let currentCount = parseInt($('#reviewCount').text()) || 0;
                            $('#reviewCount').text(currentCount > 0 ? currentCount - 1 : 0);
                            
                            $('#create-review-section').slideDown();
                            
                            if (currentCount - 1 === 0) {
                                $('#reviewsListContainer').html(`
                                    <div id="no-reviews-msg" class="text-center text-secondary py-4">
                                        <i class="fas fa-comment-slash fs-1 mb-3"></i>
                                        <p>No reviews yet. Be the first to review this movie!</p>
                                    </div>
                                `);
                            }
                        });
                    } else { showToast(response.message, 'error'); }
                },
                error: function() { showToast('Error deleting review!', 'error'); }
            });
        }

        $(document).ready(function() {
            $('#commentText').on('input', function() {
                $('#charCount').text($(this).val().length);
            });

            // --------------------------------------------------------
            // 3. AJAX SỬA REVIEW
            // --------------------------------------------------------
            $(document).on('submit', '.form-edit-review', function(e) {
                e.preventDefault(); // CHẶN LOAD TRANG
                const form = $(this);
                const reviewId = form.find('input[name="Id"]').val();
                const newRating = form.find('input[name="Rating"]:checked').val();
                const newComment = form.find('textarea[name="Comment"]').val();
                const submitBtn = form.find('button[type="submit"]');

                submitBtn.prop('disabled', true).html('<i class="fas fa-spinner fa-spin"></i> Saving...');

                $.ajax({
                    url: '@Url.Action("Edit", "Reviews")',
                    type: 'POST',
                    data: form.serialize(),
                    success: function(response) {
                        if (response.success) {
                            showToast(response.message || 'Updated successfully!', 'success');
                            
                            const displayMode = $('#display-mode-' + reviewId);
                            displayMode.find('.review-content').text(newComment);
                            
                            let starsHtml = '';
                            for (let i = 1; i <= 5; i++) {
                                starsHtml += i <= newRating ? '<i class="fas fa-star"></i>' : '<i class="far fa-star"></i>';
                            }
                            displayMode.find('.review-rating').html(starsHtml);
                            hideEditForm(reviewId);
                        } else { showToast(response.message, 'error'); }
                    },
                    error: function() { showToast('An error occurred!', 'error'); },
                    complete: function() { submitBtn.prop('disabled', false).html('<i class="fas fa-save"></i> Save'); }
                });
            });

          

            // --------------------------------------------------------
            // 5. YÊU THÍCH PHIM
            // --------------------------------------------------------
            $('.favorite-toggle-btn').click(function() {
                const btn = $(this);
                $.ajax({
                    url: '@Url.Action("Toggle", "Favorites")', 
                    type: 'POST',
                    data: { movieId: btn.data('movie-id'), __RequestVerificationToken: $('input[name="__RequestVerificationToken"]').val() },
                    success: function(response) {
                        if (response.success) {
                            $('.favorite-toggle-btn').each(function() {
                                const icon = $(this).find('i'); 
                                const text = $(this).find('span');
                                if (response.isFavorite) {
                                    icon.removeClass('far').addClass('fas text-danger'); 
                                    if(text.length) text.text('Đã thích'); 
                                    $(this).addClass('active');
                                } else {
                                    icon.removeClass('fas text-danger').addClass('far'); 
                                    if(text.length) text.text('Yêu thích'); 
                                    $(this).removeClass('active');
                                }
                            });
                        }
                    }
                });
            });

            $('.star-rating-input input').on('change', function() { $('#ratingError').hide(); });
        });

        function showToast(message, type) {
            $('.toast-notification').remove();
            const borderColor = type === 'success' ? '#46d369' : '#e50914';
            const icon = type === 'success' ? 'check-circle' : 'exclamation-circle';
            const toast = $(`
                <div class="toast-notification" style="position: fixed; top: 90px; right: 20px; background: #1f1f1f; border-left: 4px solid ${borderColor}; padding: 1rem 1.5rem; border-radius: 8px; box-shadow: 0 10px 30px rgba(0,0,0,0.5); z-index: 9999; animation: slideIn 0.3s ease; display: flex; align-items: center; gap: 1rem;">
                    <i class="fas fa-${icon}" style="color: ${borderColor}; font-size: 1.3rem;"></i>
                    <span style="color: #fff; font-weight: 500;">${message}</span>
                </div>
            `);
            $('body').append(toast);
            setTimeout(() => toast.fadeOut(300, function() { $(this).remove(); }), 3000);
        }

        const style = document.createElement('style');
        style.textContent = `
            @@keyframes fadeIn { from { opacity: 0; transform: translateY(-20px); } to { opacity: 1; transform: translateY(0); } }
            @@keyframes slideIn { from { transform: translateX(100%); opacity: 0; } to { transform: translateX(0); opacity: 1; } }
            .star-rating-input { display: flex; flex-direction: row-reverse; justify-content: flex-end; }
            .star-rating-input input { display: none; }
            .star-rating-input label { color: #555; font-size: 24px; padding: 0 2px; cursor: pointer; transition: color 0.2s; }
            .star-rating-input input:checked ~ label, .star-rating-input label:hover, .star-rating-input label:hover ~ label { color: #ffc107; }
        `;
        document.head.appendChild(style);
    </script>
}