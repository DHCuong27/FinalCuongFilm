@{
    ViewData["Title"] = "Watch Movie";
    Layout = "_LayoutUser";

    var movie = ViewBag.Movie as FinalCuongFilm.Common.DTOs.MovieDto;
    var mediaFile = ViewBag.MediaFile as FinalCuongFilm.Common.DTOs.MediaFileDto;
    var currentEpisode = ViewBag.CurrentEpisode as FinalCuongFilm.Common.DTOs.EpisodeDto;
    var episodes = ViewBag.Episodes as List<FinalCuongFilm.Common.DTOs.EpisodeDto>;

    // ── FIX #2: Nhận SAS URL + quality options + subtitles từ controller ──
    var streamingUrl = ViewBag.StreamingUrl as string;
    var movieId = ViewBag.MovieId;
    var episodeId = ViewBag.EpisodeId;
}

<!DOCTYPE html>
<html>
<head>
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.0.0/css/all.min.css">
    <style>
        * {
            margin: 0;
            padding: 0;
            box-sizing: border-box;
        }

        body {
            background: #0f0f0f;
            color: #fff;
            font-family: -apple-system, BlinkMacSystemFont, 'Segoe UI', Roboto, 'Helvetica Neue', Arial, sans-serif;
            line-height: 1.6;
        }

        /* Netflix-style Scrollbar */
        ::-webkit-scrollbar {
            width: 10px;
            height: 10px;
        }

        ::-webkit-scrollbar-track {
            background: #1a1a1a;
        }

        ::-webkit-scrollbar-thumb {
            background: #404040;
            border-radius: 5px;
        }

            ::-webkit-scrollbar-thumb:hover {
                background: #4d4d4d;
            }

        /* Video Player Section - Netflix Style */
        .video-section {
            background: #000;
            position: relative;
            width: 100%;
        }

        .video-wrapper {
            position: relative;
            width: 100%;
            background: #000;
            cursor: pointer;
        }

        video {
            width: 100%;
            height: auto;
            max-height: 80vh;
            display: block;
            outline: none;
        }

        /* Custom Video Controls (Netflix Style) */
        .video-controls-overlay {
            position: absolute;
            bottom: 0;
            left: 0;
            right: 0;
            background: linear-gradient(transparent, rgba(0,0,0,0.9));
            padding: 20px;
            opacity: 0;
            transition: opacity 0.3s;
            pointer-events: none;
        }

        .video-wrapper:hover .video-controls-overlay {
            opacity: 1;
            pointer-events: auto;
        }

        /* ── FIX #4: Quality Switcher Bar ── */
        .quality-bar {
            background: rgba(0, 0, 0, 0.85);
            padding: 8px 20px;
            display: flex;
            align-items: center;
            gap: 10px;
            flex-wrap: wrap;
        }

        .quality-bar-label {
            color: #b3b3b3;
            font-size: 0.82rem;
            font-weight: 600;
            text-transform: uppercase;
            letter-spacing: 0.5px;
        }

        .quality-btn {
            padding: 4px 14px;
            border-radius: 20px;
            border: 1px solid #444;
            background: transparent;
            color: #b3b3b3;
            font-size: 0.82rem;
            font-weight: 600;
            cursor: pointer;
            transition: all 0.15s;
            font-family: inherit;
        }

            .quality-btn:hover {
                border-color: #e50914;
                color: #fff;
            }

            .quality-btn.active {
                background: #e50914;
                border-color: #e50914;
                color: #fff;
            }

        /* ── FIX #4: Resume Banner ── */
        .resume-banner {
            background: rgba(229, 9, 20, 0.1);
            border: 1px solid rgba(229, 9, 20, 0.35);
            border-radius: 6px;
            padding: 12px 18px;
            margin-bottom: 18px;
            display: none;
            align-items: center;
            justify-content: space-between;
            gap: 12px;
            flex-wrap: wrap;
        }

            .resume-banner.visible {
                display: flex;
            }

            .resume-banner p {
                color: #fff;
                font-size: 0.92rem;
                margin: 0;
            }

                .resume-banner p span {
                    color: #e50914;
                    font-weight: 700;
                }

        .resume-btn {
            padding: 6px 16px;
            background: #e50914;
            color: #fff;
            border: none;
            border-radius: 4px;
            cursor: pointer;
            font-size: 0.85rem;
            font-weight: 600;
            font-family: inherit;
        }

            .resume-btn:hover {
                background: #f40612;
            }

        .dismiss-btn {
            background: transparent;
            border: none;
            color: #b3b3b3;
            cursor: pointer;
            font-size: 1.1rem;
        }

        /* Info Section - Netflix Style */
        .info-section {
            max-width: 1400px;
            margin: 0 auto;
            padding: 30px 4%;
        }

        .movie-title {
            font-size: 2.5rem;
            font-weight: 700;
            margin-bottom: 15px;
            letter-spacing: -0.5px;
        }

            .movie-title span {
                font-size: 1.5rem;
                color: #b3b3b3;
                font-weight: 400;
            }

        .movie-meta {
            display: flex;
            align-items: center;
            gap: 15px;
            color: #b3b3b3;
            font-size: 1rem;
            margin-bottom: 20px;
            flex-wrap: wrap;
        }

        .meta-badge {
            background: rgba(255,255,255,0.1);
            padding: 4px 10px;
            border-radius: 4px;
            font-size: 0.9rem;
        }

        .match-score {
            color: #46d369;
            font-weight: 600;
        }

        .movie-description {
            color: #b3b3b3;
            line-height: 1.8;
            margin-bottom: 30px;
            max-width: 800px;
            font-size: 1.1rem;
        }

        /* Action Buttons - Netflix Style */
        .action-buttons {
            display: flex;
            gap: 15px;
            margin-bottom: 40px;
            flex-wrap: wrap;
        }

        .btn {
            display: inline-flex;
            align-items: center;
            gap: 10px;
            padding: 12px 30px;
            border-radius: 4px;
            font-weight: 600;
            font-size: 1.1rem;
            text-decoration: none;
            transition: all 0.2s;
            border: none;
            cursor: pointer;
        }

        .btn-primary {
            background: #e50914;
            color: #fff;
        }

            .btn-primary:hover {
                background: #f40612;
                transform: scale(1.05);
            }

        .btn-secondary {
            background: rgba(255,255,255,0.1);
            color: #fff;
            backdrop-filter: blur(5px);
        }

            .btn-secondary:hover {
                background: rgba(255,255,255,0.2);
                transform: scale(1.05);
            }

        /* Episodes Section - Netflix Style */
        .episodes-section {
            margin-top: 50px;
        }

        .section-header {
            display: flex;
            align-items: center;
            justify-content: space-between;
            margin-bottom: 25px;
            flex-wrap: wrap;
            gap: 15px;
        }

        .section-title {
            font-size: 1.8rem;
            font-weight: 600;
            color: #fff;
            display: flex;
            align-items: center;
            gap: 10px;
        }

        .episode-count {
            color: #b3b3b3;
            font-size: 1.2rem;
            font-weight: 400;
        }

        .episodes-grid {
            display: grid;
            grid-template-columns: repeat(auto-fill, minmax(300px, 1fr));
            gap: 25px;
        }

        .episode-card {
            background: linear-gradient(to bottom, #1f1f1f, #171717);
            border-radius: 8px;
            overflow: hidden;
            transition: all 0.3s cubic-bezier(0.5, 1, 0.89, 1);
            text-decoration: none;
            color: white;
            position: relative;
            border: 2px solid transparent;
        }

            .episode-card:hover {
                transform: scale(1.05) translateY(-10px);
                box-shadow: 0 20px 40px rgba(0,0,0,0.5);
                z-index: 10;
            }

            .episode-card.active {
                border-color: #e50914;
                box-shadow: 0 0 20px rgba(229, 9, 20, 0.3);
            }

        .episode-thumbnail {
            position: relative;
            width: 100%;
            aspect-ratio: 16/9;
            background: #2a2a2a;
            overflow: hidden;
        }

            .episode-thumbnail img {
                width: 100%;
                height: 100%;
                object-fit: cover;
                transition: transform 0.3s;
            }

        .episode-card:hover .episode-thumbnail img {
            transform: scale(1.1);
        }

        .episode-thumbnail i {
            font-size: 4rem;
            color: #404040;
            display: flex;
            align-items: center;
            justify-content: center;
            height: 100%;
        }

        /* ── FIX #4: Episode Progress Bar ── */
        .ep-progress {
            position: absolute;
            bottom: 0;
            left: 0;
            height: 3px;
            background: #e50914;
            transition: width 0.3s;
            width: 0%;
        }

        .episode-badge {
            position: absolute;
            top: 10px;
            right: 10px;
            background: rgba(0,0,0,0.8);
            color: #fff;
            padding: 4px 8px;
            border-radius: 4px;
            font-size: 0.8rem;
            font-weight: 600;
        }

        .episode-info {
            padding: 18px;
        }

        .episode-number {
            color: #e50914;
            font-size: 0.9rem;
            font-weight: 600;
            margin-bottom: 8px;
            text-transform: uppercase;
            letter-spacing: 0.5px;
        }

        .episode-title {
            font-size: 1.2rem;
            font-weight: 600;
            margin-bottom: 10px;
            line-height: 1.4;
        }

        .episode-duration {
            color: #b3b3b3;
            font-size: 0.9rem;
            display: flex;
            align-items: center;
            gap: 5px;
        }

        /* Loading State */
        .loading {
            text-align: center;
            padding: 60px;
        }

        .spinner {
            width: 50px;
            height: 50px;
            border: 3px solid #333;
            border-top-color: #e50914;
            border-radius: 50%;
            animation: spin 1s linear infinite;
            margin: 0 auto 20px;
        }

        @@keyframes spin {
            to {
                transform: rotate(360deg);
            }
        }

        /* Error Message */
        .error-container {
            min-height: 60vh;
            display: flex;
            align-items: center;
            justify-content: center;
            padding: 20px;
        }

        .error-message {
            background: linear-gradient(135deg, rgba(229, 9, 20, 0.1), rgba(229, 9, 20, 0.05));
            border: 1px solid rgba(229, 9, 20, 0.3);
            padding: 40px;
            border-radius: 12px;
            color: #fff;
            max-width: 500px;
            text-align: center;
            backdrop-filter: blur(10px);
        }

            .error-message h2 {
                color: #e50914;
                margin-bottom: 20px;
                font-size: 2rem;
            }

        .error-icon {
            font-size: 5rem;
            margin-bottom: 20px;
            color: #e50914;
        }

        /* Responsive */
        @@media (max-width: 768px) {
            .movie-title {
                font-size: 1.8rem;
            }

                .movie-title span {
                    font-size: 1.2rem;
                }

            .section-title {
                font-size: 1.5rem;
            }

            .episodes-grid {
                grid-template-columns: 1fr;
            }

            .btn {
                padding: 10px 20px;
                font-size: 1rem;
            }
        }

        /* Progress Bar - Netflix Style */
        .progress-bar {
            height: 3px;
            background: rgba(255,255,255,0.2);
            position: relative;
            cursor: pointer;
        }

        .progress-fill {
            height: 100%;
            background: #e50914;
            width: 0;
            transition: width 0.1s;
        }

        /* Volume Control */
        .volume-control {
            display: flex;
            align-items: center;
            gap: 10px;
        }

        .volume-slider {
            width: 80px;
            height: 3px;
            background: rgba(255,255,255,0.2);
            border-radius: 2px;
            position: relative;
            cursor: pointer;
        }

        .volume-fill {
            height: 100%;
            background: #fff;
            width: 100%;
            border-radius: 2px;
        }

        /* Next Episode Hint */
        .next-episode-hint {
            position: fixed;
            bottom: 20px;
            right: 20px;
            background: rgba(0,0,0,0.9);
            border-left: 3px solid #e50914;
            padding: 15px;
            border-radius: 4px;
            max-width: 300px;
            animation: slideIn 0.3s;
            z-index: 1000;
        }

        @@keyframes slideIn {
            from {
                transform: translateX(100%);
                opacity: 0;
            }

            to {
                transform: translateX(0);
                opacity: 1;
            }
        }

        .next-episode-hint h4 {
            color: #fff;
            margin-bottom: 5px;
            font-size: 1rem;
        }

        .next-episode-hint p {
            color: #b3b3b3;
            font-size: 0.9rem;
        }
    </style>
</head>
<body>
    <div class="watch-container">
        @* ── FIX #2: Kiểm tra streamingUrl thay vì mediaFile.FileUrl ── *@
        @if (movie == null || mediaFile == null || string.IsNullOrEmpty(streamingUrl))
        {
            <div class="error-container">
                <div class="error-message">
                    <div class="error-icon">
                        <i class="fas fa-exclamation-circle"></i>
                    </div>
                    <h2>Unable to Load Video</h2>
                    <p style="margin-bottom: 20px; color: #b3b3b3;">
                        @(movie == null ? "❌ Movie information not found." : "")
                        @(mediaFile == null || string.IsNullOrEmpty(streamingUrl) ? "❌ Video file not available." : "")
                    </p>
                    <a href="/Movie/Detail/@(movie?.Slug ?? "unknown")" class="btn btn-primary">
                        <i class="fas fa-arrow-left"></i> Back to Detail
                    </a>
                </div>
            </div>
        }
        else
        {
            <!-- Video Player Section -->
            <div class="video-section">
                <div class="video-wrapper">
                    @* ── FIX #2: KHÔNG đặt src ở đây — JS sẽ set sau để tránh lộ URL trong HTML source ── *@
                    <video id="videoPlayer"
                           controls
                           controlsList="nodownload"
                           preload="metadata"
                           poster="@(movie.PosterUrl ?? "")">
                        Your browser does not support the video tag.
                    </video>
                </div>

                @* ── FIX #4: Quality Switcher — chỉ hiển thị nếu có nhiều hơn 1 quality ── *@
                @{
                    var qualitySources = ViewBag.QualitySources as IEnumerable<dynamic>;
                    var qualityList = qualitySources?.ToList();
                }
                @if (qualityList != null && qualityList.Count > 1)
                {
                    <div class="quality-bar">
                        <span class="quality-bar-label"><i class="fas fa-film"></i> Quality:</span>
                        @for (int qi = 0; qi < qualityList.Count; qi++)
                        {
                            var qs = qualityList[qi];
                            <button type="button"
                                    class="quality-btn @(qi == 0 ? "active" : "")"
                                    data-url="@qs.url"
                                    onclick="switchQuality(this)">
                                @qs.quality
                            </button>
                        }
                    </div>
                }
            </div>

            <!-- Movie Info Section -->
            <div class="info-section">

                @* ── FIX #4: Resume Banner ── *@
                <div class="resume-banner" id="resumeBanner">
                    <p>You left off at <span id="resumeTime">—</span></p>
                    <div style="display:flex; gap:8px; align-items:center;">
                        <button class="resume-btn" onclick="resumePlayback()">
                            <i class="fas fa-play"></i> Resume
                        </button>
                        <button class="dismiss-btn" onclick="dismissResume()" title="Dismiss">✕</button>
                    </div>
                </div>

                <h1 class="movie-title">
                    @movie.Title
                    @if (currentEpisode != null)
                    {
                        <span>Episode @currentEpisode.EpisodeNumber</span>
                    }
                </h1>

                <div class="movie-meta">
                    @if (movie.ReleaseYear.HasValue)
                    {
                        <span>@movie.ReleaseYear</span>
                    }
                    <span class="match-score">97% Match</span>
                    <span class="meta-badge">@movie.Type</span>
                    @if (mediaFile.Quality != null)
                    {
                        <span class="meta-badge">@mediaFile.Quality</span>
                    }
                    @if (mediaFile.Language != null)
                    {
                        <span class="meta-badge">@mediaFile.Language</span>
                    }
                </div>

                <div class="action-buttons">
                    <button class="btn btn-primary" onclick="togglePlayPause()">
                        <i class="fas fa-play" id="playIcon"></i>
                        <span id="playLabel">Play</span>
                    </button>
                    <a href="#" class="btn btn-secondary">
                        <i class="fas fa-plus"></i> Add to List
                    </a>
                    <a href="#" class="btn btn-secondary">
                        <i class="fas fa-thumbs-up"></i> Like
                    </a>
                </div>

                @if (!string.IsNullOrEmpty(movie.Description))
                {
                    <div class="movie-description">
                        @movie.Description
                    </div>
                }

                <!-- Episodes List -->
                @if (episodes != null && episodes.Any())
                {
                    <div class="episodes-section">
                        <div class="section-header">
                            <h2 class="section-title">
                                <i class="fas fa-list"></i>
                                Episodes
                            </h2>
                            <span class="episode-count">@episodes.Count episodes</span>
                        </div>

                        <div class="episodes-grid">
                            @foreach (var episode in episodes)
                            {
                                var isActive = currentEpisode != null && episode.Id == currentEpisode.Id;
                                var episodeUrl = $"/Movie/Watch/{movie.Slug}?ep={episode.EpisodeNumber}";

                                <a href="@episodeUrl" class="episode-card @(isActive ? "active" : "")">
                                    <div class="episode-thumbnail">
                                        <i class="fas fa-play-circle"></i>
                                        @if (episode.DurationMinutes.HasValue)
                                        {
                                            <span class="episode-badge">@episode.DurationMinutes min</span>
                                        }
                                        @* ── FIX #4: Progress bar cho tập đang xem ── *@
                                        @if (isActive)
                                        {
                                            <div class="ep-progress" id="epProgressBar"></div>
                                        }
                                    </div>
                                    <div class="episode-info">
                                        <div class="episode-number">Episode @episode.EpisodeNumber</div>
                                        <div class="episode-title">@episode.Title</div>
                                        <div class="episode-duration">
                                            <i class="far fa-clock"></i>
                                            @(episode.DurationMinutes.HasValue ? $"{episode.DurationMinutes} min" : "Duration N/A")
                                        </div>
                                    </div>
                                </a>
                            }
                        </div>
                    </div>
                }

                <!-- Back Button -->
                <div style="margin-top: 50px;">
                    <a href="/Movie/Detail/@movie.Slug" class="btn btn-secondary">
                        <i class="fas fa-arrow-left"></i> Back to Detail
                    </a>
                </div>
            </div>
        }
    </div>

    <!-- Next Episode Hint -->
    @if (currentEpisode != null && episodes != null)
    {
        var nextEpisode = episodes.FirstOrDefault(e => e.EpisodeNumber == (currentEpisode.EpisodeNumber + 1));
        if (nextEpisode != null)
        {
            <div class="next-episode-hint" id="nextEpisodeHint" style="display: none;">
                <h4>Up next: Episode @nextEpisode.EpisodeNumber</h4>
                <p>@nextEpisode.Title</p>
                <a href="/Movie/Watch/@movie?.Slug?ep=@nextEpisode.EpisodeNumber"
                   class="btn btn-primary"
                   style="padding: 8px 16px; font-size: 0.9rem; margin-top: 10px;">
                    <i class="fas fa-play"></i> Play Next Episode
                </a>
            </div>
        }
    }

    <script>
        // ══════════════════════════════════════════
        // CONFIG — inject server-side, không để raw URL trong HTML attribute
        // ══════════════════════════════════════════
        const STREAMING_URL = '@Html.Raw(streamingUrl ?? "")';
        const MOVIE_ID      = '@Html.Raw(movieId?.ToString() ?? "")';
        const EPISODE_ID    = '@Html.Raw(episodeId?.ToString() ?? "")';

        // ══════════════════════════════════════════
        // FIX #2: Set video src qua JS — URL không xuất hiện trong HTML source
        // ══════════════════════════════════════════
        const video = document.getElementById('videoPlayer');
        let savedTime = 0;

        if (video && STREAMING_URL) {
            video.src = STREAMING_URL;

            // ── FIX #4: Load saved progress từ Session ──
            if (MOVIE_ID) {
                const epParam = EPISODE_ID ? `&episodeId=${EPISODE_ID}` : '';
                fetch(`/Stream/GetProgress?movieId=${MOVIE_ID}${epParam}`)
                    .then(r => r.json())
                    .then(data => {
                        if (data.success && data.currentTime > 10) {
                            savedTime = data.currentTime;
                            const mins = Math.floor(savedTime / 60);
                            const secs = Math.floor(savedTime % 60);
                            document.getElementById('resumeTime').textContent =
                                `${mins}:${secs.toString().padStart(2, '0')}`;
                            document.getElementById('resumeBanner').classList.add('visible');
                        }
                    })
                    .catch(() => {});
            }

            // ── Video Events (giữ nguyên từ code gốc + bổ sung) ──
            video.addEventListener('loadedmetadata', function () {
                console.log('✅ Video metadata loaded');
                console.log('Duration:', video.duration);
                console.log('Video size:', video.videoWidth, 'x', video.videoHeight);
            });

            video.addEventListener('error', function (e) {
                console.error('❌ Video error:', e);
                console.error('Error code:', video.error?.code);
                console.error('Error message:', video.error?.message);
            });

            video.addEventListener('canplay', function () {
                console.log('✅ Video can play');
            });

            video.addEventListener('waiting', function () {
                console.log('⏳ Video buffering...');
            });

            video.addEventListener('playing', function () {
                console.log('▶️ Video playing');
                document.getElementById('playIcon').className = 'fas fa-pause';
                document.getElementById('playLabel').textContent = 'Pause';
            });

            video.addEventListener('pause', function () {
                console.log('⏸️ Video paused');
                document.getElementById('playIcon').className = 'fas fa-play';
                document.getElementById('playLabel').textContent = 'Play';
            });

            video.addEventListener('ended', function () {
                console.log('🏁 Video ended');
                saveProgress();
                const nextHint = document.getElementById('nextEpisodeHint');
                if (nextHint) {
                    nextHint.style.display = 'block';
                    setTimeout(() => { nextHint.style.display = 'none'; }, 10000);
                }
            });

            // ── FIX #4: Cập nhật episode progress bar + lưu progress mỗi 5s ──
            let saveTimer;
            video.addEventListener('timeupdate', function () {
                const epBar = document.getElementById('epProgressBar');
                if (epBar && video.duration > 0) {
                    epBar.style.width = ((video.currentTime / video.duration) * 100) + '%';
                }
                clearTimeout(saveTimer);
                saveTimer = setTimeout(saveProgress, 5000);
            });

            // ── Keyboard controls (giữ nguyên + bổ sung Arrow không cần Ctrl) ──
            document.addEventListener('keydown', function (e) {
                if (['INPUT', 'TEXTAREA'].includes(document.activeElement?.tagName)) return;
                if (e.code === 'Space') {
                    e.preventDefault();
                    togglePlayPause();
                } else if (e.code === 'ArrowRight') {
                    video.currentTime += 10;
                } else if (e.code === 'ArrowLeft') {
                    video.currentTime -= 10;
                } else if (e.code === 'ArrowUp') {
                    video.volume = Math.min(1, video.volume + 0.1);
                } else if (e.code === 'ArrowDown') {
                    video.volume = Math.max(0, video.volume - 0.1);
                } else if (e.code === 'KeyF') {
                    toggleFullScreen();
                } else if (e.code === 'KeyM') {
                    video.muted = !video.muted;
                }
            });

            // Double click to fullscreen
            video.addEventListener('dblclick', toggleFullScreen);

            // Handle visibility change (giữ nguyên)
            document.addEventListener('visibilitychange', function () {
                if (document.hidden && !video.paused) {
                    console.log('👋 Page hidden, pausing video');
                    video.pause();
                    saveProgress();
                }
            });

        } else {
            console.error('❌ Video element or streaming URL not found!');
        }

        // ══════════════════════════════════════════
        // FUNCTIONS
        // ══════════════════════════════════════════
        function togglePlayPause() {
            if (!video) return;
            video.paused ? video.play() : video.pause();
        }

        function toggleFullScreen() {
            if (!video) return;
            document.fullscreenElement
                ? document.exitFullscreen()
                : video.requestFullscreen();
        }

        // ── FIX #4: Lưu progress lên /Stream/Progress ──
        function saveProgress() {
            if (!video || !video.duration || video.currentTime < 5 || !MOVIE_ID) return;
            const pct = (video.currentTime / video.duration) * 100;
            if (pct > 97) return; // Xem gần xong, không cần lưu
            fetch('/Stream/Progress', {
                method: 'POST',
                headers: { 'Content-Type': 'application/json' },
                body: JSON.stringify({
                    movieId:     MOVIE_ID,
                    episodeId:   EPISODE_ID || null,
                    currentTime: video.currentTime,
                    duration:    video.duration
                })
            }).catch(() => {});
        }

        // ── FIX #4: Resume từ vị trí đã lưu ──
        function resumePlayback() {
            if (!video || savedTime <= 0) return;
            video.currentTime = savedTime;
            video.play();
            document.getElementById('resumeBanner').classList.remove('visible');
        }

        function dismissResume() {
            document.getElementById('resumeBanner').classList.remove('visible');
        }

        // ── FIX #4: Đổi quality, giữ nguyên thời gian xem ──
        function switchQuality(btn) {
            if (!video || !btn.dataset.url) return;
            const currentTime = video.currentTime;
            const wasPaused   = video.paused;

            document.querySelectorAll('.quality-btn').forEach(b => b.classList.remove('active'));
            btn.classList.add('active');

            video.src = btn.dataset.url;
            video.load();
            video.currentTime = currentTime;
            if (!wasPaused) video.play();
        }
    </script>
</body>
</html>