@{
    ViewData["Title"] = "Watch Movie";
    Layout = "_LayoutUser";

    var movie = ViewBag.Movie as FinalCuongFilm.Common.DTOs.MovieDto;
    var mediaFile = ViewBag.MediaFile as FinalCuongFilm.Common.DTOs.MediaFileDto;
    var currentEpisode = ViewBag.CurrentEpisode as FinalCuongFilm.Common.DTOs.EpisodeDto;
    var episodes = ViewBag.Episodes as List<FinalCuongFilm.Common.DTOs.EpisodeDto>;
}

<!DOCTYPE html>
<html>
<head>
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.0.0/css/all.min.css">
    <style>
        * {
            margin: 0;
            padding: 0;
            box-sizing: border-box;
        }

        body {
            background: #0f0f0f;
            color: #fff;
            font-family: -apple-system, BlinkMacSystemFont, 'Segoe UI', Roboto, 'Helvetica Neue', Arial, sans-serif;
            line-height: 1.6;
        }

        /* Netflix-style Scrollbar */
        ::-webkit-scrollbar {
            width: 10px;
            height: 10px;
        }

        ::-webkit-scrollbar-track {
            background: #1a1a1a;
        }

        ::-webkit-scrollbar-thumb {
            background: #404040;
            border-radius: 5px;
        }

            ::-webkit-scrollbar-thumb:hover {
                background: #4d4d4d;
            }

        /* Video Player Section - Netflix Style */
        .video-section {
            background: #000;
            position: relative;
            width: 100%;
        }

        .video-wrapper {
            position: relative;
            width: 100%;
            background: #000;
            cursor: pointer;
        }

        video {
            width: 100%;
            height: auto;
            max-height: 80vh;
            display: block;
            outline: none;
        }

        /* Custom Video Controls (Netflix Style) */
        .video-controls-overlay {
            position: absolute;
            bottom: 0;
            left: 0;
            right: 0;
            background: linear-gradient(transparent, rgba(0,0,0,0.9));
            padding: 20px;
            opacity: 0;
            transition: opacity 0.3s;
            pointer-events: none;
        }

        .video-wrapper:hover .video-controls-overlay {
            opacity: 1;
            pointer-events: auto;
        }

        /* Info Section - Netflix Style */
        .info-section {
            max-width: 1400px;
            margin: 0 auto;
            padding: 30px 4%;
        }

        .movie-title {
            font-size: 2.5rem;
            font-weight: 700;
            margin-bottom: 15px;
            letter-spacing: -0.5px;
        }

            .movie-title span {
                font-size: 1.5rem;
                color: #b3b3b3;
                font-weight: 400;
            }

        .movie-meta {
            display: flex;
            align-items: center;
            gap: 15px;
            color: #b3b3b3;
            font-size: 1rem;
            margin-bottom: 20px;
            flex-wrap: wrap;
        }

        .meta-badge {
            background: rgba(255,255,255,0.1);
            padding: 4px 10px;
            border-radius: 4px;
            font-size: 0.9rem;
        }

        .match-score {
            color: #46d369;
            font-weight: 600;
        }

        .movie-description {
            color: #b3b3b3;
            line-height: 1.8;
            margin-bottom: 30px;
            max-width: 800px;
            font-size: 1.1rem;
        }

        /* Action Buttons - Netflix Style */
        .action-buttons {
            display: flex;
            gap: 15px;
            margin-bottom: 40px;
            flex-wrap: wrap;
        }

        .btn {
            display: inline-flex;
            align-items: center;
            gap: 10px;
            padding: 12px 30px;
            border-radius: 4px;
            font-weight: 600;
            font-size: 1.1rem;
            text-decoration: none;
            transition: all 0.2s;
            border: none;
            cursor: pointer;
        }

        .btn-primary {
            background: #e50914;
            color: #fff;
        }

            .btn-primary:hover {
                background: #f40612;
                transform: scale(1.05);
            }

        .btn-secondary {
            background: rgba(255,255,255,0.1);
            color: #fff;
            backdrop-filter: blur(5px);
        }

            .btn-secondary:hover {
                background: rgba(255,255,255,0.2);
                transform: scale(1.05);
            }

        /* Episodes Section - Netflix Style */
        .episodes-section {
            margin-top: 50px;
        }

        .section-header {
            display: flex;
            align-items: center;
            justify-content: space-between;
            margin-bottom: 25px;
            flex-wrap: wrap;
            gap: 15px;
        }

        .section-title {
            font-size: 1.8rem;
            font-weight: 600;
            color: #fff;
            display: flex;
            align-items: center;
            gap: 10px;
        }

        .episode-count {
            color: #b3b3b3;
            font-size: 1.2rem;
            font-weight: 400;
        }

        .episodes-grid {
            display: grid;
            grid-template-columns: repeat(auto-fill, minmax(300px, 1fr));
            gap: 25px;
        }

        .episode-card {
            background: linear-gradient(to bottom, #1f1f1f, #171717);
            border-radius: 8px;
            overflow: hidden;
            transition: all 0.3s cubic-bezier(0.5, 1, 0.89, 1);
            text-decoration: none;
            color: white;
            position: relative;
            border: 2px solid transparent;
        }

            .episode-card:hover {
                transform: scale(1.05) translateY(-10px);
                box-shadow: 0 20px 40px rgba(0,0,0,0.5);
                z-index: 10;
            }

            .episode-card.active {
                border-color: #e50914;
                box-shadow: 0 0 20px rgba(229, 9, 20, 0.3);
            }

        .episode-thumbnail {
            position: relative;
            width: 100%;
            aspect-ratio: 16/9;
            background: #2a2a2a;
            overflow: hidden;
        }

            .episode-thumbnail img {
                width: 100%;
                height: 100%;
                object-fit: cover;
                transition: transform 0.3s;
            }

        .episode-card:hover .episode-thumbnail img {
            transform: scale(1.1);
        }

        .episode-thumbnail i {
            font-size: 4rem;
            color: #404040;
            display: flex;
            align-items: center;
            justify-content: center;
            height: 100%;
        }

        .episode-badge {
            position: absolute;
            top: 10px;
            right: 10px;
            background: rgba(0,0,0,0.8);
            color: #fff;
            padding: 4px 8px;
            border-radius: 4px;
            font-size: 0.8rem;
            font-weight: 600;
        }

        .episode-info {
            padding: 18px;
        }

        .episode-number {
            color: #e50914;
            font-size: 0.9rem;
            font-weight: 600;
            margin-bottom: 8px;
            text-transform: uppercase;
            letter-spacing: 0.5px;
        }

        .episode-title {
            font-size: 1.2rem;
            font-weight: 600;
            margin-bottom: 10px;
            line-height: 1.4;
        }

        .episode-duration {
            color: #b3b3b3;
            font-size: 0.9rem;
            display: flex;
            align-items: center;
            gap: 5px;
        }

        /* Loading State */
        .loading {
            text-align: center;
            padding: 60px;
        }

        .spinner {
            width: 50px;
            height: 50px;
            border: 3px solid #333;
            border-top-color: #e50914;
            border-radius: 50%;
            animation: spin 1s linear infinite;
            margin: 0 auto 20px;
        }

        @@keyframes spin {
            to

        {
            transform: rotate(360deg);
        }

        }

        /* Error Message */
        .error-container {
            min-height: 60vh;
            display: flex;
            align-items: center;
            justify-content: center;
            padding: 20px;
        }

        .error-message {
            background: linear-gradient(135deg, rgba(229, 9, 20, 0.1), rgba(229, 9, 20, 0.05));
            border: 1px solid rgba(229, 9, 20, 0.3);
            padding: 40px;
            border-radius: 12px;
            color: #fff;
            max-width: 500px;
            text-align: center;
            backdrop-filter: blur(10px);
        }

            .error-message h2 {
                color: #e50914;
                margin-bottom: 20px;
                font-size: 2rem;
            }

        .error-icon {
            font-size: 5rem;
            margin-bottom: 20px;
            color: #e50914;
        }

        /* Responsive */
        @@media (max-width: 768px) {
            .movie-title

        {
            font-size: 1.8rem;
        }

        .movie-title span {
            font-size: 1.2rem;
        }

        .section-title {
            font-size: 1.5rem;
        }

        .episodes-grid {
            grid-template-columns: 1fr;
        }

        .btn {
            padding: 10px 20px;
            font-size: 1rem;
        }

        }

        /* Progress Bar - Netflix Style */
        .progress-bar {
            height: 3px;
            background: rgba(255,255,255,0.2);
            position: relative;
            cursor: pointer;
        }

        .progress-fill {
            height: 100%;
            background: #e50914;
            width: 0;
            transition: width 0.1s;
        }

        /* Volume Control */
        .volume-control {
            display: flex;
            align-items: center;
            gap: 10px;
        }

        .volume-slider {
            width: 80px;
            height: 3px;
            background: rgba(255,255,255,0.2);
            border-radius: 2px;
            position: relative;
            cursor: pointer;
        }

        .volume-fill {
            height: 100%;
            background: #fff;
            width: 100%;
            border-radius: 2px;
        }

        /* Next Episode Hint */
        .next-episode-hint {
            position: fixed;
            bottom: 20px;
            right: 20px;
            background: rgba(0,0,0,0.9);
            border-left: 3px solid #e50914;
            padding: 15px;
            border-radius: 4px;
            max-width: 300px;
            animation: slideIn 0.3s;
            z-index: 1000;
        }

        @@keyframes slideIn {
            from

        {
            transform: translateX(100%);
            opacity: 0;
        }

        to {
            transform: translateX(0);
            opacity: 1;
        }

        }

        .next-episode-hint h4 {
            color: #fff;
            margin-bottom: 5px;
            font-size: 1rem;
        }

        .next-episode-hint p {
            color: #b3b3b3;
            font-size: 0.9rem;
        }
    </style>
</head>
<body>
    <div class="watch-container">
        @if (movie == null || mediaFile == null)
        {
            <div class="error-container">
                <div class="error-message">
                    <div class="error-icon">
                        <i class="fas fa-exclamation-circle"></i>
                    </div>
                    <h2>Không thể tải video</h2>
                    <p style="margin-bottom: 20px; color: #b3b3b3;">
                        @(movie == null ? "❌ Không tìm thấy thông tin phim" : "")
                        @(mediaFile == null ? "❌ Không tìm thấy file video" : "")
                    </p>
                    <a href="/Movie/Detail/@(movie?.Slug ?? "unknown")" class="btn btn-primary">
                        <i class="fas fa-arrow-left"></i> Quay lại trang chi tiết
                    </a>
                </div>
            </div>
        }
        else
        {
            <!-- Video Player Section -->
            <div class="video-section">
                <div class="video-wrapper">
                    <video id="videoPlayer" controls controlsList="nodownload" preload="metadata" poster="@(movie.PosterUrl ?? "")">
                        <source src="@mediaFile.FileUrl" type="video/mp4">
                        Your browser does not support the video tag.
                    </video>
                </div>
            </div>

            <!-- Movie Info Section -->
            <div class="info-section">
                <h1 class="movie-title">
                    @movie.Title
                    @if (currentEpisode != null)
                    {
                        <span>Tập @currentEpisode.EpisodeNumber</span>
                    }
                </h1>

                <div class="movie-meta">
                    @if (movie.ReleaseYear.HasValue)
                    {
                        <span>@movie.ReleaseYear</span>
                    }
                    <span class="match-score">97% Match</span>
                    <span class="meta-badge">@movie.Type</span>
                    @if (mediaFile.Quality != null)
                    {
                        <span class="meta-badge">@mediaFile.Quality</span>
                    }
                    @if (mediaFile.Language != null)
                    {
                        <span class="meta-badge">@mediaFile.Language</span>
                    }
                </div>

                <div class="action-buttons">
                    <a href="#" class="btn btn-primary" onclick="togglePlayPause()">
                        <i class="fas fa-play"></i> Phát
                    </a>
                    <a href="#" class="btn btn-secondary">
                        <i class="fas fa-plus"></i> Thêm vào danh sách
                    </a>
                    <a href="#" class="btn btn-secondary">
                        <i class="fas fa-thumbs-up"></i> Thích
                    </a>
                </div>

                @if (!string.IsNullOrEmpty(movie.Description))
                {
                    <div class="movie-description">
                        @movie.Description
                    </div>
                }

                <!-- Episodes List -->
                @if (episodes != null && episodes.Any())
                {
                    <div class="episodes-section">
                        <div class="section-header">
                            <h2 class="section-title">
                                <i class="fas fa-list"></i>
                                Tập phim
                            </h2>
                            <span class="episode-count">@episodes.Count tập</span>
                        </div>

                        <div class="episodes-grid">
                            @foreach (var episode in episodes)
                            {
                                var isActive = currentEpisode != null && episode.Id == currentEpisode.Id;
                                var episodeUrl = $"/Movie/Watch/{movie.Slug}?ep={episode.EpisodeNumber}";

                                <a href="@episodeUrl" class="episode-card @(isActive ? "active" : "")">
                                    <div class="episode-thumbnail">
                                        <i class="fas fa-play-circle"></i>
                                        @if (episode.DurationMinutes.HasValue)
                                        {
                                            <span class="episode-badge">@episode.DurationMinutes phút</span>
                                        }
                                    </div>
                                    <div class="episode-info">
                                        <div class="episode-number">Tập @episode.EpisodeNumber</div>
                                        <div class="episode-title">@episode.Title</div>
                                        <div class="episode-duration">
                                            <i class="far fa-clock"></i>
                                            @(episode.DurationMinutes.HasValue ? $"{episode.DurationMinutes} phút" : "Chưa có thời lượng")
                                        </div>
                                    </div>
                                </a>
                            }
                        </div>
                    </div>
                }

                <!-- Back Button -->
                <div style="margin-top: 50px;">
                    <a href="/Movie/Detail/@movie.Slug" class="btn btn-secondary">
                        <i class="fas fa-arrow-left"></i> Quay lại trang chi tiết
                    </a>
                </div>
            </div>
        }
    </div>

    <!-- Next Episode Hint (Optional) -->
    @if (currentEpisode != null && episodes != null)
    {
        var nextEpisode = episodes.FirstOrDefault(e => e.EpisodeNumber == (currentEpisode.EpisodeNumber + 1));
        if (nextEpisode != null)
        {
            <div class="next-episode-hint" id="nextEpisodeHint" style="display: none;">
                <h4>Tiếp theo: Tập @nextEpisode.EpisodeNumber</h4>
                <p>@nextEpisode.Title</p>
                <a href="/Movie/Watch/@movie.Slug?ep=@nextEpisode.EpisodeNumber" class="btn btn-primary" style="padding: 8px 16px; font-size: 0.9rem; margin-top: 10px;">
                    <i class="fas fa-play"></i> Phát tập tiếp theo
                </a>
            </div>
        }
    }

    <script>
        console.log('=== WATCH PAGE LOADED ===');
        console.log('Movie:', '@(movie?.Title ?? "NULL")');
        console.log('Media File:', '@(mediaFile?.FileName ?? "NULL")');
        console.log('Video URL:', '@(mediaFile?.FileUrl ?? "NULL")');
        console.log('Current Episode:', '@(currentEpisode?.EpisodeNumber ?? 0)');

        const video = document.getElementById('videoPlayer');

        if (video) {
            // Video Events
            video.addEventListener('loadedmetadata', function() {
                console.log(' Video metadata loaded');
                console.log('Duration:', video.duration);
                console.log('Video size:', video.videoWidth, 'x', video.videoHeight);
            });

            video.addEventListener('error', function(e) {
                console.error('❌ Video error:', e);
                console.error('Error code:', video.error?.code);
                console.error('Error message:', video.error?.message);
            });

            video.addEventListener('canplay', function() {
                console.log(' Video can play');
            });

            video.addEventListener('waiting', function() {
                console.log('⏳ Video buffering...');
            });

            video.addEventListener('playing', function() {
                console.log('▶️ Video playing');
            });

            video.addEventListener('pause', function() {
                console.log('⏸️ Video paused');
            });

            video.addEventListener('ended', function() {
                console.log('🏁 Video ended');
                // Show next episode hint
                const nextHint = document.getElementById('nextEpisodeHint');
                if (nextHint) {
                    nextHint.style.display = 'block';
                    setTimeout(() => {
                        nextHint.style.display = 'none';
                    }, 10000);
                }
            });

            // Keyboard controls
            document.addEventListener('keydown', function(e) {
                if (e.code === 'Space' && document.activeElement?.tagName !== 'INPUT') {
                    e.preventDefault();
                    togglePlayPause();
                } else if (e.code === 'ArrowRight' && e.ctrlKey) {
                    video.currentTime += 10;
                } else if (e.code === 'ArrowLeft' && e.ctrlKey) {
                    video.currentTime -= 10;
                } else if (e.code === 'KeyF') {
                    toggleFullScreen();
                }
            });

            // Double click to fullscreen
            video.addEventListener('dblclick', toggleFullScreen);
        } else {
            console.error('❌ Video element not found!');
        }

        // Helper functions
        function togglePlayPause() {
            if (video) {
                if (video.paused) {
                    video.play();
                } else {
                    video.pause();
                }
            }
        }

        function toggleFullScreen() {
            if (video) {
                if (document.fullscreenElement) {
                    document.exitFullscreen();
                } else {
                    video.requestFullscreen();
                }
            }
        }

        // Save watch progress
        if (video) {
            let saveTimeout;
            video.addEventListener('timeupdate', function() {
                clearTimeout(saveTimeout);
                saveTimeout = setTimeout(() => {
                    const progress = (video.currentTime / video.duration) * 100;
                    if (progress > 5 && progress < 95) {
                        console.log('📊 Saving progress:', Math.round(progress) + '%');
                        // Here you can add API call to save progress
                    }
                }, 3000);
            });
        }

        // Handle visibility change
        document.addEventListener('visibilitychange', function() {
            if (document.hidden && video && !video.paused) {
                console.log('👋 Page hidden, pausing video');
                video.pause();
            }
        });

        
    </script>
</body>
</html>