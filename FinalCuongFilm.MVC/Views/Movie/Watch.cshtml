@using FinalCuongFilm.ApplicationCore.Entities
@using System.Security.Claims
@using FinalCuongFilm.ApplicationCore.Entities.Identity
@using Microsoft.AspNetCore.Identity
@model FinalCuongFilm.MVC.Models.ViewModels.MovieWatchViewModel
@using static FinalCuongFilm.ApplicationCore.Entities.Enum
@inject FinalCuongFilm.Service.Interfaces.IVipService VipService
@inject UserManager<CuongFilmUser> UserManager

@{
    ViewData["Title"] = "Watch " + Model.Movie.Title;
    Layout = "_LayoutUser";

    var userId = User.FindFirstValue(ClaimTypes.NameIdentifier);
    bool isVip = userId != null && await VipService.HasActiveVipAsync(userId);

    // ĐỒNG BỘ LOGIC AVATAR/NAME TỪ LAYOUT USER
    string currentUserName = User.Identity?.Name ?? "Unknown";
    string currentUserAvatar = "/img/avatar.jpg";

    if (User.Identity?.IsAuthenticated == true)
    {
        var currentUser = await UserManager.GetUserAsync(User);
        if (currentUser != null)
        {
            if (!string.IsNullOrEmpty(currentUser.AvatarUrl))
            {
                currentUserAvatar = currentUser.AvatarUrl;
            }
            currentUserName = !string.IsNullOrEmpty(currentUser.FullName) ? currentUser.FullName : currentUser.UserName;
        }
    }

    var currentEpisode = Model.CurrentEpisode;
    var episodes = Model.Episodes ?? new List<FinalCuongFilm.Common.DTOs.EpisodeDto>();
    var mediaFile = Model.MediaFiles?.FirstOrDefault();

    var isFavorited = ViewBag.IsFavorited != null ? (bool)ViewBag.IsFavorited : false;
    var actors = ViewBag.Actors as IEnumerable<FinalCuongFilm.Common.DTOs.ActorDto> ?? new List<FinalCuongFilm.Common.DTOs.ActorDto>();
    var streamingUrl = ViewBag.StreamingUrl as string ?? "";
    var subtitles = ViewBag.SubtitleFiles as IEnumerable<dynamic>;

    // Khai báo biến cho phần Review
    var reviews = ViewBag.Reviews as IEnumerable<FinalCuongFilm.Common.DTOs.ReviewDto> ?? new List<FinalCuongFilm.Common.DTOs.ReviewDto>();

    var currentUrl = Url.Action("Watch", "Movie", new { slug = Model.Movie?.Slug, ep = currentEpisode?.EpisodeNumber });
    var isVideoAvailable = Model.Movie != null && mediaFile != null && !string.IsNullOrEmpty(streamingUrl);
    var isHlsStream = streamingUrl.Contains(".m3u8");
}

<link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.0.0/css/all.min.css" />
<link rel="stylesheet" href="https://cdn.plyr.io/3.7.8/plyr.css" />
<link href="https://fonts.cdnfonts.com/css/netflix-sans" rel="stylesheet" />

<style>
    :root {
        --netflix-red: #e50914;
        --netflix-black: #141414;
        --netflix-dark: #181818;
        --netflix-text: #ffffff;
        --netflix-text-secondary: #a3a3a3;
        --bg-card: #1a1a1a;
        --bg-hover: #2a2a2a;
        --border-color: #303030;
        --accent-yellow: #f5c518;
        --transition: all 0.2s ease;
    }

    /* ---------------- PLAYER & INFO ---------------- */
    .cinema-section {
        position: relative;
        width: 100%;
        background-color: #000;
        border-bottom: 1px solid #333;
    }

    .cinema-screen-wrapper {
        position: relative;
        width: 100%;
        max-width: 1400px;
        margin: 0 auto;
    }

    .cinema-screen {
        position: relative;
        width: 100%;
        background: #000;
        overflow: hidden;
    }

    .plyr {
        width: 100%;
        --plyr-color-main: var(--netflix-red);
        --plyr-video-background: #000;
        --plyr-menu-background: rgba(20, 20, 20, 0.95);
        --plyr-menu-color: #fff;
        --plyr-control-radius: 4px;
    }

        .plyr video {
            aspect-ratio: 16 / 9;
            width: 100%;
            max-height: 80vh;
            object-fit: contain;
        }

    .cinema-top-bar {
        position: absolute;
        top: 0;
        left: 0;
        right: 0;
        padding: 20px 30px;
        background: linear-gradient(180deg, rgba(0,0,0,0.9) 0%, transparent 100%);
        z-index: 20;
        display: flex;
        align-items: center;
        opacity: 0;
        transition: opacity 0.3s;
        pointer-events: none;
    }

    .cinema-screen:hover .cinema-top-bar, .plyr.plyr--paused .cinema-top-bar {
        opacity: 1;
        pointer-events: auto;
    }

    .cinema-back-btn {
        background: transparent;
        border: none;
        color: #fff;
        width: 40px;
        height: 40px;
        border-radius: 50%;
        cursor: pointer;
        margin-right: 20px;
        transition: var(--transition);
    }

    .cinema-title h2 {
        font-size: 1.3rem;
        font-weight: 500;
    }

    .info-section {
        max-width: 1400px;
        margin: 0 auto;
        padding: 30px 40px;
    }

    .movie-title {
        font-size: 2.5rem;
        font-weight: 700;
        margin-bottom: 10px;
        display: flex;
        gap: 15px;
    }

    .movie-meta {
        display: flex;
        gap: 12px;
        margin-bottom: 20px;
    }

    .meta-badge {
        background: rgba(255,255,255,0.1);
        padding: 4px 10px;
        border-radius: 4px;
        font-size: 0.85rem;
        border: 1px solid #333;
    }

    .action-buttons {
        display: flex;
        gap: 15px;
        margin-bottom: 30px;
    }

    .btn-action {
        background: rgba(255,255,255,0.1);
        color: white;
        padding: 10px 24px;
        border-radius: 6px;
        font-weight: 600;
        border: none;
        display: inline-flex;
        align-items: center;
        gap: 10px;
        cursor: pointer;
        text-decoration: none;
        transition: var(--transition);
    }

        .btn-action:hover {
            background: rgba(255,255,255,0.2);
            transform: translateY(-2px);
        }

        .btn-action.active {
            color: var(--netflix-red);
            background: rgba(229, 9, 20, 0.1);
            border: 1px solid var(--netflix-red);
        }

    .movie-description {
        color: #b3b3b3;
        max-width: 900px;
        margin-bottom: 40px;
    }

    /* ---------------- GIAO DIỆN BÌNH LUẬN CHỈ TEXT ---------------- */
    .review-box {
        background: var(--bg-card);
        border: 1px solid var(--border-color);
        border-radius: 12px;
        padding: 2rem;
        margin-bottom: 2rem;
    }

    .section-title {
        font-size: 1.4rem;
        font-weight: 600;
        margin-bottom: 20px;
        display: flex;
        align-items: center;
        gap: 10px;
    }

    .review-textarea {
        width: 100%;
        background: rgba(255,255,255,0.03);
        border: 1px solid var(--border-color);
        border-radius: 8px;
        color: var(--netflix-text);
        padding: 1.2rem;
        font-size: 1rem;
        resize: vertical;
        margin-bottom: 0.5rem;
        transition: all 0.3s;
    }

        .review-textarea:focus {
            outline: none;
            border-color: var(--netflix-red);
            background: rgba(255,255,255,0.06);
        }

    .btn-submit-review {
        background: var(--netflix-red);
        color: white;
        padding: 0.6rem 1.5rem;
        border: none;
        border-radius: 6px;
        font-weight: 600;
        cursor: pointer;
        transition: all 0.2s;
        display: inline-flex;
        align-items: center;
        gap: 0.5rem;
        z-index: 10;
        position: relative;
    }

        .btn-submit-review:hover {
            background: #f40612;
        }

    .reviews-list {
        display: flex;
        flex-direction: column;
        gap: 1.2rem;
    }

    .review-item {
        background: rgba(255,255,255,0.02);
        border: 1px solid var(--border-color);
        border-radius: 12px;
        padding: 1.5rem;
        transition: all 0.3s;
        margin-bottom: 1rem;
    }

    .review-header {
        display: flex;
        justify-content: space-between;
        align-items: flex-start;
        margin-bottom: 1rem;
    }

    .review-author {
        display: flex;
        align-items: center;
        gap: 1rem;
    }

    /* Chỉnh sửa hiển thị Avatar ảnh/text */
    .author-avatar {
        width: 45px;
        height: 45px;
        border-radius: 50%;
        background: linear-gradient(135deg, var(--netflix-red), #ff4b4b);
        display: flex;
        align-items: center;
        justify-content: center;
        font-weight: 700;
        font-size: 1.2rem;
        color: #fff;
        overflow: hidden;
        border: 1px solid rgba(255,255,255,0.1);
    }

        .author-avatar img {
            width: 100%;
            height: 100%;
            object-fit: cover;
        }

    .author-info h4 {
        font-size: 1.05rem;
        font-weight: 700;
        margin-bottom: 0;
        display: flex;
        align-items: center;
    }

    .review-date {
        font-size: 0.9rem;
        color: var(--netflix-text-secondary);
    }

    .review-content {
        color: #e0e0e0;
        line-height: 1.6;
        font-size: 1rem;
        margin-top: 5px;
    }

    .review-actions {
        display: flex;
        gap: 1.2rem;
        margin-top: 0.8rem;
        padding-top: 0.8rem;
        border-top: 1px solid rgba(255,255,255,0.05);
    }

    .review-action-btn {
        background: none;
        border: none;
        color: var(--netflix-text-secondary);
        font-size: 0.9rem;
        font-weight: 500;
        cursor: pointer;
        transition: all 0.2s;
        display: inline-flex;
        align-items: center;
        gap: 0.3rem;
    }

        .review-action-btn:hover {
            color: var(--text-primary);
        }

    .login-prompt {
        text-align: center;
        padding: 2rem 1rem;
        background: rgba(255,255,255,0.02);
        border-radius: 12px;
        border: 1px dashed var(--border-color);
    }

    /* Toast */
    .toast-notification {
        position: fixed;
        top: 90px;
        right: 20px;
        background: var(--netflix-dark);
        padding: 1rem 1.5rem;
        border-radius: 6px;
        box-shadow: 0 10px 30px rgba(0,0,0,0.5);
        z-index: 9999;
        display: flex;
        align-items: center;
        gap: 1rem;
        border-left: 4px solid var(--netflix-red);
        animation: slideInRight 0.3s ease;
    }

    @@keyframes slideInRight {
        from {
            opacity: 0;
            transform: translateX(120%);
        }

        to {
            opacity: 1;
            transform: translateX(0);
        }
    }

    @@keyframes fadeIn {
        from {
            opacity: 0;
            transform: translateY(-20px);
        }

        to {
            opacity: 1;
            transform: translateY(0);
        }
    }

    @@media (max-width: 768px) {
        .info-section {
            padding: 20px;
        }

        .movie-title {
            font-size: 1.8rem;
            flex-direction: column;
            gap: 5px;
        }
    }
</style>

@if (!isVideoAvailable)
{
    <div class="error-container text-center" style="padding: 120px 20px;">
        <i class="fas fa-video-slash" style="font-size: 4rem; color: var(--netflix-red); margin-bottom: 20px;"></i>
        <h2>Video Unavailable</h2>
        <p style="color: #888; margin: 15px 0 25px;">The video file is currently processing or cannot be found.</p>
        <a href="@Url.Action("Detail", "Movie", new { slug = Model.Movie?.Slug ?? "unknown" })" class="btn-action">Return to Details</a>
    </div>
}
else
{
    <div class="cinema-section">
        <div class="cinema-screen-wrapper">
            <div class="cinema-screen">
                <div class="cinema-top-bar">
                    <button class="cinema-back-btn" onclick="window.location.href='@Url.Action("Detail", "Movie", new { slug = Model.Movie?.Slug })'">
                        <i class="fas fa-arrow-left"></i>
                    </button>
                    <div class="cinema-title">
                        <h2>@Model.Movie.Title</h2>
                        @if (currentEpisode != null)
                        {
                            <span>E @currentEpisode.EpisodeNumber</span>
                        }
                    </div>
                </div>

                <video id="player" playsinline controls crossorigin poster="@(Model.Movie.PosterUrl ?? "")">
                    @if (isHlsStream)
                    {
                        <source src="@streamingUrl" type="application/x-mpegURL" />
                    }
                    else
                    {
                        <source src="@streamingUrl" type="video/mp4" />
                    }

                    @if (subtitles != null)
                    {
                        foreach (var sub in subtitles)
                        {
                            <track kind="captions" label="@sub.label" srclang="@sub.language" src="@sub.url" />
                        }
                    }
                </video>
            </div>
        </div>
    </div>

    <div class="info-section">

        <div class="movie-title">
            @Model.Movie.Title
            @if (currentEpisode != null)
            {
                <span>Episode @currentEpisode.EpisodeNumber</span>
            }
        </div>

        <div class="movie-meta">
            <span class="meta-badge">@Model.Movie.ReleaseYear</span>
            <span class="meta-badge">@Model.Movie.Type</span>
            @if (mediaFile?.Quality != null)
            {
                <span class="meta-badge">@mediaFile.Quality</span>
            }
        </div>

        <div class="action-buttons">
            <a href="@Url.Action("Detail", "Movie", new { slug = Model.Movie.Slug })" class="btn-action">
                <i class="fas fa-info-circle"></i> View Details
            </a>

            @if (User.Identity?.IsAuthenticated == true)
            {
                <button type="button" class="btn-action favorite-toggle-btn @(isFavorited ? "active" : "")" data-movie-id="@Model.Movie.Id">
                    <i class="@(isFavorited ? "fas fa-check" : "fas fa-plus")"></i>
                    <span>@(isFavorited ? "In My List" : "My List")</span>
                </button>
            }

            <button type="button" class="btn-action" onclick="navigator.clipboard.writeText(window.location.href); showToast('Link copied to clipboard!', 'success');">
                <i class="fas fa-share-alt"></i> Share
            </button>
        </div>

        @if (!string.IsNullOrEmpty(Model.Movie.Description))
        {
            <div class="movie-description">@Model.Movie.Description</div>
        }

        <hr style="border-color: #333; margin: 40px 0;" />

        <div class="review-box" id="create-review-section">
            @if (User.Identity?.IsAuthenticated == true)
            {
                <h2 class="section-title"><i class="fas fa-comment-dots text-danger"></i> Leave a Comment</h2>
                <form id="mainCommentForm" method="post">
                    @Html.AntiForgeryToken()
                    <input type="hidden" name="MovieId" value="@Model.Movie.Id" />
                    <input type="hidden" name="Rating" value="5" /> <div class="mb-3">
                        <textarea name="Comment" class="review-textarea" rows="3" placeholder="Share your thoughts about this movie..." required></textarea>
                    </div>

                    <button type="submit" class="btn-submit-review btn-main-submit">
                        <i class="fas fa-paper-plane"></i> Post Comment
                    </button>
                </form>
            }
            else
            {
                <div class="login-prompt">
                    <i class="fas fa-user-lock mb-3 d-block" style="font-size: 3rem;"></i>
                    <p class="mb-3">Sign in to share your thoughts.</p>
                    <a href="/Identity/Account/Login?returnUrl=@Uri.EscapeDataString(currentUrl)" class="btn-submit-review text-decoration-none">
                        <i class="fas fa-sign-in-alt"></i> Sign In
                    </a>
                </div>
            }
        </div>

        <div class="review-box" id="all-reviews-section">
            <h2 class="section-title">
                <i class="fas fa-comments text-danger"></i> Comments (<span id="reviewCount">@(reviews?.Count() ?? 0)</span>)
            </h2>

            <div class="reviews-list" id="reviewsListContainer">
                @if (reviews != null && reviews.Any())
                {
                    // Lọc để lấy comment gốc, phẳng
                    var rootComments = reviews.Where(r => r.GetType().GetProperty("ParentId") == null || r.GetType().GetProperty("ParentId")?.GetValue(r, null) == null).ToList();

                    @foreach (var comment in rootComments)
                    {
                        // Dò Name
                        var rawName = comment.UserName ?? "User";
                        var baseName = rawName.Contains("@") ? rawName.Split('@')[0] : rawName;
                        bool isMyComment = (rawName == User.Identity?.Name || baseName == currentUserName);
                        string displayName = isMyComment ? currentUserName : baseName;

                        // Dò Avatar từ DTO (Dùng reflection nếu backend có gán Avatar)
                        var avatarProp = comment.GetType().GetProperty("AvatarUrl") ?? comment.GetType().GetProperty("Avatar");
                        string dbAvatar = avatarProp?.GetValue(comment, null)?.ToString();

                        // Ép Avatar chuẩn nếu là của mình
                        string displayAvatar = isMyComment && !currentUserAvatar.Contains("avatar.jpg") ? currentUserAvatar : dbAvatar;

                        string[] colors = { "#e50914", "#f5c518", "#3498db", "#2ecc71", "#9b59b6" };
                        string avatarBg = colors[Math.Abs(displayName.GetHashCode()) % colors.Length];

                        <div class="review-item" id="review-@comment.Id" style="@(isMyComment ? "border-color: var(--netflix-red); background: rgba(229, 9, 20, 0.02);" : "")">
                            <div id="display-mode-@comment.Id">
                                <div class="review-header">
                                    <div class="review-author">
                                        <div class="author-avatar" style="background: @avatarBg;">
                                            @if (!string.IsNullOrEmpty(displayAvatar))
                                            {
                                                <img src="@displayAvatar" alt="Avatar" />
                                            }
                                            else
                                            {
                                                @displayName.Substring(0, 1).ToUpper()
                                            }
                                        </div>
                                        <div class="author-info">
                                            <h4>
                                                @displayName
                                                @if (isMyComment)
                                                {
                                                    <span class="badge bg-danger ms-2" style="font-size: 0.7rem;">You</span>
                                                }
                                            </h4>
                                        </div>
                                    </div>
                                    <div class="review-date">@comment.CreatedAt.ToString("MMM dd, yyyy")</div>
                                </div>

                                @if (!string.IsNullOrEmpty(comment.Comment))
                                {
                                    <div class="review-content">@comment.Comment</div>
                                }

                                <div class="review-actions">
                                    @if (isMyComment)
                                    {
                                        <button class="review-action-btn text-primary" onclick="showEditForm('@comment.Id')"><i class="fas fa-edit"></i> Edit</button>
                                        <button class="review-action-btn text-danger ms-3" onclick="deleteReview('@comment.Id')"><i class="fas fa-trash"></i> Delete</button>
                                    }
                                    else
                                    {
                                        <button class="review-action-btn"><i class="far fa-thumbs-up"></i> Helpful</button>
                                        <button class="review-action-btn ms-3"><i class="far fa-flag"></i> Report</button>
                                    }
                                </div>
                            </div>

                            @if (isMyComment)
                            {
                                <div id="edit-mode-@comment.Id" style="display: none;">
                                    <form class="form-edit-review" method="post">
                                        @Html.AntiForgeryToken()
                                        <input type="hidden" name="Id" value="@comment.Id" />
                                        <input type="hidden" name="MovieId" value="@Model.Movie.Id" />
                                        <input type="hidden" name="Rating" value="5" />

                                        <div class="mt-3 mb-3">
                                            <textarea name="Comment" class="review-textarea" rows="2" required>@comment.Comment</textarea>
                                        </div>
                                        <div class="d-flex gap-2">
                                            <button type="submit" class="btn btn-danger px-4 fw-bold">Save</button>
                                            <button type="button" class="btn btn-secondary px-4 fw-bold" onclick="hideEditForm('@comment.Id')">Cancel</button>
                                        </div>
                                    </form>
                                </div>
                            }
                        </div>
                    }
                }
                else
                {
                    <div id="no-reviews-msg" class="text-center text-secondary py-4">
                        <i class="fas fa-comment-slash fs-1 mb-3"></i>
                        <p>No comments yet. Be the first to share your thoughts!</p>
                    </div>
                }
            </div>
        </div>

    </div>
}

@section Scripts {
    <script src="https://cdn.jsdelivr.net/npm/hls.js@latest"></script>
    <script src="https://cdn.plyr.io/3.7.8/plyr.polyfilled.js"></script>

    <script>
        const STREAMING_URL = '@Html.Raw(streamingUrl ?? "")';
        const currentUserName = '@Html.Raw(currentUserName)';
        const currentUserAvatar = '@Html.Raw(currentUserAvatar)';

        document.addEventListener("DOMContentLoaded", () => {
            const video = document.getElementById("player");
            if (video) {
                const defaultOptions = { controls: ['play-large', 'play', 'progress', 'current-time', 'duration', 'mute', 'volume', 'captions', 'settings', 'fullscreen'] };
                if (Hls.isSupported() && STREAMING_URL.includes('.m3u8')) {
                    const hls = new Hls(); hls.loadSource(STREAMING_URL); hls.attachMedia(video);
                    new Plyr(video, defaultOptions);
                } else { new Plyr(video, defaultOptions); }
            }

            // Xử lý Favorite
            $('.favorite-toggle-btn').click(function() {
                const btn = $(this);
                fetch('@Url.Action("Toggle", "Favorites")', {
                    method: 'POST',
                    headers: { 'Content-Type': 'application/x-www-form-urlencoded', 'RequestVerificationToken': document.querySelector('input[name="__RequestVerificationToken"]').value },
                    body: `movieId=${btn.data('movie-id')}`
                }).then(r => r.json()).then(data => {
                    if (data.success) {
                        if (data.isFavorite) { btn.addClass('active').find('span').text('In My List'); btn.find('i').attr('class', 'fas fa-check'); }
                        else { btn.removeClass('active').find('span').text('My List'); btn.find('i').attr('class', 'fas fa-plus'); }
                        showToast(data.isFavorite ? 'Added to List' : 'Removed from List', 'success');
                    }
                });
            });
        });

        // --- HỆ THỐNG AJAX BÌNH LUẬN ---
        function showEditForm(reviewId) { $('#display-mode-' + reviewId).hide(); $('#edit-mode-' + reviewId).fadeIn(200); }
        function hideEditForm(reviewId) { $('#edit-mode-' + reviewId).hide(); $('#display-mode-' + reviewId).fadeIn(200); }

        function deleteReview(reviewId) {
            if (!confirm('Are you sure you want to delete this comment?')) return;
            $.ajax({
                url: '@Url.Action("Delete", "Reviews")', type: 'POST',
                data: { id: reviewId, __RequestVerificationToken: $('input[name="__RequestVerificationToken"]').val() },
                success: function(response) {
                    if (response.success) {
                        showToast('Deleted successfully!', 'success');
                        $('#review-' + reviewId).fadeOut(300, function() {
                            $(this).remove();
                            let count = parseInt($('#reviewCount').text()) - 1;
                            $('#reviewCount').text(count > 0 ? count : 0);
                            if (count <= 0) $('#reviewsListContainer').html(`<div id="no-reviews-msg" class="text-center text-secondary py-4"><i class="fas fa-comment-slash fs-1 mb-3"></i><p>No comments yet.</p></div>`);
                        });
                    }
                }
            });
        }

        $(document).ready(function() {

            // 1. TẠO COMMENT MỚI (AJAX)
            $('#mainCommentForm').on('submit', function(e) {
                e.preventDefault();
                const form = $(this);
                const submitBtn = form.find('.btn-main-submit');

                submitBtn.prop('disabled', true).html('<i class="fas fa-spinner fa-spin"></i> Posting...');
                $.ajax({
                    url: '@Url.Action("Create", "Reviews")', type: 'POST', data: form.serialize(),
                    success: function(response) {
                        if (response.success) {
                            showToast('Comment posted!', 'success');
                            form[0].reset();

                            const newId = response.review ? response.review.id : 'temp-' + Date.now();
                            const commentText = form.find('textarea[name="Comment"]').val();
                            const firstLetter = currentUserName.charAt(0).toUpperCase();

                            // Render Ảnh Avatar hoặc Chữ
                            let avatarContent = (currentUserAvatar && !currentUserAvatar.includes("avatar.jpg"))
                                ? `<img src="${currentUserAvatar}" alt="Avatar" />`
                                : `${firstLetter}`;

                            const token = $('input[name="__RequestVerificationToken"]').val();

                            const reviewHtml = `
                                <div class="review-item" id="review-${newId}" style="border: 1px solid var(--netflix-red); background: rgba(229, 9, 20, 0.05); opacity: 0; animation: fadeIn 0.5s ease forwards; margin-bottom: 1rem;">
                                    <div id="display-mode-${newId}">
                                        <div class="review-header">
                                            <div class="review-author">
                                                <div class="author-avatar" style="background: linear-gradient(135deg, #f5c518, #ffda44); color: #000;">
                                                    ${avatarContent}
                                                </div>
                                                <div class="author-info">
                                                    <h4 class="mb-0">${currentUserName} <span class="badge bg-danger ms-2" style="font-size: 0.6rem;">You</span></h4>
                                                </div>
                                            </div>
                                            <div class="review-date">Just now</div>
                                        </div>
                                        <div class="review-content mt-2">${commentText}</div>
                                        <div class="review-actions mt-3 pt-3" style="border-top: 1px solid rgba(255,255,255,0.05);">
                                            <button class="review-action-btn text-primary" onclick="showEditForm('${newId}')"><i class="fas fa-edit"></i> Edit</button>
                                            <button class="review-action-btn text-danger ms-3" onclick="deleteReview('${newId}')"><i class="fas fa-trash"></i> Delete</button>
                                        </div>
                                    </div>
                                    <div id="edit-mode-${newId}" style="display: none;">
                                        <form class="form-edit-review" method="post">
                                            <input type="hidden" name="__RequestVerificationToken" value="${token}" />
                                            <input type="hidden" name="Id" value="${newId}" />
                                            <input type="hidden" name="MovieId" value="@Model.Movie.Id" />
                                            <input type="hidden" name="Rating" value="5" />
                                            <div class="mb-3 mt-3">
                                                <textarea name="Comment" class="review-textarea" rows="2" required>${commentText}</textarea>
                                            </div>
                                            <div class="d-flex gap-2 mt-2">
                                                <button type="submit" class="btn btn-danger btn-sm px-3 fw-bold">Save</button>
                                                <button type="button" class="btn btn-secondary btn-sm px-3 fw-bold" onclick="hideEditForm('${newId}')">Cancel</button>
                                            </div>
                                        </form>
                                    </div>
                                </div>`;

                            $('#no-reviews-msg').remove();
                            $('#reviewsListContainer').prepend(reviewHtml);

                            let count = parseInt($('#reviewCount').text()) + 1;
                            $('#reviewCount').text(count);

                        } else { showToast(response.message, 'error'); }
                    },
                    complete: function() { submitBtn.prop('disabled', false).html('<i class="fas fa-paper-plane"></i> Post Comment'); }
                });
            });

            // 2. SỬA COMMENT (In-place)
            $(document).on('submit', '.form-edit-review', function(e) {
                e.preventDefault();
                const form = $(this);
                const reviewId = form.find('input[name="Id"]').val();
                const newComment = form.find('textarea[name="Comment"]').val();

                $.ajax({
                    url: '@Url.Action("Edit", "Reviews")', type: 'POST', data: form.serialize(),
                    success: function(response) {
                        if (response.success) {
                            showToast('Saved!', 'success');
                            const displayMode = $('#display-mode-' + reviewId);
                            displayMode.find('.review-content').text(newComment);
                            hideEditForm(reviewId);
                        }
                    }
                });
            });
        });

        // UI Toast
        function showToast(message, type) {
            $('.toast-notification').remove();
            const borderColor = type === 'success' ? '#46d369' : '#e50914';
            const icon = type === 'success' ? 'check-circle' : 'exclamation-circle';
            const toast = $(`<div class="toast-notification" style="border-left-color: ${borderColor};"><i class="fas fa-${icon}" style="color: ${borderColor};"></i><span>${message}</span></div>`);
            $('body').append(toast);
            setTimeout(() => toast.fadeOut(300, function() { $(this).remove(); }), 3000);
        }
    </script>
}