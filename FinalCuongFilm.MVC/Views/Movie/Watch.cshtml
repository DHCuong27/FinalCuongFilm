@using FinalCuongFilm.ApplicationCore.Entities
@model FinalCuongFilm.MVC.Models.ViewModels.MovieWatchViewModel
@using static FinalCuongFilm.ApplicationCore.Entities.Enum

@{
    ViewData["Title"] = "Watch " + Model.Movie.Title;
    Layout = "_LayoutUser";

    var currentEpisode = Model.CurrentEpisode;
    var episodes = Model.Episodes ?? new List<FinalCuongFilm.Common.DTOs.EpisodeDto>();
    var mediaFile = Model.MediaFiles?.FirstOrDefault();

    var isFavorited = ViewBag.IsFavorited != null ? (bool)ViewBag.IsFavorited : false;
    var actors = ViewBag.Actors as IEnumerable<FinalCuongFilm.Common.DTOs.ActorDto> ?? new List<FinalCuongFilm.Common.DTOs.ActorDto>();
    var streamingUrl = ViewBag.StreamingUrl as string ?? "";
    var qualitySources = ViewBag.QualitySources as IEnumerable<dynamic> ?? new List<dynamic>();
    var subtitles = ViewBag.SubtitleFiles as IEnumerable<dynamic>;

    var currentUrl = Url.Action("Watch", "Movie", new { slug = Model.Movie?.Slug, ep = currentEpisode?.EpisodeNumber });
    var isVideoAvailable = Model.Movie != null && mediaFile != null && !string.IsNullOrEmpty(streamingUrl);
    var isHlsStream = streamingUrl.Contains(".m3u8");
}

<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>@ViewData["Title"] - FinalCuongFilm</title>
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.0.0/css/all.min.css">
    <link rel="stylesheet" href="https://cdn.plyr.io/3.7.8/plyr.css" />
    <link href="https://fonts.cdnfonts.com/css/netflix-sans" rel="stylesheet">

    <style>
        :root {
            --netflix-red: #e50914;
            --netflix-black: #141414;
            --netflix-dark: #181818;
            --netflix-text: #ffffff;
            --netflix-text-secondary: #a3a3a3;
            --transition: all 0.2s ease;
        }

        * {
            margin: 0;
            padding: 0;
            box-sizing: border-box;
        }

        body {
            background-color: var(--netflix-black);
            color: var(--netflix-text);
            font-family: 'Netflix Sans', 'Helvetica Neue', Helvetica, Arial, sans-serif;
            line-height: 1.5;
            -webkit-font-smoothing: antialiased;
        }

        .cinema-section {
            position: relative;
            width: 100%;
            background-color: #000;
            border-bottom: 6px solid #222;
        }

        .cinema-screen-wrapper {
            position: relative;
            width: 100%;
            max-width: 1400px;
            margin: 0 auto;
        }

        .cinema-screen {
            position: relative;
            width: 100%;
            background: #000;
            overflow: hidden;
        }

        .plyr {
            width: 100%;
            --plyr-color-main: var(--netflix-red);
            --plyr-video-background: #000;
            --plyr-menu-background: rgba(20, 20, 20, 0.95);
            --plyr-menu-color: #fff;
            --plyr-control-radius: 4px;
        }

            .plyr video {
                aspect-ratio: 16 / 9;
                width: 100%;
                max-height: 80vh;
                object-fit: contain;
            }

        .cinema-top-bar {
            position: absolute;
            top: 0;
            left: 0;
            right: 0;
            padding: 20px 30px;
            background: linear-gradient(180deg, rgba(0,0,0,0.9) 0%, transparent 100%);
            z-index: 20;
            display: flex;
            align-items: center;
            opacity: 0;
            transition: opacity 0.3s;
            pointer-events: none;
        }

        .cinema-screen:hover .cinema-top-bar,
        .plyr.plyr--paused .cinema-top-bar {
            opacity: 1;
            pointer-events: auto;
        }

        .cinema-back-btn {
            background: transparent;
            border: none;
            color: #fff;
            width: 40px;
            height: 40px;
            border-radius: 50%;
            display: flex;
            align-items: center;
            justify-content: center;
            cursor: pointer;
            margin-right: 20px;
            transition: var(--transition);
        }

            .cinema-back-btn:hover {
                background: rgba(255,255,255,0.1);
                transform: scale(1.05);
            }

        .cinema-title {
            display: flex;
            align-items: baseline;
            gap: 10px;
        }

            .cinema-title h2 {
                font-size: 1.3rem;
                font-weight: 500;
                text-shadow: 0 2px 4px rgba(0,0,0,0.5);
            }

            .cinema-title span {
                font-size: 0.9rem;
                color: var(--netflix-text-secondary);
                font-weight: 400;
            }

        .cinema-next-hint {
            position: absolute;
            bottom: 80px;
            right: 30px;
            background: rgba(20, 20, 20, 0.95);
            border-left: 4px solid var(--netflix-red);
            padding: 16px 20px;
            border-radius: 6px;
            z-index: 25;
            backdrop-filter: blur(8px);
            box-shadow: 0 10px 20px rgba(0,0,0,0.6);
            display: none;
            min-width: 260px;
            animation: slideInRight 0.3s ease-out;
        }

            .cinema-next-hint .next-label {
                font-size: 0.8rem;
                text-transform: uppercase;
                color: var(--netflix-text-secondary);
                letter-spacing: 1px;
                margin-bottom: 4px;
            }

            .cinema-next-hint .next-title {
                font-weight: 600;
                margin-bottom: 12px;
                color: #fff;
            }

            .cinema-next-hint .next-btn {
                background: var(--netflix-red);
                color: white;
                border: none;
                padding: 8px 16px;
                border-radius: 4px;
                font-weight: 600;
                display: flex;
                align-items: center;
                justify-content: center;
                gap: 8px;
                cursor: pointer;
                transition: var(--transition);
                text-decoration: none;
            }

                .cinema-next-hint .next-btn:hover {
                    background: #f40612;
                }

        .info-section {
            max-width: 1400px;
            margin: 0 auto;
            padding: 30px 40px;
        }

        .resume-banner {
            background: linear-gradient(90deg, #2a2a2a 0%, #1a1a1a 100%);
            border-radius: 8px;
            padding: 12px 20px;
            margin-bottom: 30px;
            display: none;
            align-items: center;
            justify-content: space-between;
            border-left: 4px solid var(--netflix-red);
            box-shadow: 0 2px 8px rgba(0,0,0,0.4);
        }

            .resume-banner.visible {
                display: flex;
            }

        .resume-info {
            display: flex;
            align-items: center;
            gap: 12px;
        }

            .resume-info i {
                color: var(--netflix-red);
                font-size: 1.1rem;
            }

            .resume-info p {
                font-size: 0.95rem;
            }

            .resume-info strong {
                font-weight: 600;
            }

        .resume-actions {
            display: flex;
            gap: 10px;
        }

        .resume-btn {
            background: var(--netflix-red);
            border: none;
            color: white;
            padding: 6px 16px;
            border-radius: 4px;
            font-weight: 600;
            cursor: pointer;
            transition: var(--transition);
        }

            .resume-btn:hover {
                background: #f40612;
            }

        .resume-dismiss {
            background: transparent;
            border: 1px solid #555;
            color: #ccc;
            padding: 6px 16px;
            border-radius: 4px;
            cursor: pointer;
            transition: var(--transition);
        }

            .resume-dismiss:hover {
                border-color: #fff;
                color: #fff;
            }

        .movie-title {
            font-size: 2.5rem;
            font-weight: 700;
            margin-bottom: 10px;
            display: flex;
            align-items: baseline;
            gap: 15px;
        }

            .movie-title span {
                font-size: 1.2rem;
                font-weight: 400;
                color: var(--netflix-text-secondary);
            }

        .movie-meta {
            display: flex;
            gap: 12px;
            margin-bottom: 20px;
            font-size: 0.95rem;
            align-items: center;
        }

        .match-score {
            color: #46d369;
            font-weight: 700;
        }

        .meta-badge {
            background: rgba(255,255,255,0.1);
            padding: 4px 10px;
            border-radius: 4px;
            font-size: 0.85rem;
            border: 1px solid #333;
        }

        .action-buttons {
            display: flex;
            gap: 15px;
            margin-bottom: 30px;
        }

        .btn {
            padding: 10px 25px;
            border-radius: 4px;
            font-weight: 600;
            font-size: 1rem;
            text-decoration: none;
            display: inline-flex;
            align-items: center;
            gap: 10px;
            cursor: pointer;
            border: none;
            transition: var(--transition);
        }

        .btn-secondary {
            background: rgba(255,255,255,0.2);
            color: white;
        }

            .btn-secondary:hover {
                background: rgba(255,255,255,0.3);
            }

            .btn-secondary.active {
                background: rgba(255,255,255,0.3);
                color: var(--netflix-red);
            }

                .btn-secondary.active i {
                    color: var(--netflix-red);
                }

        .movie-description {
            color: #b3b3b3;
            max-width: 900px;
            font-size: 1.05rem;
            line-height: 1.6;
            margin-bottom: 40px;
        }

        .section-title {
            font-size: 1.4rem;
            font-weight: 500;
            margin-bottom: 20px;
        }

        .cast-section {
            margin-bottom: 50px;
        }

        .cast-scroll {
            display: flex;
            gap: 20px;
            overflow-x: auto;
            padding-bottom: 10px;
            scrollbar-width: thin;
            scrollbar-color: #555 #222;
        }

            .cast-scroll::-webkit-scrollbar {
                height: 6px;
            }

            .cast-scroll::-webkit-scrollbar-track {
                background: #222;
            }

            .cast-scroll::-webkit-scrollbar-thumb {
                background: #555;
                border-radius: 10px;
            }

        .cast-card {
            flex: 0 0 auto;
            text-align: center;
            width: 100px;
        }

        .cast-avatar {
            width: 80px;
            height: 80px;
            border-radius: 50%;
            background: #2a2a2a;
            margin: 0 auto 8px;
            overflow: hidden;
            border: 2px solid #333;
            transition: var(--transition);
        }

        .cast-card:hover .cast-avatar {
            border-color: var(--netflix-red);
        }

        .cast-avatar img {
            width: 100%;
            height: 100%;
            object-fit: cover;
        }

        .cast-avatar i {
            line-height: 80px;
            color: #777;
        }

        .cast-name {
            font-size: 0.9rem;
            color: #ddd;
            white-space: nowrap;
            overflow: hidden;
            text-overflow: ellipsis;
        }

        .episodes-section {
            margin-bottom: 40px;
        }

        .episodes-list {
            display: flex;
            flex-direction: column;
            gap: 10px;
        }

        .episode-item {
            display: flex;
            gap: 20px;
            background: var(--netflix-dark);
            border-radius: 8px;
            overflow: hidden;
            transition: var(--transition);
            border: 1px solid transparent;
            text-decoration: none;
            color: inherit;
        }

            .episode-item:hover {
                background: #282828;
                border-color: #404040;
            }

            .episode-item.active {
                background: rgba(229, 9, 20, 0.1);
                border-color: var(--netflix-red);
            }

        .episode-thumbnail {
            flex: 0 0 180px;
            aspect-ratio: 16 / 9;
            background: #000;
            position: relative;
            overflow: hidden;
        }

            .episode-thumbnail img {
                width: 100%;
                height: 100%;
                object-fit: cover;
                opacity: 0.8;
            }

        .ep-progress {
            position: absolute;
            bottom: 0;
            left: 0;
            height: 3px;
            background: var(--netflix-red);
            width: 0%;
        }

        .episode-info {
            flex: 1;
            padding: 15px 15px 15px 0;
        }

        .episode-header {
            display: flex;
            align-items: baseline;
            gap: 15px;
            margin-bottom: 5px;
        }

        .episode-number {
            font-size: 0.9rem;
            color: var(--netflix-text-secondary);
            font-weight: 500;
        }

        .episode-title {
            font-size: 1.1rem;
            font-weight: 600;
        }

        .episode-description {
            color: #b3b3b3;
            font-size: 0.9rem;
            line-height: 1.5;
            margin: 8px 0;
            display: -webkit-box;
            -webkit-line-clamp: 2;
            -webkit-box-orient: vertical;
            overflow: hidden;
        }

        .episode-meta {
            display: flex;
            gap: 15px;
            font-size: 0.8rem;
            color: var(--netflix-text-secondary);
        }

        .error-container {
            text-align: center;
            padding: 120px 20px;
        }

        .error-icon {
            font-size: 4rem;
            color: var(--netflix-red);
            margin-bottom: 20px;
        }

        /* Toast Notifications */
        .toast-notification {
            position: fixed;
            top: 90px;
            right: 20px;
            background: var(--netflix-dark);
            padding: 1rem 1.5rem;
            border-radius: 6px;
            box-shadow: 0 10px 30px rgba(0,0,0,0.5);
            z-index: 9999;
            display: flex;
            align-items: center;
            gap: 1rem;
            border-left: 4px solid var(--netflix-red);
            animation: slideInRight 0.3s ease;
        }

        @@keyframes slideInRight {
            from

        {
            opacity: 0;
            transform: translateX(120%);
        }

        to {
            opacity: 1;
            transform: translateX(0);
        }

        }

        @@media (max-width: 768px) {
            .cinema-section

        {
            border-bottom: none;
        }

        .info-section {
            padding: 20px;
        }

        .movie-title {
            font-size: 1.8rem;
            flex-direction: column;
            gap: 5px;
        }

        .action-buttons {
            flex-direction: column;
        }

        .btn {
            width: 100%;
            justify-content: center;
        }

        .episode-item {
            flex-direction: column;
            gap: 10px;
        }

        .episode-thumbnail {
            flex: 0 0 auto;
            width: 100%;
        }

        .episode-info {
            padding: 0 15px 15px;
        }

        }
    </style>
</head>
<body>
    @if (!isVideoAvailable)
    {
        <div class="error-container">
            <i class="fas fa-video-slash error-icon"></i>
            <h2>Video Unavailable</h2>
            <p style="color: #888; margin: 15px 0 25px;">The video file is currently processing or cannot be found.</p>
            <a href="@Url.Action("Detail", "Movie", new { slug = Model.Movie?.Slug ?? "unknown" })" class="btn btn-secondary">Return to Details</a>
        </div>
    }
    else
    {
        <div class="cinema-section">
            <div class="cinema-screen-wrapper">
                <div class="cinema-screen">

                    <div class="cinema-top-bar">
                        <button class="cinema-back-btn" onclick="window.location.href='@Url.Action("Detail", "Movie", new { slug = Model.Movie?.Slug })'">
                            <i class="fas fa-arrow-left"></i>
                        </button>
                        <div class="cinema-title">
                            <h2>@Model.Movie.Title</h2>
                            @if (currentEpisode != null)
                            {
                                <span>E @currentEpisode.EpisodeNumber</span>
                            }
                        </div>
                    </div>

                    <video id="player" playsinline controls crossorigin poster="@(Model.Movie.PosterUrl ?? "")">
                        @if (isHlsStream)
                        {
                            <source src="@streamingUrl" type="application/x-mpegURL" />
                        }
                        else
                        {
                            <source src="@streamingUrl" type="video/mp4" />
                        }

                        @if (subtitles != null)
                        {
                            foreach (var sub in subtitles)
                            {
                                <track kind="captions" label="@sub.label" srclang="@sub.language" src="@sub.url" />
                            }
                        }
                    </video>

                    @if (currentEpisode != null && episodes != null && episodes.Any())
                    {
                        var nextEpisode = episodes.FirstOrDefault(e => e.EpisodeNumber == (currentEpisode.EpisodeNumber + 1));
                        if (nextEpisode != null)
                        {
                            <div class="cinema-next-hint" id="nextEpisodeHint">
                                <div class="next-label">Up Next</div>
                                <div class="next-title">E@(nextEpisode.EpisodeNumber): @nextEpisode.Title</div>
                                <a href="@Url.Action("Watch", "Movie", new { slug = Model.Movie?.Slug, ep = nextEpisode.EpisodeNumber })" class="next-btn">
                                    <i class="fas fa-play"></i> Play Now
                                </a>
                            </div>
                        }
                    }
                </div>
            </div>
        </div>

        <div class="info-section">
            <div class="resume-banner" id="resumeBanner">
                <div class="resume-info">
                    <i class="fas fa-history"></i>
                    <p>Welcome back! Resume playing from <strong id="resumeTime">—</strong></p>
                </div>
                <div class="resume-actions">
                    <button class="resume-btn" onclick="resumePlayback()">Resume</button>
                    <button class="resume-dismiss" onclick="dismissResume()">Dismiss</button>
                </div>
            </div>

            <div class="movie-title">
                @Model.Movie.Title
                @if (currentEpisode != null)
                {
                    <span>Episode @currentEpisode.EpisodeNumber</span>
                }
            </div>

            <div class="movie-meta">
                <span class="meta-badge">@Model.Movie.ReleaseYear</span>
                <span class="meta-badge">@Model.Movie.Type</span>
                @if (mediaFile?.Quality != null)
                {
                    <span class="meta-badge">@mediaFile.Quality</span>
                }
            </div>

            <div class="action-buttons">
                <a href="@Url.Action("Detail", "Movie", new { slug = Model.Movie.Slug })" class="btn btn-secondary">
                    <i class="fas fa-info-circle"></i> More Info
                </a>
                @if (User.Identity?.IsAuthenticated == true)
                {
                    <button type="button" class="btn btn-secondary favorite-toggle-btn @(isFavorited ? "active" : "")"
                            data-movie-id="@Model.Movie.Id">
                        <i class="@(isFavorited ? "fas fa-check" : "fas fa-plus")" id="favoriteIcon"></i>
                        <span id="favoriteText">@(isFavorited ? "In My List" : "My List")</span>
                    </button>
                }
            </div>

            @if (!string.IsNullOrEmpty(Model.Movie.Description))
            {
                <div class="movie-description">@Model.Movie.Description</div>
            }

            @if (actors != null && actors.Any())
            {
                <div class="cast-section">
                    <div class="section-title">Cast</div>
                    <div class="cast-scroll">
                        @foreach (var actor in actors.Take(10))
                        {
                            <div class="cast-card">
                                <div class="cast-avatar">
                                    @if (!string.IsNullOrEmpty(actor.AvartUrl))
                                    {
                                        <img src="@actor.AvartUrl" alt="@actor.Name">
                                    }
                                    else
                                    {
                                        <i class="fas fa-user"></i>
                                    }
                                </div>
                                <div class="cast-name">@actor.Name</div>
                            </div>
                        }
                    </div>
                </div>
            }

            @if (episodes != null && episodes.Any())
            {
                <div class="episodes-section">
                    <div class="section-title">Episodes</div>
                    <div class="episodes-list">
                        @foreach (var episode in episodes)
                        {
                            var isActive = currentEpisode != null && episode.Id == currentEpisode.Id;
                            var episodeUrl = Url.Action("Watch", "Movie", new { slug = Model.Movie.Slug, ep = episode.EpisodeNumber });

                            <a href="@episodeUrl" class="episode-item @(isActive ? "active" : "")">
                                <div class="episode-thumbnail">
                                    @if (isActive)
                                    {
                                        <div class="ep-progress" id="epProgressBar"></div>
                                    }
                                </div>
                                <div class="episode-info">
                                    <div class="episode-header">
                                        <span class="episode-number">Episode @episode.EpisodeNumber</span>
                                        <span class="episode-title">@episode.Title</span>
                                    </div>
                                    <div class="episode-description">
                                        @episode.Description
                                    </div>
                                    <div class="episode-meta">
                                        @if (episode.DurationMinutes.HasValue)
                                        {
                                            <span><i class="far fa-clock"></i> @episode.DurationMinutes.Value.ToString(@"hh\:mm")</span>
                                        }
                                    </div>
                                </div>
                            </a>
                        }
                    </div>
                </div>
            }
        </div>
    }

    @Html.AntiForgeryToken()

    @section Scripts {
        <script src="https://cdn.jsdelivr.net/npm/hls.js@latest"></script>
        <script src="https://cdn.plyr.io/3.7.8/plyr.polyfilled.js"></script>

        <script>
            const STREAMING_URL = '@Html.Raw(streamingUrl ?? "")';
            const MOVIE_ID      = '@Html.Raw(Model.Movie?.Id.ToString() ?? "")';
            const EPISODE_ID    = '@Html.Raw(currentEpisode?.Id.ToString() ?? "")';

            let player;
            let savedTime = 0;

            document.addEventListener("DOMContentLoaded", () => {
                const video = document.getElementById("player");
                if (!video) return;

                const defaultOptions = {
                    controls: [
                        'play-large', 'play', 'progress', 'current-time', 'duration',
                        'mute', 'volume', 'captions', 'settings', 'pip', 'fullscreen'
                    ],
                    settings: ['captions', 'quality', 'speed'],
                    keyboard: { focused: false, global: false },
                    tooltips: { controls: true }
                };

                if (Hls.isSupported() && STREAMING_URL.includes('.m3u8')) {
                    const hls = new Hls({ maxBufferLength: 60 });
                    hls.loadSource(STREAMING_URL);
                    hls.attachMedia(video);

                    hls.on(Hls.Events.MANIFEST_PARSED, function () {
                        // Map descending for UI
                        const availableQualities = hls.levels.map(l => l.height).sort((a, b) => b - a);
                        defaultOptions.quality = {
                            default: availableQualities[0],
                            options: availableQualities,
                            forced: true,
                            onChange: e => window.hls.currentLevel = window.hls.levels.findIndex(l => l.height === e)
                        };
                        player = new Plyr(video, defaultOptions);
                        setupPlayerEvents(player);
                    });
                    window.hls = hls;
                } else {
                    player = new Plyr(video, defaultOptions);
                    setupPlayerEvents(player);
                }

                if (MOVIE_ID) loadSavedProgress();

                // Setup Favorite Button Event
                setupFavoriteToggle();
            });

            window.addEventListener('beforeunload', () => { if (window.hls) window.hls.destroy(); });

            function setupPlayerEvents(playerInstance) {
                playerInstance.on('ended', () => {
                    saveProgress();
                    const hint = document.getElementById('nextEpisodeHint');
                    if (hint) { hint.style.display = 'block'; setTimeout(() => hint.style.display = 'none', 10000); }
                });

                let saveTimer;
                playerInstance.on('timeupdate', () => {
                    const bar = document.getElementById('epProgressBar');
                    if (bar && playerInstance.duration) {
                        bar.style.width = (playerInstance.currentTime / playerInstance.duration * 100) + '%';
                    }
                    clearTimeout(saveTimer);
                    saveTimer = setTimeout(saveProgress, 10000);
                });

                playerInstance.on('pause', saveProgress);
            }

            function loadSavedProgress() {
                const epParam = EPISODE_ID ? `&episodeId=${EPISODE_ID}` : '';
                fetch(`/Stream/GetProgress?movieId=${MOVIE_ID}${epParam}`)
                    .then(r => r.json())
                    .then(data => {
                        if (data.success && data.currentTime > 10) {
                            savedTime = data.currentTime;
                            document.getElementById('resumeTime').textContent =
                                `${Math.floor(savedTime/60)}:${Math.floor(savedTime%60).toString().padStart(2,'0')}`;
                            document.getElementById('resumeBanner').classList.add('visible');
                        }
                    }).catch(() => {});
            }

            function resumePlayback() {
                if (!player || savedTime <= 0) return;
                player.currentTime = savedTime; player.play();
                dismissResume();
            }

            function dismissResume() {
                const banner = document.getElementById('resumeBanner');
                if(banner) banner.classList.remove('visible');
            }

            function saveProgress() {
                if (!player || !player.duration || player.currentTime < 5 || !MOVIE_ID) return;
                if ((player.currentTime / player.duration) > 0.98) return;

                fetch('/Stream/Progress', {
                    method: 'POST',
                    headers: {
                        'Content-Type': 'application/json',
                        'RequestVerificationToken': document.querySelector('input[name="__RequestVerificationToken"]').value
                    },
                    body: JSON.stringify({
                        movieId: MOVIE_ID, episodeId: EPISODE_ID || null,
                        currentTime: player.currentTime, duration: player.duration
                    })
                }).catch(() => {});
            }

            // Favorite Logic
            function setupFavoriteToggle() {
                const favoriteBtn = document.querySelector('.favorite-toggle-btn');
                if (!favoriteBtn) return;

                favoriteBtn.addEventListener('click', function() {
                    const btn = this;
                    const movieId = btn.getAttribute('data-movie-id');
                    const token = document.querySelector('input[name="__RequestVerificationToken"]').value;

                    fetch('@Url.Action("Toggle", "Favorites")', {
                        method: 'POST',
                        headers: {
                            'Content-Type': 'application/x-www-form-urlencoded',
                            'RequestVerificationToken': token
                        },
                        body: `movieId=${movieId}`
                    })
                    .then(response => response.json())
                    .then(data => {
                        if (data.success) {
                            const icon = btn.querySelector('i');
                            const text = btn.querySelector('span');

                            if (data.isFavorite) {
                                icon.className = 'fas fa-check';
                                text.textContent = 'In My List';
                                btn.classList.add('active');
                                showToast('Added to My List', 'success');
                            } else {
                                icon.className = 'fas fa-plus';
                                text.textContent = 'My List';
                                btn.classList.remove('active');
                                showToast('Removed from My List', 'success');
                            }
                        } else {
                            showToast(data.message || 'An error occurred!', 'error');
                        }
                    })
                    .catch(() => showToast('Network error occurred!', 'error'));
                });
            }

            // Toast Notification System
            function showToast(message, type) {
                const existingToast = document.querySelector('.toast-notification');
                if (existingToast) existingToast.remove();

                const borderColor = type === 'success' ? '#46d369' : '#e50914';
                const icon = type === 'success' ? 'check-circle' : 'exclamation-circle';

                const toast = document.createElement('div');
                toast.className = 'toast-notification';
                toast.style.borderLeftColor = borderColor;
                toast.innerHTML = `
                    <i class="fas fa-${icon}" style="color: ${borderColor}; font-size: 1.3rem;"></i>
                    <span style="color: var(--text-primary); font-weight: 500;">${message}</span>
                `;

                document.body.appendChild(toast);

                setTimeout(() => {
                    toast.style.opacity = '0';
                    toast.style.transform = 'translateX(120%)';
                    toast.style.transition = 'all 0.3s ease';
                    setTimeout(() => toast.remove(), 300);
                }, 3000);
            }
        </script>
    }
</body>
</html>