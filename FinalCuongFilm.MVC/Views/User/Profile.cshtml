@{
    ViewData["Title"] = "Tài khoản";
    Layout = "~/Views/Shared/_Layout.cshtml";
}

<link href="~/layout_user/css/layout.css" rel="stylesheet" />
<body class="user-management-body">
    <div class="user-management-container">
        <!-- Compact Fixed Sidebar -->
        <aside class="sidebar-fixed">
            <div class="sidebar-header">
                <h4>Quản lý tài khoản</h4>
            </div>

            <nav>
                <ul class="sidebar-nav">
                    <li class="sidebar-nav__item">
                        <a href="@Url.Action("favorites", "user")" class="sidebar-nav__link">
                            <span class="sidebar-nav__icon">♥</span>
                            <span>Yêu thích</span>
                        </a>
                    </li>
                    <li class="sidebar-nav__item">
                        <a href="@Url.Action("lists", "user")" class="sidebar-nav__link">
                            <span class="sidebar-nav__icon">📋</span>
                            <span>Danh sách</span>
                        </a>
                    </li>
                    <li class="sidebar-nav__item">
                        <a href="@Url.Action("continueWatching", "user")" class="sidebar-nav__link">
                            <span class="sidebar-nav__icon">▶️</span>
                            <span>Xem tiếp</span>
                        </a>
                    </li>
                    <li class="sidebar-nav__item">
                        <a href="@Url.Action("notifications", "user")" class="sidebar-nav__link">
                            <span class="sidebar-nav__icon">🔔</span>
                            <span>Thông báo</span>
                        </a>
                    </li>
                    <li class="sidebar-nav__item">
                        <a href="@Url.Action("Profile", "User")" class="sidebar-nav__link">
                            <span class="sidebar-nav__icon">👤</span>
                            <span>Tài khoản</span>
                        </a>
                    </li>
                </ul>
            </nav>

            <div class="sidebar-separator"></div>

            <div class="sidebar-footer">
                <div class="user-info">
                    <strong>@Model.UserName</strong>
                    <small>@Model.Email</small>
                    <a href="#" data-bs-toggle="modal" data-bs-target="#changePasswordModal">
                        Đổi mật khẩu, nhấn vào đây
                    </a>
                </div>
            </div>
        </aside>

        <!-- Fixed Main Content -->
        <main class="main-content-fixed">
            <div class="content-area">
                <div class="form-section">
                    <h5 class="mb-4">Tài khoản</h5>
                    <div class="mb-3 text-center">
                        <img src="/Layout_CuongPhim/img/myface.jpg" alt="Avatar" class="profile-avatar">
                        <div><small>Ảnh đại diện</small></div>
                    </div>

                    <form id="profileForm">
                        <input type="hidden" name="Email" value="@Model.Email" />

                        <div class="mb-3">
                            <label class="form-label">Email</label>
                            <input type="email" class="form-control" value="@Model.Email" readonly />
                        </div>

                        <div class="mb-3">
                            <label class="form-label">Tên</label>
                            <input type="text" class="form-control" name="UserName" value="@Model.UserName" />
                        </div>

                        <div class="mb-3">
                            <label class="form-label">Giới tính</label>
                            <div>
                                <div class="form-check form-check-inline">
                                    <input class="form-check-input" type="radio" name="Gender" value="Nam" @(Model.Gender == "Nam" ? "checked" : "")>
                                    <label class="form-check-label">Nam</label>
                                </div>
                                <div class="form-check form-check-inline">
                                    <input class="form-check-input" type="radio" name="Gender" value="Nữ" @(Model.Gender == "Nữ" ? "checked" : "")>
                                    <label class="form-check-label">Nữ</label>
                                </div>
                                <div class="form-check form-check-inline">
                                    <input class="form-check-input" type="radio" name="Gender" value="Khác" @(Model.Gender == "Khác" ? "checked" : "")>
                                    <label class="form-check-label">Không xác định</label>
                                </div>
                            </div>
                        </div>

                        <button type="submit" class="btn btn-primary">Cập nhật</button>
                        <div id="resultMessage" class="mt-3"></div>
                    </form>
                </div>
            </div>
        </main>
    </div>

    <!-- Modal -->
    <div class="modal fade" id="changePasswordModal" tabindex="-1" aria-labelledby="changePasswordLabel" aria-hidden="true">
        <div class="modal-dialog">
            <form id="changePasswordForm" class="modal-content">
                <div class="modal-header">
                    <h5 class="modal-title" id="changePasswordLabel">Đổi mật khẩu</h5>
                    <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Đóng"></button>
                </div>
                <div class="modal-body">
                    <div class="mb-3">
                        <label class="form-label">Mật khẩu hiện tại</label>
                        <input type="password" class="form-control" name="CurrentPassword" required />
                    </div>
                    <div class="mb-3">
                        <label class="form-label">Mật khẩu mới</label>
                        <input type="password" class="form-control" name="NewPassword" required />
                    </div>
                    <div class="mb-3">
                        <label class="form-label">Xác nhận mật khẩu mới</label>
                        <input type="password" class="form-control" name="ConfirmPassword" required />
                    </div>
                    <div id="passwordResult" class="mt-2"></div>
                </div>
                <div class="modal-footer">
                    <button type="submit" class="btn btn-primary">Xác nhận</button>
                </div>
            </form>
        </div>
    </div>

    @section Scripts {
        <script>
            $('#profileForm').submit(function (e) {
                e.preventDefault();

                $.ajax({
                    url: '@Url.Action("UpdateProfile", "User")',
                    type: 'POST',
                    data: $(this).serialize(),
                    success: function (res) {
                        if (res.success) {
                            $('#resultMessage').html('<div class="alert alert-success">' + res.message + '</div>');
                            $('.user-info strong').text(res.newName);
                        } else {
                            $('#resultMessage').html('<div class="alert alert-danger">' + res.message + '</div>');
                        }
                    },
                    error: function () {
                        $('#resultMessage').html('<div class="alert alert-danger">Có lỗi xảy ra khi cập nhật.</div>');
                    }
                });
            });

            $('#changePasswordForm').submit(function (e) {
                e.preventDefault();

                $.ajax({
                    url: '@Url.Action("ChangePassword", "User")',
                    type: 'POST',
                    data: $(this).serialize(),
                    success: function (res) {
                        if (res.success) {
                            $('#passwordResult').html('<div class="alert alert-success">' + res.message + '</div>');
                            setTimeout(() => $('#changePasswordModal').modal('hide'), 1500);
                        } else {
                            $('#passwordResult').html('<div class="alert alert-danger">' + res.message + '</div>');
                        }
                    },
                    error: function () {
                        $('#passwordResult').html('<div class="alert alert-danger">Có lỗi xảy ra khi đổi mật khẩu.</div>');
                    }
                });
            });
        </script>
    }
</body>