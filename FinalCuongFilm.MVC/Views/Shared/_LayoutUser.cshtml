@using FinalCuongFilm.ApplicationCore.Entities.Identity
@using Microsoft.AspNetCore.Identity
@inject UserManager<CuongFilmUser> UserManager
@using System.Security.Claims
@inject FinalCuongFilm.Service.Interfaces.IVipService VipService
@inject Microsoft.Extensions.Caching.Memory.IMemoryCache Cache
@using Microsoft.Extensions.Caching.Memory
@{
    var userId = User.FindFirstValue(ClaimTypes.NameIdentifier);
    
    // Cache VIP check for 5 minutes
    bool isVip = false;
    if (userId != null)
    {
        var cacheKey = $"VipCheck_{userId}";
        isVip = await Cache.GetOrCreateAsync(cacheKey, async entry =>
        {
            entry.AbsoluteExpirationRelativeToNow = TimeSpan.FromMinutes(5);
            var currentVip = await VipService.GetCurrentUserSubscriptionAsync(userId);
            return currentVip != null;
        });
    }

    string currentController = ViewContext.RouteData.Values["controller"]?.ToString() ?? "Home";
    string currentAction = ViewContext.RouteData.Values["action"]?.ToString() ?? "Index";
    bool isHomePage = (currentController == "Home" && currentAction == "Index");
}
<!DOCTYPE html>
<html lang="vi">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="theme-color" content="#07080b" />
    <link rel="preconnect" href="https://cdnjs.cloudflare.com" crossorigin />

    <title>@ViewData["Title"] - CuongFilm</title>

    <meta name="description" content="@(ViewData["MetaDescription"] ?? "CuongFilm - High-quality online movie streaming channel, with new movies updated daily.")" />

    <meta property="og:site_name" content="CuongFilm" />
    <meta property="og:type" content="@(ViewData["OgType"] ?? "website")" />
    <meta property="og:title" content="@ViewData["Title"] - CuongFilm" />
    <meta property="og:description" content="@(ViewData["MetaDescription"] ?? "CuongFilm - High-quality online movie streaming channel, with new movies updated daily.")" />
    <meta property="og:image" content="@(ViewData["OgImage"] ?? "https://www.cuongfilm.site/images/default-share-banner.jpg")" />

    @if (ViewData["CanonicalUrl"] != null)
    {
        <meta property="og:url" content="@ViewData["CanonicalUrl"]" />
        <link rel="canonical" href="@ViewData["CanonicalUrl"]" />
    }

    <link rel="icon" type="image/png" href="~/img/LogoCfv6-40.png" />
    <link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.min.css" asp-append-version="true" />
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css" media="print" onload="this.media='all'" />
    <noscript><link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css" /></noscript>
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/css/cuongfilm-taste.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/css/layout-user.css" asp-append-version="true" />

        <style>
        html, body {
            height: 100%;
            margin: 0;
            padding: 0;
        }
        body {
            background-color: #0f0f0f;
            color: #ffffff;
            font-family: 'Segoe UI', 'Helvetica Neue', Helvetica, Arial, sans-serif;
            padding-top: 80px;
        }
    </style>

    @await RenderSectionAsync("Styles", required: false)
</head>
<body>
    <!-- Graduation project and payment sandbox disclaimer -->
    <div id="disclaimer-modal" class="cf-modal-overlay active" role="dialog" aria-modal="true" aria-labelledby="disclaimer-title" aria-describedby="disclaimer-description">
        <div class="cf-modal-content">
            <div class="cf-modal-header">
                <i class="fa-solid fa-scale-balanced cf-modal-icon" aria-hidden="true"></i>
                <h2 id="disclaimer-title">Thông báo trước khi sử dụng website</h2>
            </div>
            <div id="disclaimer-description" class="cf-modal-body">
                <p>Chào mừng bạn đến với <strong>CuongFilm</strong>. Website này được xây dựng nhằm phục vụ <strong>đồ án tốt nghiệp</strong>, mục đích học tập, nghiên cứu và trình bày kỹ thuật phát triển hệ thống web xem phim.</p>
                <p class="highlight-text"><i class="fa-solid fa-circle-info" aria-hidden="true"></i> Website không hoạt động thương mại, không bán nội dung phim/video và không thu tiền thật từ người dùng.</p>
                <p>Những video hoặc dữ liệu minh họa nếu xuất hiện trong hệ thống chỉ được dùng để kiểm thử chức năng như upload, phát video, phân quyền VIP, lịch sử xem và giao diện người dùng. Nhóm/cá nhân thực hiện cam kết không cố ý khai thác, phân phối hoặc vi phạm bản quyền video.</p>
                <p>Chức năng thanh toán VIP chỉ là mô phỏng nghiệp vụ, được tích hợp qua <strong>ZaloPay Sandbox for Developer</strong>. Vì vậy các giao dịch trong website là giao dịch thử nghiệm, không phải tiền thật và không tạo giá trị mua bán thực tế.</p>
                <p>Bằng cách tiếp tục, bạn xác nhận đã hiểu phạm vi sử dụng của website là đồ án học tập và đồng ý trải nghiệm hệ thống trong bối cảnh thử nghiệm.</p>
            </div>
            <div class="cf-modal-footer">
                <button id="btn-accept-disclaimer" class="btn-cf-primary" type="button">Tôi đã hiểu và tiếp tục</button>
            </div>
        </div>
    </div>
    <div class="wrapper">
        <nav class="navbar navbar-expand-lg netflix-nav" id="mainNav">
            <div class="container-fluid px-4">
                <a class="navbar-brand d-flex align-items-center text-decoration-none" href="/">

                    <img src="~/img/LogoCfv6-40.png" alt="CuongFilm Icon" width="40" height="40" decoding="async" fetchpriority="high" style="height: 40px; width: 40px; margin-right: 12px; object-fit: contain;" />

                    <div class="d-flex flex-column justify-content-center">

                        <span style="color: #8c0b14; font-weight: 800; font-size: 1.5rem; font-family: 'Helvetica Neue', Helvetica, Arial, sans-serif; letter-spacing: -0.5px; line-height: 1; text-shadow: 1px 1px 3px rgba(0, 0, 0, 0.6);">
                            CuongFilm
                        </span>

                        <span style="color: #ffffff; font-size: 0.65rem; font-family: 'Helvetica Neue', Helvetica, Arial, sans-serif; letter-spacing: 1.5px; text-transform: uppercase; margin-top: 4px; opacity: 0.8;">
                            Embracing the art of cinema
                        </span>

                    </div>
                </a>

                <button class="navbar-toggler" type="button" data-bs-toggle="collapse" data-bs-target="#navbarMain" aria-label="Toggle navigation" style="background: rgba(255,255,255,0.1); border: none;">
                    <span class="navbar-toggler-icon"></span>
                </button>

                <div class="collapse navbar-collapse" id="navbarMain">
                    <ul class="navbar-nav me-auto mb-2 mb-lg-0">
                        <li class="nav-item">
                            <a class="nav-link" asp-controller="Home" asp-action="Index">Home</a>
                        </li>

                        <li class="nav-item dropdown">
                            <a class="nav-link dropdown-toggle" href="#" id="genreDropdown" role="button" data-bs-toggle="dropdown">
                                Genres
                            </a>
                            <ul class="dropdown-menu mega-menu" aria-labelledby="genreDropdown">
                                @if (ViewBag.Genres != null)
                                {
                                    foreach (var genre in ViewBag.Genres)
                                    {
                                        <li>
                                            <a class="dropdown-item" asp-controller="Genre" asp-action="Index" asp-route-slug="@genre.Slug">
                                                @genre.Name
                                            </a>
                                        </li>
                                    }
                                }
                                else
                                {
                                    <li><span class="dropdown-item text-muted">Loading...</span></li>
                                }
                            </ul>
                        </li>

                        <li class="nav-item dropdown">
                            <a class="nav-link dropdown-toggle" href="#" id="countryDropdown" role="button" data-bs-toggle="dropdown">
                                Countries
                            </a>
                            <ul class="dropdown-menu" style="columns: 3; min-width: 500px;" aria-labelledby="countryDropdown">
                                @if (ViewBag.Countries != null)
                                {
                                    foreach (var country in ViewBag.Countries)
                                    {
                                        <li>
                                            <a class="dropdown-item" asp-controller="Countries" asp-action="Index" asp-route-slug="@country.Slug">@country.Name</a>
                                        </li>
                                    }
                                }
                                else
                                {
                                    <li><span class="dropdown-item text-muted">Loading...</span></li>
                                }
                            </ul>
                        </li>

                        <li class="nav-item">
                            <a asp-controller="Home" asp-action="Browse" asp-route-type="1" class="nav-link">Movies</a>
                        </li>
                        <li class="nav-item">
                            <a class="nav-link" asp-controller="Home" asp-action="Browse" asp-route-type="2">TV Series</a>
                        </li>
                        <li class="nav-item">
                            <a class="nav-link text-warning fw-bold" asp-controller="Movie" asp-action="PremiumMovies">
                                <i class="fa-solid fa-crown"></i> VIP Movies
                            </a>
                        </li>
                        <li class="nav-item">
                            <a class="nav-link" asp-controller="Premium" asp-action="Index" style="color: #f59e0b; font-weight: bold; background-color: rgba(245, 158, 11, 0.1); border-radius: 4px; padding: 8px 15px;">
                                <i class="zmdi zmdi-star"></i> Buy Premium
                            </a>
                        </li>
                    </ul>

                    <div class="d-flex align-items-center">

                        <div class="search-container">
                            <form action="/Search" method="get" id="searchForm">
                                <input type="text" name="q" id="searchInput" placeholder="Search Movie..." autocomplete="off" />
                                <button type="submit"><i class="fas fa-search"></i></button>
                            </form>

                            <div id="searchSuggestions" class="suggestions-box" style="display: none;"></div>
                        </div>

                        @{
                            string avatarUrl = "/img/avatar.jpg";
                            string displayNavbarName = User.Identity?.Name ?? "Unknown";

                            if (User.Identity?.IsAuthenticated == true)
                            {
                                var currentUser = userId != null ? await Cache.GetOrCreateAsync($"User_{userId}", async entry =>
                                {
                                    entry.AbsoluteExpirationRelativeToNow = TimeSpan.FromMinutes(5);
                                    return await UserManager.GetUserAsync(User);
                                }) : null;
                                if (currentUser != null)
                                {
                                    if (!string.IsNullOrEmpty(currentUser.AvatarUrl))
                                    {
                                        avatarUrl = currentUser.AvatarUrl;
                                    }
                                    displayNavbarName = !string.IsNullOrEmpty(currentUser.FullName) ? currentUser.FullName : currentUser.UserName;
                                }
                            }
                        }

                        <div class="d-flex align-items-center">
                            @if (User.Identity?.IsAuthenticated == true)
                            {
                                <div class="dropdown ms-3">
                                    <a class="nav-link dropdown-toggle d-flex align-items-center" href="#" id="userDropdown" role="button" data-bs-toggle="dropdown" style="text-decoration: none;">
                                        <img src="@avatarUrl" alt="User Avatar" class="user-avatar me-2" width="35" height="35" loading="lazy" decoding="async" style="width: 35px; height: 35px; border-radius: 50%; object-fit: cover; border: 1px solid rgba(255,255,255,0.2);" />

                                        <span class="d-none d-lg-inline text-white me-2">@displayNavbarName</span>

                                        @if (isVip)
                                        {
                                            <span class="badge bg-warning text-dark rounded-pill d-flex align-items-center" style="font-size: 0.65rem; padding: 0.35em 0.6em; letter-spacing: 0.5px;">
                                                <i class="fa fa-crown me-1"></i> VIP
                                            </span>
                                        }
                                    </a>

                                    <ul class="dropdown-menu dropdown-menu-end" aria-labelledby="userDropdown" style="background-color: var(--nf-card-bg, #1f1f1f); border: 1px solid var(--nf-border, #333);">
                                        <li>
                                            <a class="dropdown-item text-light" asp-controller="User" asp-action="Profile" onmouseover="this.style.backgroundColor='rgba(255,255,255,0.1)'" onmouseout="this.style.backgroundColor='transparent'">
                                                <i class="fas fa-user me-2"></i> Profile
                                            </a>
                                        </li>
                                        <li>
                                            <a class="dropdown-item text-light" asp-controller="User" asp-action="ContinueWatching" onmouseover="this.style.backgroundColor='rgba(255,255,255,0.1)'" onmouseout="this.style.backgroundColor='transparent'">
                                                <i class="fas fa-play-circle me-2"></i> Continue Watching
                                            </a>
                                        </li>
                                        <li>
                                            <a class="dropdown-item text-light" asp-controller="User" asp-action="MyList" onmouseover="this.style.backgroundColor='rgba(255,255,255,0.1)'" onmouseout="this.style.backgroundColor='transparent'">
                                                <i class="fas fa-list me-2"></i> My List
                                            </a>
                                        </li>
                                        <li><hr class="dropdown-divider" style="border-color: #404040;" /></li>

                                        @if (User.IsInRole("Admin"))
                                        {
                                            <li>
                                                <a class="dropdown-item text-light" asp-area="Admin" asp-controller="Dashboard" asp-action="Index" onmouseover="this.style.backgroundColor='rgba(255,255,255,0.1)'" onmouseout="this.style.backgroundColor='transparent'">
                                                    <i class="fas fa-cog me-2"></i> Admin Dashboard
                                                </a>
                                            </li>
                                            <li><hr class="dropdown-divider" style="border-color: #404040;" /></li>
                                        }

                                        <li>
                                            <form asp-area="Identity" asp-page="/Account/Logout" method="post" class="d-inline">
                                                <button type="submit" class="dropdown-item text-light" onmouseover="this.style.backgroundColor='rgba(229, 9, 20, 0.8)'" onmouseout="this.style.backgroundColor='transparent'">
                                                    <i class="fas fa-sign-out-alt me-2"></i> Logout
                                                </button>
                                            </form>
                                        </li>
                                    </ul>
                                </div>
                            }
                            else
                            {
                                <a class="nav-link ms-3 text-white" asp-area="Identity" asp-page="/Account/Login">
                                    <i class="fas fa-sign-in-alt me-1"></i> Login
                                </a>
                            }
                        </div>
                    </div>
                </div>
            </div>
        </nav>

        <main>
            @RenderBody()
        </main>

        <footer class="netflix-footer">
            <div class="footer-content">
                <div class="social-links">
                    <a href="#" aria-label="Facebook"><i class="fab fa-facebook" aria-hidden="true"></i></a>
                    <a href="#" aria-label="Instagram"><i class="fab fa-instagram" aria-hidden="true"></i></a>
                    <a href="#" aria-label="Twitter"><i class="fab fa-twitter" aria-hidden="true"></i></a>
                    <a href="#" aria-label="YouTube"><i class="fab fa-youtube" aria-hidden="true"></i></a>
                </div>

                <div class="footer-grid">
                    <div class="footer-section">
                        <h5>Explore</h5>
                        <ul>
                            <li><a href="/">New Movies</a></li>
                            <li><a href="#">Trending</a></li>
                            <li><a href="#">Genres</a></li>
                            <li><a href="#">Countries</a></li>
                        </ul>
                    </div>

                    <div class="footer-section">
                        <h5>Support</h5>
                        <ul>
                            <li><a href="#">Help Center</a></li>
                            <li><a href="#">FAQ</a></li>
                            <li><a href="#">Contact Us</a></li>
                            <li><a href="#">Terms of Use</a></li>
                        </ul>
                    </div>

                    <div class="footer-section">
                        <h5>About Us</h5>
                        <ul>
                            <li><a href="#">About</a></li>
                            <li><a href="#">Careers</a></li>
                            <li><a href="#">Privacy Policy</a></li>
                            <li><a href="#">Legal Notices</a></li>
                        </ul>
                    </div>

                    <div class="footer-section">
                        <h5>Apps</h5>
                        <ul>
                            <li><a href="#"><i class="fab fa-apple"></i> App Store</a></li>
                            <li><a href="#"><i class="fab fa-google-play"></i> Google Play</a></li>
                            <li><a href="#"><i class="fab fa-windows"></i> Windows App</a></li>
                        </ul>
                    </div>
                </div>

                <div class="footer-bottom">
                    <div>&copy; @DateTime.Now.Year - CuongFilm </div>
                    <div class="footer-bottom-links">
                        <a href="#">Terms</a>
                        <a href="#">Privacy</a>
                        <a href="#">Cookies</a>
                    </div>
                    <div class="payment-methods">
                        <i class="fab fa-cc-visa"></i>
                        <i class="fab fa-cc-mastercard"></i>
                        <i class="fab fa-cc-paypal"></i>
                        <i class="fab fa-cc-amazon-pay"></i>
                    </div>
                </div>
            </div>
        </footer>
    </div>

    <script src="~/lib/jquery/dist/jquery.min.js" asp-append-version="true" defer></script>
    <script src="~/lib/bootstrap/dist/js/bootstrap.bundle.min.js" asp-append-version="true" defer></script>

    <script>
        (function () {
            const nav = document.getElementById('mainNav');
            if (!nav || !('IntersectionObserver' in window)) return;

            const sentinel = document.createElement('div');
            sentinel.setAttribute('aria-hidden', 'true');
            sentinel.style.position = 'absolute';
            sentinel.style.top = '0';
            sentinel.style.left = '0';
            sentinel.style.width = '1px';
            sentinel.style.height = '1px';
            document.body.prepend(sentinel);

            const observer = new IntersectionObserver(entries => {
                nav.classList.toggle('scrolled', !entries[0].isIntersecting);
            }, { rootMargin: '-32px 0px 0px 0px' });
            observer.observe(sentinel);
        })();

        $(document).ready(function () {
            let debounceTimer;

            $('#searchInput').on('input', function () {
                clearTimeout(debounceTimer);
                const query = $(this).val().trim();

                if (query.length < 2) {
                    $('#searchSuggestions').hide();
                    return;
                }

                debounceTimer = setTimeout(() => {
                    $.ajax({
                        url: '/Search/Suggestions',
                        type: 'GET',
                        data: { q: query },
                        success: function (data) {
                            const suggestionsBox = $('#searchSuggestions');
                            suggestionsBox.empty();

                            if (data && data.length > 0) {
                                data.forEach(movie => {
                                    const item = `
                                        <a href="/Movie/Detail?slug=${movie.slug}" class="suggestion-item">
                                            <img src="${movie.posterUrl || 'https://via.placeholder.com/40x60/2d2d2d/ffffff?text=No+Poster'}"
                                                 alt="${movie.title}"
                                                 onerror="this.src='https://via.placeholder.com/40x60/2d2d2d/ffffff?text=No+Poster'">
                                            <div>
                                                <div style="font-weight: 600;">${movie.title}</div>
                                                <div style="font-size: 0.8rem; color: #b3b3b3;">${movie.year || ''}</div>
                                            </div>
                                        </a>`;
                                    suggestionsBox.append(item);
                                });
                                suggestionsBox.show();
                            } else {
                                suggestionsBox.html('<div style="padding: 15px; color: #b3b3b3; text-align: center;">No results found</div>');
                                suggestionsBox.show();
                            }
                        }
                    });
                }, 300);
            });

            $(document).on('click', function (e) {
                if (!$(e.target).closest('.search-container').length) {
                    $('#searchSuggestions').fadeOut(200);
                }
            });
        });

        
        // JAVASCRIPT: CLEAN SEPARATION OF C# AND JS
        
        document.addEventListener("DOMContentLoaded", function () {
            const disclaimerModal = document.getElementById('disclaimer-modal');
            const btnAccept = document.getElementById('btn-accept-disclaimer');
            const disclaimerKey = 'cuongfilm-disclaimer-accepted-v2';

            if (!disclaimerModal || !btnAccept) return;

            if (localStorage.getItem(disclaimerKey) === 'true') {
                disclaimerModal.classList.remove('active');
                document.body.classList.remove('cf-disclaimer-open');
                return;
            }

            disclaimerModal.classList.add('active');
            document.body.classList.add('cf-disclaimer-open');
            btnAccept.focus({ preventScroll: true });

            btnAccept.addEventListener('click', function () {
                disclaimerModal.classList.remove('active');
                document.body.classList.remove('cf-disclaimer-open');
                localStorage.setItem(disclaimerKey, 'true');
            });
        });
    </script>

    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>



