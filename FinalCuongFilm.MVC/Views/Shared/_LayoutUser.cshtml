<!DOCTYPE html>
<html lang="vi">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - CuongFilm</title>
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" />
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css" />
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
</head>
<body>
    <!-- Navigation -->
    <nav class="navbar navbar-expand-lg netflix-nav" id="mainNav">
        <div class="container-fluid px-4">
            <a class="navbar-brand" href="/">
                <i class="fas fa-film"></i> CuongFilm
            </a>

            <button class="navbar-toggler" type="button" data-bs-toggle="collapse" data-bs-target="#navbarMain" style="border-color: rgba(255,255,255,0.5);">
                <span class="navbar-toggler-icon" style="filter: invert(1);"></span>
            </button>

            <div class="collapse navbar-collapse" id="navbarMain">
                <ul class="navbar-nav me-auto mb-2 mb-lg-0">
                    <li class="nav-item">
                        <a class="nav-link" asp-controller="Home" asp-action="Index">Trang chủ</a>
                    </li>

                    <li class="nav-item dropdown">
                        <a class="nav-link dropdown-toggle" href="#" id="genreDropdown" role="button" data-bs-toggle="dropdown">
                            Thể loại
                        </a>
                        <ul class="dropdown-menu mega-menu" aria-labelledby="genreDropdown">
                            @if (ViewBag.Genres != null)
                            {
                                foreach (var genre in ViewBag.Genres)
                                {
                                    <li>
                                        <a class="dropdown-item" asp-controller="Genre" asp-action="Index" asp-route-slug="@genre.Slug">
                                            @genre.Name
                                        </a>
                                    </li>
                                }
                            }
                            else
                            {
                                <li><span class="dropdown-item text-muted">Đang tải...</span></li>
                            }
                        </ul>
                    </li>

                    <li class="nav-item dropdown">
                        <a class="nav-link dropdown-toggle" href="#" id="countryDropdown" role="button" data-bs-toggle="dropdown">
                            Quốc gia
                        </a>
                        <ul class="dropdown-menu country-menu" aria-labelledby="countryDropdown">
                            @if (ViewBag.Countries != null)
                            {
                                foreach (var country in ViewBag.Countries)
                                {
                                    <li>
                                        <a class="dropdown-item" href="#">@country.Name</a>
                                    </li>
                                }
                            }
                            else
                            {
                                <li><span class="dropdown-item text-muted">Đang tải...</span></li>
                            }
                        </ul>
                    </li>

                    <li class="nav-item">
                        <a class="nav-link" href="#">Phim lẻ</a>
                    </li>
                    <li class="nav-item">
                        <a class="nav-link" href="#">Phim bộ</a>
                    </li>
                </ul>

                <ul class="navbar-nav ms-auto align-items-center">
                    <li class="nav-item me-3">
                        <form asp-controller="Search" asp-action="Index" method="get" class="netflix-search">
                            <input type="text" name="q" placeholder="Tìm kiếm phim..." />
                            <button type="submit">
                                <i class="fas fa-search"></i>
                            </button>
                        </form>
                    </li>

                    @if (User.Identity?.IsAuthenticated == true)
                    {
                        <li class="nav-item dropdown">
                            <a class="nav-link dropdown-toggle d-flex align-items-center" href="#" id="userDropdown" role="button" data-bs-toggle="dropdown">
                                <div class="user-avatar me-2">
                                    @User.Identity.Name?.Substring(0, 1).ToUpper()
                                </div>
                                <span class="d-none d-lg-inline">@User.Identity.Name</span>
                            </a>
                            <ul class="dropdown-menu dropdown-menu-end" aria-labelledby="userDropdown">
                                <li>
                                    <a class="dropdown-item" asp-controller="Home" asp-action="Profile">
                                        <i class="fas fa-user me-2"></i> Hồ sơ
                                    </a>
                                </li>
                                <li>
                                    <a class="dropdown-item" asp-controller="Home" asp-action="ContinueWatching">
                                        <i class="fas fa-play-circle me-2"></i> Xem tiếp
                                    </a>
                                </li>
                                <li>
                                    <a class="dropdown-item" asp-controller="Home" asp-action="MyList">
                                        <i class="fas fa-list me-2"></i> Danh sách của tôi
                                    </a>
                                </li>
                                <li><hr class="dropdown-divider" style="border-color: rgba(255,255,255,0.15);" /></li>
                                @if (User.IsInRole("Admin"))
                                {
                                    <li>
                                        <a class="dropdown-item" asp-area="Admin" asp-controller="Dashboard" asp-action="Index">
                                            <i class="fas fa-cog me-2"></i> Admin Dashboard
                                        </a>
                                    </li>
                                    <li><hr class="dropdown-divider" style="border-color: rgba(255,255,255,0.15);" /></li>
                                }
                                <li>
                                    <form asp-area="Identity" asp-page="/Account/Logout" method="post" class="d-inline">
                                        <button type="submit" class="dropdown-item">
                                            <i class="fas fa-sign-out-alt me-2"></i> Đăng xuất
                                        </button>
                                    </form>
                                </li>
                            </ul>
                        </li>
                    }
                    else
                    {
                        <li class="nav-item">
                            <a class="nav-link" asp-area="Identity" asp-page="/Account/Login">
                                <i class="fas fa-sign-in-alt me-1"></i> Đăng nhập
                            </a>
                        </li>
                    }
                </ul>
            </div>
        </div>
    </nav>

    <!-- Main Content -->
    <main>
        @RenderBody()
    </main>

    <!-- Footer -->
    <footer class="bg-dark text-white py-4 mt-5" style="border-top: 1px solid rgba(255,255,255,0.1);">
        <div class="container">
            <div class="row">
                <div class="col-md-6">
                    <h5><i class="fas fa-film"></i> CuongFilm</h5>
                    <p>Xem phim online miễn phí chất lượng cao</p>
                </div>
                <div class="col-md-6 text-end">
                    <p class="mb-2">&copy; 2024 CuongFilm. All rights reserved.</p>
                    <p>
                        <a href="#" class="text-white me-3 text-decoration-none">Về chúng tôi</a>
                        <a href="#" class="text-white me-3 text-decoration-none">Liên hệ</a>
                        <a href="#" class="text-white text-decoration-none">Điều khoản</a>
                    </p>
                </div>
            </div>
        </div>
    </footer>

    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/js/bootstrap.bundle.min.js"></script>

    <script>
        // Navbar scroll effect
        window.addEventListener('scroll', function() {
            const nav = document.getElementById('mainNav');
            if (window.scrollY > 50) {
                nav.classList.add('scrolled');
            } else {
                nav.classList.remove('scrolled');
            }
        });
    </script>

    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>