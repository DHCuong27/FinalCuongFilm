				$.ajax({
					url: "/Account/Register",
					type: "POST",
					data: $(this).serialize(),
					success: function (res) {
						$("#registerLoading").addClass("d-none");
						if (res.success) {
							$("#registerMessage").html(`<div class="alert alert-success">${res.message}</div>`);
							setTimeout(() => location.reload(), 1000);
						} else {
							$("#registerMessage").html(`<div class="alert alert-danger">${res.message}</div>`);
						}
					},
					error: function () {
						$("#registerLoading").addClass("d-none");
						$("#registerMessage").html(`<div class="alert alert-danger">Có lỗi xảy ra. Vui lòng thử lại!</div>`);
					}
				});
			});

			// FORGOT PASSWORD
			$("#forgotForm").on("submit", function (e) {
				e.preventDefault();
				$("#forgotMessage").html("");

				$.post("/Account/ForgotPassword", $(this).serialize(), function (res) {
					if (res.success) {
						$("#forgotMessage").html(`<div class="alert alert-success">${res.message}</div>`);
					} else {
						$("#forgotMessage").html(`<div class="alert alert-danger">${res.message}</div>`);
					}
				}).fail(function () {
					$("#forgotMessage").html(`<div class="alert alert-danger">Có lỗi xảy ra. Vui lòng thử lại!</div>`);
