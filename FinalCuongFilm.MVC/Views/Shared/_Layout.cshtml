									<div class="text-center mt-4">
										<div id="g_id_onload"
											 data-client_id="324732710940-ufir8fe90iv37efa36pgm1dejfj7a3q8.apps.googleusercontent.com"
											 data-context="signin"
											 data-ux_mode="redirect"
											 data-login_uri="https://localhost:7180/Account/GoogleOneTapCallback"
											 data-auto_prompt="true">
										</div>
									</div>


									<div class="g_id_signin" data-type="standard"></div>

