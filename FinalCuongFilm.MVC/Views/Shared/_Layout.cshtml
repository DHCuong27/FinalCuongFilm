	<script src="https://code.jquery.com/jquery-3.6.0.min.js"></script>
	<script>
		$(function () {
			// LOGIN
			$("#loginForm").submit(function (e) {
				e.preventDefault();
				$.post("/Account/Login", $(this).serialize(), function (res) {
					if (res.success) {
						$("#loginMessage").html(`<div class="alert alert-success">${res.message}</div>`);
						setTimeout(() => location.reload(), 1000);
					} else {
						$("#loginMessage").html(`<div class="alert alert-danger">${res.message}</div>`);
					}
				});
			});

			// REGISTER
			$("#registerForm").submit(function (e) {
				e.preventDefault();
				$.post("/Account/Register", $(this).serialize(), function (res) {
					if (res.success) {
						$("#registerMessage").html(`<div class="alert alert-success">${res.message}</div>`);
						setTimeout(() => location.reload(), 1000);
					} else {
						$("#registerMessage").html(`<div class="alert alert-danger">${res.message}</div>`);
					}
				});
			});

			// FORGOT PASSWORD
			$("#forgotForm").submit(function (e) {
				e.preventDefault();
				$.post("/Account/ForgotPassword", $(this).serialize(), function (res) {
					if (res.success) {
						$("#forgotMessage").html(`<div class="alert alert-success">${res.message}</div>`);
					} else {
						$("#forgotMessage").html(`<div class="alert alert-danger">${res.message}</div>`);
					}
				});
			});
		});
				document.addEventListener("DOMContentLoaded", function () {
			// Login form
			const loginForm = document.getElementById("loginForm");
			if (loginForm) {
				loginForm.addEventListener("submit", function (e) {
					e.preventDefault();
					document.getElementById("loginLoading").classList.remove("d-none");

					// simulate AJAX processing
					setTimeout(() => {
						document.getElementById("loginLoading").classList.add("d-none");
						document.getElementById("loginMessage").innerHTML =
							`<div class="alert alert-success">Login successful!</div>`;
					}, 2000);
				});
			}

			// Register form
			const registerForm = document.getElementById("registerForm");
			if (registerForm) {
				registerForm.addEventListener("submit", function (e) {
					e.preventDefault();
					document.getElementById("registerLoading").classList.remove("d-none");

					setTimeout(() => {
						document.getElementById("registerLoading").classList.add("d-none");
						document.getElementById("registerMessage").innerHTML =
							`<div class="alert alert-success">Registration successful!</div>`;
					}, 2000);
				});
			}
		});

