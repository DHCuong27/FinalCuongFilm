@using FinalCuongFilm.ApplicationCore.Entities.Identity
@using Microsoft.AspNetCore.Identity

@inject SignInManager<CuongFilmUser> SignInManager
@inject UserManager<CuongFilmUser> UserManager

<ul class="navbar-nav ms-auto">
    @if (SignInManager.IsSignedIn(User))
    {
        <li class="nav-item dropdown">
            <a class="nav-link dropdown-toggle d-flex align-items-center px-3 text-light"
               href="#" id="userDropdown" role="button"
               data-bs-toggle="dropdown" aria-expanded="false">
                <i class="bi bi-person-circle me-2"></i>
                @UserManager.GetUserName(User)
            </a>
            <ul class="dropdown-menu dropdown-menu-dark dropdown-menu-end" aria-labelledby="userDropdown">
                <li>
                    <a id="manage" class="dropdown-item" asp-area="Identity" asp-page="/Account/Manage/Index" title="Manage">
                        <i class="bi bi-gear me-2"></i>Manage Account
                    </a>
                </li>
                <li><hr class="dropdown-divider"></li>
                <li>
                    <form id="logoutForm" class="form-inline" asp-area="Identity" asp-page="/Account/Logout"
                          asp-route-returnUrl="@Url.Action("Index", "Home", new { area = "" })">
                        <button id="logout" type="submit" class="dropdown-item text-danger">
                            <i class="bi bi-box-arrow-right me-2"></i>Logout
                        </button>
                    </form>
                </li>
            </ul>
        </li>
    }
    else
    {
        <li class="nav-item dropdown">
            <a class="nav-link dropdown-toggle d-flex align-items-center px-3 text-light"
               href="#" id="memberDropdown" role="button"
               data-bs-toggle="dropdown" aria-expanded="false">
                <i class="bi bi-person-fill me-2"></i>Member
            </a>
            <ul class="dropdown-menu dropdown-menu-dark dropdown-menu-end" aria-labelledby="memberDropdown">
                <li>
                    <a class="dropdown-item" id="login" asp-area="Identity" asp-page="/Account/Login">
                        <i class="bi bi-box-arrow-in-right me-2"></i>Login
                    </a>
                </li>
                <li>
                    <a class="dropdown-item" id="register" asp-area="Identity" asp-page="/Account/Register">
                        <i class="bi bi-person-plus me-2"></i>Register
                    </a>
                </li>
            </ul>
        </li>
    }
</ul>

                        <style>
    /* Style cho Member dropdown */
    #memberDropdown {
        color: rgba(255, 255, 255, 0.85) !important;
        transition: all 0.3s ease;
        background-color: transparent;
        border: none;
    }

        #memberDropdown:hover {
            color: #fff !important;
            background-color: rgba(255, 255, 255, 0.1);
            border-radius: 0.375rem;
        }

    /* Hiệu ứng hover cho dropdown items */
    .dropdown-item {
        padding: 0.6rem 1rem;
        font-size: 0.9rem;
        transition: all 0.2s ease;
        border-radius: 0.25rem;
        margin: 0.1rem 0.5rem;
        width: auto;
    }

        .dropdown-item:hover {
            background-color: rgba(255, 193, 7, 0.15);
            transform: translateX(3px);
        }

        /* Icons trong dropdown */
        .dropdown-item i {
            width: 1.2rem;
            text-align: center;
            font-size: 1rem;
        }

    .nav-item.dropdown {
        margin-left: auto;
    }

    .dropdown-menu {
        position: absolute !important;
        right: 0;
        left: auto;
    }

    
                        </style>