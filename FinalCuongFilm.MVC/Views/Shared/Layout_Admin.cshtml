    <script>
        // Dashboard functionality
        document.addEventListener('DOMContentLoaded', function() {
            // Initialize DataTables
            $('#filmsTable').DataTable({
                "order": [[0, "desc"]],
                "pageLength": 10,
                "responsive": true
            });

            $('#usersTable').DataTable({
                "order": [[0, "desc"]],
                "pageLength": 10,
                "responsive": true
            });

            // Load sample data
            loadSampleData();

            // Initialize charts
            initCharts();

            // Form submission
            document.getElementById('saveFilmBtn').addEventListener('click', function() {
                saveFilm();
            });
        });

        function loadSampleData() {
            // Sample films data
            const films = [
