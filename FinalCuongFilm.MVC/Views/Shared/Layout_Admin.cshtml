        function initCharts() {
            // Film Statistics Chart
            const filmCtx = document.getElementById('filmChart').getContext('2d');
            new Chart(filmCtx, {
                type: 'line',
                data: {
                    labels: ['Jan', 'Feb', 'Mar', 'Apr', 'May', 'Jun'],
                    datasets: [{
                        label: 'New Films',
                        data: [12, 19, 8, 15, 22, 18],
                        borderColor: 'rgba(255, 255, 255, 0.8)',
                        backgroundColor: 'rgba(255, 255, 255, 0.1)',
                        tension: 0.4
                    }]
                },
                options: {
                    responsive: true,
                    maintainAspectRatio: false,
                    plugins: {
                        legend: {
                            display: false
                        }
                    },
                    scales: {
                        y: {
                            display: false
                        },
                        x: {
                            display: false
                        }
                    }
                }
            });
        }

        // CRUD Operations
        function saveFilm() {
            const filmData = {
                title: document.getElementById('filmTitle').value,
                description: document.getElementById('filmDescription').value,
                category: document.getElementById('filmCategory').value,
                poster: document.getElementById('filmPoster').value,
                trailer: document.getElementById('filmTrailer').value,
                status: document.getElementById('filmStatus').value,
                genres: document.getElementById('filmGenres').value
            };

            // Here you would typically make an AJAX call to save the film
            console.log('Saving film:', filmData);

            // Show success message
            alert('Film saved successfully!');

            // Close modal
            const modal = bootstrap.Modal.getInstance(document.getElementById('addFilmModal'));
            modal.hide();

            // Reset form
            document.getElementById('filmForm').reset();

            // Reload films table (in a real app, this would be an AJAX call)
            location.reload();
        }

        function editFilm(id) {
            console.log('Editing film:', id);
            // In a real app, load film data and show edit modal
            alert(`Editing film ID: ${id}`);
        }

        function viewFilm(id) {
            console.log('Viewing film:', id);
            // In a real app, redirect to film detail page
            window.open(`/Admin/Films/View/${id}`, '_blank');
        }

        function deleteFilm(id) {
            if (confirm('Are you sure you want to delete this film?')) {
                console.log('Deleting film:', id);
                // In a real app, make AJAX call to delete film
                alert(`Film ${id} deleted successfully!`);
                location.reload();
            }
        }

        function editUser(id) {
            console.log('Editing user:', id);
            // In a real app, load user data and show edit modal
            alert(`Editing user ID: ${id}`);
        }

        function deleteUser(id) {
            if (confirm('Are you sure you want to delete this user?')) {
                console.log('Deleting user:', id);
                // In a real app, make AJAX call to delete user
                alert(`User ${id} deleted successfully!`);
                location.reload();
            }
        }
    </script>
