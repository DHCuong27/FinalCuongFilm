    <style>
        :root {
            --film-primary: #dc3545;
            --film-secondary: #6c757d;
            --film-success: #28a745;
            --film-info: #17a2b8;
            --film-warning: #ffc107;
            --film-danger: #e74c3c;
        }

        .film-card {
            border-radius: 15px;
            overflow: hidden;
            transition: transform 0.3s ease;
            border: none;
        }

            .film-card:hover {
                transform: translateY(-5px);
            }

            .film-card.c1 {
                background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
            }

            .film-card.c2 {
                background: linear-gradient(135deg, #f093fb 0%, #f5576c 100%);
            }

            .film-card.c3 {
                background: linear-gradient(135deg, #4facfe 0%, #00f2fe 100%);
            }

            .film-card.c4 {
                background: linear-gradient(135deg, #43e97b 0%, #38f9d7 100%);
            }

        .btn-film {
            background: var(--film-primary);
            color: white;
            border: none;
            padding: 10px 25px;
            border-radius: 8px;
            transition: all 0.3s ease;
        }

            .btn-film:hover {
                background: #c82333;
                transform: translateY(-2px);
                box-shadow: 0 5px 15px rgba(220, 53, 69, 0.3);
            }

        .film-table {
            background: white;
            border-radius: 10px;
            overflow: hidden;
        }

            .film-table th {
                background: #f8f9fa;
                border-bottom: 2px solid #dee2e6;
                font-weight: 600;
            }

        .action-buttons .btn {
            padding: 5px 10px;
            margin: 0 2px;
            font-size: 12px;
        }

        .film-poster {
            width: 60px;
            height: 80px;
            object-fit: cover;
            border-radius: 5px;
        }

        .status-badge {
            padding: 4px 10px;
            border-radius: 20px;
            font-size: 12px;
            font-weight: 500;
        }

        .status-active {
            background: rgba(40, 167, 69, 0.1);
            color: var(--film-success);
        }

        .status-inactive {
            background: rgba(108, 117, 125, 0.1);
            color: var(--film-secondary);
        }

        .status-premium {
            background: rgba(255, 193, 7, 0.1);
            color: var(--film-warning);
        }

        .film-modal .modal-content {
            border-radius: 15px;
            border: none;
        }

        .film-form .form-label {
            font-weight: 600;
            color: #495057;
        }

        .film-form .form-control {
            border-radius: 8px;
            border: 1px solid #ced4da;
            padding: 10px 15px;
        }

            .film-form .form-control:focus {
                border-color: var(--film-primary);
                box-shadow: 0 0 0 0.2rem rgba(220, 53, 69, 0.25);
            }

        .genre-tag {
            display: inline-block;
            background: #e9ecef;
            padding: 4px 12px;
            border-radius: 20px;
            margin: 2px;
            font-size: 12px;
        }
    </style>
</head>

