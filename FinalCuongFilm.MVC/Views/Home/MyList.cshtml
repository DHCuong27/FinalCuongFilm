@model IEnumerable<FinalCuongFilm.Common.DTOs.FavoriteDto>

@{
    ViewData["Title"] = "Danh sách của tôi";
    Layout = "_LayoutUser";
}

<style>
    :root {
        --netflix-red: #e50914;
        --bg-dark: #0f0f0f;
        --bg-card: #1a1a1a;
        --bg-hover: #2a2a2a;
        --text-primary: #ffffff;
        --text-secondary: #a8a8a8;
        --border-color: #303030;
    }

    body {
        background-color: var(--bg-dark);
        color: var(--text-primary);
    }

    .mylist-container {
        max-width: 1400px;
        margin: 0 auto;
        padding: 100px 50px 50px;
    }

    .page-header {
        margin-bottom: 40px;
    }

    .page-title {
        font-size: 2.5rem;
        font-weight: 700;
        margin-bottom: 1rem;
    }

    .page-subtitle {
        color: var(--text-secondary);
        font-size: 1.1rem;
    }

    /* Movies Grid */
    .favorites-grid {
        display: grid;
        grid-template-columns: repeat(auto-fill, minmax(200px, 1fr));
        gap: 20px;
    }

    .favorite-card {
        position: relative;
        border-radius: 6px;
        overflow: hidden;
        transition: all 0.3s;
        cursor: pointer;
        aspect-ratio: 2/3;
        text-decoration: none;
    }

        .favorite-card:hover {
            transform: scale(1.05);
            z-index: 10;
        }

    .favorite-poster {
        width: 100%;
        height: 100%;
        object-fit: cover;
    }

    .favorite-overlay {
        position: absolute;
        top: 0;
        left: 0;
        right: 0;
        bottom: 0;
        background: linear-gradient(to top, rgba(0,0,0,0.95), transparent 50%);
        opacity: 0;
        transition: all 0.3s;
        display: flex;
        flex-direction: column;
        justify-content: flex-end;
        padding: 20px;
    }

    .favorite-card:hover .favorite-overlay {
        opacity: 1;
    }

    .favorite-title {
        font-size: 1rem;
        font-weight: 600;
        margin-bottom: 8px;
        color: var(--text-primary);
    }

    .favorite-meta {
        font-size: 0.85rem;
        color: var(--text-secondary);
        margin-bottom: 15px;
    }

    .favorite-actions {
        display: flex;
        gap: 10px;
    }

    .btn-play-small {
        flex: 1;
        background: var(--netflix-red);
        color: white;
        border: none;
        padding: 8px;
        border-radius: 4px;
        font-size: 0.9rem;
        cursor: pointer;
        transition: all 0.2s;
    }

        .btn-play-small:hover {
            background: #b8070f;
        }

    .btn-remove {
        width: 35px;
        height: 35px;
        background: rgba(42, 42, 42, 0.8);
        border: 1px solid rgba(255,255,255,0.3);
        color: white;
        border-radius: 50%;
        display: flex;
        align-items: center;
        justify-content: center;
        cursor: pointer;
        transition: all 0.2s;
    }

        .btn-remove:hover {
            background: var(--netflix-red);
            border-color: var(--netflix-red);
        }

    /* Empty State */
    .empty-state {
        text-align: center;
        padding: 100px 20px;
    }

    .empty-icon {
        font-size: 5rem;
        color: var(--text-secondary);
        margin-bottom: 30px;
    }

    .empty-title {
        font-size: 1.8rem;
        font-weight: 700;
        margin-bottom: 15px;
    }

    .empty-text {
        color: var(--text-secondary);
        font-size: 1.1rem;
        margin-bottom: 30px;
    }

    .btn-browse {
        background: var(--netflix-red);
        color: white;
        padding: 12px 30px;
        border: none;
        border-radius: 6px;
        font-size: 1rem;
        font-weight: 600;
        cursor: pointer;
        text-decoration: none;
        display: inline-block;
        transition: all 0.2s;
    }

        .btn-browse:hover {
            background: #b8070f;
            color: white;
            transform: scale(1.05);
        }

    /* Responsive */
    @@media (max-width: 768px) {
        .mylist-container {
            padding: 80px 20px 30px;
        }

        .page-title {
            font-size: 2rem;
        }

        .favorites-grid {
            grid-template-columns: repeat(auto-fill, minmax(150px, 1fr));
            gap: 15px;
        }
    }
</style>

<div class="mylist-container">
    <div class="page-header">
        <h1 class="page-title">
            <i class="fas fa-heart" style="color: var(--netflix-red);"></i>
            Danh sách của tôi
        </h1>
        <p class="page-subtitle">
            @if (Model.Any())
            {
                @:@Model.Count() phim yêu thích
            }
            else
            {
                @:Chưa có phim nào trong danh sách
            }
        </p>
    </div>

    @if (Model.Any())
    {
        <div class="favorites-grid">
            @foreach (var favorite in Model)
            {
                <div class="favorite-card" data-favorite-id="@favorite.Id" data-movie-id="@favorite.MovieId">
                    <img src="@(favorite.MoviePosterUrl ?? "/images/no-poster.jpg")"
                         alt="@favorite.MovieTitle"
                         class="favorite-poster">

                    <div class="favorite-overlay">
                        <div class="favorite-title">@favorite.MovieTitle</div>
                        <div class="favorite-meta">
                            <i class="far fa-calendar"></i>
                            @favorite.CreatedAt.ToString("dd/MM/yyyy")
                        </div>
                        <div class="favorite-actions">
                            <button class="btn-play-small" onclick="window.location.href='@Url.Action("Detail", "Movie", new { slug = favorite.MovieTitle.ToLower().Replace(" ", "-") })'">
                                <i class="fas fa-play"></i> Xem
                            </button>
                            <button class="btn-remove" onclick="removeFavorite('@favorite.MovieId', this)">
                                <i class="fas fa-times"></i>
                            </button>
                        </div>
                    </div>
                </div>
            }
        </div>
    }
    else
    {
        <div class="empty-state">
            <div class="empty-icon">
                <i class="far fa-heart"></i>
            </div>
            <h2 class="empty-title">Danh sách trống</h2>
            <p class="empty-text">
                Bạn chưa thêm phim nào vào danh sách yêu thích.<br>
                Hãy khám phá và thêm những bộ phim yêu thích của bạn!
            </p>
            <a href="@Url.Action("Index", "Home")" class="btn-browse">
                <i class="fas fa-film"></i> Khám phá phim
            </a>
        </div>
    }
</div>

@section Scripts {
    <script>
        function removeFavorite(movieId, button) {
            if (!confirm('Bạn có chắc muốn xóa phim này khỏi danh sách?')) {
                return;
            }

            const card = button.closest('.favorite-card');

            $.ajax({
                url: '@Url.Action("Remove", "Favorites")',
                type: 'POST',
                data: {
                    movieId: movieId,
                    __RequestVerificationToken: $('input[name="__RequestVerificationToken"]').val()
                },
                success: function(response) {
                    if (response.success) {
                        // Remove card with animation
                        card.style.transform = 'scale(0)';
                        card.style.opacity = '0';

                        setTimeout(() => {
                            card.remove();

                            // Check if list is empty
                            const remaining = document.querySelectorAll('.favorite-card').length;
                            if (remaining === 0) {
                                location.reload();
                            } else {
                                // Update count
                                const subtitle = document.querySelector('.page-subtitle');
                                if (subtitle) {
                                    subtitle.textContent = remaining + ' phim yêu thích';
                                }
                            }
                        }, 300);

                        showToast(response.message, 'success');
                    } else {
                        showToast(response.message, 'error');
                    }
                },
                error: function() {
                    showToast('Có lỗi xảy ra!', 'error');
                }
            });
        }

        function showToast(message, type) {
            const borderColor = type === 'success' ? '#46d369' : '#e50914';
            const icon = type === 'success' ? 'check-circle' : 'exclamation-circle';

            const toast = $(`
                <div style="
                    position: fixed;
                    top: 80px;
                    right: 20px;
                    background: var(--bg-card);
                    border-left: 4px solid ${borderColor};
                    padding: 1rem 1.5rem;
                    border-radius: 6px;
                    box-shadow: 0 10px 30px rgba(0,0,0,0.7);
                    z-index: 9999;
                    animation: slideIn 0.3s ease;
                    display: flex;
                    align-items: center;
                    gap: 1rem;
                    min-width: 300px;
                ">
                    <i class="fas fa-${icon}" style="color: ${borderColor}; font-size: 1.3rem;"></i>
                    <span style="color: var(--text-primary);">${message}</span>
                </div>
            `);

            $('body').append(toast);

            setTimeout(() => {
                toast.fadeOut(300, function() { $(this).remove(); });
            }, 3000);
        }
    </script>
}

@Html.AntiForgeryToken()