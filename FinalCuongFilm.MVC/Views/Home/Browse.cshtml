@using FinalCuongFilm.ApplicationCore.Entities
@model FinalCuongFilm.MVC.Models.ViewModels.MovieFilterViewModel
@{
    ViewData["Title"] = Model.PageTitle;
    Layout = "_LayoutUser";
}

<style>

    .premium-movie-badge {
        position: absolute;
        top: 8px;
        right: 8px;
        background: linear-gradient(45deg, #FFD700, #FFA500);
        color: #000;
        font-size: 0.75rem;
        font-weight: bold;
        padding: 3px 8px;
        border-radius: 5px;
        z-index: 10;
        box-shadow: 0 2px 5px rgba(0,0,0,0.5);
    }
    /* NETFLIX THEME & CUSTOM FILTER STYLES */
    .netflix-theme {
        --nf-bg: #141414;
        --nf-panel-bg: #1e1e1e;
        --nf-text: #e5e5e5;
        --nf-text-muted: #8c8c8c;
        --nf-red: #e50914;
        --nf-red-hover: #b20710;
        --nf-input-bg: #000000;
        --nf-border: #333333;
        background-color: var(--nf-bg);
        color: var(--nf-text);
        padding-top: 2rem;
        padding-bottom: 3rem;
        min-height: 100vh;
    }

    /* Page Header & Toggle Button */
    .page-header-wrapper {
        display: flex;
        justify-content: space-between;
        align-items: flex-end;
        border-bottom: 1px solid var(--nf-border);
        padding-bottom: 10px;
        margin-bottom: 20px;
    }

    .title-group {
        position: relative;
    }

    .section-title {
        color: #fff;
        font-weight: 700;
        font-size: 2rem;
        margin-bottom: 0;
    }

    .title-underline {
        height: 3px;
        width: 60px;
        background-color: var(--nf-red);
        position: absolute;
        bottom: -11px;
        left: 0;
    }

    .btn-filter-toggle {
        background-color: var(--nf-red);
        color: #fff;
        border: none;
        padding: 8px 20px;
        border-radius: 4px;
        font-weight: 600;
        display: flex;
        align-items: center;
        gap: 8px;
        transition: background-color 0.2s;
    }

        .btn-filter-toggle:hover {
            background-color: var(--nf-red-hover);
            color: #fff;
        }

    /* Filter Panel (Transparent with gradient & red accent) */
    .custom-filter-panel {
        background-color: transparent;
        border: 1px solid var(--nf-border);
        border-left: 3px solid var(--nf-red);
        border-radius: 4px;
        padding: 20px;
        margin-bottom: 30px;
        background-image: linear-gradient(to right, rgba(229, 9, 20, 0.05), transparent);
    }

    .filter-label {
        color: #b3b3b3;
        font-size: 0.75rem;
        font-weight: 600;
        text-transform: uppercase;
        letter-spacing: 1px;
        margin-bottom: 8px;
        display: flex;
        align-items: center;
        gap: 6px;
    }

    /* Form Controls Override */
    .netflix-theme .form-control,
    .netflix-theme .form-select {
        background-color: rgba(255, 255, 255, 0.05);
        color: #fff;
        border: 1px solid #404040;
        border-radius: 6px;
        height: 42px;
    }

        .netflix-theme .form-control:focus,
        .netflix-theme .form-select:focus {
            background-color: rgba(255, 255, 255, 0.1);
            border-color: var(--nf-red);
            box-shadow: none;
        }

    /* Search Input Group */
    .search-input-group {
        display: flex;
    }

        .search-input-group .form-control {
            border-top-right-radius: 0;
            border-bottom-right-radius: 0;
            border-right: none;
        }

        .search-input-group .btn-search {
            background-color: var(--nf-red);
            color: #fff;
            border: none;
            border-top-right-radius: 6px;
            border-bottom-right-radius: 6px;
            padding: 0 15px;
            transition: background-color 0.2s;
        }

            .search-input-group .btn-search:hover {
                background-color: var(--nf-red-hover);
            }

    /* Reset Button */
    .btn-reset {
        background-color: transparent;
        color: var(--nf-text-muted);
        border: 1px solid var(--nf-border);
        border-radius: 6px;
        padding: 0 20px;
        height: 42px;
        display: inline-flex;
        align-items: center;
        gap: 6px;
        text-decoration: none;
        transition: all 0.2s;
    }

        .btn-reset:hover {
            background-color: rgba(255,255,255,0.05);
            color: #fff;
            border-color: #fff;
        }

    /* Movie Card Styles */
    .nf-movie-card {
        position: relative;
        transition: transform 0.3s cubic-bezier(0.4, 0, 0.2, 1);
        cursor: pointer;
        border-radius: 4px;
        overflow: hidden;
    }

        .nf-movie-card:hover {
            transform: scale(1.08);
            z-index: 10;
            box-shadow: 0 10px 20px rgba(0,0,0,0.8);
        }

    .nf-poster {
        width: 100%;
        aspect-ratio: 2/3;
        object-fit: cover;
        border-radius: 4px;
    }

    .nf-movie-info {
        padding: 8px 0;
    }

    .nf-movie-title {
        color: #fff;
        font-size: 1rem;
        font-weight: 600;
        margin-bottom: 2px;
        text-decoration: none;
    }

        .nf-movie-title:hover {
            text-decoration: underline;
            color: #fff;
        }

    .nf-movie-meta {
        font-size: 0.85rem;
        color: var(--nf-text-muted);
        display: flex;
        align-items: center;
        gap: 6px;
    }

    /* Pagination Styles */
    .netflix-theme .pagination .page-link {
        background-color: #000;
        color: #fff;
        border: 1px solid var(--nf-border);
    }

    .netflix-theme .pagination .page-item.active .page-link {
        background-color: var(--nf-red);
        border-color: var(--nf-red);
    }

    .netflix-theme .pagination .page-link:hover {
        background-color: rgba(255,255,255,0.1);
    }
</style>

<div class="netflix-theme">
    <div class="container">

        <div class="page-header-wrapper">
            <div class="title-group">
                <h2 class="section-title">@Model.PageTitle</h2>
                <div class="title-underline"></div>
            </div>

            <button class="btn-filter-toggle" type="button" data-bs-toggle="collapse" data-bs-target="#filterCollapsePanel" aria-expanded="false" aria-controls="filterCollapsePanel">
                <i class="zmdi zmdi-filter-list"></i> Filter
            </button>
        </div>

        <div class="collapse" id="filterCollapsePanel">
            <div class="custom-filter-panel">
                <form asp-action="Browse" method="get">
                    <input type="hidden" name="type" value="@Model.Type" />
               
                    <div class="row align-items-end g-4">
                        <div class="col-12 col-md-4 col-lg-3">
                            <label class="filter-label">Search</label>
                            <div class="search-input-group">
                                <input type="text" name="search" value="@Model.Search" class="form-control" placeholder="Type a title..." />
                                <button type="submit" class="btn-search"><i class="zmdi zmdi-search"></i></button>
                            </div>
                        </div>

                        <div class="col-6 col-md-4 col-lg-2">
                            <label class="filter-label">Genre</label>
                            <select name="genreId" class="form-select" onchange="this.form.submit()">
                                <option value="">All Genres</option>
                                @if (ViewBag.Genres != null)
                                {
                                    foreach (var genre in ViewBag.Genres)
                                    {
                                        <option value="@genre.Id" selected="@(genre.Id == Model.GenreId)">@genre.Name</option>
                                    }
                                }
                            </select>
                        </div>

                        <div class="col-6 col-md-4 col-lg-2">
                            <label class="filter-label">Country</label>
                            <select name="countryId" class="form-select" onchange="this.form.submit()">
                                <option value="">All Countries</option>
                                @if (ViewBag.Countries != null)
                                {
                                    foreach (var country in ViewBag.Countries)
                                    {
                                        <option value="@country.Id" selected="@(country.Id == Model.CountryId)">@country.Name</option>
                                    }
                                }
                            </select>
                        </div>

                        <div class="col-6 col-md-4 col-lg-2">
                            <label class="filter-label">Sort By</label>
                            <select name="sortBy" class="form-select" onchange="this.form.submit()">
                                <option value="latest" selected="@(Model.SortBy == "latest")">Latest</option>
                                <option value="popular" selected="@(Model.SortBy == "popular")">Most Popular</option>
                                <option value="year_asc" selected="@(Model.SortBy == "year_asc")">Oldest</option>
                            </select>
                        </div>

                        <div class="col-6 col-md-8 col-lg-3 text-start text-lg-end">
                            <a asp-action="Browse" asp-route-type="@Model.Type" class="btn-reset">
                                <i class="zmdi zmdi-refresh"></i> Reset Filters
                            </a>
                        </div>
                    </div>
                </form>

                <div class="mt-4 pt-3 border-top" style="border-color: rgba(255,255,255,0.1) !important; font-size: 0.9rem; color: var(--nf-text-muted);">
                    Showing <span style="color: #fff; font-weight: bold;">@(Model.Movies?.Count ?? 0)</span> results out of <span style="color: #fff; font-weight: bold;">@Model.TotalItems</span> total
                </div>
            </div>
        </div>

        <div class="row g-3 g-md-4">
            @if (Model.Movies != null && Model.Movies.Any())
            {
                foreach (var item in Model.Movies)
                {
                    <div class="col-6 col-sm-4 col-md-3 col-lg-2-4" style="width: 20%; flex: 0 0 auto; min-width: 150px;">
                        <div class="nf-movie-card">
                            <!-- THÊM ĐOẠN NÀY VÀO ĐÂY -->
                            @if (item.IsVipOnly)
                            {
                                <div class="premium-movie-badge">
                                    <i class="fa-solid fa-crown"></i> VIP
                                </div>
                            }
                                <a asp-controller="Movie" asp-action="Detail" asp-route-slug="@item.Slug" class="d-block">
                                <img src="@item.PosterUrl" alt="@item.Title" class="nf-poster" />
                            </a>
                            <div class="nf-movie-info">
                                <a asp-controller="Movie" asp-action="Detail" asp-route-slug="@item.Slug" class="nf-movie-title text-truncate d-block">
                                    @item.Title  -
                                    <span>@item.ReleaseYear</span>
                                </a>
                  
                            </div>
                        </div>
                    </div>
                }
            }
            else
            {
                <div class="col-12 text-center" style="padding: 100px 0;">
                    <i class="zmdi zmdi-movie" style="font-size: 5rem; color: #404040;"></i>
                    <h4 class="mt-3" style="color: #fff;">No content matches your filters</h4>
                    <p class="text-muted">Try adjusting your search or filter categories.</p>
                </div>
            }
        </div>

        @if (Model.TotalPages > 1)
        {
            <div class="row mt-5 mb-4">
                <div class="col-12 d-flex justify-content-center">
                    <ul class="pagination">
                        <li class="page-item @(!Model.HasPreviousPage ? "disabled" : "")">
                            <a class="page-link" asp-action="Browse"
                               asp-route-type="@Model.Type" asp-route-search="@Model.Search"
                               asp-route-genreId="@Model.GenreId" asp-route-countryId="@Model.CountryId"
                               asp-route-sortBy="@Model.SortBy" asp-route-pageNumber="@(Model.PageNumber - 1)">«</a>
                        </li>

                        @for (int i = 1; i <= Model.TotalPages; i++)
                        {
                            <li class="page-item @(i == Model.PageNumber ? "active" : "")">
                                <a class="page-link" asp-action="Browse"
                                   asp-route-type="@Model.Type" asp-route-search="@Model.Search"
                                   asp-route-genreId="@Model.GenreId" asp-route-countryId="@Model.CountryId"
                                   asp-route-sortBy="@Model.SortBy" asp-route-pageNumber="@i">@i</a>
                            </li>
                        }

                        <li class="page-item @(!Model.HasNextPage ? "disabled" : "")">
                            <a class="page-link" asp-action="Browse"
                               asp-route-type="@Model.Type" asp-route-search="@Model.Search"
                               asp-route-genreId="@Model.GenreId" asp-route-countryId="@Model.CountryId"
                               asp-route-sortBy="@Model.SortBy" asp-route-pageNumber="@(Model.PageNumber + 1)">»</a>
                        </li>
                    </ul>
                </div>
            </div>
        }
    </div>
</div>