@using FinalCuongFilm.ApplicationCore.Entities
@model FinalCuongFilm.MVC.Models.ViewModels.MovieFilterViewModel
@{
    ViewData["Title"] = Model.PageTitle;
    Layout = "_LayoutUser";
}

<style>
    :root {
        --netflix-red: #e50914;
        --netflix-dark: #0f0f0f;
        --netflix-dark-bg: #1a1a1a;
        --netflix-gray: #2d2d2d;
        --netflix-light-gray: #b3b3b3;
        --netflix-white: #ffffff;
    }

    .premium-movie-badge {
        position: absolute;
        top: 8px;
        right: 8px;
        background: linear-gradient(45deg, #FFD700, #FFA500);
        color: #000;
        font-size: 0.75rem;
        font-weight: bold;
        padding: 3px 8px;
        border-radius: 5px;
        z-index: 10;
        box-shadow: 0 2px 5px rgba(0,0,0,0.5);
    }

    body {
        background-color: var(--netflix-dark);
        color: var(--netflix-white);
        font-family: 'Segoe UI', sans-serif;
    }

    .page-container {
        max-width: 1400px;
        margin: 0 auto;
        padding: 100px 2rem 3rem;
    }

    /* Section Header */
    .section-header {
        display: flex;
        align-items: center;
        justify-content: space-between;
        gap: 1rem;
        margin-bottom: 2rem;
        padding-bottom: 0.75rem;
        border-bottom: 1px solid rgba(255,255,255,0.1);
        position: relative;
    }

        .section-header::after {
            content: '';
            position: absolute;
            bottom: -1px;
            left: 0;
            width: 60px;
            height: 2px;
            background: var(--netflix-red);
            opacity: 0.6;
        }

    .section-header-left {
        display: flex;
        align-items: center;
        gap: 0.75rem;
    }

        .section-header-left i {
            font-size: 1.5rem;
            color: var(--netflix-red);
        }

        .section-header-left h1 {
            font-size: 1.8rem;
            font-weight: 700;
            margin: 0;
        }

        .section-header-left p {
            color: var(--netflix-light-gray);
            font-size: 0.9rem;
            margin: 0.2rem 0 0;
        }

    /* Toggle Filter Button */
    .btn-toggle-filter {
        background: rgba(255,255,255,0.1);
        color: var(--netflix-white);
        border: 1px solid rgba(255,255,255,0.3);
        border-radius: 8px;
        padding: 0.6rem 1.2rem;
        font-size: 0.95rem;
        font-weight: 600;
        cursor: pointer;
        display: flex;
        align-items: center;
        gap: 8px;
        transition: all 0.3s;
    }

        .btn-toggle-filter:hover, .btn-toggle-filter.active {
            background: var(--netflix-red);
            border-color: var(--netflix-red);
        }

    /* Filter Bar */
    .filter-bar {
        background: var(--netflix-dark-bg);
        border: 1px solid var(--netflix-gray);
        border-radius: 12px;
        padding: 1.5rem;
        margin-bottom: 2rem;
    }

    .filter-row {
        display: flex;
        flex-wrap: wrap;
        gap: 1rem;
        align-items: flex-end;
    }

    .filter-group {
        display: flex;
        flex-direction: column;
        gap: 0.4rem;
        flex: 1;
        min-width: 140px;
    }

        .filter-group label {
            font-size: 0.8rem;
            font-weight: 600;
            color: var(--netflix-light-gray);
            text-transform: uppercase;
            letter-spacing: 0.5px;
        }

    .filter-select {
        background: var(--netflix-gray);
        border: 1px solid rgba(255,255,255,0.15);
        color: white;
        border-radius: 8px;
        padding: 0.6rem 1rem;
        font-size: 0.9rem;
        cursor: pointer;
        transition: border-color 0.2s;
    }

        .filter-select:focus {
            outline: none;
            border-color: var(--netflix-red);
        }

        .filter-select option {
            background: var(--netflix-gray);
        }

    /* Search Input Wrapper */
    .search-input-wrapper {
        display: flex;
        background: var(--netflix-gray);
        border: 1px solid rgba(255,255,255,0.15);
        border-radius: 8px;
        overflow: hidden;
        transition: border-color 0.2s;
    }

        .search-input-wrapper:focus-within {
            border-color: var(--netflix-red);
        }

        .search-input-wrapper input {
            flex: 1;
            background: transparent;
            border: none;
            color: white;
            font-size: 0.9rem;
            padding: 0.6rem 1rem;
            outline: none;
        }

        .search-input-wrapper input::placeholder {
            color: var(--netflix-light-gray);
        }

        .search-input-wrapper .btn-search {
            background: var(--netflix-red);
            color: white;
            border: none;
            padding: 0.6rem 1rem;
            cursor: pointer;
            font-size: 0.85rem;
            transition: background 0.2s;
        }

        .search-input-wrapper .btn-search:hover {
            background: #f40612;
        }

    /* Reset Button */
    .btn-reset {
        background: transparent;
        color: var(--netflix-light-gray);
        border: 1px solid rgba(255,255,255,0.2);
        border-radius: 8px;
        padding: 0.65rem 1.2rem;
        font-size: 0.9rem;
        cursor: pointer;
        transition: all 0.2s;
        white-space: nowrap;
        text-decoration: none;
        display: inline-flex;
        align-items: center;
        gap: 0.3rem;
    }

        .btn-reset:hover {
            border-color: var(--netflix-red);
            color: var(--netflix-red);
        }

    /* Filter Result Count */
    .filter-result-count {
        font-size: 0.9rem;
        color: var(--netflix-light-gray);
        margin-top: 0.8rem;
    }

        .filter-result-count span {
            color: var(--netflix-red);
            font-weight: 700;
        }

    /* Movie Card Styles */
    .nf-movie-card {
        position: relative;
        transition: transform 0.3s cubic-bezier(0.4, 0, 0.2, 1);
        cursor: pointer;
        border-radius: 4px;
        overflow: hidden;
    }

        .nf-movie-card:hover {
            transform: scale(1.08);
            z-index: 10;
            box-shadow: 0 10px 20px rgba(0,0,0,0.8);
        }

    .nf-poster {
        width: 100%;
        aspect-ratio: 2/3;
        object-fit: cover;
        border-radius: 4px;
    }

    .nf-movie-info {
        padding: 8px 0;
    }

    .nf-movie-title {
        color: #fff;
        font-size: 1rem;
        font-weight: 600;
        margin-bottom: 2px;
        text-decoration: none;
    }

        .nf-movie-title:hover {
            text-decoration: underline;
            color: #fff;
        }

    .nf-movie-meta {
        font-size: 0.85rem;
        color: var(--netflix-light-gray);
        display: flex;
        align-items: center;
        gap: 6px;
    }

    /* Pagination Styles */
    .pagination-wrapper {
        display: flex;
        justify-content: center;
        align-items: center;
        gap: 0.5rem;
        margin: 2rem 0;
        flex-wrap: wrap;
    }

    .page-btn {
        background: var(--netflix-gray);
        color: white;
        border: 1px solid rgba(255,255,255,0.1);
        padding: 0.5rem 0.9rem;
        border-radius: 6px;
        cursor: pointer;
        text-decoration: none;
        font-size: 0.9rem;
        transition: all 0.2s;
    }

        .page-btn:hover {
            background: var(--netflix-red);
            border-color: var(--netflix-red);
            color: white;
        }

        .page-btn.active {
            background: var(--netflix-red);
            border-color: var(--netflix-red);
            font-weight: 700;
        }

        .page-btn.disabled {
            opacity: 0.4;
            pointer-events: none;
        }

    .pagination-info {
        color: var(--netflix-light-gray);
        font-size: 0.85rem;
        margin: 0 0.5rem;
    }

    /* No results */
    .netflix-alert {
        background: var(--netflix-dark-bg);
        border: 1px solid var(--netflix-gray);
        border-radius: 8px;
        padding: 3rem 2rem;
        margin: 2rem 0;
        text-align: center;
    }

        .netflix-alert i {
            color: var(--netflix-red);
            font-size: 3rem;
            margin-bottom: 1rem;
            display: block;
        }

        .netflix-alert h3 {
            font-size: 1.5rem;
            margin-bottom: 0.5rem;
        }

        .netflix-alert p {
            color: var(--netflix-light-gray);
        }

    @@media (max-width: 768px) {
        .page-container {
            padding: 80px 1rem 2rem;
        }

        .section-header-left h1 {
            font-size: 1.4rem;
        }

        .filter-row {
            flex-direction: column;
        }
    }
</style>

<div class="page-container">

    <div class="section-header">
        <div class="section-header-left">
            <i class="fas fa-@(Model.Type == 2 ? "tv" : "film")"></i>
            <div>
                <h1>@Model.PageTitle</h1>
                @if (!string.IsNullOrEmpty(Model.PageSubTitle))
                {
                    <p>@Model.PageSubTitle</p>
                }
            </div>
        </div>

        <button id="btnToggleFilter" class="btn-toggle-filter">
            <i class="fas fa-sliders-h"></i> Filter
        </button>
    </div>

    <div class="filter-bar" id="filterBarPanel" style="display: none;">
        <form method="get" asp-action="Browse" asp-controller="Home" id="filterForm">
            <input type="hidden" name="type" value="@Model.Type" />

            <div class="filter-row">
                <div class="filter-group" style="flex:2; min-width:200px;">
                    <label><i class="fas fa-search"></i> Search</label>
                    <div class="search-input-wrapper">
                        <input type="text" name="search" value="@Model.Search" placeholder="Movie title..." />
                        <button type="submit" class="btn-search"><i class="fas fa-search"></i></button>
                    </div>
                </div>

                <div class="filter-group">
                    <label><i class="fas fa-theater-masks"></i> Genre</label>
                    <select name="genreId" class="filter-select">
                        <option value="">All</option>
                        @foreach (var g in Model.Genres)
                        {
                            <option value="@g.Id" selected="@(Model.GenreId == g.Id ? "selected" : null)">@g.Name</option>
                        }
                    </select>
                </div>

                <div class="filter-group">
                    <label><i class="fas fa-globe"></i> Country</label>
                    <select name="countryId" class="filter-select">
                        <option value="">All</option>
                        @foreach (var c in Model.Countries)
                        {
                            <option value="@c.Id" selected="@(Model.CountryId == c.Id ? "selected" : null)">@c.Name</option>
                        }
                    </select>
                </div>

                <div class="filter-group">
                    <label><i class="fas fa-sort"></i> Sort by</label>
                    <select name="sortBy" class="filter-select">
                        <option value="latest" selected="@(Model.SortBy == "latest" ? "selected" : null)">Latest</option>
                        <option value="popular" selected="@(Model.SortBy == "popular" ? "selected" : null)">Most Popular</option>
                        <option value="title" selected="@(Model.SortBy == "title" ? "selected" : null)">Name A-Z</option>
                    </select>
                </div>

                <div class="filter-group" style="justify-content:flex-end; flex-direction:row; gap:0.5rem;">
                    <a asp-action="Browse" asp-controller="Home" asp-route-type="@Model.Type" class="btn-reset"><i class="fas fa-times"></i> Reset</a>
                </div>
            </div>

            <div class="filter-result-count">
                Showing <span>@Model.Movies.Count</span> / <span>@Model.TotalItems</span> @(Model.Type == 2 ? "series" : "movies")
                @if (!string.IsNullOrEmpty(Model.Search) || Model.GenreId.HasValue || Model.CountryId.HasValue)
                {
                    <span style="margin-left:0.5rem; color:var(--netflix-light-gray);">(filtered)</span>
                }
            </div>
        </form>
    </div>

    <div class="row g-3 g-md-4">
        @if (Model.Movies != null && Model.Movies.Any())
        {
            foreach (var item in Model.Movies)
            {
                <div class="col-6 col-sm-4 col-md-3 col-lg-2-4" style="width: 20%; flex: 0 0 auto; min-width: 150px;">
                    <div class="nf-movie-card">
                        @if (item.IsVipOnly)
                        {
                            <div class="premium-movie-badge">
                                <i class="fa-solid fa-crown"></i> VIP
                            </div>
                        }
                        <a asp-controller="Movie" asp-action="Detail" asp-route-slug="@item.Slug" class="d-block">
                            <img src="@item.PosterUrl" alt="@item.Title" class="nf-poster" />
                        </a>
                        <div class="nf-movie-info">
                            <a asp-controller="Movie" asp-action="Detail" asp-route-slug="@item.Slug" class="nf-movie-title text-truncate d-block">
                                @item.Title
                            </a>
                            <div class="nf-movie-meta">
                                @if (item.ReleaseYear.HasValue)
                                {
                                    <span><i class="fas fa-calendar"></i> @item.ReleaseYear</span>
                                }
                                @if (!string.IsNullOrEmpty(item.CountryName))
                                {
                                    <span>@item.CountryName</span>
                                }
                            </div>
                        </div>
                    </div>
                </div>
            }
        }
        else
        {
            <div class="col-12">
                <div class="netflix-alert">
                    <i class="fas fa-search"></i>
                    <h3>No content matches your filters</h3>
                    <p>Try adjusting your search or filter categories, or <a asp-action="Browse" asp-controller="Home" asp-route-type="@Model.Type" style="color:var(--netflix-red);">reset all filters</a>.</p>
                </div>
            </div>
        }
    </div>

    @if (Model.TotalPages > 1)
    {
        <div class="pagination-wrapper">
            <a asp-action="Browse" asp-controller="Home"
               asp-route-type="@Model.Type" asp-route-search="@Model.Search"
               asp-route-genreId="@Model.GenreId" asp-route-countryId="@Model.CountryId"
               asp-route-sortBy="@Model.SortBy" asp-route-pageNumber="@(Model.PageNumber - 1)"
               class="page-btn @(!Model.HasPreviousPage ? "disabled" : "")">
                <i class="fas fa-chevron-left"></i> Previous
            </a>

            @if (Model.PageNumber > 3)
            {
                <span class="pagination-info">...</span>
            }

            @for (int i = Math.Max(1, Model.PageNumber - 2); i <= Math.Min(Model.TotalPages, Model.PageNumber + 2); i++)
            {
                <a asp-action="Browse" asp-controller="Home"
                   asp-route-type="@Model.Type" asp-route-search="@Model.Search"
                   asp-route-genreId="@Model.GenreId" asp-route-countryId="@Model.CountryId"
                   asp-route-sortBy="@Model.SortBy" asp-route-pageNumber="@i"
                   class="page-btn @(i == Model.PageNumber ? "active" : "")">@i</a>
            }

            @if (Model.PageNumber < Model.TotalPages - 2)
            {
                <span class="pagination-info">...</span>
            }

            <a asp-action="Browse" asp-controller="Home"
               asp-route-type="@Model.Type" asp-route-search="@Model.Search"
               asp-route-genreId="@Model.GenreId" asp-route-countryId="@Model.CountryId"
               asp-route-sortBy="@Model.SortBy" asp-route-pageNumber="@(Model.PageNumber + 1)"
               class="page-btn @(!Model.HasNextPage ? "disabled" : "")">
                Next <i class="fas fa-chevron-right"></i>
            </a>
        </div>
        <div style="text-align:center; color:var(--netflix-light-gray); font-size:0.85rem; margin-top:-1rem; margin-bottom:2rem;">
            Page @Model.PageNumber of @Model.TotalPages — @Model.TotalItems @(Model.Type == 2 ? "series" : "movies") total
        </div>
    }
</div>

@section Scripts {
    <script>
        $(document).ready(function () {
            $('#btnToggleFilter').click(function () {
                $('#filterBarPanel').slideToggle(300);
                $(this).toggleClass('active');
            });

            // Keep filter open if URL has active filter params
            if (window.location.search.length > 1) {
                var params = new URLSearchParams(window.location.search);
                if (params.get('search') || params.get('genreId') || params.get('countryId') || params.get('sortBy')) {
                    $('#filterBarPanel').show();
                    $('#btnToggleFilter').addClass('active');
                }
            }
        });
    </script>
}