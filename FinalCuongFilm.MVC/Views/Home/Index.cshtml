@model FinalCuongFilm.MVC.Models.ViewModels.HomeFilterViewModel
@{
    ViewData["Title"] = "Home";
    Layout = "_LayoutUser";
    var f = Model.AllMoviesFilter;

    // Get top 5 popular movies for the slider
    var featuredMovies = Model.PopularMovies.Take(5).ToList();
}

<style>
    :root {
        --netflix-red: #e50914;
        --netflix-dark: #0f0f0f;
        --netflix-dark-bg: #1a1a1a;
        --netflix-gray: #2d2d2d;
        --netflix-light-gray: #b3b3b3;
        --netflix-white: #ffffff;
    }

    body {
        background-color: var(--netflix-dark);
        color: var(--netflix-white);
        font-family: 'Segoe UI', sans-serif;
        margin: 0;
        padding: 0;
    }

    /* =========================================
           HERO SLIDER SECTION (UPDATED POSTER SIZE)
           ========================================= */
    .hero-slider-section {
        position: relative;
        margin-bottom: 4rem;
        background-color: var(--netflix-dark);
    }

    .hero-slider-container {
        position: relative;
        height: 90vh; /* Tăng chiều cao */
        min-height: 700px;
        overflow: hidden;
    }

    .hero-slide {
        position: absolute;
        inset: 0;
        opacity: 0;
        visibility: hidden;
        transition: opacity 0.8s ease-in-out, visibility 0.8s;
        z-index: 1;
        display: flex;
        align-items: center;
        justify-content: center;
    }

        .hero-slide.active {
            opacity: 1;
            visibility: visible;
            z-index: 2;
        }

    .hero-bg {
        position: absolute;
        inset: -20px;
        background-size: cover;
        background-position: center top;
        filter: blur(15px) brightness(0.3);
        z-index: 1;
    }

    .hero-slider-container::after {
        content: '';
        position: absolute;
        bottom: 0;
        left: 0;
        right: 0;
        height: 150px;
        background: linear-gradient(180deg, transparent 0%, var(--netflix-dark) 100%);
        z-index: 5;
        pointer-events: none;
    }

    .hero-content-wrapper {
        position: relative;
        z-index: 3;
        width: 100%;
        max-width: 1400px;
        margin: 0 auto;
        padding: 0 4rem;
        display: flex;
        align-items: center;
        justify-content: space-between;
        gap: 3rem;
    }

    /* Left Text Content */
    .hero-text-content {
        flex: 1;
        max-width: 700px;
        transform: translateY(30px);
        opacity: 0;
        transition: all 0.8s ease-out 0.3s;
    }

    .hero-slide.active .hero-text-content {
        transform: translateY(0);
        opacity: 1;
    }

    .featured-title {
        font-size: 3.5rem;
        font-weight: 900;
        margin-bottom: 1rem;
        text-shadow: 2px 2px 4px rgba(0,0,0,0.6);
        line-height: 1.1;
    }

    .featured-meta {
        display: flex;
        align-items: center;
        gap: 1rem;
        margin-bottom: 1.5rem;
        font-size: 1.1rem;
        color: var(--netflix-white);
        text-shadow: 1px 1px 2px rgba(0,0,0,0.8);
    }

        .featured-meta .match {
            color: #46d369;
            font-weight: 700;
        }

        .featured-meta .badge-hd {
            border: 1px solid rgba(255,255,255,0.6);
            padding: 0.1rem 0.5rem;
            border-radius: 3px;
            font-size: 0.8rem;
        }

    .featured-desc {
        font-size: 1.2rem;
        color: #e5e5e5;
        margin-bottom: 2rem;
        line-height: 1.5;
        display: -webkit-box;
        -webkit-line-clamp: 3;
        -webkit-box-orient: vertical;
        overflow: hidden;
        text-shadow: 1px 1px 2px rgba(0,0,0,0.8);
    }

    .featured-actions {
        display: flex;
        gap: 1rem;
        margin-bottom: 2.5rem;
    }

    .btn-netflix-primary, .btn-netflix-secondary {
        display: flex;
        align-items: center;
        gap: 0.6rem;
        padding: 0.8rem 2rem;
        border-radius: 6px;
        font-size: 1.1rem;
        font-weight: 600;
        text-decoration: none;
        transition: 0.2s;
        border: none;
        cursor: pointer;
    }

    .btn-netflix-primary {
        background: white;
        color: black;
    }

        .btn-netflix-primary:hover {
            background: rgba(255,255,255,0.75);
        }

    .btn-netflix-secondary {
        background: rgba(109,109,110,0.7);
        color: white;
    }

        .btn-netflix-secondary:hover {
            background: rgba(109,109,110,0.4);
        }

    /* Right Poster Content (Enlarged) */
    .hero-poster-content {
        flex: 0 0 400px; /* Poster rộng hơn */
        transform: scale(0.9) translateX(30px);
        opacity: 0;
        transition: all 0.8s ease-out 0.4s;
        z-index: 10;
    }

    .hero-slide.active .hero-poster-content {
        transform: scale(1) translateX(0);
        opacity: 1;
    }

    .full-poster-img {
        width: 100%;
        height: auto;
        max-height: 600px;
        aspect-ratio: 2/3;
        object-fit: cover;
        border-radius: 16px;
        box-shadow: 0 25px 60px rgba(0,0,0,0.95);
        border: 1px solid rgba(255,255,255,0.15);
        transition: transform 0.4s ease;
    }

        .full-poster-img:hover {
            transform: translateY(-10px) scale(1.02);
            box-shadow: 0 30px 70px rgba(0,0,0,1);
        }

    /* Slider Nav & Indicators */
    .slider-nav-btn {
        position: absolute;
        top: 50%;
        transform: translateY(-50%);
        background: rgba(0,0,0,0.3);
        color: white;
        border: none;
        font-size: 2rem;
        width: 60px;
        height: 100px;
        cursor: pointer;
        z-index: 10;
        display: flex;
        align-items: center;
        justify-content: center;
        transition: 0.3s;
    }

        .slider-nav-btn:hover {
            background: rgba(0,0,0,0.8);
            color: var(--netflix-red);
        }

    .prev-btn {
        left: 0;
        border-radius: 0 8px 8px 0;
    }

    .next-btn {
        right: 0;
        border-radius: 8px 0 0 8px;
    }

    .slider-indicators {
        position: absolute;
        bottom: 80px;
        left: 50%;
        transform: translateX(-50%);
        display: flex;
        gap: 10px;
        z-index: 10;
    }

        .slider-indicators .dot {
            width: 12px;
            height: 12px;
            background: rgba(255,255,255,0.4);
            border-radius: 50%;
            cursor: pointer;
            transition: 0.3s;
        }

            .slider-indicators .dot.active {
                background: var(--netflix-red);
                transform: scale(1.3);
            }

    /* Search Overlay */
    .global-search-overlay {
        position: absolute;
        bottom: 120px;
        left: 0;
        right: 0;
        z-index: 15;
    }

    .banner-search-container {
        max-width: 600px;
        margin: 0 auto;
        position: relative;
        padding: 0 2rem;
    }

    .search-input-wrapper {
        display: flex;
        background: rgba(0,0,0,0.75);
        border: 2px solid rgba(255,255,255,0.1);
        border-radius: 40px;
        padding: 3px 3px 3px 20px;
        backdrop-filter: blur(10px);
        transition: all 0.3s;
    }

        .search-input-wrapper:focus-within {
            border-color: var(--netflix-red);
            background: rgba(0,0,0,0.95);
            box-shadow: 0 0 20px rgba(229,9,20,0.3);
        }

        .search-input-wrapper input {
            flex: 1;
            background: transparent;
            border: none;
            color: white;
            font-size: 1.1rem;
            padding: 12px 0;
            outline: none;
        }

            .search-input-wrapper input::placeholder {
                color: var(--netflix-light-gray);
            }

        .search-input-wrapper .btn-search {
            background: var(--netflix-red);
            color: white;
            border: none;
            border-radius: 40px;
            padding: 12px 30px;
            font-size: 1rem;
            font-weight: 600;
            cursor: pointer;
            display: flex;
            align-items: center;
            gap: 8px;
        }

            .search-input-wrapper .btn-search:hover {
                background: #f40612;
            }

    .search-suggestions-box {
        position: absolute;
        top: 100%;
        left: 0;
        right: 0;
        margin-top: 10px;
        background: var(--netflix-dark-bg);
        border: 1px solid var(--netflix-gray);
        border-radius: 10px;
        overflow: hidden;
        box-shadow: 0 10px 30px rgba(0,0,0,0.8);
        display: none;
    }

    .suggestion-item {
        display: flex;
        align-items: center;
        padding: 10px 15px;
        color: white;
        text-decoration: none;
        border-bottom: 1px solid rgba(255,255,255,0.05);
        transition: 0.2s;
    }

        .suggestion-item:hover {
            background: rgba(255,255,255,0.1);
        }

        .suggestion-item img {
            width: 40px;
            height: 60px;
            object-fit: cover;
            border-radius: 4px;
            margin-right: 15px;
        }

    /* =========================================
           GENERAL LAYOUT & GRIDS
           ========================================= */
    .container {
        max-width: 1400px;
        margin: 0 auto;
        padding: 0 2rem;
    }

    .section-header {
        display: flex;
        align-items: center;
        justify-content: space-between;
        gap: 1rem;
        margin-bottom: 2rem;
        padding-bottom: 1rem;
        border-bottom: 2px solid var(--netflix-gray);
        position: relative;
    }

        .section-header::after {
            content: '';
            position: absolute;
            bottom: -2px;
            left: 0;
            width: 100px;
            height: 2px;
            background: var(--netflix-red);
        }

    .section-header-left {
        display: flex;
        align-items: center;
        gap: 1rem;
    }

    .section-header i {
        font-size: 2rem;
        color: var(--netflix-red);
        background: rgba(229,9,20,0.1);
        padding: 0.8rem;
        border-radius: 8px;
    }

    .section-header h2 {
        font-size: 2rem;
        font-weight: 800;
        margin: 0;
    }

    /* Scroll Rows */
    .movies-row-container {
        position: relative;
        margin-bottom: 4rem;
    }

    .movies-row {
        display: flex;
        overflow-x: auto;
        padding: 1rem 0.5rem;
        scrollbar-width: none;
        gap: 1.2rem;
        scroll-behavior: smooth;
    }

        .movies-row::-webkit-scrollbar {
            display: none;
        }

    .scroll-arrow {
        position: absolute;
        top: 50%;
        transform: translateY(-50%);
        background: rgba(0,0,0,0.7);
        color: white;
        border: none;
        width: 40px;
        height: 40px;
        border-radius: 50%;
        display: flex;
        align-items: center;
        justify-content: center;
        cursor: pointer;
        z-index: 10;
        opacity: 0;
        transition: all 0.3s;
    }

    .scroll-left {
        left: -20px;
    }

    .scroll-right {
        right: -20px;
    }

    .movies-row-container:hover .scroll-arrow {
        opacity: 1;
    }

    .scroll-arrow:hover {
        background: var(--netflix-red);
        transform: translateY(-50%) scale(1.1);
    }

    /* Movie Cards */
    .movie-card {
        flex: 0 0 auto;
        width: 220px;
        transition: all 0.4s;
        position: relative;
        cursor: pointer;
    }

        .movie-card:hover {
            transform: scale(1.08);
            z-index: 20;
        }

    .movie-poster {
        position: relative;
        border-radius: 8px;
        overflow: hidden;
        aspect-ratio: 2/3;
        background-color: var(--netflix-gray);
        box-shadow: 0 4px 20px rgba(0,0,0,0.5);
        transition: all 0.4s;
    }

    .movie-card:hover .movie-poster {
        box-shadow: 0 10px 30px rgba(0,0,0,0.8);
        transform: translateY(-10px);
    }

    .movie-poster img {
        width: 100%;
        height: 100%;
        object-fit: cover;
        transition: transform 0.4s;
    }

    .movie-card:hover .movie-poster img {
        transform: scale(1.05);
    }

    .movie-overlay {
        position: absolute;
        inset: 0;
        background: linear-gradient(180deg, transparent 40%, rgba(0,0,0,0.9) 100%);
        display: flex;
        flex-direction: column;
        justify-content: flex-end;
        padding: 1.5rem;
        opacity: 0;
        transition: opacity 0.3s;
    }

    .movie-card:hover .movie-overlay {
        opacity: 1;
    }

    .play-button {
        position: absolute;
        top: 50%;
        left: 50%;
        transform: translate(-50%,-50%) scale(0.8);
        background: rgba(229,9,20,0.9);
        color: white;
        width: 60px;
        height: 60px;
        border-radius: 50%;
        display: flex;
        align-items: center;
        justify-content: center;
        font-size: 1.8rem;
        opacity: 0;
        transition: all 0.3s;
        border: 3px solid white;
    }

    .movie-card:hover .play-button {
        opacity: 1;
        transform: translate(-50%,-50%) scale(1);
    }

    .movie-info {
        padding: 1rem 0.5rem 0.5rem;
    }

    .movie-title {
        font-size: 1rem;
        font-weight: 700;
        margin: 0 0 0.5rem;
        white-space: nowrap;
        overflow: hidden;
        text-overflow: ellipsis;
    }

        .movie-title a {
            color: white;
            text-decoration: none;
        }

            .movie-title a:hover {
                color: var(--netflix-red);
            }

    .movie-meta {
        display: flex;
        align-items: center;
        gap: 0.8rem;
        font-size: 0.85rem;
        color: var(--netflix-light-gray);
    }

        .movie-meta i {
            color: var(--netflix-red);
        }

    .view-badge {
        position: absolute;
        top: 15px;
        left: 15px;
        background: linear-gradient(135deg, var(--netflix-red), #b20710);
        color: white;
        padding: 0.4rem 0.8rem;
        border-radius: 4px;
        font-size: 0.75rem;
        font-weight: 700;
        z-index: 3;
        display: flex;
        align-items: center;
        gap: 0.3rem;
    }

    .favorite-icon-btn {
        position: absolute;
        top: 10px;
        right: 10px;
        background: rgba(0,0,0,0.7);
        border: none;
        width: 36px;
        height: 36px;
        border-radius: 50%;
        display: flex;
        align-items: center;
        justify-content: center;
        color: white;
        opacity: 0;
        transition: opacity 0.3s;
        cursor: pointer;
    }

    .movie-card:hover .favorite-icon-btn {
        opacity: 1;
    }

    .favorite-icon-btn:hover {
        background: var(--netflix-red);
    }

    /* Filter Bar */
    .filter-bar {
        background: var(--netflix-dark-bg);
        border: 1px solid var(--netflix-gray);
        border-radius: 12px;
        padding: 1.5rem;
        margin-bottom: 2rem;
    }

    .filter-row {
        display: flex;
        flex-wrap: wrap;
        gap: 1rem;
        align-items: flex-end;
    }

    .filter-group {
        display: flex;
        flex-direction: column;
        gap: 0.4rem;
        flex: 1;
        min-width: 140px;
    }

        .filter-group label {
            font-size: 0.8rem;
            font-weight: 600;
            color: var(--netflix-light-gray);
            text-transform: uppercase;
            letter-spacing: 0.5px;
        }

    .filter-select {
        background: var(--netflix-gray);
        border: 1px solid rgba(255,255,255,0.15);
        color: white;
        border-radius: 8px;
        padding: 0.6rem 1rem;
        font-size: 0.9rem;
        cursor: pointer;
        transition: border-color 0.2s;
    }

        .filter-select:focus {
            outline: none;
            border-color: var(--netflix-red);
        }

        .filter-select option {
            background: var(--netflix-gray);
        }

    .btn-reset {
        background: transparent;
        color: var(--netflix-light-gray);
        border: 1px solid rgba(255,255,255,0.2);
        border-radius: 8px;
        padding: 0.65rem 1.2rem;
        font-size: 0.9rem;
        cursor: pointer;
        transition: all 0.2s;
        white-space: nowrap;
    }

        .btn-reset:hover {
            border-color: var(--netflix-red);
            color: var(--netflix-red);
        }

    .filter-result-count {
        font-size: 0.9rem;
        color: var(--netflix-light-gray);
        margin-top: 0.8rem;
    }

        .filter-result-count span {
            color: var(--netflix-red);
            font-weight: 700;
        }

    /* Grid & AJAX Loading */
    #filtered-movies-wrapper {
        transition: opacity 0.3s ease;
    }

    .loading-state {
        opacity: 0.5;
        pointer-events: none;
    }

    .movies-grid {
        display: grid;
        grid-template-columns: repeat(auto-fill, minmax(180px, 1fr));
        gap: 1.2rem;
        margin-bottom: 3rem;
    }

    .grid-card {
        position: relative;
        border-radius: 8px;
        overflow: hidden;
        background: var(--netflix-dark-bg);
        border: 1px solid var(--netflix-gray);
        transition: transform 0.3s, box-shadow 0.3s;
    }

        .grid-card:hover {
            transform: translateY(-6px);
            box-shadow: 0 12px 30px rgba(0,0,0,0.7);
        }

    .grid-card-poster {
        position: relative;
        aspect-ratio: 2/3;
        overflow: hidden;
    }

        .grid-card-poster img {
            width: 100%;
            height: 100%;
            object-fit: cover;
            transition: transform 0.4s;
        }

    .grid-card:hover .grid-card-poster img {
        transform: scale(1.05);
    }

    .grid-card-overlay {
        position: absolute;
        inset: 0;
        background: linear-gradient(180deg, transparent 50%, rgba(0,0,0,0.9) 100%);
        opacity: 0;
        transition: opacity 0.3s;
        display: flex;
        align-items: flex-end;
        padding: 1rem;
    }

    .grid-card:hover .grid-card-overlay {
        opacity: 1;
    }

    .btn-play-card {
        display: inline-flex;
        align-items: center;
        gap: 0.4rem;
        background: var(--netflix-red);
        color: white;
        padding: 0.5rem 1rem;
        border-radius: 6px;
        text-decoration: none;
        font-size: 0.85rem;
        font-weight: 600;
    }

    .grid-card-info {
        padding: 0.8rem;
    }

    .grid-card-title {
        font-size: 0.9rem;
        font-weight: 600;
        margin-bottom: 0.3rem;
        white-space: nowrap;
        overflow: hidden;
        text-overflow: ellipsis;
    }

        .grid-card-title a {
            color: white;
            text-decoration: none;
        }

            .grid-card-title a:hover {
                color: var(--netflix-red);
            }

    .grid-card-meta {
        font-size: 0.78rem;
        color: var(--netflix-light-gray);
        display: flex;
        gap: 0.5rem;
    }

    .badge-type {
        position: absolute;
        top: 8px;
        left: 8px;
        background: rgba(229,9,20,0.85);
        color: white;
        padding: 0.2rem 0.6rem;
        border-radius: 4px;
        font-size: 0.7rem;
        font-weight: 700;
        z-index: 3;
    }

    /* Pagination & Alerts */
    .pagination-wrapper {
        display: flex;
        justify-content: center;
        align-items: center;
        gap: 0.5rem;
        margin: 2rem 0 4rem;
        flex-wrap: wrap;
    }

    .page-btn {
        background: var(--netflix-gray);
        color: white;
        border: 1px solid rgba(255,255,255,0.1);
        padding: 0.5rem 0.9rem;
        border-radius: 6px;
        cursor: pointer;
        text-decoration: none;
        font-size: 0.9rem;
        transition: all 0.2s;
    }

        .page-btn:hover {
            background: var(--netflix-red);
            border-color: var(--netflix-red);
            color: white;
        }

        .page-btn.active {
            background: var(--netflix-red);
            border-color: var(--netflix-red);
            font-weight: 700;
        }

        .page-btn.disabled {
            opacity: 0.4;
            pointer-events: none;
        }

    .netflix-alert {
        background: var(--netflix-dark-bg);
        border: 1px solid var(--netflix-gray);
        border-radius: 8px;
        padding: 2rem;
        margin: 2rem 0;
        text-align: center;
    }

        .netflix-alert i {
            color: var(--netflix-red);
            font-size: 2rem;
            margin-bottom: 1rem;
            display: block;
        }

    /* Responsive Defaults */
    @@media (max-width: 992px) {
        .hero-poster-content {
            display: none;
        }

        .hero-text-content {
            max-width: 100%;
            text-align: center;
        }

        .featured-meta, .featured-actions {
            justify-content: center;
        }
    }

    @@media (max-width: 768px) {
        .hero-slider-container {
            height: 100vh;
            min-height: 600px;
        }

        .featured-title {
            font-size: 2.5rem;
        }

        .global-search-overlay {
            bottom: 90px;
        }

        .filter-row {
            flex-direction: column;
        }

        .movies-grid {
            grid-template-columns: repeat(auto-fill, minmax(140px, 1fr));
        }
    }
</style>

@if (featuredMovies.Any())
{
    <div class="hero-slider-section">
        <div class="hero-slider-container" id="heroSlider">

            @for (int i = 0; i < featuredMovies.Count; i++)
            {
                var movie = featuredMovies[i];
                var bgImage = movie.PosterUrl ?? "https://images.unsplash.com/photo-1536440136628-849c177e76a1?ixlib=rb-4.0.3&auto=format&fit=crop&w=1920&q=80";

                <div class="hero-slide @(i == 0 ? "active" : "")" data-index="@i">
                    <div class="hero-bg" style="background-image: url('@bgImage');"></div>

                    <div class="hero-content-wrapper">
                        <div class="hero-text-content">
                            <h1 class="featured-title">@movie.Title</h1>

                            <div class="featured-meta">
                                <span class="match">Top Trending</span>
                                @if (movie.ReleaseYear.HasValue)
                                {
                                    <span>@movie.ReleaseYear</span>
                                }
                                <span class="badge-hd">HD</span>
                                <span>@(movie.Type.ToString() == "Series" ? "Series" : "Movie")</span>
                            </div>

                            <p class="featured-desc">
                                Discover @movie.Title today. Enjoy wonderful moments of entertainment with HD quality and standard subtitles.
                            </p>

                            <div class="featured-actions">
                                <a asp-controller="Movie" asp-action="Watch" asp-route-slug="@movie.Slug" class="btn-netflix-primary">
                                    <i class="fas fa-play"></i> Play
                                </a>
                                <a asp-controller="Movie" asp-action="Detail" asp-route-slug="@movie.Slug" class="btn-netflix-secondary">
                                    <i class="fas fa-info-circle"></i> More Info
                                </a>
                            </div>
                        </div>

                        <div class="hero-poster-content">
                            <a asp-controller="Movie" asp-action="Detail" asp-route-slug="@movie.Slug">
                                <img src="@bgImage" alt="@movie.Title" class="full-poster-img" />
                            </a>
                        </div>
                    </div>
                </div>
            }

            <button class="slider-nav-btn prev-btn" id="heroPrev"><i class="fas fa-chevron-left"></i></button>
            <button class="slider-nav-btn next-btn" id="heroNext"><i class="fas fa-chevron-right"></i></button>

            <div class="slider-indicators">
                @for (int i = 0; i < featuredMovies.Count; i++)
                {
                    <span class="dot @(i == 0 ? "active" : "")" data-slide="@i"></span>
                }
            </div>
        </div>
    </div>
}

<div class="container" id="filter-section-container">
    <div class="section-header">
        <div class="section-header-left">
            <i class="fas fa-film"></i>
            <h2>All Movies</h2>
        </div>
        <a asp-controller="Movie" asp-action="Index" style="color:var(--netflix-light-gray); font-size:0.9rem;">
           <i class="fas fa-arrow-right"></i>
        </a>
    </div>

    <div class="filter-bar">
        <form method="get" asp-action="Index" asp-controller="Home" id="filterForm">
            <div class="filter-row">
                <div class="filter-group" style="flex:2; min-width:200px;">
                    <label><i class="fas fa-search"></i> Search</label>
                    <div class="search-input-wrapper" style="border-radius:8px; padding:2px 2px 2px 14px;">
                        <input type="text" name="search" value="@f.Search" placeholder="Movie title..." style="font-size:0.9rem; padding:8px 0;" />
                        <button type="submit" class="btn-search" style="border-radius:6px; padding:8px 16px; font-size:0.85rem;">
                            <i class="fas fa-search"></i>
                        </button>
                    </div>
                </div>
                <div class="filter-group">
                    <label><i class="fas fa-theater-masks"></i> Genre</label>
                    <select name="genreId" class="filter-select">
                        <option value="">All</option>
                        @foreach (var g in f.Genres)
                        {
                            <option value="@g.Id" selected="@(f.GenreId == g.Id ? "selected" : null)">@g.Name</option>
                        }
                    </select>
                </div>
                <div class="filter-group">
                    <label><i class="fas fa-globe"></i> Country</label>
                    <select name="countryId" class="filter-select">
                        <option value="">All</option>
                        @foreach (var c in f.Countries)
                        {
                            <option value="@c.Id" selected="@(f.CountryId == c.Id ? "selected" : null)">@c.Name</option>
                        }
                    </select>
                </div>
                <div class="filter-group">
                    <label><i class="fas fa-tv"></i> Movie Type</label>
                    <select name="type" class="filter-select">
                        <option value="">All</option>
                        <option value="1" selected="@(f.Type == 1 ? "selected" : null)">Movie</option>
                        <option value="2" selected="@(f.Type == 2 ? "selected" : null)">Series</option>
                    </select>
                </div>
                <div class="filter-group">
                    <label><i class="fas fa-sort"></i> Sort by</label>
                    <select name="sortBy" class="filter-select">
                        <option value="latest" selected="@(f.SortBy == "latest" ? "selected" : null)">Latest</option>
                        <option value="popular" selected="@(f.SortBy == "popular" ? "selected" : null)">Most Popular</option>
                        <option value="year_desc" selected="@(f.SortBy == "year_desc" ? "selected" : null)">Year Descending</option>
                        <option value="year_asc" selected="@(f.SortBy == "year_asc" ? "selected" : null)">Year Ascending</option>
                        <option value="title" selected="@(f.SortBy == "title" ? "selected" : null)">Name A-Z</option>
                    </select>
                </div>
                <div class="filter-group" style="justify-content:flex-end; flex-direction:row; gap:0.5rem;">
                    <a asp-action="Index" asp-controller="Home" class="btn-reset"><i class="fas fa-times"></i> Reset</a>
                </div>
            </div>
            <div class="filter-result-count" id="filter-count-wrapper">
                Showing <span>@f.Movies.Count</span> / <span>@f.TotalItems</span> movies
                @if (!string.IsNullOrEmpty(f.Search) || f.GenreId.HasValue || f.CountryId.HasValue || f.Type.HasValue)
                {
                    <span style="margin-left:0.5rem; color:var(--netflix-light-gray);">(filtered)</span>
                }
            </div>
        </form>
    </div>

    <div id="filtered-movies-wrapper">
        @if (f.Movies.Any())
        {
            <div class="movies-grid">
                @foreach (var movie in f.Movies)
                {
                    <div class="grid-card">
                        <div class="grid-card-poster">
                            <a asp-controller="Movie" asp-action="Detail" asp-route-slug="@movie.Slug">
                                <img src="@(movie.PosterUrl ?? "https://via.placeholder.com/300x450/2d2d2d/fff?text=No+Poster")" alt="@movie.Title" loading="lazy" />
                            </a>
                            <span class="badge-type">@(movie.Type.ToString() == "Series" ? "Series" : "Movie")</span>
                            <div class="grid-card-overlay">
                                <a asp-controller="Movie" asp-action="Watch" asp-route-slug="@movie.Slug" class="btn-play-card">
                                    <i class="fas fa-play"></i> Watch Now
                                </a>
                            </div>
                        </div>
                        <div class="grid-card-info">
                            <div class="grid-card-title">
                                <a asp-controller="Movie" asp-action="Detail" asp-route-slug="@movie.Slug">@movie.Title</a>
                            </div>
                            <div class="grid-card-meta">
                                @if (movie.ReleaseYear.HasValue)
                                {
                                    <span><i class="fas fa-calendar"></i> @movie.ReleaseYear</span>
                                }
                                @if (!string.IsNullOrEmpty(movie.CountryName))
                                {
                                    <span>@movie.CountryName</span>
                                }
                            </div>
                        </div>
                        @if (User.Identity?.IsAuthenticated == true)
                        {
                            <button class="favorite-icon-btn" data-movie-id="@movie.Id" style="top:46px;"><i class="far fa-heart"></i></button>
                        }
                    </div>
                }
            </div>

            @if (f.TotalPages > 1)
            {
                <div class="pagination-wrapper">
                    <a asp-action="Index" asp-controller="Home"
                       asp-route-search="@f.Search" asp-route-genreId="@f.GenreId" asp-route-countryId="@f.CountryId"
                       asp-route-type="@f.Type" asp-route-sortBy="@f.SortBy" asp-route-pageNumber="@(f.PageNumber - 1)"
                       class="page-btn @(!f.HasPreviousPage ? "disabled" : null)">
                        <i class="fas fa-chevron-left"></i>
                    </a>

                    @for (int i = Math.Max(1, f.PageNumber - 2); i <= Math.Min(f.TotalPages, f.PageNumber + 2); i++)
                    {
                        <a asp-action="Index" asp-controller="Home"
                           asp-route-search="@f.Search" asp-route-genreId="@f.GenreId" asp-route-countryId="@f.CountryId"
                           asp-route-type="@f.Type" asp-route-sortBy="@f.SortBy" asp-route-pageNumber="@i"
                           class="page-btn @(i == f.PageNumber ? "active" : null)">@i</a>
                    }

                    <a asp-action="Index" asp-controller="Home"
                       asp-route-search="@f.Search" asp-route-genreId="@f.GenreId" asp-route-countryId="@f.CountryId"
                       asp-route-type="@f.Type" asp-route-sortBy="@f.SortBy" asp-route-pageNumber="@(f.PageNumber + 1)"
                       class="page-btn @(!f.HasNextPage ? "disabled" : null)">
                        <i class="fas fa-chevron-right"></i>
                    </a>
                </div>
            }
        }
        else
        {
            <div class="netflix-alert">
                <i class="fas fa-search"></i>
                <h3>No movies found</h3>
                <p>Try changing the filter or <a asp-action="Index" asp-controller="Home" style="color:var(--netflix-red);">view all movies</a></p>
            </div>
        }
    </div>
</div>

