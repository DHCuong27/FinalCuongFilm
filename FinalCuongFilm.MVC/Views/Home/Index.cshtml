<div class="container" id="filter-section-container" style="margin-top: 3rem;">
    <div class="section-header">
        <div class="section-header-left">
            <i class="fas fa-film"></i>
            <h2>Explore All Movies</h2>
        </div>
        <button id="btnToggleFilter" class="btn-toggle-filter">
            <i class="fas fa-sliders-h"></i> Filter
        </button>
    </div>

    <div class="filter-bar" id="filterBarPanel" style="display: none;">
        <form method="get" asp-action="Index" asp-controller="Home" id="filterForm">
            <div class="filter-row">
                <div class="filter-group" style="flex:2; min-width:200px;">
                    <label><i class="fas fa-search"></i> Search</label>
                    <div class="search-input-wrapper" style="border-radius:8px; padding:2px 2px 2px 14px;">
                        <input type="text" name="search" value="@f.Search" placeholder="Movie title..." style="font-size:0.9rem; padding:8px 0;" />
                        <button type="submit" class="btn-search" style="border-radius:6px; padding:8px 16px; font-size:0.85rem;">
                            <i class="fas fa-search"></i>
                        </button>
                    </div>
                </div>
                <div class="filter-group">
                    <label><i class="fas fa-theater-masks"></i> Genre</label>
                    <select name="genreId" class="filter-select">
                        <option value="">All</option>
                        @foreach (var g in f.Genres)
                        {
                            <option value="@g.Id" selected="@(f.GenreId == g.Id ? "selected" : null)">@g.Name</option>
                        }
                    </select>
                </div>
                <div class="filter-group">
                    <label><i class="fas fa-globe"></i> Country</label>
                    <select name="countryId" class="filter-select">
                        <option value="">All</option>
                        @foreach (var c in f.Countries)
                        {
                            <option value="@c.Id" selected="@(f.CountryId == c.Id ? "selected" : null)">@c.Name</option>
                        }
                    </select>
                </div>
                <div class="filter-group">
                    <label><i class="fas fa-tv"></i> Movie Type</label>
                    <select name="type" class="filter-select">
                        <option value="">All</option>
                        <option value="1" selected="@(f.Type == 1 ? "selected" : null)">Movie</option>
                        <option value="2" selected="@(f.Type == 2 ? "selected" : null)">Series</option>
                    </select>
                </div>
                <div class="filter-group">
                    <label><i class="fas fa-sort"></i> Sort by</label>
                    <select name="sortBy" class="filter-select">
                        <option value="latest" selected="@(f.SortBy == "latest" ? "selected" : null)">Latest</option>
                        <option value="popular" selected="@(f.SortBy == "popular" ? "selected" : null)">Most Popular</option>
                        <option value="title" selected="@(f.SortBy == "title" ? "selected" : null)">Name A-Z</option>
                    </select>
                </div>
                <div class="filter-group" style="justify-content:flex-end; flex-direction:row; gap:0.5rem;">
                    <a asp-action="Index" asp-controller="Home" class="btn-reset"><i class="fas fa-times"></i> Reset</a>
                </div>
            </div>
            <div class="filter-result-count" id="filter-count-wrapper">
                Showing <span>@f.Movies.Count</span> / <span>@f.TotalItems</span> movies
                @if (!string.IsNullOrEmpty(f.Search) || f.GenreId.HasValue || f.CountryId.HasValue || f.Type.HasValue)
                {
                    <span style="margin-left:0.5rem; color:var(--netflix-light-gray);">(filtered)</span>
                }
            </div>
        </form>
    </div>

    <div id="filtered-movies-wrapper">
        @if (f.Movies.Any())
        {
            <div class="movies-grid">
                @foreach (var movie in f.Movies)
                {
                    <div class="grid-card">
                        <div class="grid-card-poster">
                            <span class="badge-type">@(movie.Type.ToString() == "Series" ? "Series" : "Movie")</span>
                            @if (movie.IsVipOnly)
                            {
                                <div class="premium-movie-badge">
                                    <i class="fa-solid fa-crown"></i> VIP
                                </div>
                            }

                            <a asp-controller="Movie" asp-action="Detail" asp-route-slug="@movie.Slug">
                                <img src="@(string.IsNullOrEmpty(movie.PosterUrl) ? "https://via.placeholder.com/300x450/2d2d2d/fff?text=No+Poster" : movie.PosterUrl)" alt="@movie.Title" loading="lazy" />
                            </a>

                            <div class="grid-card-overlay">
                                <a asp-controller="Movie" asp-action="Watch" asp-route-slug="@movie.Slug" class="btn-play-card">
                                    <i class="fas fa-play"></i> Watch Now
                                </a>
                            </div>
                        </div>
                        <div class="grid-card-info">
                            <div class="grid-card-title">
                                <a asp-controller="Movie" asp-action="Detail" asp-route-slug="@movie.Slug">@movie.Title</a>
                            </div>
                            <div class="grid-card-meta">
                                @if (movie.ReleaseYear.HasValue)
                                {
                                    <span><i class="fas fa-calendar"></i> @movie.ReleaseYear</span>
                                }
                                @if (!string.IsNullOrEmpty(movie.CountryName))
                                {
                                    <span>@movie.CountryName</span>
                                }
                            </div>
                        </div>
                    </div>
                }
            </div>

            @if (f.TotalPages > 1)
            {
                int maxPagesToShow = 5;
                int startPage = Math.Max(1, f.PageNumber - maxPagesToShow / 2);
                int endPage = Math.Min(f.TotalPages, startPage + maxPagesToShow - 1);

                if (endPage - startPage + 1 < maxPagesToShow)
                {
                    startPage = Math.Max(1, endPage - maxPagesToShow + 1);
                }

                <div class="pagination-wrapper">
                    <a asp-action="Index" asp-controller="Home"
                       asp-route-search="@f.Search" asp-route-genreId="@f.GenreId" asp-route-countryId="@f.CountryId"
                       asp-route-type="@f.Type" asp-route-sortBy="@f.SortBy" asp-route-pageNumber="@(f.PageNumber - 1)"
                       class="page-btn @(!f.HasPreviousPage ? "disabled" : null)">
                        <i class="fas fa-chevron-left"></i>
                    </a>

                    @for (int i = startPage; i <= endPage; i++)
                    {
                        <a asp-action="Index" asp-controller="Home"
                           asp-route-search="@f.Search" asp-route-genreId="@f.GenreId" asp-route-countryId="@f.CountryId"
                           asp-route-type="@f.Type" asp-route-sortBy="@f.SortBy" asp-route-pageNumber="@i"
                           class="page-btn @(i == f.PageNumber ? "active" : null)">@i</a>
                    }

                    <a asp-action="Index" asp-controller="Home"
                       asp-route-search="@f.Search" asp-route-genreId="@f.GenreId" asp-route-countryId="@f.CountryId"
                       asp-route-type="@f.Type" asp-route-sortBy="@f.SortBy" asp-route-pageNumber="@(f.PageNumber + 1)"
                       class="page-btn @(!f.HasNextPage ? "disabled" : null)">
                        <i class="fas fa-chevron-right"></i>
                    </a>
                </div>
            }
        }
        else
        {
            <div class="col-12">
                <div class="netflix-alert">
                    <i class="fas fa-search"></i>
                    <h3>No content matches your filters</h3>
                    <p>Try adjusting your search or filter categories, or <a asp-action="Index" asp-controller="Home" style="color:var(--netflix-red);">reset all filters</a>.</p>
                </div>
            </div>
        }
    </div>
</div>

@Html.AntiForgeryToken()

@section Scripts {
    <script>
        $(document).ready(function () {
            let debounceTimer;
            $('.searchInputField').on('input', function () {
                clearTimeout(debounceTimer);
                const query = $(this).val().trim();
                const box = $(this).closest('.banner-search-container').find('.searchSuggestionsBox');

                if (query.length < 2) { box.hide(); return; }

                debounceTimer = setTimeout(() => {
                    $.get('/Search/Suggestions', { q: query }, function (data) {
                        box.empty();
                        if (data && data.length > 0) {
                            data.forEach(m => {
                                box.append(`<a href="/Movie/Detail/${m.slug}" class="suggestion-item">
                                    <img src="${m.posterUrl}" onerror="this.src='https://via.placeholder.com/40x60/2d2d2d/fff?text=N/A'" />
                                    <div><div style="font-weight:600">${m.title}</div>
                                    <div style="font-size:0.85rem;color:#b3b3b3"><i class="fas fa-calendar-alt"></i> ${m.year || 'N/A'}</div></div>
                                </a>`);
                            });
                            box.fadeIn(150);
                        } else {
                            box.html('<div style="padding:15px;color:#b3b3b3;text-align:center">No matching movies found</div>').fadeIn(150);
                        }
                    });
                }, 300);
            });
            $(document).on('click', function (e) {
                if (!$(e.target).closest('.banner-search-container').length) $('.searchSuggestionsBox').fadeOut(150);
            });

            const $slides = $('.hero-slide');
            const $thumbnails = $('.thumbnail-item-compact');
            let currentSlide = 0;
            const totalSlides = $slides.length;
            let slideInterval;

            function goToSlide(index) {
                $slides.removeClass('active');
                $thumbnails.removeClass('active');

                currentSlide = index;
                if (currentSlide >= totalSlides) currentSlide = 0;
                if (currentSlide < 0) currentSlide = totalSlides - 1;

                $slides.eq(currentSlide).addClass('active');
                $thumbnails.eq(currentSlide).addClass('active');

                const $activeThumb = $thumbnails.eq(currentSlide);
                const thumbnailStrip = document.querySelector('.thumbnail-strip-compact');
                if (thumbnailStrip && $activeThumb.length) {
                    const thumbLeft = $activeThumb[0].offsetLeft;
                    const thumbWidth = $activeThumb.outerWidth();
                    const stripWidth = thumbnailStrip.offsetWidth;
                    const scrollLeft = thumbnailStrip.scrollLeft;

                    if (thumbLeft < scrollLeft || thumbLeft + thumbWidth > scrollLeft + stripWidth) {
                        thumbnailStrip.scrollTo({
                            left: thumbLeft - (stripWidth / 2) + (thumbWidth / 2),
                            behavior: 'smooth'
                        });
                    }
                }
            }

            function nextSlide() { goToSlide(currentSlide + 1); }
            function prevSlide() { goToSlide(currentSlide - 1); }

            function startSlideShow() {
                slideInterval = setInterval(nextSlide, 8000); // Tăng thời gian xem lên 8 giây cho ngầu
            }
            function resetSlideShow() {
                clearInterval(slideInterval);
                startSlideShow();
            }

            $thumbnails.click(function () {
                goToSlide($(this).data('slide'));
                resetSlideShow();
            });

            if (totalSlides > 1) {
                startSlideShow();
            }

            $(document).keydown(function (e) {
                if (e.key === 'ArrowLeft') {
                    prevSlide();
                    resetSlideShow();
                } else if (e.key === 'ArrowRight') {
                    nextSlide();
                    resetSlideShow();
                }
            });

            $(document).on('change', '#filterForm select', function () {
                $('#filterForm').trigger('submit');
            });

            $(document).on('submit', '#filterForm', function (e) {
                e.preventDefault();
                let url = $(this).attr('action') + '?' + $(this).serialize();
                loadFilteredMovies(url);
            });

            $(document).on('click', '.pagination-wrapper a.page-btn', function (e) {
                e.preventDefault();
                let url = $(this).attr('href');
                if (url && !$(this).hasClass('disabled')) {
                    loadFilteredMovies(url);
                    $('html, body').animate({
                        scrollTop: $("#filter-section-container").offset().top - 50
                    }, 500);
                }
            });

            function loadFilteredMovies(url) {
                let $wrapper = $('#filtered-movies-wrapper');
                $wrapper.addClass('loading-state');

                $.ajax({
                    url: url,
                    type: 'GET',
                    success: function (data) {
                        let parsedData = $(data);
                        $('#filter-count-wrapper').html(parsedData.find('#filter-count-wrapper').html());
                        $wrapper.html(parsedData.find('#filtered-movies-wrapper').html());
                        $wrapper.removeClass('loading-state');
                        window.history.pushState({ path: url }, '', url);
                    },
                    error: function () {
                        $wrapper.removeClass('loading-state');
                        alert('An error occurred while loading movies.');
                    }
                });
            }

            $('#btnToggleFilter').click(function () {
                const filterPanel = $('#filterBarPanel');
                filterPanel.slideToggle(300);
                $(this).toggleClass('active');
            });

            if (window.location.search.length > 1) {
                $('#filterBarPanel').show();
                $('#btnToggleFilter').addClass('active');
            }
        });

        function doScrollLeft(id) { document.getElementById(id + '-movies-row').scrollBy({ left: -600, behavior: 'smooth' }); }
        function doScrollRight(id) { document.getElementById(id + '-movies-row').scrollBy({ left: 600, behavior: 'smooth' }); }
    </script>
}