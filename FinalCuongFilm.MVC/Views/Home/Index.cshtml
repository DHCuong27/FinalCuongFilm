@model IEnumerable<FinalCuongFilm.Common.DTOs.MovieDto>
@{
    ViewData["Title"] = "Trang chủ";
    Layout = "_LayoutUser";

    var latestMovies = ViewBag.LatestMovies as List<FinalCuongFilm.Common.DTOs.MovieDto>;
    var popularMovies = ViewBag.PopularMovies as List<FinalCuongFilm.Common.DTOs.MovieDto>;
}

<style>
    /* Netflix Style CSS - Cải tiến */
    :root {
        --netflix-red: #e50914;
        --netflix-dark: #0f0f0f;
        --netflix-dark-bg: #1a1a1a;
        --netflix-gray: #2d2d2d;
        --netflix-light-gray: #b3b3b3;
        --netflix-white: #ffffff;
    }

    body {
        background-color: var(--netflix-dark);
        color: var(--netflix-white);
        font-family: 'Segoe UI', 'Helvetica Neue', Helvetica, Arial, sans-serif;
        margin: 0;
        padding: 0;
        line-height: 1.6;
    }

    /* Hero Banner */
    .hero-banner {
        position: relative;
        background: linear-gradient(180deg, rgba(0,0,0,0.8) 0%, rgba(0,0,0,0.5) 50%, rgba(20,20,20,0.3) 100%), url('https://images.unsplash.com/photo-1536440136628-849c177e76a1?ixlib=rb-4.0.3&auto=format&fit=crop&w=1920&q=80');
        background-size: cover;
        background-position: center top;
        background-attachment: fixed;
        height: 85vh;
        min-height: 550px;
        display: flex;
        align-items: center;
        margin-bottom: 3rem;
        overflow: hidden;
    }

        .hero-banner::after {
            content: '';
            position: absolute;
            bottom: 0;
            left: 0;
            right: 0;
            height: 100px;
            background: linear-gradient(180deg, transparent 0%, var(--netflix-dark) 100%);
            z-index: 1;
        }

        .hero-banner .container {
            z-index: 2;
            position: relative;
            width: 100%;
            max-width: 1200px;
            margin: 0 auto;
            padding: 0 2rem;
        }

    .hero-content {
        max-width: 650px;
        animation: fadeInUp 1s ease-out;
    }

    .hero-banner h1 {
        font-size: 3.8rem;
        font-weight: 900;
        margin-bottom: 1.5rem;
        text-shadow: 3px 3px 6px rgba(0,0,0,0.8);
        line-height: 1.1;
        background: linear-gradient(90deg, #fff 0%, var(--netflix-red) 100%);
        -webkit-background-clip: text;
        -webkit-text-fill-color: transparent;
        background-clip: text;
    }

    .hero-banner .lead {
        font-size: 1.6rem;
        margin-bottom: 2.5rem;
        color: #f0f0f0;
        text-shadow: 2px 2px 4px rgba(0,0,0,0.7);
        font-weight: 400;
        line-height: 1.4;
    }

    .netflix-btn {
        background-color: var(--netflix-red);
        color: white;
        border: none;
        padding: 1rem 2.5rem;
        font-size: 1.3rem;
        font-weight: 700;
        border-radius: 6px;
        text-transform: uppercase;
        letter-spacing: 0.8px;
        transition: all 0.3s cubic-bezier(0.4, 0, 0.2, 1);
        display: inline-flex;
        align-items: center;
        justify-content: center;
        gap: 0.8rem;
        text-decoration: none;
        box-shadow: 0 4px 15px rgba(229, 9, 20, 0.3);
        position: relative;
        overflow: hidden;
    }

        .netflix-btn:hover {
            background-color: #f40612;
            color: white;
            transform: translateY(-3px);
            box-shadow: 0 8px 25px rgba(229, 9, 20, 0.4);
        }

    /* Section Header */
    .section-header {
        display: flex;
        align-items: center;
        gap: 1rem;
        margin-bottom: 2rem;
        padding-bottom: 1rem;
        border-bottom: 2px solid var(--netflix-gray);
        position: relative;
    }

        .section-header::after {
            content: '';
            position: absolute;
            bottom: -2px;
            left: 0;
            width: 100px;
            height: 2px;
            background: var(--netflix-red);
        }

        .section-header i {
            font-size: 2rem;
            color: var(--netflix-red);
            background: rgba(229, 9, 20, 0.1);
            padding: 0.8rem;
            border-radius: 8px;
        }

        .section-header h2 {
            font-size: 2rem;
            font-weight: 800;
            margin: 0;
            color: white;
            letter-spacing: -0.5px;
        }

    /* Movies Row */
    .movies-row-container {
        position: relative;
        margin-bottom: 4rem;
    }

    .movies-row {
        display: flex;
        overflow-x: auto;
        padding: 1rem 0.5rem;
        scrollbar-width: none;
        -ms-overflow-style: none;
        gap: 1.2rem;
        scroll-behavior: smooth;
    }

        .movies-row::-webkit-scrollbar {
            display: none;
        }

    .scroll-arrow {
        position: absolute;
        top: 50%;
        transform: translateY(-50%);
        background: rgba(0, 0, 0, 0.7);
        color: white;
        border: none;
        width: 40px;
        height: 40px;
        border-radius: 50%;
        display: flex;
        align-items: center;
        justify-content: center;
        cursor: pointer;
        z-index: 10;
        opacity: 0;
        transition: all 0.3s ease;
        font-size: 1.2rem;
    }

    .scroll-left {
        left: -20px;
    }

    .scroll-right {
        right: -20px;
    }

    .movies-row-container:hover .scroll-arrow {
        opacity: 1;
    }

    .scroll-arrow:hover {
        background: var(--netflix-red);
        transform: translateY(-50%) scale(1.1);
    }

    /* Movie Card */
    .movie-card {
        flex: 0 0 auto;
        width: 220px;
        transition: all 0.4s cubic-bezier(0.4, 0, 0.2, 1);
        position: relative;
        cursor: pointer;
        background: transparent;
        border: none;
        box-shadow: none;
    }

        .movie-card:hover {
            transform: scale(1.08);
            z-index: 20;
        }

    .movie-poster {
        position: relative;
        border-radius: 8px;
        overflow: hidden;
        aspect-ratio: 2/3;
        background-color: var(--netflix-gray);
        box-shadow: 0 4px 20px rgba(0, 0, 0, 0.5);
        transition: all 0.4s ease;
    }

    .movie-card:hover .movie-poster {
        box-shadow: 0 10px 30px rgba(0, 0, 0, 0.8);
        transform: translateY(-10px);
    }

    .movie-poster img {
        width: 100%;
        height: 100%;
        object-fit: cover;
        transition: transform 0.4s ease;
    }

    .movie-card:hover .movie-poster img {
        transform: scale(1.05);
    }

    .movie-overlay {
        position: absolute;
        top: 0;
        left: 0;
        right: 0;
        bottom: 0;
        background: linear-gradient(180deg, transparent 40%, rgba(0, 0, 0, 0.9) 100%);
        display: flex;
        flex-direction: column;
        justify-content: flex-end;
        padding: 1.5rem;
        opacity: 0;
        transition: opacity 0.3s ease;
    }

    .movie-card:hover .movie-overlay {
        opacity: 1;
    }

    .play-button {
        position: absolute;
        top: 50%;
        left: 50%;
        transform: translate(-50%, -50%) scale(0.8);
        background: rgba(229, 9, 20, 0.9);
        color: white;
        width: 60px;
        height: 60px;
        border-radius: 50%;
        display: flex;
        align-items: center;
        justify-content: center;
        font-size: 1.8rem;
        opacity: 0;
        transition: all 0.3s ease;
        border: 3px solid white;
        box-shadow: 0 4px 15px rgba(0, 0, 0, 0.5);
    }

    .movie-card:hover .play-button {
        opacity: 1;
        transform: translate(-50%, -50%) scale(1);
    }

    .play-button:hover {
        background: #f40612;
        transform: translate(-50%, -50%) scale(1.1);
    }

    .movie-info {
        padding: 1rem 0.5rem 0.5rem;
        position: relative;
        z-index: 2;
    }

    .movie-title {
        font-size: 1rem;
        font-weight: 700;
        margin: 0 0 0.5rem;
        line-height: 1.3;
        white-space: nowrap;
        overflow: hidden;
        text-overflow: ellipsis;
    }

        .movie-title a {
            color: white;
            text-decoration: none;
            transition: color 0.2s ease;
            display: block;
        }

            .movie-title a:hover {
                color: var(--netflix-red);
            }

    .movie-meta {
        display: flex;
        align-items: center;
        gap: 0.8rem;
        font-size: 0.85rem;
        color: var(--netflix-light-gray);
    }

        .movie-meta span {
            display: flex;
            align-items: center;
            gap: 0.3rem;
        }

        .movie-meta i {
            color: var(--netflix-red);
        }

    .view-badge {
        position: absolute;
        top: 15px;
        left: 15px;
        background: linear-gradient(135deg, var(--netflix-red) 0%, #b20710 100%);
        color: white;
        padding: 0.4rem 0.8rem;
        border-radius: 4px;
        font-size: 0.75rem;
        font-weight: 700;
        z-index: 3;
        display: flex;
        align-items: center;
        gap: 0.3rem;
        box-shadow: 0 2px 8px rgba(0, 0, 0, 0.4);
    }

        .view-badge i {
            font-size: 0.9rem;
        }

    /* No Movies Alert */
    .netflix-alert {
        background: var(--netflix-dark-bg);
        color: white;
        border: 1px solid var(--netflix-gray);
        border-radius: 8px;
        padding: 2rem;
        margin: 2rem 0;
        text-align: center;
        animation: fadeIn 0.5s ease;
    }

        .netflix-alert i {
            color: var(--netflix-red);
            font-size: 2rem;
            margin-bottom: 1rem;
        }

        .netflix-alert h3 {
            font-size: 1.5rem;
            margin-bottom: 0.5rem;
        }

        .netflix-alert p {
            color: var(--netflix-light-gray);
            margin: 0;
        }

    /* Container */
    .container {
        max-width: 1400px;
        margin: 0 auto;
        padding: 0 2rem;
    }

    /* Grid Layout for Index view */
    .row {
        display: grid;
        grid-template-columns: repeat(auto-fill, minmax(250px, 1fr));
        gap: 1.5rem;
        margin: 2rem 0;
    }

    .card {
        background: var(--netflix-dark-bg);
        border: 1px solid var(--netflix-gray);
        border-radius: 8px;
        overflow: hidden;
        transition: transform 0.3s;
    }

        .card:hover {
            transform: translateY(-5px);
        }

    .card-img-top {
        width: 100%;
        height: 350px;
        object-fit: cover;
    }

    .favorite-icon-btn {
        position: absolute;
        top: 10px;
        right: 10px;
        background: rgba(0, 0, 0, 0.7);
        border: none;
        width: 40px;
        height: 40px;
        border-radius: 50%;
        display: flex;
        align-items: center;
        justify-content: center;
        color: white;
        opacity: 0;
        transition: opacity 0.3s;
    }

    .card:hover .favorite-icon-btn {
        opacity: 1;
    }

    .favorite-icon-btn:hover {
        background: var(--netflix-red);
    }

    .badge {
        padding: 0.5rem 0.8rem;
        font-size: 0.75rem;
        font-weight: 600;
    }

    .card-body {
        padding: 1.5rem;
    }

    .card-title a {
        color: white;
        text-decoration: none;
        font-size: 1.1rem;
        font-weight: 600;
        display: block;
        margin-bottom: 0.5rem;
    }

        .card-title a:hover {
            color: var(--netflix-red);
        }

    .card-text {
        color: var(--netflix-light-gray);
        font-size: 0.9rem;
    }

    .card-footer {
        padding: 1rem 1.5rem;
        background: var(--netflix-gray);
        border-top: 1px solid rgba(255, 255, 255, 0.1);
    }

    .btn-primary {
        background-color: var(--netflix-red);
        border-color: var(--netflix-red);
        color: white;
        font-weight: 600;
        padding: 0.6rem 1rem;
        border-radius: 6px;
    }

        .btn-primary:hover {
            background-color: #f40612;
            border-color: #f40612;
        }

    .text-warning {
        color: #ffc107 !important;
    }

    .text-muted {
        color: var(--netflix-light-gray) !important;
    }

    .text-dark {
        color: white !important;
    }

    @@keyframes fadeIn {
        from {
            opacity: 0;
        }

        to {
            opacity: 1;
        }
    }

    @@keyframes fadeInUp {
        from {
            opacity: 0;
            transform: translateY(30px);
        }

        to {
            opacity: 1;
            transform: translateY(0);
        }
    }
</style>

<!-- PHIM MỚI NHẤT -->
<div class="container">
    <div class="section-header">
        <i class="fas fa-fire"></i>
        <h2>Phim Mới Nhất</h2>
    </div>

    @if (latestMovies != null && latestMovies.Any())
    {
        <div class="movies-row-container">
            <button class="scroll-arrow scroll-left" onclick="scrollLeft('latest')">
                <i class="fas fa-chevron-left"></i>
            </button>

            <div class="movies-row" id="latest-movies-row">
                @foreach (var movie in latestMovies)
                {
                    <div class="movie-card">
                        <!--  FIXED: asp-controller="Movie" -->
                        <a asp-controller="Movie" asp-action="Detail" asp-route-slug="@movie.Slug">
                            <div class="movie-poster">
                                <img src="@(string.IsNullOrEmpty(movie.PosterUrl) ? "https://via.placeholder.com/300x450/2d2d2d/ffffff?text=No+Poster" : movie.PosterUrl)"
                                     alt="@movie.Title"
                                     loading="lazy" />
                                <div class="movie-overlay">
                                    <div class="play-button">
                                        <i class="fas fa-play"></i>
                                    </div>
                                </div>
                            </div>
                        </a>
                        <div class="movie-info">
                            <h6 class="movie-title">
                                <!--  FIXED -->
                                <a asp-controller="Movie" asp-action="Detail" asp-route-slug="@movie.Slug">
                                    @movie.Title
                                </a>
                            </h6>
                            <div class="movie-meta">
                                <span>
                                    <i class="fas fa-calendar"></i> @movie.ReleaseYear
                                </span>
                                @if (!string.IsNullOrEmpty(movie.CountryName))
                                {
                                    <span>
                                        <i class="fas fa-globe"></i> @movie.CountryName
                                    </span>
                                }
                            </div>
                        </div>

                        @if (User.Identity?.IsAuthenticated == true)
                        {
                            <button class="favorite-icon-btn" data-movie-id="@movie.Id">
                                <i class="far fa-heart"></i>
                            </button>
                        }
                    </div>
                }
            </div>

            <button class="scroll-arrow scroll-right" onclick="scrollRight('latest')">
                <i class="fas fa-chevron-right"></i>
            </button>
        </div>
    }
    else
    {
        <div class="netflix-alert">
            <i class="fas fa-info-circle"></i>
            <h3>Chưa có phim nào</h3>
            <p>Vui lòng quay lại sau hoặc khám phá các phim khác</p>
        </div>
    }
</div>

