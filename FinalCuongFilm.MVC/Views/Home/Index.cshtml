        transition: opacity .2s, background .2s, transform .2s, border-color .2s;
    }

    .scroll-btn-l {
        left: -14px;
    }

    .scroll-btn-r {
        right: -14px;
    }

    .row-wrap:hover .scroll-btn {
        opacity: 1;
    }

    .scroll-btn:hover {
        background: var(--cf-red);
        border-color: var(--cf-red);
        transform: translateY(-50%) scale(1.1);
    }

    .scroll-btn:focus-visible {
