    </div>
}

<!-- TẤT CẢ PHIM - Netflix Grid -->
@if (Model != null && Model.Any())
{
    <div class="netflix-grid">
        <div class="grid-header">
            <h2>Tất Cả Phim</h2>
            <div class="grid-filters">
                <button class="filter-btn active">Tất cả</button>
                <button class="filter-btn">Phim lẻ</button>
                <button class="filter-btn">Phim bộ</button>
                <button class="filter-btn">Chiếu rạp</button>
            </div>
        </div>

        <div class="movies-grid">
            @foreach (var movie in Model.Take(20))
            {
                <div class="grid-card">
                    <div class="grid-card-poster">
                        <img src="@(movie.PosterUrl ?? "https://via.placeholder.com/300x450/2d2d2d/ffffff?text=No+Poster")"
                             alt="@movie.Title"
                             loading="lazy" />

                        <div class="grid-card-overlay">
                            <a asp-controller="Movie" asp-action="Watch" asp-route-slug="@movie.Slug"
                               class="grid-card-play">
                                <i class="fas fa-play"></i>
                            </a>
                        </div>

                        @if (User.Identity?.IsAuthenticated == true)
                        {
                            <button class="favorite-icon-btn" data-movie-id="@movie.Id">
                                <i class="far fa-heart"></i>
                            </button>
                        }
                    </div>

                    <div class="grid-card-info">
                        <h3>@movie.Title</h3>
                        <div class="grid-card-meta">
                            <span>
                                <i class="fas fa-calendar"></i> @(movie.ReleaseYear?.ToString() ?? "N/A")
                            </span>
                            <span>
                                <i class="fas fa-eye"></i> @(movie.ViewCount.ToString("N0") ?? "0")
                            </span>
                        </div>
                    </div>
                </div>
            }
        </div>
    </div>
}

<script>
    // Smooth scroll for movie rows
    function scrollMovies(section, direction) {
        const row = document.getElementById(`${section}-row`);
        if (row) {
            const scrollAmount = direction === 'left' ? -500 : 500;
            row.scrollBy({ left: scrollAmount, behavior: 'smooth' });
        }
    }

    // Update scroll buttons state
    function updateScrollButtons() {
        document.querySelectorAll('.movies-row').forEach(row => {
            const container = row.closest('.movies-row-container');
            if (!container) return;

            const leftArrow = container.querySelector('.scroll-left');
            const rightArrow = container.querySelector('.scroll-right');

            if (row.scrollLeft <= 10) {
                leftArrow.style.opacity = '0.3';
                leftArrow.style.pointerEvents = 'none';
            } else {
                leftArrow.style.opacity = '1';
                leftArrow.style.pointerEvents = 'auto';
            }

            if (row.scrollWidth - row.clientWidth - row.scrollLeft <= 10) {
                rightArrow.style.opacity = '0.3';
                rightArrow.style.pointerEvents = 'none';
            } else {
                rightArrow.style.opacity = '1';
                rightArrow.style.pointerEvents = 'auto';
            }
        });
    }

    // Favorite functionality
    document.addEventListener('click', function(e) {
        const favoriteBtn = e.target.closest('.favorite-btn, .favorite-icon-btn');
        if (favoriteBtn) {
            e.preventDefault();
            e.stopPropagation();

            const movieId = favoriteBtn.dataset.movieId;
            const icon = favoriteBtn.querySelector('i');

            // Toggle favorite logic here
            if (icon.classList.contains('far')) {
                icon.classList.remove('far');
                icon.classList.add('fas');
                icon.style.color = '#e50914';
            } else {
                icon.classList.remove('fas');
                icon.classList.add('far');
                icon.style.color = '';
            }
        }
    });

    // Initialize scroll listeners
    document.addEventListener('DOMContentLoaded', function() {
        document.querySelectorAll('.movies-row').forEach(row => {
            row.addEventListener('scroll', updateScrollButtons);
        });

        updateScrollButtons();

        // Filter buttons
        document.querySelectorAll('.filter-btn').forEach(btn => {
            btn.addEventListener('click', function() {
                document.querySelectorAll('.filter-btn').forEach(b => b.classList.remove('active'));
                this.classList.add('active');
            });
        });
    });

    // Add touch support for mobile
    let touchStartX = 0;
    document.querySelectorAll('.movies-row').forEach(row => {
        row.addEventListener('touchstart', e => {
            touchStartX = e.touches[0].clientX;
        }, { passive: true });

        row.addEventListener('touchend', e => {
            const touchEndX = e.changedTouches[0].clientX;
            const diff = touchStartX - touchEndX;

            if (Math.abs(diff) > 50) {
                if (diff > 0) {
                    row.scrollBy({ left: 300, behavior: 'smooth' });
                } else {
                    row.scrollBy({ left: -300, behavior: 'smooth' });
                }
            }
        });
    });
</script>

