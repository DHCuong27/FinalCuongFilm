@model FinalCuongFilm.MVC.Models.ViewModels.HomeFilterViewModel
@{
    ViewData["Title"] = "Home";
    Layout = "_LayoutUser";
    var f = Model.AllMoviesFilter;
    var featuredMovies = Model.PopularMovies.Take(5).ToList();
}

<style>
    :root {
        --netflix-red: #e50914;
        --netflix-dark: #0f0f0f;
        --netflix-dark-bg: #1a1a1a;
        --netflix-gray: #2d2d2d;
        --netflix-light-gray: #b3b3b3;
        --netflix-white: #ffffff;
    }

    body {
        background-color: var(--netflix-dark);
        color: var(--netflix-white);
        font-family: 'Segoe UI', sans-serif;
        margin: 0;
        padding: 0;
    }

    .premium-movie-badge {
        position: absolute;
        top: 8px;
        right: 8px;
        background: linear-gradient(45deg, #FFD700, #FFA500);
        color: #000;
        font-size: 0.75rem;
        font-weight: bold;
        padding: 3px 8px;
        border-radius: 5px;
        z-index: 10;
        box-shadow: 0 2px 5px rgba(0,0,0,0.5);
    }

    .hero-slider-section {
        position: relative;
        margin-bottom: 4rem;
        background-color: var(--netflix-dark);
    }

    .hero-slider-container {
        position: relative;
        height: 85vh;
        min-height: 600px;
        overflow: hidden;
    }

    .hero-slide {
        position: absolute;
        inset: 0;
        opacity: 0;
        visibility: hidden;
        transition: opacity 0.8s ease-in-out, visibility 0.8s;
        z-index: 1;
        display: flex;
        align-items: center;
    }

        .hero-slide.active {
            opacity: 1;
            visibility: visible;
            z-index: 2;
        }

    /* Tối ưu hóa background để khớp mọi loại ảnh */
    .hero-bg {
        position: absolute;
        inset: 0;
        background-size: cover;
        background-position: center 15%;
        background-repeat: no-repeat;
        background-color: var(--netflix-dark);
        z-index: 1;
    }

        /* Mặt nạ bảo vệ Text (Gradient từ trái sang phải) */
        .hero-bg::before {
            content: '';
            position: absolute;
            inset: 0;
            background: linear-gradient(90deg, var(--netflix-dark) 0%, rgba(15,15,15,0.9) 25%, rgba(15,15,15,0.4) 60%, transparent 100%);
            z-index: 2;
        }

        /* Mặt nạ làm mềm viền (Gradient trên, dưới, phải) */
        .hero-bg::after {
            content: '';
            position: absolute;
            inset: 0;
            background: linear-gradient(0deg, var(--netflix-dark) 0%, transparent 25%), linear-gradient(180deg, var(--netflix-dark) 0%, transparent 15%), linear-gradient(270deg, var(--netflix-dark) 0%, transparent 15%);
            z-index: 3;
        }

    .hero-content-wrapper {
        position: relative;
        z-index: 4;
        width: 100%;
        max-width: 1400px;
        margin: 0 auto;
        padding: 0 4rem;
        display: flex;
        align-items: center;
    }

    /* Left Text Content */
    .hero-text-content {
        flex: 1;
        max-width: 650px;
        transform: translateY(30px);
        opacity: 0;
        transition: all 0.8s ease-out 0.3s;
    }

    .hero-slide.active .hero-text-content {
        transform: translateY(0);
        opacity: 1;
    }

    .featured-title {
        font-size: 3.5rem;
        font-weight: 800;
        margin-bottom: 0.5rem;
        line-height: 1.2;
        text-shadow: 2px 2px 10px rgba(0,0,0,0.5);
    }

    .featured-subtitle {
        font-size: 1.1rem;
        color: #d6b074;
        margin-bottom: 1.5rem;
        font-style: italic;
    }

    .featured-meta-badges {
        display: flex;
        flex-wrap: wrap;
        align-items: center;
        gap: 0.8rem;
        margin-bottom: 1rem;
    }

    .badge-outline {
        border: 1px solid rgba(255,255,255,0.6);
        padding: 0.2rem 0.6rem;
        border-radius: 4px;
        font-size: 0.85rem;
        color: var(--netflix-white);
        background: rgba(0,0,0,0.3);
    }

    .featured-tags {
        display: flex;
        flex-wrap: wrap;
        align-items: center;
        gap: 0.5rem;
        margin-bottom: 1.5rem;
    }

    .tag-dark {
        background: rgba(255,255,255,0.15);
        padding: 0.2rem 0.8rem;
        border-radius: 4px;
        font-size: 0.85rem;
        color: #e5e5e5;
    }

    .featured-desc {
        font-size: 1rem;
        color: #e0e0e0;
        margin-bottom: 2rem;
        line-height: 1.6;
        display: -webkit-box;
        -webkit-line-clamp: 3;
        -webkit-box-orient: vertical;
        overflow: hidden;
        text-shadow: 1px 1px 4px rgba(0,0,0,0.8);
    }

    /* Action Buttons */
    .featured-actions-round {
        display: flex;
        gap: 1.5rem;
        align-items: center;
    }

    /* UPDATED: Play button changed to red */
    .btn-play-round {
        width: 60px;
        height: 60px;
        border-radius: 50%;
        background-color: var(--netflix-red);
        color: #fff;
        display: flex;
        align-items: center;
        justify-content: center;
        font-size: 1.6rem;
        text-decoration: none;
        transition: 0.3s;
        box-shadow: 0 4px 15px rgba(229, 9, 20, 0.4);
        padding-left: 5px;
    }

        .btn-play-round:hover {
            transform: scale(1.08);
            background-color: #f40612;
        }

    .btn-icon-round {
        width: 45px;
        height: 45px;
        border-radius: 50%;
        background-color: rgba(0,0,0,0.4);
        border: 1px solid rgba(255,255,255,0.3);
        color: white;
        display: flex;
        align-items: center;
        justify-content: center;
        font-size: 1.2rem;
        text-decoration: none;
        transition: 0.3s;
        cursor: pointer;
    }

        .btn-icon-round:hover {
            background-color: rgba(255,255,255,0.2);
            border-color: rgba(255,255,255,0.8);
        }

    .hero-poster-content {
        display: none;
    }

    /* NEW: Compact Thumbnail Navigation Strip - Bottom Right Corner */
    .thumbnail-strip-compact {
        position: absolute;
        bottom: 30px;
        right: 30px;
        display: flex;
        gap: 8px;
        z-index: 20;
        padding: 8px 12px;
        background: rgba(0, 0, 0, 0.5);
        backdrop-filter: blur(8px);
        border-radius: 40px;
        border: 1px solid rgba(255, 255, 255, 0.15);
        max-width: 400px;
        overflow-x: auto;
        scrollbar-width: none; /* Hide scrollbar for cleaner look */
    }

        .thumbnail-strip-compact::-webkit-scrollbar {
            display: none; /* Hide scrollbar for Chrome/Safari */
        }

    .thumbnail-item-compact {
        flex: 0 0 auto;
        width: 50px;
        height: 70px;
        border-radius: 6px;
        overflow: hidden;
        cursor: pointer;
        position: relative;
        transition: all 0.2s ease;
        border: 2px solid transparent;
        box-shadow: 0 2px 8px rgba(0, 0, 0, 0.4);
        opacity: 0.7;
    }

        .thumbnail-item-compact:hover {
            opacity: 1;
            transform: translateY(-3px);
            border-color: rgba(255, 255, 255, 0.8);
        }

        .thumbnail-item-compact.active {
            border-color: var(--netflix-red);
            opacity: 1;
            transform: scale(1.05);
            box-shadow: 0 0 15px rgba(229, 9, 20, 0.5);
        }

        .thumbnail-item-compact img {
            width: 100%;
            height: 100%;
            object-fit: cover;
        }

        .thumbnail-item-compact .thumbnail-number {
            position: absolute;
            bottom: 2px;
            right: 2px;
            background: var(--netflix-red);
            color: white;
            font-size: 0.6rem;
            font-weight: bold;
            width: 16px;
            height: 16px;
            border-radius: 50%;
            display: flex;
            align-items: center;
            justify-content: center;
            border: 1px solid white;
        }

    /* Optional: Add a small label for the thumbnail strip */
    .thumbnail-label {
        position: absolute;
        bottom: 110px;
        right: 30px;
        color: rgba(255,255,255,0.5);
        font-size: 0.7rem;
        text-transform: uppercase;
        letter-spacing: 1px;
        z-index: 19;
    }

    .global-search-overlay {
        position: absolute;
        bottom: 120px;
        left: 0;
        right: 0;
        z-index: 15;
    }

    .banner-search-container {
        max-width: 600px;
        margin: 0 auto;
        position: relative;
        padding: 0 2rem;
    }

    .search-input-wrapper {
        display: flex;
        background: rgba(0,0,0,0.75);
        border: 2px solid rgba(255,255,255,0.1);
        border-radius: 40px;
        padding: 3px 3px 3px 20px;
        backdrop-filter: blur(10px);
        transition: all 0.3s;
    }

        .search-input-wrapper:focus-within {
            border-color: var(--netflix-red);
            background: rgba(0,0,0,0.95);
            box-shadow: 0 0 20px rgba(229,9,20,0.3);
        }

        .search-input-wrapper input {
            flex: 1;
            background: transparent;
            border: none;
            color: white;
            font-size: 1.1rem;
            padding: 12px 0;
            outline: none;
        }

            .search-input-wrapper input::placeholder {
                color: var(--netflix-light-gray);
            }

        .search-input-wrapper .btn-search {
            background: var(--netflix-red);
            color: white;
            border: none;
            border-radius: 40px;
            padding: 12px 30px;
            font-size: 1rem;
            font-weight: 600;
            cursor: pointer;
            display: flex;
            align-items: center;
            gap: 8px;
        }

            .search-input-wrapper .btn-search:hover {
                background: #f40612;
            }

    .search-suggestions-box {
        position: absolute;
        top: 100%;
        left: 0;
        right: 0;
        margin-top: 10px;
        background: var(--netflix-dark-bg);
        border: 1px solid var(--netflix-gray);
        border-radius: 10px;
        overflow: hidden;
        box-shadow: 0 10px 30px rgba(0,0,0,0.8);
        display: none;
    }

    .suggestion-item {
        display: flex;
        align-items: center;
        padding: 10px 15px;
        color: white;
        text-decoration: none;
        border-bottom: 1px solid rgba(255,255,255,0.05);
        transition: 0.2s;
    }

        .suggestion-item:hover {
            background: rgba(255,255,255,0.1);
        }

        .suggestion-item img {
            width: 40px;
            height: 60px;
            object-fit: cover;
            border-radius: 4px;
            margin-right: 15px;
        }

    .container {
        max-width: 1400px;
        margin: 0 auto;
        padding: 0 2rem;
    }

    .section-header {
        display: flex;
        align-items: center;
        justify-content: space-between;
        gap: 1rem;
        margin-bottom: 2rem;
        padding-bottom: 1rem;
        border-bottom: 2px solid var(--netflix-gray);
        position: relative;
    }

        .section-header::after {
            content: '';
            position: absolute;
            bottom: -2px;
            left: 0;
            width: 100px;
            height: 2px;
            background: var(--netflix-red);
        }

    .section-header-left {
        display: flex;
        align-items: center;
        gap: 1rem;
    }

    .section-header {
        display: flex;
        align-items: center;
        justify-content: space-between;
        gap: 1rem;
        margin-bottom: 2rem;
        padding-bottom: 0.75rem;
        border-bottom: 1px solid rgba(255,255,255,0.1);
        position: relative;
    }

    .section-header-left {
        display: flex;
        align-items: center;
        gap: 0.75rem;
    }

    .section-header i {
        font-size: 1.5rem;
        color: var(--netflix-dark);
        background: transparent;
        padding: 0;
        border-radius: 0;
    }

    .section-header h2 {
        font-size: 1.5rem;
        font-weight: 600;
        margin: 0;
        letter-spacing: -0.5px;
    }

    /* Optional: subtle red accent line */
    .section-header::after {
        content: '';
        position: absolute;
        bottom: -1px;
        left: 0;
        width: 60px;
        height: 2px;
        background: var(--netflix-red);
        opacity: 0.6;
    }

    .movies-row-container {
        position: relative;
        margin-bottom: 4rem;
    }

    .movies-row {
        display: flex;
        overflow-x: auto;
        padding: 1rem 0.5rem;
        scrollbar-width: none;
        gap: 1.2rem;
        scroll-behavior: smooth;
    }

        .movies-row::-webkit-scrollbar {
            display: none;
        }

    .scroll-arrow {
        position: absolute;
        top: 50%;
        transform: translateY(-50%);
        background: rgba(0,0,0,0.7);
        color: white;
        border: none;
        width: 40px;
        height: 40px;
        border-radius: 50%;
        display: flex;
        align-items: center;
        justify-content: center;
        cursor: pointer;
        z-index: 10;
        opacity: 0;
        transition: all 0.3s;
    }

    .scroll-left {
        left: -20px;
    }

    .scroll-right {
        right: -20px;
    }

    .movies-row-container:hover .scroll-arrow {
        opacity: 1;
    }

    .scroll-arrow:hover {
        background: var(--netflix-red);
        transform: translateY(-50%) scale(1.1);
    }

    .movie-card {
        flex: 0 0 auto;
        width: 220px;
        transition: all 0.4s;
        position: relative;
        cursor: pointer;
    }

        .movie-card:hover {
            transform: scale(1.08);
            z-index: 20;
        }

    .movie-poster {
        position: relative;
        border-radius: 8px;
        overflow: hidden;
        aspect-ratio: 2/3;
        background-color: var(--netflix-gray);
        box-shadow: 0 4px 20px rgba(0,0,0,0.5);
        transition: all 0.4s;
    }

    .movie-card:hover .movie-poster {
        box-shadow: 0 10px 30px rgba(0,0,0,0.8);
        transform: translateY(-10px);
    }

    .movie-poster img {
        width: 100%;
        height: 100%;
        object-fit: cover;
        transition: transform 0.4s;
    }

    .movie-card:hover .movie-poster img {
        transform: scale(1.05);
    }

    .movie-overlay {
        position: absolute;
        inset: 0;
        background: linear-gradient(180deg, transparent 40%, rgba(0,0,0,0.9) 100%);
        display: flex;
        flex-direction: column;
        justify-content: flex-end;
        padding: 1.5rem;
        opacity: 0;
        transition: opacity 0.3s;
    }

    .movie-card:hover .movie-overlay {
        opacity: 1;
    }

    .play-button {
        position: absolute;
        top: 50%;
        left: 50%;
        transform: translate(-50%,-50%) scale(0.8);
        background: rgba(229,9,20,0.9);
        color: white;
        width: 60px;
        height: 60px;
        border-radius: 50%;
        display: flex;
        align-items: center;
        justify-content: center;
        font-size: 1.8rem;
        opacity: 0;
        transition: all 0.3s;
        border: 3px solid white;
    }

    .movie-card:hover .play-button {
        opacity: 1;
        transform: translate(-50%,-50%) scale(1);
    }

    .movie-info {
        padding: 1rem 0.5rem 0.5rem;
    }

    .movie-title {
        font-size: 1rem;
        font-weight: 700;
        margin: 0 0 0.5rem;
        white-space: nowrap;
        overflow: hidden;
        text-overflow: ellipsis;
    }

        .movie-title a {
            color: white;
            text-decoration: none;
        }

            .movie-title a:hover {
                color: var(--netflix-red);
            }

    .movie-meta {
        display: flex;
        align-items: center;
        gap: 0.8rem;
        font-size: 0.85rem;
        color: var(--netflix-light-gray);
    }

        .movie-meta i {
            color: var(--netflix-red);
        }

    .view-badge {
        position: absolute;
        top: 15px;
        left: 15px;
        background: linear-gradient(135deg, var(--netflix-red), #b20710);
        color: white;
        padding: 0.4rem 0.8rem;
        border-radius: 4px;
        font-size: 0.75rem;
        font-weight: 700;
        z-index: 3;
        display: flex;
        align-items: center;
        gap: 0.3rem;
    }

    .favorite-icon-btn {
        position: absolute;
        top: 10px;
        right: 10px;
        background: rgba(0,0,0,0.7);
        border: none;
        width: 36px;
        height: 36px;
        border-radius: 50%;
        display: flex;
        align-items: center;
        justify-content: center;
        color: white;
        opacity: 0;
        transition: opacity 0.3s;
        cursor: pointer;
    }

    .movie-card:hover .favorite-icon-btn {
        opacity: 1;
    }

    .favorite-icon-btn:hover {
        background: var(--netflix-red);
    }

    .filter-bar {
        background: var(--netflix-dark-bg);
        border: 1px solid var(--netflix-gray);
        border-radius: 12px;
        padding: 1.5rem;
        margin-bottom: 2rem;
    }

    .filter-row {
        display: flex;
        flex-wrap: wrap;
        gap: 1rem;
        align-items: flex-end;
    }

    .filter-group {
        display: flex;
        flex-direction: column;
        gap: 0.4rem;
        flex: 1;
        min-width: 140px;
    }

        .filter-group label {
            font-size: 0.8rem;
            font-weight: 600;
            color: var(--netflix-light-gray);
            text-transform: uppercase;
            letter-spacing: 0.5px;
        }

    .filter-select {
        background: var(--netflix-gray);
        border: 1px solid rgba(255,255,255,0.15);
        color: white;
        border-radius: 8px;
        padding: 0.6rem 1rem;
        font-size: 0.9rem;
        cursor: pointer;
        transition: border-color 0.2s;
    }

        .filter-select:focus {
            outline: none;
            border-color: var(--netflix-red);
        }

        .filter-select option {
            background: var(--netflix-gray);
        }

    .btn-reset {
        background: transparent;
        color: var(--netflix-light-gray);
        border: 1px solid rgba(255,255,255,0.2);
        border-radius: 8px;
        padding: 0.65rem 1.2rem;
        font-size: 0.9rem;
        cursor: pointer;
        transition: all 0.2s;
        white-space: nowrap;
    }

        .btn-reset:hover {
            border-color: var(--netflix-red);
            color: var(--netflix-red);
        }

    .filter-result-count {
        font-size: 0.9rem;
        color: var(--netflix-light-gray);
        margin-top: 0.8rem;
    }

        .filter-result-count span {
            color: var(--netflix-red);
            font-weight: 700;
        }

    #filtered-movies-wrapper {
        transition: opacity 0.3s ease;
    }

    .loading-state {
        opacity: 0.5;
        pointer-events: none;
    }

    .movies-grid {
        display: grid;
        grid-template-columns: repeat(auto-fill, minmax(180px, 1fr));
        gap: 1.2rem;
        margin-bottom: 3rem;
    }

    .grid-card {
        position: relative;
        border-radius: 8px;
        overflow: hidden;
        background: var(--netflix-dark-bg);
        border: 1px solid var(--netflix-gray);
        transition: transform 0.3s, box-shadow 0.3s;
    }

        .grid-card:hover {
            transform: translateY(-6px);
            box-shadow: 0 12px 30px rgba(0,0,0,0.7);
        }

    .grid-card-poster {
        position: relative;
        aspect-ratio: 2/3;
        overflow: hidden;
    }

        .grid-card-poster img {
            width: 100%;
            height: 100%;
            object-fit: cover;
            transition: transform 0.4s;
        }

    .grid-card:hover .grid-card-poster img {
        transform: scale(1.05);
    }

    .grid-card-overlay {
        position: absolute;
        inset: 0;
        background: linear-gradient(180deg, transparent 50%, rgba(0,0,0,0.9) 100%);
        opacity: 0;
        transition: opacity 0.3s;
        display: flex;
        align-items: flex-end;
        padding: 1rem;
    }

    .grid-card:hover .grid-card-overlay {
        opacity: 1;
    }

    .btn-play-card {
        display: inline-flex;
        align-items: center;
        gap: 0.4rem;
        background: var(--netflix-red);
        color: white;
        padding: 0.5rem 1rem;
        border-radius: 6px;
        text-decoration: none;
        font-size: 0.85rem;
        font-weight: 600;
    }

    .grid-card-info {
        padding: 0.8rem;
    }

    .grid-card-title {
        font-size: 0.9rem;
        font-weight: 600;
        margin-bottom: 0.3rem;
        white-space: nowrap;
        overflow: hidden;
        text-overflow: ellipsis;
    }

        .grid-card-title a {
            color: white;
            text-decoration: none;
        }

            .grid-card-title a:hover {
                color: var(--netflix-red);
            }

    .grid-card-meta {
        font-size: 0.78rem;
        color: var(--netflix-light-gray);
        display: flex;
        gap: 0.5rem;
    }

    .badge-type {
        position: absolute;
        top: 8px;
        left: 8px;
        background: rgba(229,9,20,0.85);
        color: white;
        padding: 0.2rem 0.6rem;
        border-radius: 4px;
        font-size: 0.7rem;
        font-weight: 700;
        z-index: 3;
    }

    .pagination-wrapper {
        display: flex;
        justify-content: center;
        align-items: center;
        gap: 0.5rem;
        margin: 2rem 0 4rem;
        flex-wrap: wrap;
    }

    .page-btn {
        background: var(--netflix-gray);
        color: white;
        border: 1px solid rgba(255,255,255,0.1);
        padding: 0.5rem 0.9rem;
        border-radius: 6px;
        cursor: pointer;
        text-decoration: none;
        font-size: 0.9rem;
        transition: all 0.2s;
    }

        .page-btn:hover {
            background: var(--netflix-red);
            border-color: var(--netflix-red);
            color: white;
        }

        .page-btn.active {
            background: var(--netflix-red);
            border-color: var(--netflix-red);
            font-weight: 700;
        }

        .page-btn.disabled {
            opacity: 0.4;
            pointer-events: none;
        }

    .netflix-alert {
        background: var(--netflix-dark-bg);
        border: 1px solid var(--netflix-gray);
        border-radius: 8px;
        padding: 2rem;
        margin: 2rem 0;
        text-align: center;
    }

        .netflix-alert i {
            color: var(--netflix-red);
            font-size: 2rem;
            margin-bottom: 1rem;
            display: block;
        }

    @@media (max-width: 992px) {
        .hero-text-content

    {
