@Html.AntiForgeryToken()

@section Scripts {
    <script>
        $(document).ready(function () {
            // --- 1. SEARCH SUGGESTIONS ---
            let debounceTimer;
            $('.searchInputField').on('input', function () {
                clearTimeout(debounceTimer);
                const query = $(this).val().trim();
                const box = $(this).closest('.banner-search-container').find('.searchSuggestionsBox');

                if (query.length < 2) { box.hide(); return; }

                debounceTimer = setTimeout(() => {
                    $.get('/Search/Suggestions', { q: query }, function (data) {
                        box.empty();
                        if (data && data.length > 0) {
                            data.forEach(m => {
                                box.append(`<a href="/Movie/Detail/${m.slug}" class="suggestion-item">
                                    <img src="${m.posterUrl}" onerror="this.src='https://via.placeholder.com/40x60/2d2d2d/fff?text=N/A'" />
                                    <div><div style="font-weight:600">${m.title}</div>
                                    <div style="font-size:0.85rem;color:#b3b3b3"><i class="fas fa-calendar-alt"></i> ${m.year || 'N/A'}</div></div>
                                </a>`);
                            });
                            box.fadeIn(150);
                        } else {
                            box.html('<div style="padding:15px;color:#b3b3b3;text-align:center">No matching movies found</div>').fadeIn(150);
                        }
                    });
                }, 300);
            });
            $(document).on('click', function (e) {
                if (!$(e.target).closest('.banner-search-container').length) $('.searchSuggestionsBox').fadeOut(150);
            });

            // --- 2. HERO SLIDER ---
            const $slides = $('.hero-slide');
            const $dots = $('.slider-indicators .dot');
            let currentSlide = 0;
            const totalSlides = $slides.length;
            let slideInterval;

            function goToSlide(index) {
                $slides.removeClass('active');
                $dots.removeClass('active');

                currentSlide = index;
                if (currentSlide >= totalSlides) currentSlide = 0;
                if (currentSlide < 0) currentSlide = totalSlides - 1;

                $slides.eq(currentSlide).addClass('active');
                $dots.eq(currentSlide).addClass('active');
            }

            function nextSlide() { goToSlide(currentSlide + 1); }
            function prevSlide() { goToSlide(currentSlide - 1); }

            function startSlideShow() {
                slideInterval = setInterval(nextSlide, 6000); // Đổi slide mỗi 6 giây
            }
            function resetSlideShow() {
                clearInterval(slideInterval);
                startSlideShow();
            }

            $('#heroNext').click(function () { nextSlide(); resetSlideShow(); });
            $('#heroPrev').click(function () { prevSlide(); resetSlideShow(); });

            $dots.click(function () {
                goToSlide($(this).data('slide'));
                resetSlideShow();
            });

            if(totalSlides > 1) {
                startSlideShow();
            }

            // --- 3. AJAX FILTER LOGIC ---
            $(document).on('change', '#filterForm select', function () {
                $('#filterForm').trigger('submit');
            });

            $(document).on('submit', '#filterForm', function (e) {
                e.preventDefault();
                let url = $(this).attr('action') + '?' + $(this).serialize();
                loadFilteredMovies(url);
            });

            $(document).on('click', '.pagination-wrapper a.page-btn', function (e) {
                e.preventDefault();
                let url = $(this).attr('href');
                if (url && !$(this).hasClass('disabled')) {
                    loadFilteredMovies(url);
                    $('html, body').animate({
                        scrollTop: $("#filter-section-container").offset().top - 50
                    }, 500);
                }
            });

            function loadFilteredMovies(url) {
                let $wrapper = $('#filtered-movies-wrapper');
                $wrapper.addClass('loading-state');

                $.ajax({
                    url: url,
                    type: 'GET',
                    success: function (data) {
                        let parsedData = $(data);
                        $('#filter-count-wrapper').html(parsedData.find('#filter-count-wrapper').html());
                        $wrapper.html(parsedData.find('#filtered-movies-wrapper').html());
                        $wrapper.removeClass('loading-state');
                        window.history.pushState({ path: url }, '', url);
                    },
                    error: function () {
                        $wrapper.removeClass('loading-state');
                        alert('An error occurred while loading movies.');
                    }
                });
            }
        });

        // --- 4. SCROLL ARROWS CHO MOVIE ROWS ---
        function doScrollLeft(id)  { document.getElementById(id + '-movies-row').scrollBy({ left: -600, behavior: 'smooth' }); }
        function doScrollRight(id) { document.getElementById(id + '-movies-row').scrollBy({ left:  600, behavior: 'smooth' }); }
    </script>
}