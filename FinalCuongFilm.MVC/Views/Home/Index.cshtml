@model FinalCuongFilm.MVC.Models.ViewModels.HomeFilterViewModel
@{
    Layout = "_LayoutUser";
    var f = Model.AllMoviesFilter;
    var featuredMovies = Model.PopularMovies.Take(5).ToList();
}
<h1 class="visually-hidden">CuongFilm - Xem phim chất lượng cao</h1>

<style>
    :root {
        --netflix-red: #e50914;
        --netflix-dark: #0f0f0f;
        --netflix-dark-bg: #1a1a1a;
        --netflix-gray: #2d2d2d;
        --netflix-light-gray: #b3b3b3;
        --netflix-white: #ffffff;
    }

    body {
        background-color: var(--netflix-dark);
        color: var(--netflix-white);
        font-family: 'Segoe UI', sans-serif;
        margin: 0;
        padding: 0;
    }

    /* VIP Badge (Top Right) */
    .premium-movie-badge {
        position: absolute;
        top: 8px;
        right: 8px;
        background: linear-gradient(45deg, #FFD700, #FFA500);
        color: #000;
        font-size: 0.75rem;
        font-weight: 800;
        padding: 4px 10px;
        border-radius: 4px;
        z-index: 10;
        box-shadow: 0 4px 10px rgba(0,0,0,0.5);
    }

    /* Type Badge (Top Left) */
    .badge-type {
        position: absolute;
        top: 8px;
        left: 8px;
        background: var(--netflix-red);
        color: white;
        padding: 0.3rem 0.8rem;
        border-radius: 4px;
        font-size: 0.75rem;
        font-weight: 700;
        z-index: 10;
        box-shadow: 0 4px 10px rgba(229, 9, 20, 0.4);
    }

    /* =========================================
           HERO SLIDER (CINEMATIC NETFLIX STYLE)
           ========================================= */
    .hero-slider-section {
        position: relative;
        margin-bottom: 4rem;
        background-color: var(--netflix-dark);
    }

    .hero-slider-container {
        position: relative;
        height: 85vh;
        min-height: 650px;
        overflow: hidden;
    }

    .hero-slide {
        position: absolute;
        inset: 0;
        opacity: 0;
        visibility: hidden;
        transition: opacity 1s ease-in-out, visibility 1s;
        z-index: 1;
        display: flex;
        align-items: center;
    }

        .hero-slide.active {
            opacity: 1;
            visibility: visible;
            z-index: 2;
        }

    /* Tràn viền ảnh nền toàn màn hình */
    .hero-bg {
        position: absolute;
        inset: 0;
        background-size: cover;
        background-position: center 20%; /* Giữ trọng tâm ảnh ở nửa trên */
        background-repeat: no-repeat;
        z-index: 1;
        transition: transform 6s linear; /* Hiệu ứng ken-burns nhẹ khi active */
    }

    .hero-slide.active .hero-bg {
        transform: scale(1.05); /* Ảnh nền từ từ zoom lên */
    }

    /* Gradient Gradient bóng đêm để chữ nổi bật, không cần hộp đen */
    .hero-bg::before {
        content: '';
        position: absolute;
        inset: 0;
        background: linear-gradient(90deg, #0f0f0f 0%, rgba(15,15,15,0.85) 30%, rgba(15,15,15,0.4) 60%, transparent 100%), linear-gradient(0deg, #0f0f0f 0%, transparent 25%);
        z-index: 2;
    }

    .hero-content-wrapper {
        position: relative;
        z-index: 5;
        width: 100%;
        max-width: 1400px;
        margin: 0 auto;
        padding: 0 4rem;
        display: flex;
        align-items: center;
    }

    /* Left Text Content & Hiệu ứng Staggered Fade Up */
    .hero-text-content {
        flex: 1;
        max-width: 650px;
        padding: 1rem 0;
    }

        /* Set up các element con để làm animation */
        .hero-text-content > * {
            transform: translateY(40px);
            opacity: 0;
            transition: all 0.8s cubic-bezier(0.25, 0.46, 0.45, 0.94);
        }

    .hero-slide.active .hero-text-content .featured-title {
        transition-delay: 0.2s;
        transform: translateY(0);
        opacity: 1;
    }

    .hero-slide.active .hero-text-content .featured-meta-badges {
        transition-delay: 0.4s;
        transform: translateY(0);
        opacity: 1;
    }

    .hero-slide.active .hero-text-content .featured-desc {
        transition-delay: 0.6s;
        transform: translateY(0);
        opacity: 1;
    }

    .hero-slide.active .hero-text-content .featured-actions-round {
        transition-delay: 0.8s;
        transform: translateY(0);
        opacity: 1;
    }

    .featured-title {
        font-size: 4rem;
        font-weight: 900;
        margin-bottom: 0.8rem;
        line-height: 1.1;
        text-shadow: 2px 4px 15px rgba(0,0,0,0.8);
        letter-spacing: -1px;
    }

    .featured-meta-badges {
        display: flex;
        flex-wrap: wrap;
        align-items: center;
        gap: 0.8rem;
        margin-bottom: 1.5rem;
    }

    .badge-outline {
        border: 1px solid rgba(255,255,255,0.7);
        padding: 0.3rem 0.8rem;
        border-radius: 4px;
        font-size: 0.85rem;
        font-weight: 600;
        color: var(--netflix-white);
        background: rgba(0,0,0,0.4);
        backdrop-filter: blur(4px);
    }

    /* Typography đẹp hơn cho phần mô tả */
    .featured-desc {
        font-size: 1.15rem;
        color: #e5e5e5;
        margin-bottom: 2.5rem;
        line-height: 1.7;
        display: -webkit-box;
        -webkit-line-clamp: 4; /* Cho phép tối đa 4 dòng */
        -webkit-box-orient: vertical;
        overflow: hidden;
        text-shadow: 1px 2px 6px rgba(0,0,0,0.9);
        font-weight: 400;
        letter-spacing: 0.3px;
    }

    /* =========================================
           ACTION BUTTONS & PULSE GLOW
           ========================================= */
    .featured-actions-round {
        display: flex;
        gap: 1.5rem;
        align-items: center;
    }

    @@keyframes pulse-glow {
        0%

    {
        box-shadow: 0 0 0 0 rgba(229, 9, 20, 0.7);
    }

    70% {
        box-shadow: 0 0 0 20px rgba(229, 9, 20, 0);
    }

    100% {
        box-shadow: 0 0 0 0 rgba(229, 9, 20, 0);
    }

    }

    .btn-play-round {
        width: 65px;
        height: 65px;
        border-radius: 50%;
        background-color: var(--netflix-red);
        color: #fff;
        display: flex;
        align-items: center;
        justify-content: center;
        font-size: 1.8rem;
        text-decoration: none;
        transition: transform 0.3s;
        padding-left: 6px; /* Căn giữa icon play */
        animation: pulse-glow 2s infinite;
    }

        .btn-play-round:hover {
            transform: scale(1.1);
            background-color: #f40612;
            color: #fff;
            animation: none; /* Dừng chớp nháy khi hover */
            box-shadow: 0 8px 25px rgba(229, 9, 20, 0.6);
        }

    .btn-icon-round {
        width: 50px;
        height: 50px;
        border-radius: 50%;
        background-color: rgba(255,255,255,0.1);
        border: 2px solid rgba(255,255,255,0.4);
        color: white;
        display: flex;
        align-items: center;
        justify-content: center;
        font-size: 1.3rem;
        text-decoration: none;
        transition: all 0.3s;
        backdrop-filter: blur(5px);
    }

        .btn-icon-round:hover {
            background-color: rgba(255,255,255,0.3);
            border-color: #fff;
            transform: scale(1.1);
            color: #fff;
        }

    /* Thumbnail Strip */
    .thumbnail-strip-compact {
        position: absolute;
        bottom: 30px;
        right: 40px;
        display: flex;
        gap: 12px;
        z-index: 20;
        padding: 10px 15px;
        background: rgba(0, 0, 0, 0.4);
        backdrop-filter: blur(10px);
        border-radius: 12px;
        border: 1px solid rgba(255, 255, 255, 0.1);
        max-width: 450px;
        overflow-x: auto;
        scrollbar-width: none;
    }

        .thumbnail-strip-compact::-webkit-scrollbar {
            display: none;
        }

    .thumbnail-item-compact {
        flex: 0 0 auto;
        width: 55px;
        height: 80px;
        border-radius: 6px;
        overflow: hidden;
        cursor: pointer;
        position: relative;
        transition: all 0.3s ease;
        border: 2px solid transparent;
        opacity: 0.6;
    }

        .thumbnail-item-compact:hover {
            opacity: 1;
            transform: translateY(-5px);
        }

        .thumbnail-item-compact.active {
            border-color: var(--netflix-white);
            opacity: 1;
            transform: scale(1.05);
            box-shadow: 0 4px 15px rgba(0, 0, 0, 0.8);
        }

        .thumbnail-item-compact img {
            width: 100%;
            height: 100%;
            object-fit: cover;
            object-position: center;
        }

        .thumbnail-item-compact .thumbnail-number {
            position: absolute;
            bottom: 4px;
            right: 4px;
            background: var(--netflix-red);
            color: white;
            font-size: 0.65rem;
            font-weight: 800;
            width: 18px;
            height: 18px;
            border-radius: 50%;
            display: flex;
            align-items: center;
            justify-content: center;
        }

    /* Container and Section Headers */
    .container {
        max-width: 1400px;
        margin: 0 auto;
        padding: 0 2rem;
    }

    .section-header {
        display: flex;
        align-items: center;
        justify-content: space-between;
        gap: 1rem;
        margin-bottom: 1.5rem;
        padding-bottom: 0.75rem;
        border-bottom: 1px solid rgba(255,255,255,0.1);
        position: relative;
    }

        .section-header::after {
            content: '';
            position: absolute;
            bottom: -1px;
            left: 0;
            width: 60px;
            height: 3px;
            background: var(--netflix-red);
            border-radius: 3px;
        }

    .section-header-left {
        display: flex;
        align-items: center;
        gap: 0.75rem;
    }

        .section-header-left i {
            font-size: 1.5rem;
            color: var(--netflix-red);
        }

        .section-header-left h2 {
            font-size: 1.5rem;
            font-weight: 700;
            margin: 0;
            letter-spacing: 0.5px;
        }

    /* =========================================
           MOVIE ROW SCROLLERS & CARDS
           ========================================= */
    .movies-row-container {
        position: relative;
        margin-bottom: 4rem;
    }

    .movies-row {
        display: flex;
        overflow-x: auto;
        padding: 1.5rem 0.5rem; /* Padding rộng ra để card có chỗ phóng to */
        scrollbar-width: none;
        gap: 1.2rem;
        scroll-behavior: smooth;
    }

        .movies-row::-webkit-scrollbar {
            display: none;
        }

    .scroll-arrow {
        position: absolute;
        top: 40%;
        transform: translateY(-50%);
        background: rgba(0,0,0,0.6);
        color: white;
        border: 1px solid rgba(255,255,255,0.2);
        width: 45px;
        height: 45px;
        border-radius: 50%;
        display: flex;
        align-items: center;
        justify-content: center;
        cursor: pointer;
        z-index: 10;
        opacity: 0;
        transition: all 0.3s;
        backdrop-filter: blur(5px);
    }

    .scroll-left {
        left: -22px;
    }

    .scroll-right {
        right: -22px;
    }

    .movies-row-container:hover .scroll-arrow {
        opacity: 1;
    }

    .scroll-arrow:hover {
        background: var(--netflix-red);
        border-color: var(--netflix-red);
        transform: translateY(-50%) scale(1.1);
    }

    .movie-card {
        flex: 0 0 auto;
        width: 220px;
        transition: transform 0.4s cubic-bezier(0.25, 0.46, 0.45, 0.94);
        position: relative;
        cursor: pointer;
        border-radius: 8px;
    }

        .movie-card:hover {
            transform: translateY(-8px); /* Nhấc card lên nhẹ nhàng */
            z-index: 20;
        }

    .movie-poster,
    .grid-card-poster {
        position: relative;
        aspect-ratio: 2 / 3;
        overflow: hidden;
        background: #1a1a1a;
        border-radius: 8px;
        box-shadow: 0 4px 10px rgba(0,0,0,0.3);
        transition: box-shadow 0.4s;
    }

        .movie-poster img,
        .grid-card-poster img {
            width: 100%;
            height: 100%;
            object-fit: cover;
            object-position: center;
            transition: transform 0.6s cubic-bezier(0.25, 0.46, 0.45, 0.94);
            display: block;
        }

    .movie-card:hover .movie-poster,
    .grid-card:hover .grid-card-poster {
        /* Đổ bóng đỏ viền nhẹ cực kỳ sang trọng */
        box-shadow: 0 15px 30px rgba(0,0,0,0.8), 0 0 20px rgba(229, 9, 20, 0.25);
    }

        .movie-card:hover .movie-poster img,
        .grid-card:hover .grid-card-poster img {
            transform: scale(1.08); /* Ảnh bên trong phóng to */
        }

    .movie-overlay {
        position: absolute;
        inset: 0;
        background: linear-gradient(180deg, transparent 30%, rgba(0,0,0,0.95) 100%);
        display: flex;
        flex-direction: column;
        justify-content: flex-end;
        padding: 1.5rem;
        opacity: 0;
        transition: opacity 0.3s;
    }

    .movie-card:hover .movie-overlay {
        opacity: 1;
    }

    .play-button {
        position: absolute;
        top: 50%;
        left: 50%;
        transform: translate(-50%,-50%) scale(0.8);
        background: rgba(229,9,20,0.9);
        color: white;
        width: 60px;
        height: 60px;
        border-radius: 50%;
        display: flex;
        align-items: center;
        justify-content: center;
        font-size: 1.8rem;
        opacity: 0;
        transition: all 0.3s cubic-bezier(0.25, 0.46, 0.45, 0.94);
        border: 2px solid white;
        padding-left: 4px;
    }

    .movie-card:hover .play-button {
        opacity: 1;
        transform: translate(-50%,-50%) scale(1);
    }

    .movie-info {
        padding: 1rem 0.5rem 0.5rem;
    }

    .movie-title {
        font-size: 1.05rem;
        font-weight: 700;
        margin: 0 0 0.5rem;
        white-space: nowrap;
        overflow: hidden;
        text-overflow: ellipsis;
        transition: color 0.3s;
    }

        .movie-title a {
            color: white;
            text-decoration: none;
        }

    .movie-card:hover .movie-title a {
        color: var(--netflix-red);
    }

    .movie-meta {
        display: flex;
        align-items: center;
        gap: 0.8rem;
        font-size: 0.85rem;
        color: var(--netflix-light-gray);
    }

        .movie-meta i {
            color: var(--netflix-red);
        }

    .view-badge {
        position: absolute;
        top: 15px;
        left: 15px;
        background: rgba(0,0,0,0.7);
        border: 1px solid rgba(255,255,255,0.2);
        backdrop-filter: blur(4px);
        color: white;
        padding: 0.3rem 0.7rem;
        border-radius: 4px;
        font-size: 0.75rem;
        font-weight: 600;
        z-index: 3;
        display: flex;
        align-items: center;
        gap: 0.4rem;
    }

        .view-badge i {
            color: var(--netflix-red);
        }

    /* =========================================
           FILTER SECTION & GRID
           ========================================= */
    .btn-toggle-filter {
        background: rgba(255,255,255,0.1);
        color: var(--netflix-white);
        border: 1px solid rgba(255,255,255,0.3);
        border-radius: 8px;
        padding: 0.6rem 1.2rem;
        font-size: 0.95rem;
        font-weight: 600;
        cursor: pointer;
        display: flex;
        align-items: center;
        gap: 8px;
        transition: all 0.3s;
    }

        .btn-toggle-filter:hover, .btn-toggle-filter.active {
            background: var(--netflix-red);
            border-color: var(--netflix-red);
        }

    .filter-bar {
        background: var(--netflix-dark-bg);
        border: 1px solid var(--netflix-gray);
        border-radius: 12px;
        padding: 1.5rem;
        margin-bottom: 2rem;
    }

    .filter-row {
        display: flex;
        flex-wrap: wrap;
        gap: 1rem;
        align-items: flex-end;
    }

    .filter-group {
        display: flex;
        flex-direction: column;
        gap: 0.4rem;
        flex: 1;
        min-width: 140px;
    }

        .filter-group label {
            font-size: 0.8rem;
            font-weight: 600;
            color: var(--netflix-light-gray);
            text-transform: uppercase;
        }

    .filter-select {
        background: var(--netflix-gray);
        border: 1px solid rgba(255,255,255,0.15);
        color: white;
        border-radius: 8px;
        padding: 0.6rem 1rem;
        font-size: 0.9rem;
        cursor: pointer;
    }

        .filter-select:focus {
            outline: none;
            border-color: var(--netflix-red);
        }

        .filter-select option {
            background: var(--netflix-gray);
        }

    .search-input-wrapper {
        display: flex;
        background: var(--netflix-gray);
        border: 1px solid rgba(255,255,255,0.15);
        border-radius: 8px;
        overflow: hidden;
        transition: border-color 0.2s;
    }

        .search-input-wrapper:focus-within {
            border-color: var(--netflix-red);
        }

        .search-input-wrapper input {
            flex: 1;
            background: transparent;
            border: none;
            color: white;
            font-size: 0.9rem;
            padding: 0.6rem 1rem;
            outline: none;
        }

            .search-input-wrapper input::placeholder {
                color: var(--netflix-light-gray);
            }

        .search-input-wrapper .btn-search {
            background: var(--netflix-red);
            color: white;
            border: none;
            padding: 0.6rem 1rem;
            cursor: pointer;
            transition: background 0.2s;
        }

            .search-input-wrapper .btn-search:hover {
                background: #f40612;
            }

    .btn-reset {
        background: transparent;
        color: var(--netflix-light-gray);
        border: 1px solid rgba(255,255,255,0.2);
        border-radius: 8px;
        padding: 0.65rem 1.2rem;
        font-size: 0.9rem;
        cursor: pointer;
        transition: all 0.2s;
        text-decoration: none;
        display: inline-flex;
        align-items: center;
        gap: 0.3rem;
    }

        .btn-reset:hover {
            border-color: var(--netflix-red);
            color: var(--netflix-red);
        }

    .filter-result-count {
        font-size: 0.9rem;
        color: var(--netflix-light-gray);
        margin-top: 1rem;
    }

        .filter-result-count span {
            color: var(--netflix-red);
            font-weight: 700;
        }

    .movies-grid {
        display: grid;
        grid-template-columns: repeat(auto-fill, minmax(180px, 1fr));
        gap: 1.5rem;
        margin-bottom: 3rem;
    }

    .grid-card {
        position: relative;
        border-radius: 8px;
        background: transparent;
        transition: transform 0.3s;
    }

        .grid-card:hover {
            transform: translateY(-8px);
            z-index: 10;
        }

    .grid-card-overlay {
        position: absolute;
        inset: 0;
        background: linear-gradient(180deg, transparent 40%, rgba(0,0,0,0.95) 100%);
        opacity: 0;
        transition: opacity 0.3s;
        display: flex;
        align-items: flex-end;
        padding: 1rem;
    }

    .grid-card:hover .grid-card-overlay {
        opacity: 1;
    }

    .btn-play-card {
        display: inline-flex;
        align-items: center;
        gap: 0.4rem;
        background: var(--netflix-red);
        color: white;
        padding: 0.6rem 1rem;
        border-radius: 6px;
        text-decoration: none;
        font-size: 0.9rem;
        font-weight: 700;
        width: 100%;
        justify-content: center;
        transition: background 0.3s;
    }

        .btn-play-card:hover {
            background: #f40612;
            color: white;
        }

    .grid-card-info {
        padding: 1rem 0.5rem;
    }

    .grid-card-title {
        font-size: 1rem;
        font-weight: 700;
        margin-bottom: 0.4rem;
        white-space: nowrap;
        overflow: hidden;
        text-overflow: ellipsis;
        transition: color 0.3s;
    }

        .grid-card-title a {
            color: white;
            text-decoration: none;
        }

    .grid-card:hover .grid-card-title a {
        color: var(--netflix-red);
    }

    .grid-card-meta {
        font-size: 0.8rem;
        color: var(--netflix-light-gray);
        display: flex;
        gap: 0.6rem;
    }

        .grid-card-meta i {
            color: var(--netflix-red);
        }

    /* Pagination */
    .pagination-wrapper {
        display: flex;
        justify-content: center;
        align-items: center;
        gap: 0.5rem;
        margin: 2rem 0 4rem;
        flex-wrap: wrap;
    }

    .page-btn {
        background: var(--netflix-gray);
        color: white;
        border: 1px solid rgba(255,255,255,0.1);
        padding: 0.5rem 1rem;
        border-radius: 6px;
        cursor: pointer;
        text-decoration: none;
        font-size: 0.95rem;
        font-weight: 600;
        transition: all 0.2s;
    }

        .page-btn:hover {
            background: var(--netflix-red);
            border-color: var(--netflix-red);
            color: white;
        }

        .page-btn.active {
            background: var(--netflix-red);
            border-color: var(--netflix-red);
        }

        .page-btn.disabled {
            opacity: 0.4;
            pointer-events: none;
        }

    .netflix-alert {
        background: var(--netflix-dark-bg);
        border: 1px solid var(--netflix-gray);
        border-radius: 8px;
        padding: 3rem;
        margin: 2rem 0;
        text-align: center;
    }

        .netflix-alert i {
            color: var(--netflix-red);
            font-size: 2.5rem;
            margin-bottom: 1rem;
            display: block;
        }

    @@media (max-width: 992px) {
        .hero-text-content {
            max-width: 100%;
        }
    }

    @@media (max-width: 768px) {
        .hero-slider-container {
            height: 100vh;
            min-height: 600px;
        }

        .featured-title {
            font-size: 2.8rem;
        }

        .filter-row {
            flex-direction: column;
        }

        .movies-grid {
            grid-template-columns: repeat(auto-fill, minmax(140px, 1fr));
        }

        .thumbnail-strip-compact {
            bottom: 20px;
            right: 20px;
            max-width: 280px;
            padding: 6px 10px;
        }

        .thumbnail-item-compact {
            width: 45px;
            height: 65px;
        }
    }
</style>

@if (featuredMovies.Any())
{
    <div class="hero-slider-section">
        <div class="hero-slider-container" id="heroSlider">
            @for (int i = 0; i < featuredMovies.Count; i++)
            {
                var movie = featuredMovies[i];
                var bgImage = movie.BackdropUrl
                ?? movie.PosterUrl?.Replace("/w500/", "/original/")
                ?? "https://images.unsplash.com/photo-1536440136628-849c177e76a1?ixlib=rb-4.0.3&auto=format&fit=crop&w=1920&q=80";

                <div class="hero-slide @(i == 0 ? "active" : "")" data-index="@i">
                    <div class="hero-bg" style="background-image: url('@bgImage');"></div>

                    <div class="hero-content-wrapper">
                        <div class="hero-text-content">
                            <h1 class="featured-title">@movie.Title</h1>
                            <div class="featured-meta-badges">
                                <span class="badge-outline">HD</span>
                                <span class="badge-outline">@(movie.Type.ToString() == "Series" ? "Series" : "Movie")</span>
                                @if (movie.IsVipOnly)
                                {
                                    <span class="badge-outline" style="border-color: #FFD700; color: #FFD700;">
                                        <i class="fa-solid fa-crown"></i> VIP
                                    </span>
                                }
                            </div>

                            <p class="featured-desc">@movie.Description</p>

                            <div class="featured-actions-round">
                                <a asp-controller="Movie" asp-action="Watch" asp-route-slug="@movie.Slug" class="btn-play-round" title="Play">
                                    <i class="fas fa-play"></i>
                                </a>
                                <a asp-controller="Movie" asp-action="Detail" asp-route-slug="@movie.Slug" class="btn-icon-round" title="More Info">
                                    <i class="fas fa-info"></i>
                                </a>
                            </div>
                        </div>
                    </div>
                </div>
            }

            <div class="thumbnail-strip-compact">
                @for (int i = 0; i < featuredMovies.Count; i++)
                {
                    var movie = featuredMovies[i];
                    <div class="thumbnail-item-compact @(i == 0 ? "active" : "")" data-slide="@i" title="@movie.Title">
                        <img src="@(string.IsNullOrEmpty(movie.PosterUrl) ? "https://via.placeholder.com/300x450/2d2d2d/fff?text=No+Poster" : movie.PosterUrl)" alt="@movie.Title" />
                        <span class="thumbnail-number">@(i + 1)</span>
                    </div>
                }
            </div>
        </div>
    </div>
}

