<!-- PHIM TỪ MODEL (dạng grid) -->
@if (Model != null && Model.Any())
{
    <div class="container" style="margin-top: 4rem;">
        <div class="section-header">
            <i class="fas fa-film"></i>
            <h2>Tất Cả Phim</h2>
        </div>

        <div class="row">
            @foreach (var movie in Model.Take(12))
            {
                <div class="card">
                    <div class="position-relative">
                        <!--  FIXED -->
                        <a asp-controller="Movie" asp-action="Detail" asp-route-slug="@movie.Slug">
                            <img src="@(movie.PosterUrl ?? "https://via.placeholder.com/300x450/2d2d2d/ffffff?text=No+Poster")" 
                                 class="card-img-top" 
                                 alt="@movie.Title">
                        </a>

                        @if (User.Identity?.IsAuthenticated == true)
                        {
                            <button class="favorite-icon-btn" data-movie-id="@movie.Id">
                                <i class="far fa-heart"></i>
                            </button>
                        }

                        <span class="badge bg-danger position-absolute top-0 start-0 m-2">HD</span>

                        <span class="badge bg-dark position-absolute bottom-0 end-0 m-2">
                            <i class="fas fa-eye"></i> @movie.ViewCount.ToString("N0")
                        </span>
                    </div>

                    <div class="card-body">
                        <h6 class="card-title">
                            <!--  FIXED -->
                            <a asp-controller="Movie" asp-action="Detail" asp-route-slug="@movie.Slug">
                                @movie.Title
                            </a>
                        </h6>

                        <div class="mb-2">
                            <small class="text-warning">
                                @for (int i = 1; i <= 5; i++)
                                {
                                    <i class="@(i <= 4 ? "fas" : "far") fa-star"></i>
                                }
                                <span class="text-muted">4.0</span>
                            </small>
                        </div>

                        <p class="card-text">
                            @if (movie.ReleaseYear.HasValue)
                            {
                                <span>@movie.ReleaseYear</span>
                            }
                            @if (movie.DurationMinutes.HasValue)
                            {
                                <span> • @movie.DurationMinutes phút</span>
                            }
                        </p>
                    </div>

                    <div class="card-footer">
                        <!--  FIXED -->
                        <a asp-controller="Movie" asp-action="Watch" asp-route-slug="@movie.Slug" 
                           class="btn btn-primary w-100">
                            <i class="fas fa-play"></i> Xem phim
                        </a>
                    </div>
                </div>
            }
        </div>
    </div>
}

<script>
    function scrollLeft(section) {
        const row = document.getElementById(`${section}-movies-row`);
        if (row) {
            row.scrollBy({ left: -300, behavior: 'smooth' });
        }
    }

    function scrollRight(section) {
        const row = document.getElementById(`${section}-movies-row`);
        if (row) {
            row.scrollBy({ left: 300, behavior: 'smooth' });
        }
    }

    document.addEventListener('DOMContentLoaded', function() {
        const rows = document.querySelectorAll('.movies-row');
        rows.forEach(row => {
            row.addEventListener('scroll', function() {
                const leftArrow = this.parentElement.querySelector('.scroll-left');
                const rightArrow = this.parentElement.querySelector('.scroll-right');

                if (this.scrollLeft <= 10) {
                    leftArrow.style.opacity = '0.5';
                } else {
                    leftArrow.style.opacity = '1';
                }

                if (this.scrollWidth - this.clientWidth - this.scrollLeft <= 10) {
                    rightArrow.style.opacity = '0.5';
                } else {
                    rightArrow.style.opacity = '1';
                }
            });
        });

        // Favorite functionality
        const favoriteButtons = document.querySelectorAll('.favorite-icon-btn');
        favoriteButtons.forEach(btn => {
            btn.addEventListener('click', function(e) {
                e.preventDefault();
                e.stopPropagation();
                
                const movieId = this.getAttribute('data-movie-id');
                const icon = this.querySelector('i');
                
                const token = document.querySelector('input[name="__RequestVerificationToken"]')?.value;
                
                fetch('/Favorites/Toggle', {
                    method: 'POST',
                    headers: {
                        'Content-Type': 'application/json',
                        'RequestVerificationToken': token || ''
                    },
                    body: JSON.stringify({ movieId: movieId })
                })
                .then(response => response.json())
                .then(data => {
                    if (data.success) {
                        if (data.isFavorite) {
                            icon.classList.remove('far');
                            icon.classList.add('fas');
                            icon.style.color = '#e50914';
                        } else {
                            icon.classList.remove('fas');
                            icon.classList.add('far');
                            icon.style.color = 'white';
                        }
                    }
                })
                .catch(error => console.error('Error:', error));
            });
        });
    });
</script>

@Html.AntiForgeryToken()