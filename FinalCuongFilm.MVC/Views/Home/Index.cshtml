                            </div>

                            <div class="movie-overlay">
                                <div class="movie-actions">
                                    <a asp-controller="Movie" asp-action="Watch" asp-route-slug="@movie.Slug"
                                       class="movie-action-btn play-btn">
                                        <i class="fas fa-play"></i>
                                    </a>
                                    @if (User.Identity?.IsAuthenticated == true)
                                    {
                                        <button class="movie-action-btn favorite-btn" data-movie-id="@movie.Id">
