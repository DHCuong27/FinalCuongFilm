@model FinalCuongFilm.MVC.Models.ViewModels.HomeFilterViewModel
@{
    Layout = "_LayoutUser";
    var f = Model.AllMoviesFilter;
    var featuredMovies = Model.PopularMovies.Take(5).ToList();
    ViewData["Title"] ??= "Xem phim online chất lượng cao";
    ViewData["MetaDescription"] ??= "CuongFilm cập nhật phim mới, phim phổ biến, phim Hàn, phim Trung và nội dung VIP với giao diện xem phim rõ nét.";
}
<h1 class="visually-hidden">CuongFilm - Xem phim chất lượng cao</h1>

@section Styles {
    <link rel="stylesheet" href="~/css/home-page.css" asp-append-version="true" />
}

@* â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•
   HERO SLIDER
â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â• *@
@if (featuredMovies.Any())
{
    <div class="hero-wrap">
        <div class="hero-container" id="heroSlider">

            @for (int i = 0; i < featuredMovies.Count; i++)
            {
                var movie = featuredMovies[i];
                var bgImage = (movie.BackdropUrl ?? movie.PosterUrl ?? "https://images.unsplash.com/photo-1536440136628-849c177e76a1?w=2400&q=95")
                    .Replace("/w300/", "/original/")
                    .Replace("/w342/", "/original/")
                    .Replace("/w500/", "/original/")
                    .Replace("/w780/", "/original/")
                    .Replace("/w1280/", "/original/");

                <div class="hero-slide @(i == 0 ? "active" : "")" data-index="@i">

                    <div class="hero-bg-wrap">
                        <img class="hero-bg-img"
                             src="@bgImage.Replace("/original/", "/w1280/")"
                             srcset="@(bgImage.Replace("/original/", "/w780/")) 780w,
                                     @(bgImage.Replace("/original/", "/w1280/")) 1280w,
                                     @bgImage 1920w"
                             sizes="100vw"
                             alt=""
                             aria-hidden="true"
                             fetchpriority="@(i == 0 ? "high" : "low")"
                             loading="@(i == 0 ? "eager" : "lazy")" decoding="async" />
                        <div class="hero-bg-overlay"></div>
                    </div>

                    <div class="hero-body">
                        <div class="hero-text">
                            <div class="hero-eyebrow">
                                <span class="dot" aria-hidden="true"></span>
                                @(movie.Type.ToString() == "Series" ? "Series nổi bật" : "Phim nổi bật")
                            </div>

                            <h2 class="hero-title">@movie.Title</h2>

                            <div class="hero-badges" aria-label="Thông tin phim">
                                <span class="hbadge">HD</span>
                                <span class="hbadge">@(movie.Type.ToString() == "Series" ? "Series" : "Movie")</span>
                                @if (movie.IsVipOnly)
                                {
                                    <span class="hbadge hbadge-vip">
                                        <i class="fa-solid fa-crown" aria-hidden="true"></i> VIP
                                    </span>
                                }
                            </div>

                            <p class="hero-desc">@movie.Description</p>

                            <div class="hero-actions">
                                <a asp-controller="Movie" asp-action="Watch"
                                   asp-route-slug="@movie.Slug"
                                   class="btn-hero-play"
                                   aria-label="Xem ngay: @movie.Title">
                                    <i class="fas fa-play" aria-hidden="true"></i>
                                    Xem ngay
                                </a>
                                <a asp-controller="Movie" asp-action="Detail"
                                   asp-route-slug="@movie.Slug"
                                   class="btn-hero-info"
                                   aria-label="Chi tiết: @movie.Title">
                                    <i class="fas fa-circle-info" aria-hidden="true"></i>
                                    Chi tiết
                                </a>
                            </div>
                        </div>
                    </div>
                </div>
            }

            @* Thumbnail strip *@
            <div class="hero-thumbs" role="tablist" aria-label="Chọn slide">
                @for (int i = 0; i < featuredMovies.Count; i++)
                {
                    var movie = featuredMovies[i];
                    var thumb = string.IsNullOrEmpty(movie.PosterUrl)
                    ? "https://via.placeholder.com/300x450/1c1c1c/555?text=N/A"
                    : movie.PosterUrl;
                    <button class="thumb-item @(i == 0 ? "active" : "")"
                            data-slide="@i"
                            type="button"
                            role="tab"
                            aria-selected="@(i == 0 ? "true" : "false")"
                            aria-label="Slide @(i + 1): @movie.Title"
                            title="@movie.Title">
                        <img src="@thumb"
                             alt="@movie.Title"
                             loading="@(i == 0 ? "eager" : "lazy")" decoding="async" width="48" height="72" />
                        <span class="thumb-num" aria-hidden="true">@(i + 1)</span>
                    </button>
                }
            </div>

            @* Progress dots *@
            <div class="hero-dots" role="tablist" aria-label="Tiến trình slide">
                @for (int i = 0; i < featuredMovies.Count; i++)
                {
                    <button class="cf-dot @(i == 0 ? "active" : "")"
                            data-slide="@i"
                            type="button"
                            role="tab"
                            aria-label="Slide @(i + 1)"></button>
                }
            </div>

        </div>
    </div>
}

@* â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•
   CONTINUE WATCHING
â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â• *@
@if (Model.ContinueWatchingMovies != null && Model.ContinueWatchingMovies.Any())
{
    <div class="container" style="margin-bottom:var(--sp-10)">
        <div class="sec-head">
            <div class="sec-head-left">
                <i class="fas fa-history" aria-hidden="true"></i>
                <h2>Xem tiếp</h2>
            </div>
        </div>
        <div class="row-wrap">
            <button class="scroll-btn scroll-btn-l" onclick="cfScroll('continue',-1)"
                    aria-label="Cuộn trái">
                <i class="fas fa-chevron-left"></i>
            </button>
            <div class="movies-row" id="continue-movies-row">
                @foreach (var movie in Model.ContinueWatchingMovies)
                {
                    <div class="movie-card">
                        <a asp-controller="Movie" asp-action="Watch" asp-route-slug="@movie.Slug"
                           aria-label="Tiếp tục xem: @movie.Title">
                            <div class="movie-poster">
                                @if (movie.IsVipOnly)
                                {
                                    <div class="badge-vip-card" aria-label="Nội dung VIP">
                                        <i class="fa-solid fa-crown"></i> VIP
                                    </div>
                                }
                                <img src="@(string.IsNullOrEmpty(movie.PosterUrl) ? "https://via.placeholder.com/300x450/1c1c1c/555?text=No+Poster" : movie.PosterUrl)"
                                     alt="@movie.Title" loading="lazy" decoding="async" width="300" height="450" />
                                <div class="movie-overlay">
                                    <div class="play-circle" aria-hidden="true">
                                        <i class="fas fa-play"></i>
                                    </div>
                                </div>
                                <div class="progress-bar-wrap">
                                    <div class="progress-bar-fill" style="width:65%"></div>
                                </div>
                            </div>
                        </a>
                        <div class="movie-info">
                            <div class="movie-title">
                                <a asp-controller="Movie" asp-action="Watch" asp-route-slug="@movie.Slug">@movie.Title</a>
                            </div>
                        </div>
                    </div>
                }
            </div>
            <button class="scroll-btn scroll-btn-r" onclick="cfScroll('continue',1)"
                    aria-label="Cuộn phải">
                <i class="fas fa-chevron-right"></i>
            </button>
        </div>
    </div>
}

