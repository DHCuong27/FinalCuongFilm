@page
@model LoginModel

@{
    ViewData["Title"] = "Sign In";
    Layout = "/Areas/Identity/Pages/_Layout.cshtml";
}

<style>
    :root {
        --netflix-red: #e50914;
        --netflix-red-hover: #f6121d;
        --netflix-dark: #141414;
        --netflix-darker: #0b0b0b;
        --netflix-light: #b3b3b3;
        --netflix-white: #ffffff;
        --netflix-gray: #333;
        --netflix-input-bg: #333;
        --netflix-input-focus: #454545;
    }

    /* ===== GLOBAL ===== */
    body {
        background-color: var(--netflix-dark);
        color: var(--netflix-white);
        font-family: 'Helvetica Neue', Helvetica, Arial, sans-serif;
        min-height: 100vh;
    }

    /* ===== BACKGROUND ===== */
    .netflix-login-container {
        position: relative;
        min-height: 100vh;
    }

    /* ===== HEADER ===== */
    .netflix-header {
        padding: 24px 48px;
        position: absolute;
        top: 0;
        left: 0;
        z-index: 10;
    }

    .netflix-logo {
        height: 42px;
    }

    /* ===== LOGIN BOX ===== */
    .netflix-login-box {
        background: rgba(0, 0, 0, 0.78);
        backdrop-filter: blur(6px);
        border-radius: 6px;
        padding: 60px 68px 48px;
        margin: 0 auto;
        max-width: 450px;
        min-height: 640px;
        position: relative;
        top: 90px;
        box-shadow: 0 20px 40px rgba(0, 0, 0, 0.7), 0 0 0 1px rgba(255, 255, 255, 0.04);
    }

    .netflix-login-title {
        font-size: 32px;
        font-weight: 700;
        margin-bottom: 28px;
    }

    /* ===== FORM ===== */
    .netflix-form-group {
        margin-bottom: 16px;
        position: relative;
    }

    .netflix-input {
        width: 100%;
        height: 52px;
        background-color: var(--netflix-input-bg);
        border: 1px solid var(--netflix-gray);
        border-radius: 4px;
        color: var(--netflix-white);
        font-size: 16px;
        padding: 20px 16px 6px;
        transition: all 0.2s ease;
    }

        .netflix-input:focus {
            background-color: var(--netflix-input-focus);
            border-color: var(--netflix-white);
            box-shadow: 0 0 0 1px rgba(255,255,255,0.3);
            outline: none;
        }

    .netflix-label {
        position: absolute;
        top: 16px;
        left: 16px;
        color: var(--netflix-light);
        font-size: 16px;
        pointer-events: none;
        transition: all 0.18s ease;
    }

    .netflix-input:focus + .netflix-label,
    .netflix-input:not(:placeholder-shown) + .netflix-label {
        top: 6px;
        font-size: 11px;
        color: #8c8c8c;
    }

    /* ===== BUTTON ===== */
    .netflix-btn {
        width: 100%;
        height: 50px;
        background-color: var(--netflix-red);
        color: var(--netflix-white);
        border: none;
        border-radius: 4px;
        font-size: 16px;
        font-weight: 700;
        margin: 24px 0 12px;
        cursor: pointer;
        transition: background 0.2s ease, transform 0.05s ease;
    }

        .netflix-btn:hover {
            background-color: var(--netflix-red-hover);
        }

        .netflix-btn:active {
            transform: scale(0.98);
        }

    /* ===== REMEMBER / HELP ===== */
    .netflix-remember-help {
        display: flex;
        justify-content: space-between;
        align-items: center;
        font-size: 13px;
        color: var(--netflix-light);
    }

    .netflix-help-link {
        color: var(--netflix-light);
    }

        .netflix-help-link:hover {
            text-decoration: underline;
        }

    /* ===== DIVIDER ===== */
    .netflix-or-divider {
        display: flex;
        align-items: center;
        margin: 22px 0;
        font-size: 13px;
        color: var(--netflix-light);
    }

        .netflix-or-divider::before,
        .netflix-or-divider::after {
            content: '';
            flex: 1;
            height: 1px;
            background-color: var(--netflix-gray);
        }

        .netflix-or-divider span {
            padding: 0 12px;
        }

    /* ===== GOOGLE BUTTON ===== */
    .netflix-google-btn {
        width: 100%;
        height: 50px;
        background-color: transparent;
        color: var(--netflix-light);
        border: 1px solid var(--netflix-gray);
        border-radius: 4px;
        font-size: 15px;
        font-weight: 500;
        display: flex;
        align-items: center;
        justify-content: center;
        gap: 10px;
        transition: all 0.2s ease;
    }

        .netflix-google-btn:hover {
            background-color: rgba(255, 255, 255, 0.08);
            border-color: var(--netflix-white);
            color: var(--netflix-white);
        }

    /* ===== VALIDATION ===== */
    .validation-summary {
        background-color: rgba(232, 124, 3, 0.15);
        color: #ffb74d;
        padding: 12px 16px;
        border-radius: 4px;
        margin-bottom: 20px;
        font-size: 14px;
    }

    /* ===== FOOTER ===== */
    .netflix-footer {
        background-color: rgba(0, 0, 0, 0.75);
        padding: 32px 0;
        margin-top: 120px;
    }

   
</style>

<div class="netflix-login-container">
    <!-- Login Form -->
    <div class="container">
        <div class="netflix-login-box">
            <h1 class="netflix-login-title">Sign In</h1>

            @if (!ViewData.ModelState.IsValid)
            {
                <div class="validation-summary" role="alert">
                    <ul>
                        @foreach (var error in ViewData.ModelState.Values.SelectMany(v => v.Errors))
                        {
                            <li>@error.ErrorMessage</li>
                        }
                    </ul>
                </div>
            }

            <form id="account" method="post">
                <div class="netflix-form-group">
                    <input asp-for="Input.Email"
                           class="netflix-input"
                           autocomplete="username"
                           aria-required="true"
                           placeholder=" " />
                    <label asp-for="Input.Email" class="netflix-label">Email</label>
                    <span asp-validation-for="Input.Email" class="validation-message"></span>
                </div>

                <div class="netflix-form-group">
                    <input asp-for="Input.Password"
                           class="netflix-input"
                           autocomplete="current-password"
                           aria-required="true"
                           placeholder=" " />
                    <label asp-for="Input.Password" class="netflix-label">Password</label>
                    <span asp-validation-for="Input.Password" class="validation-message"></span>
                </div>

                <div class="netflix-remember-help">
                    <div class="netflix-checkbox">
                        <input class="form-check-input" asp-for="Input.RememberMe" />
                        <label asp-for="Input.RememberMe" class="form-label">
                            Remember me
                        </label>
                    </div>
                    <a id="forgot-password" asp-page="./ForgotPassword" class="netflix-help-link">
                        Need help?
                    </a>
                </div>

                <button id="login-submit" type="submit" class="netflix-btn">
                    Sign In
                </button>

                <div class="netflix-or-divider">
                    <span>OR</span>
                </div>

                <div class="netflix-signup-now">
                    New to Netflix?
                    <a asp-page="./Register" asp-route-returnUrl="@Model.ReturnUrl" class="netflix-signup-link">
                        Sign up now
                    </a>
                </div>
            </form>
        </div>
    </div>
</div>



@section Scripts {
    <partial name="_ValidationScriptsPartial" />
    <script>
        // Add Bootstrap Icons if not already included
        if (!document.querySelector('link[href*="bootstrap-icons"]')) {
            const link = document.createElement('link');
            link.rel = 'stylesheet';
            link.href = 'https://cdn.jsdelivr.net/npm/bootstrap-icons@1.10.0/font/bootstrap-icons.css';
            document.head.appendChild(link);
        }

        // Enhanced input label animation
        document.querySelectorAll('.netflix-input').forEach(input => {
            input.addEventListener('focus', function() {
                this.parentElement.classList.add('focused');
            });

            input.addEventListener('blur', function() {
                if (!this.value) {
                    this.parentElement.classList.remove('focused');
                }
            });

            // Check on page load
            if (input.value) {
                input.parentElement.classList.add('focused');
            }
        });
    </script>
}