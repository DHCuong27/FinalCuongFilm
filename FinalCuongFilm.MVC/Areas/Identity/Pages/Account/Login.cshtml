@page
@model LoginModel

@{
    ViewData["Title"] = "Sign In";
    Layout = "/Areas/Identity/Pages/_Layout.cshtml";
}

<style>
    /* Ẩn header, footer của layout chính */
    header, footer, .navbar {
        display: none !important;
    }

    :root {
        --netflix-red: #e50914;
        --netflix-red-hover: #f6121d;
        --netflix-dark: #141414;
        --netflix-white: #ffffff;
        --netflix-gray: #333;
        --netflix-input-bg: #333;
        --netflix-input-focus: #454545;
        --netflix-light: #b3b3b3;
    }

    body {
        background-color: var(--netflix-dark);
        color: var(--netflix-white);
        font-family: 'Helvetica Neue', Helvetica, Arial, sans-serif;
        min-height: 100vh;
        margin: 0;
        padding: 0;
    }

    .netflix-login-container {
        position: relative;
        min-height: 100vh;
        background: linear-gradient(rgba(0, 0, 0, 0.5), rgba(0, 0, 0, 0.5));
        background-size: cover;
        background-position: center;
        display: flex;
        flex-direction: column;
    }

    /* ===== HEADER ===== */
    .netflix-header {
        padding: 24px 3%;
        position: absolute;
        top: 0;
        left: 0;
        width: 100%;
        z-index: 10;
    }

    .netflix-brand {
        font-size: 2.5rem; /* Kích thước logo lớn */
        font-weight: bold;
        color: var(--netflix-red);
        text-decoration: none;
        text-shadow: 2px 2px 4px rgba(0,0,0,0.5);
    }

        .netflix-brand:hover {
            color: var(--netflix-red); /* Giữ nguyên màu khi hover */
        }

    /* ===== CONTENT ===== */
    .netflix-content-wrap {
        flex: 1;
        display: flex;
        align-items: center;
        justify-content: center;
        padding: 20px;
    }

    .netflix-login-box {
        background: rgba(0, 0, 0, 0.75);
        border-radius: 4px;
        padding: 60px 68px 40px;
        width: 100%;
        max-width: 450px;
        min-height: 550px;
    }

    .netflix-login-title {
        font-size: 32px;
        font-weight: 700;
        margin-bottom: 28px;
        color: #fff;
    }

    /* ===== FORM ===== */
    .netflix-form-group {
        margin-bottom: 16px;
        position: relative;
    }

    .netflix-input {
        width: 100%;
        height: 50px;
        background-color: var(--netflix-input-bg);
        border: none;
        border-radius: 4px;
        color: #fff;
        font-size: 16px;
        padding: 16px 20px 0;
    }

        .netflix-input:focus {
            background-color: var(--netflix-input-focus);
            outline: none;
        }

    .netflix-label {
        position: absolute;
        top: 16px;
        left: 20px;
        color: var(--netflix-light);
        font-size: 16px;
        pointer-events: none;
        transition: all 0.1s ease;
    }

    .netflix-input:focus + .netflix-label,
    .netflix-input:not(:placeholder-shown) + .netflix-label {
        top: 6px;
        font-size: 11px;
    }

    .netflix-btn {
        width: 100%;
        height: 50px;
        background-color: var(--netflix-red);
        color: #fff;
        border: none;
        border-radius: 4px;
        font-size: 16px;
        font-weight: 700;
        margin-top: 24px;
        cursor: pointer;
    }

        .netflix-btn:hover {
            background-color: var(--netflix-red-hover);
        }

    .netflix-remember-help {
        display: flex;
        justify-content: space-between;
        align-items: center;
        margin-top: 10px;
        font-size: 13px;
        color: #b3b3b3;
    }

    .netflix-help-link {
        color: #b3b3b3;
        text-decoration: none;
    }

        .netflix-help-link:hover {
            text-decoration: underline;
        }

    .netflix-signup-now {
        color: #737373;
        font-size: 16px;
        margin-top: 16px;
    }

    .netflix-signup-link {
        color: #fff;
        text-decoration: none;
        margin-left: 5px;
    }

        .netflix-signup-link:hover {
            text-decoration: underline;
        }

    /* ===== FOOTER ===== */
    .netflix-footer {
        background: rgba(0,0,0,0.75);
        padding: 30px 0;
        margin-top: auto; /* Đẩy footer xuống đáy nếu nội dung ngắn */
        color: #737373;
        font-size: 13px;
    }

    .footer-content {
        max-width: 1000px;
        margin: 0 auto;
        padding: 0 20px;
        text-align: center;
    }

    .validation-summary {
        background-color: #e87c03;
        border-radius: 4px;
        font-size: 14px;
        margin-bottom: 16px;
        padding: 10px 20px;
        color: white;
    }

        .validation-summary ul {
            list-style: none;
            padding: 0;
            margin: 0;
        }

    .validation-message {
        color: #e87c03;
        font-size: 13px;
    }
</style>

<div class="netflix-login-container">
    <!-- Header -->
    <div class="netflix-header">
        <a href="/" class="netflix-brand">
            <!-- Bạn có thể thay bằng thẻ <img> nếu có file logo -->
            <i class="fas fa-film"></i> CuongFilm
        </a>
    </div>

    <!-- Main Content -->
    <div class="netflix-content-wrap">
        <div class="netflix-login-box">
            <h1 class="netflix-login-title">Sign In</h1>

            @if (!ViewData.ModelState.IsValid)
            {
                <div class="validation-summary" role="alert">
                    <ul>
                        @foreach (var error in ViewData.ModelState.Values.SelectMany(v => v.Errors))
                        {
                            <li>@error.ErrorMessage</li>
                        }
                    </ul>
                </div>
            }

            <form id="account" method="post">
                <div class="netflix-form-group">
                    <input asp-for="Input.Email" class="netflix-input" autocomplete="username" placeholder=" " />
                    <label asp-for="Input.Email" class="netflix-label">Email</label>
                    <span asp-validation-for="Input.Email" class="validation-message"></span>
                </div>

                <div class="netflix-form-group">
                    <input asp-for="Input.Password" class="netflix-input" autocomplete="current-password" placeholder=" " />
                    <label asp-for="Input.Password" class="netflix-label">Password</label>
                    <span asp-validation-for="Input.Password" class="validation-message"></span>
                </div>

                <button id="login-submit" type="submit" class="netflix-btn">Sign In</button>

                <div class="netflix-remember-help">
                    <div class="form-check">
                        <input class="form-check-input" asp-for="Input.RememberMe" style="background-color: #333; border-color: #333;" />
                        <label class="form-check-label" asp-for="Input.RememberMe">Remember me</label>
                    </div>
                    <a id="forgot-password" asp-page="./ForgotPassword" class="netflix-help-link">Need help?</a>
                </div>

                <div class="netflix-signup-now">
                    New to CuongFilm?
                    <a asp-page="./Register" asp-route-returnUrl="@Model.ReturnUrl" class="netflix-signup-link">Sign up now</a>
                </div>
            </form>
        </div>
    </div>

    <!-- Footer -->
    <div class="netflix-footer">
        <div class="footer-content">
            <p>&copy; @DateTime.Now.Year - CuongFilm Inc.</p>
        </div>
    </div>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}