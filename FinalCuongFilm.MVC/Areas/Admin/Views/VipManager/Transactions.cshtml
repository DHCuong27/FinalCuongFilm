@model IEnumerable<FinalCuongFilm.ApplicationCore.Entities.Transaction>
@{
    ViewData["Title"] = "Transaction History";
    Layout = "~/Areas/Admin/Views/Shared/_LayoutAdmin.cshtml";

    int currentPage = ViewBag.CurrentPage ?? 1;
    int totalPages = ViewBag.TotalPages ?? 1;
    int totalItems = ViewBag.TotalItems ?? Model?.Count() ?? 0;

    // Cast the ViewBag dictionary for safe and easy access
    var userDict = ViewBag.UserDictionary as Dictionary<string, FinalCuongFilm.ApplicationCore.Entities.Identity.CuongFilmUser>;
}

<style>
    :root {
        --primary-color: #4f46e5;
        --secondary-color: #64748b;
        --success-color: #10b981;
        --warning-color: #f59e0b;
        --danger-color: #ef4444;
        --text-dark: #1e293b;
        --text-muted: #64748b;
        --border-color: #e2e8f0;
        --bg-light: #f8fafc;
        --bg-white: #ffffff;
        --radius-md: 12px;
        --shadow-sm: 0 1px 2px 0 rgba(0, 0, 0, 0.05);
    }

    .media-container {
        max-width: 1400px;
        margin: 0 auto;
        padding: 24px 20px;
        font-family: 'Inter', -apple-system, BlinkMacSystemFont, 'Segoe UI', Roboto, sans-serif;
    }

    .page-header {
        display: flex;
        justify-content: space-between;
        align-items: center;
        margin-bottom: 24px;
        background: var(--bg-white);
        padding: 20px 24px;
        border-radius: var(--radius-md);
        box-shadow: var(--shadow-sm);
        border: 1px solid var(--border-color);
    }

    .page-title {
        font-size: 22px;
        font-weight: 700;
        color: var(--text-dark);
        margin: 0;
        display: flex;
        align-items: center;
        gap: 12px;
    }

    .total-badge {
        font-size: 13px;
        background: #e0e7ff;
        color: var(--primary-color);
        padding: 6px 14px;
        border-radius: 20px;
        font-weight: 600;
    }

    .table-container {
        background: var(--bg-white);
        border-radius: var(--radius-md);
        box-shadow: var(--shadow-sm);
        border: 1px solid var(--border-color);
        overflow-x: auto;
    }

    .data-table {
        width: 100%;
        border-collapse: collapse;
        min-width: 1000px;
    }

        .data-table thead {
            background: var(--bg-light);
            border-bottom: 2px solid var(--border-color);
        }

        .data-table th {
            padding: 16px 20px;
            text-align: left;
            font-size: 13px;
            font-weight: 600;
            color: var(--secondary-color);
            text-transform: uppercase;
            letter-spacing: 0.05em;
        }

        .data-table td {
            padding: 16px 20px;
            border-bottom: 1px solid var(--border-color);
            vertical-align: middle;
            font-size: 14px;
            color: var(--text-dark);
        }

        .data-table tbody tr:hover td {
            background-color: #f8fafc;
        }

    .status-badge {
        padding: 6px 12px;
        border-radius: 20px;
        font-size: 12px;
        font-weight: 600;
        display: inline-flex;
        align-items: center;
        gap: 4px;
    }

    .badge-success {
        background: #d1fae5;
        color: #065f46;
    }

    .badge-warning {
        background: #fef3c7;
        color: #b45309;
    }

    .badge-danger {
        background: #fee2e2;
        color: #991b1b;
    }

    .badge-info {
        background: #dbeafe;
        color: #1e40af;
        border: 1px solid #bfdbfe;
    }

    .amount {
        font-weight: 700;
        color: var(--text-dark);
    }

    .iso-badge {
        background: var(--bg-light);
        padding: 4px 8px;
        border-radius: 6px;
        border: 1px solid var(--border-color);
        font-family: 'SFMono-Regular', Consolas, monospace;
        color: var(--secondary-color);
        font-size: 13px;
    }

    .user-info {
        display: flex;
        flex-direction: column;
    }

        .user-info strong {
            color: var(--text-dark);
            font-size: 14px;
        }

        .user-info span {
            color: var(--text-muted);
            font-size: 12px;
        }

    .empty-state {
        text-align: center;
        padding: 64px 20px;
    }

    .pagination-wrapper {
        display: flex;
        justify-content: space-between;
        align-items: center;
        padding: 16px 24px;
        background: var(--bg-white);
        border-top: 1px solid var(--border-color);
        border-bottom-left-radius: var(--radius-md);
        border-bottom-right-radius: var(--radius-md);
    }

    .pagination-info {
        font-size: 14px;
        color: var(--text-muted);
    }

    .pagination-controls {
        display: flex;
        gap: 4px;
    }

    .page-btn {
        padding: 8px 14px;
        border: 1px solid var(--border-color);
        background: var(--bg-white);
        color: var(--text-dark);
        border-radius: 6px;
        font-size: 14px;
        font-weight: 500;
        text-decoration: none;
        transition: all 0.2s;
    }

        .page-btn:hover:not(.disabled):not(.active) {
            background: var(--bg-light);
            border-color: #cbd5e1;
        }

        .page-btn.active {
            background: var(--primary-color);
            color: white;
            border-color: var(--primary-color);
        }

        .page-btn.disabled {
            color: #94a3b8;
            background: #f1f5f9;
            cursor: not-allowed;
        }
</style>

<div class="media-container">
    <div class="page-header">
        <div class="page-title">
            <i class="fa fa-wallet text-warning"></i> VIP Payment History
            <span class="total-badge">@totalItems transactions</span>
        </div>
    </div>

    <div class="table-container">
        <table class="data-table">
            <thead>
                <tr>
                    <th>Txn ID (Ref)</th>
                    <th>Customer</th>
                    <th>Order Info</th>
                    <th>Amount (VND)</th>
                    <th>Gateway</th>
                    <th>Date & Time</th>
                    <th>Status</th>
                </tr>
            </thead>
            <tbody>
                @if (Model != null && Model.Any())
                {
                    foreach (var item in Model)
                    {
                        <tr>
                            <td>
                                <span class="iso-badge" title="@item.Id">
                                    @(item.Id.ToString().Substring(0, 8))...
                                </span>
                            </td>
                            <td>
                                <div class="user-info">
                                    @{
                                        // Look up the user from the dictionary
                                        var hasUser = userDict != null && userDict.ContainsKey(item.UserId);
                                        var matchedUser = hasUser ? userDict[item.UserId] : null;

                                        var displayName = matchedUser != null ? (matchedUser.FullName ?? matchedUser.UserName) : "Unknown User";
                                        var displayEmail = matchedUser != null ? matchedUser.Email : (item.UserId.Substring(0, 8) + "...");
                                    }
                                    <strong>@displayName</strong>
                                    <span>@displayEmail</span>
                                </div>
                            </td>
                            <td><strong>@item.OrderInfo</strong></td>
                            <td><span class="amount">@item.Amount.ToString("N0")</span></td>
                            <td><span class="status-badge badge-info">@item.PaymentMethod</span></td>
                            <td><span class="text-muted">@item.TransactionDate.ToLocalTime().ToString("MMM dd, yyyy HH:mm")</span></td>
                            <td>
                                @if (item.Status == FinalCuongFilm.ApplicationCore.Entities.Enum.TransactionStatus.Success)
                                {
                                    <span class="status-badge badge-success"><i class="fa fa-check-circle"></i> Succeed</span>
                                }
                                else if (item.Status == FinalCuongFilm.ApplicationCore.Entities.Enum.TransactionStatus.Pending)
                                {
                                    <span class="status-badge badge-warning"><i class="fa fa-clock"></i> Pending</span>
                                }
                                else
                                {
                                    <span class="status-badge badge-danger"><i class="fa fa-times-circle"></i> Failed</span>
                                }
                            </td>
                        </tr>
                    }
                }
                else
                {
                    <tr>
                        <td colspan="7" class="empty-state">
                            <div style="font-size: 48px; margin-bottom: 16px; color: #cbd5e1;">📭</div>
                            <div style="color: var(--text-dark); font-weight: 600; font-size: 16px;">No transactions found</div>
                            <div style="color: var(--text-muted); font-size: 14px; margin-top: 4px;">Payment records will appear here once users purchase VIP.</div>
                        </td>
                    </tr>
                }
            </tbody>
        </table>

        @if (totalPages > 1)
        {
            <div class="pagination-wrapper">
                <div class="pagination-info">
                    Page <strong>@currentPage</strong> of <strong>@totalPages</strong>
                </div>
                <div class="pagination-controls">
                    <a href="@Url.Action("Transactions", new { page = currentPage - 1 })"
                       class="page-btn @(currentPage <= 1 ? "disabled" : "")">
                        <i class="fa fa-chevron-left me-1"></i> Prev
                    </a>

                    @for (int i = 1; i <= totalPages; i++)
                    {
                        <a href="@Url.Action("Transactions", new { page = i })"
                           class="page-btn @(i == currentPage ? "active" : "")">@i</a>
                    }

                    <a href="@Url.Action("Transactions", new { page = currentPage + 1 })"
                       class="page-btn @(currentPage >= totalPages ? "disabled" : "")">
                        Next <i class="fa fa-chevron-right ms-1"></i>
                    </a>
                </div>
            </div>
        }
    </div>
</div>