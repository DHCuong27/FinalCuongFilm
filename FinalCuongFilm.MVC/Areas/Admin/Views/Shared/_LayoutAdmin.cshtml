@{
    // Helper function to keep the HTML markup clean and readable
    string IsActive(string controller, string action = null)
    {
        var currentController = ViewContext.RouteData.Values["Controller"]?.ToString();
        var currentAction = ViewContext.RouteData.Values["Action"]?.ToString();

        bool matchController = string.Equals(currentController, controller, StringComparison.OrdinalIgnoreCase);
        bool matchAction = action == null || string.Equals(currentAction, action, StringComparison.OrdinalIgnoreCase);

        return matchController && matchAction ? "active" : "";
    }
}
<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1, shrink-to-fit=no">
    <title>@ViewData["Title"] - Admin Dashboard</title>

    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600;700&display=swap" rel="stylesheet">

    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/css/bootstrap.min.css" rel="stylesheet">
    <link href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.2/css/all.min.css" rel="stylesheet">

    <link href="~/_LayoutAdmin/css/LayoutAdmin.css" rel="stylesheet">
</head>
<body>

    <div class="sidebar-overlay" id="sidebarOverlay"></div>

    <aside class="sidebar" id="sidebar">
        <a asp-area="Admin" asp-controller="Admin" asp-action="Index" class="sidebar-brand">
            <i class="fa-solid fa-play"></i> CuongFilm
        </a>

        <ul class="sidebar-nav">
            <li class="sidebar-heading">Core</li>
            <li class="nav-item">
                <a class="nav-link @IsActive("Admin", "Index")" asp-area="Admin" asp-controller="Admin" asp-action="Index">
                    <i class="fa-solid fa-chart-line"></i> Dashboard
                </a>
            </li>

            <li class="sidebar-heading">Content Management</li>
            <li class="nav-item">
                <a class="nav-link @IsActive("Movies")" asp-area="Admin" asp-controller="Movies" asp-action="Index">
                    <i class="fa-solid fa-film"></i> Movies
                </a>
            </li>
            <li class="nav-item">
                <a class="nav-link @IsActive("Episodes")" asp-area="Admin" asp-controller="Episodes" asp-action="Index">
                    <i class="fa-solid fa-list-ol"></i> Episodes
                </a>
            </li>
            <li class="nav-item">
                <a class="nav-link @IsActive("MediaUpload")" asp-area="Admin" asp-controller="MediaUpload" asp-action="Index">
                    <i class="fa-solid fa-cloud-arrow-up"></i> Media Files
                </a>
            </li>
            <li class="nav-item">
                <a class="nav-link @IsActive("Actors")" asp-area="Admin" asp-controller="Actors" asp-action="Index">
                    <i class="fa-solid fa-masks-theater"></i> Actors
                </a>
            </li>
            <li class="nav-item">
                <a class="nav-link @IsActive("Genres")" asp-area="Admin" asp-controller="Genres" asp-action="Index">
                    <i class="fa-solid fa-tags"></i> Genres
                </a>
            </li>
            <li class="nav-item">
                <a class="nav-link @IsActive("Countries")" asp-area="Admin" asp-controller="Countries" asp-action="Index">
                    <i class="fa-solid fa-earth-americas"></i> Countries
                </a>
            </li>
            <li class="nav-item">
                <a class="nav-link @IsActive("Languages")" asp-area="Admin" asp-controller="Languages" asp-action="Index">
                    <i class="fa-solid fa-language"></i> Languages
                </a>
            </li>

            <li class="sidebar-heading">Users & Premium</li>
            <li class="nav-item">
                <a class="nav-link @IsActive("User")" asp-area="Admin" asp-controller="User" asp-action="Index">
                    <i class="fa-solid fa-users"></i> Accounts
                </a>
            </li>
            <li class="nav-item">
                <a class="nav-link @IsActive("VipManager", "Transactions")" asp-area="Admin" asp-controller="VipManager" asp-action="Transactions">
                    <i class="fa-solid fa-file-invoice-dollar"></i> Payment History
                </a>
            </li>
            <li class="nav-item">
                <a class="nav-link @IsActive("VipManager", "ActiveVips")" asp-area="Admin" asp-controller="VipManager" asp-action="ActiveVips">
                    <i class="fa-solid fa-user-shield"></i> Active VIPs
                </a>
            </li>
            <li class="nav-item">
                <a class="nav-link @IsActive("VipPackage")" asp-area="Admin" asp-controller="VipPackage" asp-action="Index">
                    <i class="fa-solid fa-box-open"></i> VIP Packages
                </a>
            </li>
        </ul>
    </aside>

    <main class="main-wrapper">
        <header class="top-header">
            <div class="header-left">
                <button class="sidebar-toggle d-lg-none" id="sidebarToggle" aria-label="Toggle Navigation">
                    <i class="fa-solid fa-bars"></i>
                </button>
            </div>

            <div class="header-right dropdown">
                <div class="user-profile" data-bs-toggle="dropdown" aria-expanded="false" role="button" tabindex="0">
                    <div class="user-avatar">
                        <i class="fa-solid fa-user"></i>
                    </div>
                    <div class="user-info d-none d-md-block">
                        <span class="fw-semibold d-block" style="font-size: 0.9rem;">@(User.Identity?.Name ?? "Administrator")</span>
                    </div>
                    <i class="fa-solid fa-chevron-down ms-2 text-muted" style="font-size: 0.8rem;"></i>
                </div>

                <ul class="dropdown-menu dropdown-menu-end">
                    <li><h6 class="dropdown-header">System Settings</h6></li>
                    <li><a class="dropdown-item" href="#"><i class="fa-solid fa-gear"></i> Preferences</a></li>
                    <li><hr class="dropdown-divider"></li>
                    <li>
                        <form asp-area="Identity" asp-page="/Account/Logout" asp-route-returnUrl="/" method="post" class="m-0 p-0">
                            <button type="submit" class="dropdown-item text-danger">
                                <i class="fa-solid fa-arrow-right-from-bracket"></i> Sign Out
                            </button>
                        </form>
                    </li>
                </ul>
            </div>
        </header>

        <div class="content-area">
            @RenderBody()
        </div>
    </main>

    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/js/bootstrap.bundle.min.js"></script>
    <script>
        document.addEventListener("DOMContentLoaded", () => {
            const sidebar = document.getElementById('sidebar');
            const sidebarToggle = document.getElementById('sidebarToggle');
            const sidebarOverlay = document.getElementById('sidebarOverlay');

            const toggleSidebar = () => {
                sidebar.classList.toggle('show');
                document.body.classList.toggle('sidebar-open');
            };

            if (sidebarToggle) sidebarToggle.addEventListener('click', toggleSidebar);
            if (sidebarOverlay) sidebarOverlay.addEventListener('click', toggleSidebar);
        });
    </script>

    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>