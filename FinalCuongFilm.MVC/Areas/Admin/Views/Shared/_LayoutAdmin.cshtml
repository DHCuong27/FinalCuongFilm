<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1, shrink-to-fit=no">
    <title>@ViewData["Title"] - CuongFilm Admin</title>

    <link href="~/Layout_Admin/css/font-face.css" rel="stylesheet" media="all">
    <link href="~/Layout_Admin/vendor/font-awesome-4.7/css/font-awesome.min.css" rel="stylesheet" media="all">
    <link href="~/Layout_Admin/vendor/font-awesome-5/css/fontawesome-all.min.css" rel="stylesheet" media="all">
    <link href="~/Layout_Admin/vendor/mdi-font/css/material-design-iconic-font.min.css" rel="stylesheet" media="all">
    <link href="~/Layout_Admin/vendor/bootstrap-4.1/bootstrap.min.css" rel="stylesheet" media="all">
    <link href="~/Layout_Admin/css/theme.css" rel="stylesheet" media="all">

    <style>
        :root {
            --dropdown-bg: #ffffff;
            --dropdown-border: #e9ecef;
            --dropdown-shadow: 0 10px 30px rgba(0,0,0,0.1);
            --hover-bg: #f8f9fa;
            --text-primary: #212529;
            --text-secondary: #6c757d;
            --danger: #dc3545;
            --transition: all 0.2s ease;
        }

        /* Account dropdown container */
        .account-dropdown {
            position: absolute;
            top: calc(100% + 12px);
            right: 0;
            width: 280px;
            background: var(--dropdown-bg);
            border: 1px solid var(--dropdown-border);
            border-radius: 12px;
            box-shadow: var(--dropdown-shadow);
            opacity: 0;
            visibility: hidden;
            transform: translateY(-10px);
            transition: var(--transition);
            z-index: 1050;
            overflow: hidden;
        }

            .account-dropdown.show {
                opacity: 1;
                visibility: visible;
                transform: translateY(0);
            }

            /* Mũi tên */
            .account-dropdown::before {
                content: '';
                position: absolute;
                top: -8px;
                right: 22px;
                width: 0;
                height: 0;
                border-left: 8px solid transparent;
                border-right: 8px solid transparent;
                border-bottom: 8px solid var(--dropdown-bg);
                z-index: 1;
            }

            .account-dropdown::after {
                content: '';
                position: absolute;
                top: -9px;
                right: 21px;
                width: 0;
                height: 0;
                border-left: 9px solid transparent;
                border-right: 9px solid transparent;
                border-bottom: 9px solid var(--dropdown-border);
                z-index: 0;
            }

            /* Thông tin người dùng */
            .account-dropdown .info {
                padding: 1.25rem;
                display: flex;
                align-items: center;
                background: #fafbfc;
                border-bottom: 1px solid var(--dropdown-border);
            }

                .account-dropdown .info .image {
                    flex-shrink: 0;
                    margin-right: 1rem;
                }

                    .account-dropdown .info .image a {
                        display: block;
                        width: 48px;
                        height: 48px;
                        border-radius: 50%;
                        overflow: hidden;
                        border: 2px solid #dee2e6;
                        transition: var(--transition);
                    }

                        .account-dropdown .info .image a:hover {
                            border-color: #adb5bd;
                        }

                    .account-dropdown .info .image img {
                        width: 100%;
                        height: 100%;
                        object-fit: cover;
                    }

                .account-dropdown .info .content {
                    flex: 1;
                    min-width: 0;
                }

                    .account-dropdown .info .content .name {
                        margin: 0 0 4px 0;
                        font-size: 1rem;
                        font-weight: 600;
                        color: var(--text-primary);
                    }

                        .account-dropdown .info .content .name a {
                            color: inherit;
                            text-decoration: none;
                        }

                    .account-dropdown .info .content .email {
                        display: block;
                        font-size: 0.8125rem;
                        color: var(--text-secondary);
                        white-space: nowrap;
                        overflow: hidden;
                        text-overflow: ellipsis;
                    }

        /* Menu items */
        .account-dropdown__body {
            padding: 0.5rem 0;
        }

        .account-dropdown__item a {
            display: flex;
            align-items: center;
            padding: 0.625rem 1.25rem;
            color: var(--text-primary);
            font-size: 0.875rem;
            text-decoration: none;
            transition: var(--transition);
        }

            .account-dropdown__item a:hover {
                background-color: var(--hover-bg);
                color: var(--text-primary);
            }

            .account-dropdown__item a i {
                margin-right: 0.75rem;
                font-size: 1.125rem;
                width: 1.25rem;
                text-align: center;
                color: var(--text-secondary);
            }

        /* Separator */
        .account-dropdown__separator {
            height: 1px;
            background: var(--dropdown-border);
            margin: 0.5rem 0;
        }

        /* Footer logout */
        .account-dropdown__footer {
            padding: 1rem 1.25rem;
            border-top: 1px solid var(--dropdown-border);
            background: #fff;
        }

            .account-dropdown__footer form {
                margin: 0;
            }

            .account-dropdown__footer .btn-logout {
                display: flex;
                align-items: center;
                justify-content: center;
                width: 100%;
                padding: 0.625rem;
                background: #fff;
                color: var(--danger);
                border: 1px solid #dee2e6;
                border-radius: 8px;
                font-size: 0.875rem;
                font-weight: 500;
                cursor: pointer;
                transition: var(--transition);
            }

                .account-dropdown__footer .btn-logout:hover {
                    background: var(--danger);
                    color: #fff;
                    border-color: var(--danger);
                }

                .account-dropdown__footer .btn-logout i {
                    margin-right: 0.5rem;
                    font-size: 1rem;
                }

        /* Responsive */
        @@media (max-width: 991px) {
            .account-dropdown

        {
            width: 260px;
            right: -5px;
        }

        .account-dropdown::before,
        .account-dropdown::after {
            right: 20px;
        }

        }
    </style>
</head>
<body>
    <div class="page-wrapper">
        <header class="header-mobile d-block d-lg-none">
            <div class="header-mobile__bar">
                <div class="container-fluid">
                    <div class="header-mobile-inner">
                        <a class="logo" asp-area="Admin" asp-controller="Admin" asp-action="Index">
                            <img src="~/Layout_Admin/images/icon/logo-mini.png" alt="CuongPhim Admin" />
                        </a>
                        <button class="hamburger hamburger--slider" type="button">
                            <span class="hamburger-box">
                                <span class="hamburger-inner"></span>
                            </span>
                        </button>
                    </div>
                </div>
            </div>
            <nav class="navbar-mobile">
                <div class="container-fluid">
                    <ul class="navbar-mobile__list list-unstyled">
                        <li class="@(ViewContext.RouteData.Values["Controller"]?.ToString() == "Admin" ? "active" : "")">
                            <a asp-area="Admin" asp-controller="Admin" asp-action="Index">
                                <i class="fas fa-tachometer-alt"></i>Admin
                            </a>
                        </li>
                        <li class="@(ViewContext.RouteData.Values["Controller"]?.ToString() == "Movies" ? "active" : "")">
                            <a asp-area="Admin" asp-controller="Movies" asp-action="Index">
                                <i class="fas fa-film"></i>Movies
                            </a>
                        </li>
                        <li class="@(ViewContext.RouteData.Values["Controller"]?.ToString() == "Actors" ? "active" : "")">
                            <a asp-area="Admin" asp-controller="Actors" asp-action="Index">
                                <i class="fas fa-user-friends"></i>Actors
                            </a>
                        </li>
                        <li class="@(ViewContext.RouteData.Values["Controller"]?.ToString() == "Genres" ? "active" : "")">
                            <a asp-area="Admin" asp-controller="Genres" asp-action="Index">
                                <i class="fas fa-tags"></i>Genres
                            </a>
                        </li>
                        <li class="@(ViewContext.RouteData.Values["Controller"]?.ToString() == "Countries" ? "active" : "")">
                            <a asp-area="Admin" asp-controller="Countries" asp-action="Index">
                                <i class="fas fa-globe"></i>Countries
                            </a>
                        </li>
                        <li class="@(ViewContext.RouteData.Values["Controller"]?.ToString() == "Languages" ? "active" : "")">
                            <a asp-area="Admin" asp-controller="Languages" asp-action="Index">
                                <i class="fas fa-language"></i>Languages
                            </a>
                        </li>
                        <li class="@(ViewContext.RouteData.Values["Controller"]?.ToString() == "Episodes" ? "active" : "")">
                            <a asp-area="Admin" asp-controller="Episodes" asp-action="Index">
                                <i class="fas fa-list-ol"></i>Episodes
                            </a>
                        </li>
                        <li class="@(ViewContext.RouteData.Values["Controller"]?.ToString() == "MediaUpload" ? "active" : "")">
                            <a asp-area="Admin" asp-controller="MediaUpload" asp-action="Index">
                                <i class="fas fa-photo-video"></i>Manage Media
                            </a>
                        </li>
                        <li class="@(ViewContext.RouteData.Values["Controller"]?.ToString() == "Users" ? "active" : "")">
                            <a asp-area="Admin" asp-controller="Users" asp-action="Index">
                                <i class="fas fa-photo-video"></i> Manage Users
                            </a>
                        </li>
                        <li>
                            <form asp-area="Identity" asp-page="/Account/Logout" asp-route-returnUrl="/" method="post" style="margin: 0;">
                                @Html.AntiForgeryToken()
                                <button type="submit" style="background: none; border: none; color: #dc3545; width: 100%; text-align: left; padding: 10px 15px; cursor: pointer; display: flex; align-items: center;">
                                    <i class="fas fa-sign-out-alt" style="margin-right: 10px; width: 20px;"></i>Logout
                                </button>
                            </form>
                        </li>
                    </ul>
                </div>
            </nav>
        </header>

        <aside class="menu-sidebar d-none d-lg-block">
            <div class="logo">
                <a asp-area="Admin" asp-controller="Admin" asp-action="Index">
                    <img src="~/Layout_Admin/images/icon/logo-mini.png" alt="CuongPhim Admin" />
                </a>
            </div>
            <div class="menu-sidebar__content js-scrollbar1">
                <nav class="navbar-sidebar">
                    <ul class="list-unstyled navbar__list">
                        <li class="@(ViewContext.RouteData.Values["Controller"]?.ToString() == "Admin" ? "active" : "")">
                            <a asp-area="Admin" asp-controller="Admin" asp-action="Index">
                                <i class="fas fa-tachometer-alt"></i>Admin Dashboard
                            </a>
                        </li>
                        <li class="@(ViewContext.RouteData.Values["Controller"]?.ToString() == "Movies" ? "active" : "")">
                            <a asp-area="Admin" asp-controller="Movies" asp-action="Index">
                                <i class="fas fa-film"></i>Manage Movies
                            </a>
                        </li>
                        <li class="@(ViewContext.RouteData.Values["Controller"]?.ToString() == "Actors" ? "active" : "")">
                            <a asp-area="Admin" asp-controller="Actors" asp-action="Index">
                                <i class="fas fa-user-friends"></i>Manage Actors
                            </a>
                        </li>
                        <li class="@(ViewContext.RouteData.Values["Controller"]?.ToString() == "Genres" ? "active" : "")">
                            <a asp-area="Admin" asp-controller="Genres" asp-action="Index">
                                <i class="fas fa-tags"></i>Manage Genres
                            </a>
                        </li>
                        <li class="@(ViewContext.RouteData.Values["Controller"]?.ToString() == "Countries" ? "active" : "")">
                            <a asp-area="Admin" asp-controller="Countries" asp-action="Index">
                                <i class="fas fa-globe"></i>Manage Countries
                            </a>
                        </li>
                        <li class="@(ViewContext.RouteData.Values["Controller"]?.ToString() == "Languages" ? "active" : "")">
                            <a asp-area="Admin" asp-controller="Languages" asp-action="Index">
                                <i class="fas fa-language"></i>Manage Languages
                            </a>
                        </li>
                        <li class="@(ViewContext.RouteData.Values["Controller"]?.ToString() == "Episodes" ? "active" : "")">
                            <a asp-area="Admin" asp-controller="Episodes" asp-action="Index">
                                <i class="fas fa-list-ol"></i>Manage Episodes
                            </a>
                        </li>
                        <li class="@(ViewContext.RouteData.Values["Controller"]?.ToString() == "MediaUpload" ? "active" : "")">
                            <a asp-area="Admin" asp-controller="MediaUpload" asp-action="Index">
                                <i class="fas fa-photo-video"></i>Manage Media
                            </a>
                        </li>
                    </ul>
                </nav>
            </div>
        </aside>

        <div class="page-container">
            <header class="header-desktop">
                <div class="section__content section__content--p30">
                    <div class="container-fluid">
                        <div class="header-wrap">
                            <div class="header-button">
                                <div class="account-wrap">
                                    <div class="account-item clearfix js-item-menu">
                                        <div class="image">
                                            <img src="~/Layout_Admin/images/icon/Bruno.png" alt="Admin" />
                                        </div>
                                        <div class="content">
                                            <a class="js-acc-btn" href="javascript:void(0)">@(User.Identity?.Name ?? "Admin")</a>
                                        </div>
                                        <div class="account-dropdown js-dropdown">
                                            <div class="info clearfix">
                                                <div class="image">
                                                    <a href="javascript:void(0)">
                                                        <img src="~/Layout_Admin/images/icon/Bruno.png" alt="Admin" />
                                                    </a>
                                                </div>
                                                <div class="content">
                                                    <h5 class="name">
                                                        <a href="javascript:void(0)">@(User.Identity?.Name ?? "Admin")</a>
                                                    </h5>
                                                    <span class="email">@(User.Identity?.Name ?? "admin")</span>
                                                </div>
                                            </div>
                                            <div class="account-dropdown__body">
                                                <div class="account-dropdown__item">
                                                    <a asp-area="Admin" asp-controller="Admin" asp-action="Index">
                                                        <i class="zmdi zmdi-view-dashboard"></i>Admin
                                                    </a>
                                                </div>
                                                <div class="account-dropdown__separator"></div>
                                                <div class="account-dropdown__item"></div>
                                            </div>
                                            <div class="account-dropdown__footer">
                                                <form asp-area="Identity" asp-page="/Account/Logout" asp-route-returnUrl="/" method="post">
                                                    @Html.AntiForgeryToken()
                                                    <button type="submit" class="btn-logout">
                                                        <i class="zmdi zmdi-power"></i>
                                                        <span>Logout</span>
                                                    </button>
                                                </form>
                                            </div>
                                        </div>
                                    </div>
                                </div>
                            </div>
                        </div>
                    </div>
                </div>
            </header>

            <div class="main-content">
                <div class="section__content section__content--p30">
                    <div class="container-fluid" id="main-content-container">
                        @RenderBody()
                    </div>
                </div>
            </div>
        </div>
    </div>

    <script src="https://code.jquery.com/jquery-3.6.0.min.js"></script>
    <script src="~/Layout_Admin/vendor/bootstrap-4.1/popper.min.js"></script>
    <script src="~/Layout_Admin/vendor/bootstrap-4.1/bootstrap.min.js"></script>
    <script src="~/Layout_Admin/js/main.js"></script>

    <script>
        document.addEventListener('DOMContentLoaded', function() {
            const accountItems = document.querySelectorAll('.js-item-menu');
            accountItems.forEach(item => {
                const button = item.querySelector('.js-acc-btn');
                const dropdown = item.querySelector('.js-dropdown');
                if (button && dropdown) {
                    button.addEventListener('click', function(e) {
                        e.preventDefault();
                        e.stopPropagation();
                        document.querySelectorAll('.js-dropdown').forEach(dd => {
                            if (dd !== dropdown) dd.classList.remove('show');
                        });
                        dropdown.classList.toggle('show');
                    });
                }
            });
            document.addEventListener('click', function(e) {
                if (!e.target.closest('.account-item')) {
                    document.querySelectorAll('.js-dropdown').forEach(d => d.classList.remove('show'));
                }
            });
            document.addEventListener('keydown', function(e) {
                if (e.key === 'Escape') {
                    document.querySelectorAll('.js-dropdown').forEach(d => d.classList.remove('show'));
                }
            });
            document.querySelectorAll('.js-dropdown').forEach(d => {
                d.addEventListener('click', e => e.stopPropagation());
            });
        });
    </script>

    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>