@model FinalCuongFilm.Common.DTOs.ActorDto

@{
    ViewData["Title"] = "Actor Details";
}

<style>
    :root {
        --primary-color: #2563eb;
        --text-dark: #1f2937;
        --text-gray: #6b7280;
        --border-color: #e5e7eb;
        --bg-light: #f9fafb;
        --radius-lg: 12px;
        --shadow-lg: 0 10px 25px rgba(0, 0, 0, 0.1);
    }

    body {
        background-color: #f8fafc;
        font-family: 'Segoe UI', system-ui, -apple-system, sans-serif;
    }

    .details-container {
        max-width: 800px;
        margin: 40px auto;
    }

    .details-card {
        background: white;
        border-radius: var(--radius-lg);
        box-shadow: var(--shadow-lg);
        overflow: hidden;
        border: 1px solid var(--border-color);
    }

    .card-header-banner {
        height: 120px;
        background: linear-gradient(135deg, var(--primary-color), #3b82f6);
    }

    .actor-profile-section {
        padding: 0 40px 40px 40px;
        display: flex;
        gap: 30px;
        margin-top: -60px;
    }

    .actor-avatar {
        width: 150px;
        height: 150px;
        border-radius: 50%;
        border: 5px solid white;
        box-shadow: 0 4px 10px rgba(0,0,0,0.15);
        object-fit: cover;
        background: white;
    }

    .actor-info {
        margin-top: 70px;
        flex: 1;
    }

    .actor-name {
        font-size: 28px;
        font-weight: 700;
        color: var(--text-dark);
        margin: 0 0 15px 0;
    }

    .info-grid {
        display: grid;
        grid-template-columns: repeat(2, 1fr);
        gap: 20px;
        background: var(--bg-light);
        padding: 20px;
        border-radius: 8px;
        border: 1px solid var(--border-color);
    }

    .info-item label {
        display: block;
        font-size: 12px;
        text-transform: uppercase;
        color: var(--text-gray);
        font-weight: 600;
        margin-bottom: 5px;
    }

    .info-item span {
        font-size: 15px;
        color: var(--text-dark);
        font-weight: 500;
    }

    .movies-section {
        padding: 0 40px 40px 40px;
    }

        .movies-section h3 {
            font-size: 18px;
            color: var(--text-dark);
            margin-bottom: 20px;
            padding-bottom: 10px;
            border-bottom: 2px solid var(--bg-light);
        }

    .movie-chips {
        display: flex;
        flex-wrap: wrap;
        gap: 10px;
    }

    .movie-chip {
        background: #eff6ff;
        color: #1e40af;
        border: 1px solid #bfdbfe;
        padding: 8px 16px;
        border-radius: 20px;
        font-size: 14px;
        font-weight: 500;
        display: inline-flex;
        align-items: center;
        gap: 8px;
        transition: all 0.2s;
    }

        .movie-chip:hover {
            background: #dbeafe;
            transform: translateY(-2px);
        }

    .action-buttons {
        padding: 20px 40px;
        background: var(--bg-light);
        border-top: 1px solid var(--border-color);
        display: flex;
        gap: 15px;
    }

    .btn {
        padding: 10px 24px;
        border-radius: 6px;
        font-weight: 600;
        text-decoration: none;
        display: inline-flex;
        align-items: center;
        gap: 8px;
        transition: 0.2s;
    }

    .btn-edit {
        background: var(--primary-color);
        color: white;
    }

        .btn-edit:hover {
            background: #1d4ed8;
        }

    .btn-back {
        background: white;
        color: var(--text-gray);
        border: 1px solid var(--border-color);
    }

        .btn-back:hover {
            background: #f3f4f6;
            color: var(--text-dark);
        }
</style>

<div class="details-container">
    <div class="details-card">
        <div class="card-header-banner"></div>

        <div class="actor-profile-section">
            <img src="@(string.IsNullOrEmpty(Model.AvartUrl) ? "https://via.placeholder.com/150?text=No+Avatar" : Model.AvartUrl)"
                 alt="@Model.Name" class="actor-avatar" />

            <div class="actor-info">
                <h1 class="actor-name">@Model.Name</h1>

                <div class="info-grid">
                    <div class="info-item">
                        <label>Date of Birth</label>
                        <span>@(Model.DateOfBirth?.ToString("dd/MM/yyyy") ?? "N/A")</span>
                    </div>
                    <div class="info-item">
                        <label>Gender</label>
                        <span>@(string.IsNullOrEmpty(Model.Gender) ? "N/A" : Model.Gender)</span>
                    </div>
                </div>
            </div>
        </div>

        <div class="movies-section">
            <h3><i>🎬</i> Participated Movies (@Model.ParticipatedMovieTitles.Count)</h3>

            <div class="movie-chips">
                @if (Model.ParticipatedMovieTitles.Any())
                {
                    foreach (var title in Model.ParticipatedMovieTitles)
                    {
                        <span class="movie-chip">
                            <i>🎞️</i> @title
                        </span>
                    }
                }
                else
                {
                    <span style="color: var(--text-gray); font-style: italic;">
                        This actor has not participated in any movies yet.
                    </span>
                }
            </div>
        </div>

        <div class="action-buttons">
            <a asp-action="Edit" asp-route-id="@Model.Id" class="btn btn-edit">
                <i>✏️</i> Edit Actor
            </a>
            <a asp-action="Index" class="btn btn-back">
                <i>←</i> Back to List
            </a>
        </div>
    </div>
</div>