@model FinalCuongFilm.Common.DTOs.ActorDto

@{
    ViewData["Title"] = "Delete Actor";
}

<div class="row">
    <div class="col-md-12">
        <h2 class="title-1 text-danger">@ViewData["Title"]</h2>
    </div>
</div>

<div class="row m-t-30">
    <div class="col-md-8">
        <div class="alert alert-danger">
            <h4>Are you sure you want to delete this actor?</h4>
        </div>

        <div class="card">
            <div class="card-header">
                <strong>Actor details to be deleted</strong>
            </div>
            <div class="card-body">
                <div class="row">
                    <div class="col-md-4 text-center">
                        @if (!string.IsNullOrEmpty(Model.AvartUrl))
                        {
                            <img src="@Model.AvartUrl" alt="@Model.Name" class="img-fluid rounded-circle" style="max-width: 150px;" />
                        }
                        else
                        {
                            <div style="width: 150px; height: 150px; background: #e5e7eb; border-radius: 50%; display: flex; align-items: center; justify-content: center; margin: 0 auto;">
                                <span style="font-size: 40px; color: #9ca3af;">👤</span>
                            </div>
                        }
                    </div>
                    <div class="col-md-8">
                        <dl class="row">
                            <dt class="col-sm-4">Name:</dt>
                            <dd class="col-sm-8">@Model.Name</dd>

                            <dt class="col-sm-4">Slug:</dt>
                            <dd class="col-sm-8">@Model.Slug</dd>

                            <dt class="col-sm-4">Date of Birth:</dt>
                            <dd class="col-sm-8">@(Model.DateOfBirth?.ToString("dd/MM/yyyy") ?? "N/A")</dd>

                            @* <dt class="col-sm-4">Gender:</dt>
                            <dd class="col-sm-8">@Model.Gender</dd> *@
                        </dl>
                    </div>
                </div>

                <form asp-action="Delete" method="post" class="mt-3">
                    <input type="hidden" asp-for="Id" />
                    <button type="submit" class="btn btn-danger">
                        <i class="fa fa-trash"></i> Confirm Delete
                    </button>
                    <a asp-action="Index" class="btn btn-secondary">
                        <i class="fa fa-times"></i> Cancel
                    </a>
                </form>
            </div>
        </div>
    </div>
</div>