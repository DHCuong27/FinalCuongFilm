@model FinalCuongFilm.Common.DTOs.ActorDto

@{
    ViewData["Title"] = "Xóa Diễn viên";
}

<div class="row">
    <div class="col-md-12">
        <h2 class="title-1 text-danger">@ViewData["Title"]</h2>
    </div>
</div>

<div class="row m-t-30">
    <div class="col-md-8">
        <div class="alert alert-danger">
            <h4>Bạn có chắc chắn muốn xóa diễn viên này?</h4>
        </div>

        <div class="card">
            <div class="card-header">
                <strong>Thông tin diễn viên sẽ bị xóa</strong>
            </div>
            <div class="card-body">
                <div class="row">
                    <div class="col-md-4 text-center">
                        @if (!string.IsNullOrEmpty(Model.AvartUrl))
                        {
                            <img src="@Model.AvartUrl" alt="@Model.Name" class="img-fluid rounded-circle" style="max-width: 150px;" />
                        }
                    </div>
                    <div class="col-md-8">
                        <dl class="row">
                            <dt class="col-sm-4">Tên:</dt>
                            <dd class="col-sm-8">@Model.Name</dd>

                            <dt class="col-sm-4">Slug:</dt>
                            <dd class="col-sm-8">@Model.Slug</dd>

                            <dt class="col-sm-4">Ngày sinh:</dt>
                            <dd class="col-sm-8">@Model.DateOfBirth?.ToString("dd/MM/yyyy")</dd>

                            @* <dt class="col-sm-4">Giới tính:</dt>
                            <dd class="col-sm-8">@Model.Gender</dd> *@
                        </dl>
                    </div>
                </div>

                <form asp-action="Delete" method="post" class="mt-3">
                    <input type="hidden" asp-for="Id" />
                    <button type="submit" class="btn btn-danger">
                        <i class="fa fa-trash"></i> Xác nhận xóa
                    </button>
                    <a asp-action="Index" class="btn btn-secondary">
                        <i class="fa fa-times"></i> Hủy
                    </a>
                </form>
            </div>
        </div>
    </div>
</div>