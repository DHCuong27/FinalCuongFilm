@model FinalCuongFilm.Common.DTOs.ActorUpdateDto

@{
    ViewData["Title"] = "Chỉnh sửa Diễn viên";
}

<div class="row">
    <div class="col-md-12">
        <h2 class="title-1">@ViewData["Title"]</h2>
    </div>
</div>

<div class="row m-t-30">
    <div class="col-md-8">
        <div class="card">
            <div class="card-header">
                <strong>Cập nhật thông tin diễn viên</strong>
            </div>
            <div class="card-body card-block">
                <form asp-action="Edit" method="post">
                    <input type="hidden" asp-for="Id" />
                    <div asp-validation-summary="ModelOnly" class="text-danger"></div>

                    <div class="form-group">
                        <label asp-for="Name" class="form-control-label">Tên diễn viên <span class="text-danger">*</span></label>
                        <input asp-for="Name" class="form-control" />
                        <span asp-validation-for="Name" class="text-danger"></span>
                    </div>

                    <div class="form-group">
                        <label asp-for="AvartUrl" class="form-control-label">URL Avatar</label>
                        <input asp-for="AvartUrl" class="form-control" placeholder="https://example.com/avatar.jpg" />
                        <span asp-validation-for="AvartUrl" class="text-danger"></span>
                    </div>

                    <div class="row">
                        <div class="col-md-6">
                            <div class="form-group">
                                <label asp-for="DateOfBirth" class="form-control-label">Ngày sinh</label>
                                <input asp-for="DateOfBirth" class="form-control" type="date" />
                                <span asp-validation-for="DateOfBirth" class="text-danger"></span>
                            </div>
                        </div>
                        @* <div class="col-md-6">
                            <div class="form-group">
                                <label asp-for="Gender" class="form-control-label">Giới tính</label>
                                <select asp-for="Gender" class="form-control" asp-items="Html.GetEnumSelectList<FinalCuongFilm.ApplicationCore.Entities.Enum.Gender>()">
                                </select>
                                <span asp-validation-for="Gender" class="text-danger"></span>
                            </div>
                        </div> *@
                    </div>

                    <div class="form-actions form-group">
                        <button type="submit" class="btn btn-primary btn-sm">
                            <i class="fa fa-save"></i> Cập nhật
                        </button>
                        <a asp-action="Index" class="btn btn-secondary btn-sm">
                            <i class="fa fa-times"></i> Hủy
                        </a>
                    </div>
                </form>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    @{
        await Html.RenderPartialAsync("_ValidationScriptsPartial");
    }
}