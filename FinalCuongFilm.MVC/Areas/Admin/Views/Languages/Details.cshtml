@model FinalCuongFilm.Common.DTOs.LanguageDto

@{
    ViewData["Title"] = "Chi tiết Ngôn ngữ";
}

<div class="row">
    <div class="col-md-12">
        <h2 class="title-1">@ViewData["Title"]</h2>
    </div>
</div>

<div class="row m-t-30">
    <div class="col-md-6">
        <div class="card">
            <div class="card-header">
                <strong>Thông tin ngôn ngữ</strong>
            </div>
            <div class="card-body">
                <dl class="row">
                    <dt class="col-sm-4">Tên:</dt>
                    <dd class="col-sm-8">@Model.Name</dd>

                    <dt class="col-sm-4">Slug:</dt>
                    <dd class="col-sm-8"><code>@Model.Slug</code></dd>
                </dl>
            </div>
        </div>

        <div class="m-t-20">
            <a asp-action="Edit" asp-route-id="@Model.Id" class="btn btn-primary">Chỉnh sửa</a>
            <a asp-action="Index" class="btn btn-secondary">Quay lại danh sách</a>
        </div>
    </div>
</div>