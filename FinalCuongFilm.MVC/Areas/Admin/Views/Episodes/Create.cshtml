@model FinalCuongFilm.Common.DTOs.EpisodeCreateDto

@{
    ViewData["Title"] = "Thêm Tập Phim Mới";
}

<div class="row">
    <div class="col-md-12">
        <h2 class="title-1">@ViewData["Title"]</h2>
    </div>
</div>

<div class="row m-t-30">
    <div class="col-md-8">
        <div class="card">
            <div class="card-header">
                <strong>Thông tin tập phim</strong>
            </div>
            <div class="card-body card-block">
                <form asp-action="Create" method="post">
                    <div asp-validation-summary="ModelOnly" class="text-danger"></div>

                    <div class="form-group">
                        <label asp-for="MovieId" class="form-control-label">Phim <span class="text-danger">*</span></label>
                        <select asp-for="MovieId" class="form-control" asp-items="ViewBag.Movies">
                            <option value="">-- Chọn phim --</option>
                        </select>
                        <span asp-validation-for="MovieId" class="text-danger"></span>
                    </div>

                    <div class="row">
                        <div class="col-md-6">
                            <div class="form-group">
                                <label asp-for="EpisodeNumber" class="form-control-label">Số tập <span class="text-danger">*</span></label>
                                <input asp-for="EpisodeNumber" class="form-control" type="number" min="1" />
                                <span asp-validation-for="EpisodeNumber" class="text-danger"></span>
                            </div>
                        </div>
                        <div class="col-md-6">
                            <div class="form-group">
                                <label asp-for="DurationMinutes" class="form-control-label">Thời lượng (phút)</label>
                                <input asp-for="DurationMinutes" class="form-control" type="number" min="1" />
                                <span asp-validation-for="DurationMinutes" class="text-danger"></span>
                            </div>
                        </div>
                    </div>

                    <div class="form-group">
                        <label asp-for="Title" class="form-control-label">Tiêu đề <span class="text-danger">*</span></label>
                        <input asp-for="Title" class="form-control" />
                        <span asp-validation-for="Title" class="text-danger"></span>
                    </div>

                    <div class="form-group">
                        <label asp-for="Description" class="form-control-label">Mô tả</label>
                        <textarea asp-for="Description" class="form-control" rows="4"></textarea>
                        <span asp-validation-for="Description" class="text-danger"></span>
                    </div>

                    <div class="form-group">
                        <label asp-for="AirDate" class="form-control-label">Ngày phát sóng</label>
                        <input asp-for="AirDate" class="form-control" type="date" />
                        <span asp-validation-for="AirDate" class="text-danger"></span>
                    </div>

                    <div class="form-group">
                        <div class="form-check">
                            <input asp-for="IsActive" class="form-check-input" type="checkbox" />
                            <label asp-for="IsActive" class="form-check-label">Kích hoạt</label>
                        </div>
                    </div>

                    <div class="form-actions form-group">
                        <button type="submit" class="btn btn-primary btn-sm">
                            <i class="fa fa-save"></i> Lưu
                        </button>
                        <a asp-action="Index" asp-route-movieId="@Model.MovieId" class="btn btn-secondary btn-sm">
                            <i class="fa fa-times"></i> Hủy
                        </a>
                    </div>
                </form>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    @{
        await Html.RenderPartialAsync("_ValidationScriptsPartial");
    }
}