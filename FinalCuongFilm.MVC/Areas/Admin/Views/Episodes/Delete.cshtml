@model FinalCuongFilm.Common.DTOs.EpisodeDto

@{
    ViewData["Title"] = "Xóa Episode";
}

<div class="row">
    <div class="col-md-12">
        <h2 class="title-1 text-danger">
            <i class="fas fa-trash"></i> Xác nhận xóa Episode
        </h2>
    </div>
</div>

<div class="row m-t-30">
    <div class="col-md-8">
        <div class="alert alert-danger">
            <h4><i class="fas fa-exclamation-triangle"></i> Cảnh báo!</h4>
            <p>Bạn có chắc chắn muốn xóa episode này? Hành động này không thể hoàn tác!</p>
        </div>

        <div class="card">
            <div class="card-header">
                <strong>Thông tin Episode sẽ bị xóa</strong>
            </div>
            <div class="card-body">
                <dl class="row">
                    <dt class="col-sm-4">Số tập:</dt>
                    <dd class="col-sm-8"><strong>Tập @Model.EpisodeNumber</strong></dd>

                    <dt class="col-sm-4">Tiêu đề:</dt>
                    <dd class="col-sm-8">@Model.Title</dd>

                    <dt class="col-sm-4">Mô tả:</dt>
                    <dd class="col-sm-8">@(Model.Description ?? "Chưa có mô tả")</dd>

                    <dt class="col-sm-4">Thời lượng:</dt>
                    <dd class="col-sm-8">@Model.DurationMinutes phút</dd>

                    @if (Model.AirDate.HasValue)
                    {
                        <dt class="col-sm-4">Ngày phát sóng:</dt>
                        <dd class="col-sm-8">@Model.AirDate.Value.ToString("dd/MM/yyyy")</dd>
                    }

                    <dt class="col-sm-4">Trạng thái:</dt>
                    <dd class="col-sm-8">
                        @if (Model.IsActive)
                        {
                            <span class="badge badge-success">Active</span>
                        }
                        else
                        {
                            <span class="badge badge-secondary">Inactive</span>
                        }
                    </dd>

                    <dt class="col-sm-4">Lượt xem:</dt>
                    <dd class="col-sm-8">@Model.ViewCount.ToString("N0")</dd>
                </dl>

                <hr />

                <form asp-action="Delete" method="post">
                    <input type="hidden" asp-for="Id" />
                    <div class="form-actions">
                        <button type="submit" class="btn btn-danger">
                            <i class="fas fa-trash"></i> Xác nhận xóa
                        </button>
                        <a asp-action="Index" class="btn btn-secondary">
                            <i class="fas fa-times"></i> Hủy bỏ
                        </a>
                    </div>
                </form>
            </div>
        </div>
    </div>

    <div class="col-md-4">
        <div class="card">
            <div class="card-header bg-info text-white">
                <i class="fas fa-info-circle"></i> Lưu ý
            </div>
            <div class="card-body">
                <p><strong>Khi xóa episode này:</strong></p>
                <ul>
                    <li>Tất cả media files liên quan sẽ bị xóa</li>
                    <li>Dữ liệu không thể khôi phục</li>
                    <li>Người dùng sẽ không xem được tập này</li>
                </ul>
            </div>
        </div>
    </div>
</div>