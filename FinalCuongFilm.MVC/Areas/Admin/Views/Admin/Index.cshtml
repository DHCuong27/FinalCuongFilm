@{
    ViewData["Title"] = "Admin Dashboard";
    Layout = "~/Areas/Admin/Views/Shared/_LayoutAdmin.cshtml";
}

<style>
    :root {
        --bg-body: #f1f5f9;
        --card-bg: #ffffff;
        --text-main: #1e293b;
        --text-muted: #64748b;
        --border-color: #e2e8f0;
        --radius: 12px;
        --transition: all 0.3s cubic-bezier(0.4, 0, 0.2, 1);
        --shadow-sm: 0 1px 2px 0 rgb(0 0 0 / 0.05);
        --shadow-md: 0 4px 6px -1px rgb(0 0 0 / 0.1);
        --shadow-lg: 0 10px 15px -3px rgb(0 0 0 / 0.1);
    }

    .dashboard-container {
        padding: 1.5rem;
        max-width: 1600px;
        margin: 0 auto;
        font-family: 'Segoe UI', system-ui, -apple-system, sans-serif;
    }

    .page-title {
        font-size: 1.75rem;
        font-weight: 700;
        color: var(--text-main);
        margin-bottom: 2rem;
        display: flex;
        align-items: center;
        gap: 12px;
    }

    /* Grid System */
    .dashboard-grid {
        display: grid;
        gap: 1.5rem;
        grid-template-columns: repeat(auto-fill, minmax(300px, 1fr));
    }

    @@media (min-width: 1280px) {
        .dashboard-grid

    {
        grid-template-columns: repeat(4, 1fr);
    }

    }

    /* Card Design */
    .dashboard-card {
        background-color: var(--card-bg);
        border-radius: var(--radius);
        box-shadow: var(--shadow-sm);
        border: 1px solid var(--border-color);
        display: flex;
        flex-direction: column;
        transition: var(--transition);
        overflow: hidden;
        height: 100%;
        animation: fadeInUp 0.4s ease-out forwards;
    }

        .dashboard-card:hover {
            transform: translateY(-5px);
            box-shadow: var(--shadow-lg);
            border-color: #cbd5e1;
        }

    .card-content {
        padding: 1.5rem;
        flex-grow: 1;
        display: flex;
        align-items: center;
        gap: 1.25rem;
    }

    .card-icon {
        width: 56px;
        height: 56px;
        border-radius: 12px;
        display: flex;
        align-items: center;
        justify-content: center;
        font-size: 1.5rem;
        flex-shrink: 0;
    }

    /* Dynamic Colors */
    .icon-movie {
        background: #e0f2fe;
        color: #0284c7;
    }

    .icon-user {
        background: #dcfce7;
        color: #166534;
    }

    .icon-actor {
        background: #fef08a;
        color: #ca8a04;
    }

    .icon-genre {
        background: #f3e8ff;
        color: #9333ea;
    }

    .icon-country {
        background: #ffedd5;
        color: #ea580c;
    }

    .icon-language {
        background: #e0e7ff;
        color: #4338ca;
    }

    .icon-episode {
        background: #ccfbf1;
        color: #0d9488;
    }

    .icon-media {
        background: #fee2e2;
        color: #dc2626;
    }

    /* NEW: Premium Colors */
    .icon-vip-acc {
        background: #fef3c7;
        color: #d97706;
    }

    .icon-vip-plan {
        background: #fae8ff;
        color: #a21caf;
    }

    .icon-payment {
        background: #ecfdf5;
        color: #059669;
    }

    .card-text h2 {
        font-size: 1.75rem;
        font-weight: 700;
        margin: 0;
        color: var(--text-main);
    }

    .card-text span {
        color: var(--text-muted);
        font-size: 0.85rem;
        font-weight: 600;
        text-transform: uppercase;
        letter-spacing: 0.5px;
    }

    .card-action {
        background-color: #f8fafc;
        border-top: 1px solid var(--border-color);
        padding: 0.875rem 1.5rem;
    }

    .btn-manage {
        display: flex;
        align-items: center;
        justify-content: space-between;
        color: #3b82f6;
        text-decoration: none;
        font-weight: 600;
        font-size: 0.9rem;
        transition: var(--transition);
    }

        .btn-manage:hover {
            color: #1d4ed8;
        }

        .btn-manage i {
            transition: transform 0.2s;
        }

        .btn-manage:hover i {
            transform: translateX(5px);
        }

    @@keyframes fadeInUp {
        from

    {
        opacity: 0;
        transform: translateY(15px);
    }

    to {
        opacity: 1;
        transform: translateY(0);
    }

    }
</style>

<div class="dashboard-container">
    <h1 class="page-title">
        <i class="zmdi zmdi-view-dashboard"></i> Dashboard Overview
    </h1>

    <div class="dashboard-grid">

        <div class="dashboard-card">
            <div class="card-content">
                <div class="card-icon icon-movie"><i class="fas fa-film"></i></div>
                <div class="card-text"><h2>@ViewBag.TotalMovies</h2><span>Total Movies</span></div>
            </div>
            <div class="card-action">
                <a asp-area="Admin" asp-controller="Movies" asp-action="Index" class="btn-manage">Manage Movies <i class="fas fa-arrow-right"></i></a>
            </div>
        </div>

        <div class="dashboard-card">
            <div class="card-content">
                <div class="card-icon icon-episode"><i class="fas fa-tv"></i></div>
                <div class="card-text"><h2>@ViewBag.TotalEpisodes</h2><span>Episodes</span></div>
            </div>
            <div class="card-action">
                <a asp-area="Admin" asp-controller="Episodes" asp-action="Index" class="btn-manage">Manage Episodes <i class="fas fa-arrow-right"></i></a>
            </div>
        </div>

        <div class="dashboard-card">
            <div class="card-content">
                <div class="card-icon icon-media"><i class="fas fa-file-video"></i></div>
                <div class="card-text"><h2>@ViewBag.TotalMediaFiles</h2><span>Media Files</span></div>
            </div>
            <div class="card-action">
                <a asp-area="Admin" asp-controller="MediaUpload" asp-action="Index" class="btn-manage">Manage Media <i class="fas fa-arrow-right"></i></a>
            </div>
        </div>

        <div class="dashboard-card">
            <div class="card-content">
                <div class="card-icon icon-user"><i class="fas fa-users"></i></div>
                <div class="card-text"><h2>@ViewBag.TotalUsers</h2><span>Total Users</span></div>
            </div>
            <div class="card-action">
                <a asp-area="Admin" asp-controller="User" asp-action="Index" class="btn-manage">Manage Users <i class="fas fa-arrow-right"></i></a>
            </div>
        </div>

        <div class="dashboard-card">
            <div class="card-content">
                <div class="card-icon icon-vip-acc"><i class="fas fa-crown"></i></div>
                <div class="card-text"><h2>@ViewBag.TotalPremiumUsers</h2><span>VIP Accounts</span></div>
            </div>
            <div class="card-action">
                <a asp-area="Admin" asp-controller="VipManager" asp-action="ActiveVips" class="btn-manage">Active VIPs <i class="fas fa-arrow-right"></i></a>
            </div>
        </div>

        <div class="dashboard-card">
            <div class="card-content">
                <div class="card-icon icon-vip-plan"><i class="fas fa-gem"></i></div>
                <div class="card-text"><h2>@ViewBag.TotalPremiumPlans</h2><span>Premium Plans</span></div>
            </div>
            <div class="card-action">
                <a asp-area="Admin" asp-controller="VipPackage" asp-action="Index" class="btn-manage">Manage Plans <i class="fas fa-arrow-right"></i></a>
            </div>
        </div>

        <div class="dashboard-card">
            <div class="card-content">
                <div class="card-icon icon-payment"><i class="fas fa-receipt"></i></div>
                <div class="card-text"><h2>@ViewBag.TotalTransactions</h2><span>Payment History</span></div>
            </div>
            <div class="card-action">
                <a asp-area="Admin" asp-controller="VipManager" asp-action="Transactions" class="btn-manage">View History <i class="fas fa-arrow-right"></i></a>
            </div>
        </div>

        <div class="dashboard-card">
            <div class="card-content">
                <div class="card-icon icon-actor"><i class="fas fa-user-astronaut"></i></div>
                <div class="card-text"><h2>@ViewBag.TotalActors</h2><span>Actors</span></div>
            </div>
            <div class="card-action">
                <a asp-area="Admin" asp-controller="Actors" asp-action="Index" class="btn-manage">Manage Actors <i class="fas fa-arrow-right"></i></a>
            </div>
        </div>

        <div class="dashboard-card">
            <div class="card-content">
                <div class="card-icon icon-genre"><i class="fas fa-tags"></i></div>
                <div class="card-text"><h2>@ViewBag.TotalGenres</h2><span>Genres</span></div>
            </div>
            <div class="card-action">
                <a asp-area="Admin" asp-controller="Genres" asp-action="Index" class="btn-manage">Manage Genres <i class="fas fa-arrow-right"></i></a>
            </div>
        </div>

        <div class="dashboard-card">
            <div class="card-content">
                <div class="card-icon icon-country"><i class="fas fa-globe-americas"></i></div>
                <div class="card-text"><h2>@ViewBag.TotalCountries</h2><span>Countries</span></div>
            </div>
            <div class="card-action">
                <a asp-area="Admin" asp-controller="Countries" asp-action="Index" class="btn-manage">Manage Countries <i class="fas fa-arrow-right"></i></a>
            </div>
        </div>

        <div class="dashboard-card">
            <div class="card-content">
                <div class="card-icon icon-language"><i class="fas fa-language"></i></div>
                <div class="card-text"><h2>@ViewBag.TotalLanguages</h2><span>Languages</span></div>
            </div>
            <div class="card-action">
                <a asp-area="Admin" asp-controller="Languages" asp-action="Index" class="btn-manage">Manage Languages <i class="fas fa-arrow-right"></i></a>
            </div>
        </div>

    </div>
</div>