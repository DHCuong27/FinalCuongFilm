@{
    ViewData["Title"] = "Dashboard Overview";
}

<style>
    .dashboard-header {
        font-size: 1.75rem;
        font-weight: 700;
        color: #1e293b;
        margin-bottom: 1.5rem;
    }

    .dash-card {
        border: none;
        border-radius: 16px;
        box-shadow: 0 4px 15px rgba(0, 0, 0, 0.03);
        transition: transform 0.2s ease, box-shadow 0.2s ease;
        height: 100%;
        background-color: #ffffff;
    }

        .dash-card:hover {
            transform: translateY(-5px);
            box-shadow: 0 10px 25px rgba(0, 0, 0, 0.08);
        }

    .dash-body {
        padding: 1.5rem;
        display: flex;
        align-items: center;
        gap: 1rem;
    }

    .dash-icon {
        width: 55px;
        height: 55px;
        border-radius: 12px;
        display: flex;
        align-items: center;
        justify-content: center;
        font-size: 1.5rem;
        flex-shrink: 0;
    }

    .dash-num {
        font-size: 1.75rem;
        font-weight: 700;
        color: #1e293b;
        line-height: 1.1;
        margin-bottom: 0.2rem;
    }

    .dash-label {
        font-size: 0.75rem;
        font-weight: 600;
        color: #64748b;
        letter-spacing: 0.5px;
        text-transform: uppercase;
        margin: 0;
    }

    .dash-footer {
        background-color: transparent;
        border-top: 1px solid #f1f5f9;
        padding: 1rem 1.5rem;
    }

    .dash-link {
        color: #3b82f6;
        text-decoration: none;
        font-weight: 500;
        font-size: 0.9rem;
        display: flex;
        justify-content: space-between;
        align-items: center;
        transition: color 0.2s ease;
    }

        .dash-link:hover {
            color: #2563eb;
        }

    /* Custom Icon Colors matching your design */
    .icon-blue {
        background-color: #e0f2fe;
        color: #3b82f6;
    }

    .icon-teal {
        background-color: #ccfbf1;
        color: #14b8a6;
    }

    .icon-red {
        background-color: #fee2e2;
        color: #ef4444;
    }

    .icon-green {
        background-color: #dcfce7;
        color: #10b981;
    }

    .icon-gold {
        background-color: #fef3c7;
        color: #f59e0b;
    }

    .icon-pink {
        background-color: #fce7f3;
        color: #ec4899;
    }

    .icon-lightgreen {
        background-color: #ecfccb;
        color: #10b981;
    }

    .icon-yellow {
        background-color: #fef08a;
        color: #eab308;
    }

    .icon-purple {
        background-color: #f3e8ff;
        color: #a855f7;
    }

    .icon-orange {
        background-color: #ffedd5;
        color: #f97316;
    }

    .icon-indigo {
        background-color: #e0e7ff;
        color: #6366f1;
    }
</style>

<div class="container-fluid py-4">
    <h2 class="dashboard-header">Dashboard Overview</h2>

    <div class="row g-4">
        <div class="col-12 col-md-6 col-lg-3">
            <div class="dash-card">
                <div class="dash-body">
                    <div class="dash-icon icon-blue">
                        <i class="fa-solid fa-film"></i>
                    </div>
                    <div>
                        <div class="dash-num">@ViewBag.TotalMovies</div>
                        <p class="dash-label">Total Movies</p>
                    </div>
                </div>
                <div class="dash-footer">
                    <a asp-controller="Movies" asp-action="Index" class="dash-link">
                        Manage Movies <i class="fa-solid fa-arrow-right"></i>
                    </a>
                </div>
            </div>
        </div>

        <div class="col-12 col-md-6 col-lg-3">
            <div class="dash-card">
                <div class="dash-body">
                    <div class="dash-icon icon-teal">
                        <i class="fa-solid fa-tv"></i>
                    </div>
                    <div>
                        <div class="dash-num">@ViewBag.TotalEpisodes</div>
                        <p class="dash-label">Episodes</p>
                    </div>
                </div>
                <div class="dash-footer">
                    <a asp-controller="Episodes" asp-action="Index" class="dash-link">
                        Manage Episodes <i class="fa-solid fa-arrow-right"></i>
                    </a>
                </div>
            </div>
        </div>

        <div class="col-12 col-md-6 col-lg-3">
            <div class="dash-card">
                <div class="dash-body">
                    <div class="dash-icon icon-red">
                        <i class="fa-solid fa-file-video"></i>
                    </div>
                    <div>
                        <div class="dash-num">@ViewBag.TotalMediaFiles</div>
                        <p class="dash-label">Media Files</p>
                    </div>
                </div>
                <div class="dash-footer">
                    <a asp-controller="MediaUpload" asp-action="Index" class="dash-link">
                        Manage Media <i class="fa-solid fa-arrow-right"></i>
                    </a>
                </div>
            </div>
        </div>

        <div class="col-12 col-md-6 col-lg-3">
            <div class="dash-card">
                <div class="dash-body">
                    <div class="dash-icon icon-green">
                        <i class="fa-solid fa-users"></i>
                    </div>
                    <div>
                        <div class="dash-num">@ViewBag.TotalUsers</div>
                        <p class="dash-label">Total Users</p>
                    </div>
                </div>
                <div class="dash-footer">
                    <a asp-controller="User" asp-action="Index" class="dash-link">
                        Manage Users <i class="fa-solid fa-arrow-right"></i>
                    </a>
                </div>
            </div>
        </div>

        <div class="col-12 col-md-6 col-lg-3">
            <div class="dash-card">
                <div class="dash-body">
                    <div class="dash-icon icon-gold">
                        <i class="fa-solid fa-crown"></i>
                    </div>
                    <div>
                        <div class="dash-num">@ViewBag.TotalUserSubscriptions</div>
                        <p class="dash-label">VIP Accounts</p>
                    </div>
                </div>
                <div class="dash-footer">
                    <a asp-controller="VipManager" asp-action="ActiveVips" class="dash-link">
                        Active VIPs <i class="fa-solid fa-arrow-right"></i>
                    </a>
                </div>
            </div>
        </div>

        <div class="col-12 col-md-6 col-lg-3">
            <div class="dash-card">
                <div class="dash-body">
                    <div class="dash-icon icon-pink">
                        <i class="fa-solid fa-gem"></i>
                    </div>
                    <div>
                        <div class="dash-num">@ViewBag.TotalVipPackages</div>
                        <p class="dash-label">Premium Plans</p>
                    </div>
                </div>
                <div class="dash-footer">
                    <a asp-controller="VipPackage" asp-action="Index" class="dash-link">
                        Manage Plans <i class="fa-solid fa-arrow-right"></i>
                    </a>
                </div>
            </div>
        </div>

        <div class="col-12 col-md-6 col-lg-3">
            <div class="dash-card">
                <div class="dash-body">
                    <div class="dash-icon icon-lightgreen">
                        <i class="fa-solid fa-file-invoice-dollar"></i>
                    </div>
                    <div>
                        <div class="dash-num">@ViewBag.TotalTransactions</div>
                        <p class="dash-label">Payment History</p>
                    </div>
                </div>
                <div class="dash-footer">
                    <a asp-controller="VipManager" asp-action="Transactions" class="dash-link">
                        View History <i class="fa-solid fa-arrow-right"></i>
                    </a>
                </div>
            </div>
        </div>

        <div class="col-12 col-md-6 col-lg-3">
            <div class="dash-card">
                <div class="dash-body">
                    <div class="dash-icon icon-yellow">
                        <i class="fa-solid fa-user-tie"></i>
                    </div>
                    <div>
                        <div class="dash-num">@ViewBag.TotalActors</div>
                        <p class="dash-label">Actors</p>
                    </div>
                </div>
                <div class="dash-footer">
                    <a asp-controller="Actors" asp-action="Index" class="dash-link">
                        Manage Actors <i class="fa-solid fa-arrow-right"></i>
                    </a>
                </div>
            </div>
        </div>

        <div class="col-12 col-md-6 col-lg-3">
            <div class="dash-card">
                <div class="dash-body">
                    <div class="dash-icon icon-purple">
                        <i class="fa-solid fa-tags"></i>
                    </div>
                    <div>
                        <div class="dash-num">@ViewBag.TotalGenres</div>
                        <p class="dash-label">Genres</p>
                    </div>
                </div>
                <div class="dash-footer">
                    <a asp-controller="Genres" asp-action="Index" class="dash-link">
                        Manage Genres <i class="fa-solid fa-arrow-right"></i>
                    </a>
                </div>
            </div>
        </div>

        <div class="col-12 col-md-6 col-lg-3">
            <div class="dash-card">
                <div class="dash-body">
                    <div class="dash-icon icon-orange">
                        <i class="fa-solid fa-earth-americas"></i>
                    </div>
                    <div>
                        <div class="dash-num">@ViewBag.TotalCountries</div>
                        <p class="dash-label">Countries</p>
                    </div>
                </div>
                <div class="dash-footer">
                    <a asp-controller="Countries" asp-action="Index" class="dash-link">
                        Manage Countries <i class="fa-solid fa-arrow-right"></i>
                    </a>
                </div>
            </div>
        </div>

        <div class="col-12 col-md-6 col-lg-3">
            <div class="dash-card">
                <div class="dash-body">
                    <div class="dash-icon icon-indigo">
                        <i class="fa-solid fa-language"></i>
                    </div>
                    <div>
                        <div class="dash-num">@ViewBag.TotalLanguages</div>
                        <p class="dash-label">Languages</p>
                    </div>
                </div>
                <div class="dash-footer">
                    <a asp-controller="Languages" asp-action="Index" class="dash-link">
                        Manage Languages <i class="fa-solid fa-arrow-right"></i>
                    </a>
                </div>
            </div>
        </div>

    </div>
</div>