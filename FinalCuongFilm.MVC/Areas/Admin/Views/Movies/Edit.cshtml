@model FinalCuongFilm.Common.DTOs.MovieUpdateDto

@{
    ViewData["Title"] = "Edit Movie";
}

<style>
    :root {
        --nf-red: #e50914;
        --nf-red2: #f40612;
        --nf-bg: #141414;
        --nf-dark: #181818;
        --nf-darker: #0f0f0f;
        --nf-card: #1f1f1f;
        --nf-input: #2a2a2a;
        --nf-border: #333;
        --nf-gray: #808080;
        --nf-lgray: #b3b3b3;
        --nf-white: #fff;
        --nf-green: #2ecc71;
        --nf-blue: #3498db;
        --nf-yellow: #f39c12;
    }

    .nf-page-header {
        margin-bottom: 24px;
        padding-bottom: 16px;
        border-bottom: 2px solid var(--nf-border);
    }

    .nf-page-title {
        font-size: 1.75rem;
        font-weight: 700;
        color: var(--nf-white);
        margin: 0 0 4px;
    }

        .nf-page-title span {
            color: var(--nf-red);
        }

    .nf-page-sub {
        color: var(--nf-lgray);
        font-size: .9rem;
    }

    .nf-card {
        background: var(--nf-card);
        border: 1px solid var(--nf-border);
        border-radius: 8px;
        overflow: hidden;
        margin-bottom: 18px;
        box-shadow: 0 4px 20px rgba(0,0,0,.35);
    }

    .nf-card-hd {
        background: var(--nf-darker);
        padding: 12px 20px;
        border-bottom: 2px solid var(--nf-red);
        display: flex;
        align-items: center;
        gap: 9px;
        font-size: .72rem;
        font-weight: 700;
        color: var(--nf-white);
        text-transform: uppercase;
        letter-spacing: .8px;
    }

        .nf-card-hd i {
            color: var(--nf-red);
            font-size: 1.05rem;
        }

    .nf-card-bd {
        padding: 22px 24px;
    }

    .nf-grid {
        display: grid;
        grid-template-columns: repeat(2,1fr);
        gap: 18px;
    }

    .nf-gcol2 {
        grid-column: 1/-1;
    }

    .nf-fgroup {
    }

    .nf-label {
        display: block;
        font-size: .72rem;
        font-weight: 700;
        color: var(--nf-lgray);
        margin-bottom: 6px;
        text-transform: uppercase;
        letter-spacing: .7px;
    }

        .nf-label .req {
            color: var(--nf-red);
            margin-left: 2px;
        }

    .nf-ctrl {
        display: block;
        width: 100%;
        padding: 10px 13px;
        font-size: .95rem;
        color: var(--nf-white);
        background: var(--nf-input);
        border: 1px solid var(--nf-border);
        border-radius: 5px;
        outline: none;
        font-family: inherit;
        transition: border-color .2s, box-shadow .2s;
    }

        .nf-ctrl:focus {
            border-color: var(--nf-red);
            box-shadow: 0 0 0 2px rgba(229,9,20,.18);
            background: #2f2f2f;
        }

        .nf-ctrl::placeholder {
            color: var(--nf-gray);
        }

    textarea.nf-ctrl {
        min-height: 100px;
        resize: vertical;
    }

    select.nf-ctrl[multiple] {
        display: none; /* Ẩn đi để dùng custom picker */
    }

    .nf-hint {
        font-size: .75rem;
        color: var(--nf-gray);
        margin-top: 4px;
        display: block;
    }

    .nf-err {
        color: #ff4d4f;
        font-size: .78rem;
        margin-top: 3px;
        display: block;
    }

    /* Poster URL preview */
    .nf-url-group {
        display: flex;
        gap: 8px;
    }

        .nf-url-group .nf-ctrl {
            flex: 1;
        }

    .nf-url-preview-btn {
        flex-shrink: 0;
        padding: 0 14px;
        height: 42px;
        background: var(--nf-darker);
        border: 1px solid var(--nf-border);
        border-radius: 5px;
        color: var(--nf-lgray);
        font-size: .82rem;
        font-weight: 600;
        cursor: pointer;
        white-space: nowrap;
        transition: all .2s;
        font-family: inherit;
    }

        .nf-url-preview-btn:hover {
            border-color: var(--nf-red);
            color: var(--nf-red);
        }

    .nf-img-preview-wrap {
        margin-top: 10px;
        border-radius: 6px;
        overflow: hidden;
        background: var(--nf-darker);
        border: 1px solid var(--nf-border);
        display: none;
        position: relative;
    }

        .nf-img-preview-wrap img {
            display: block;
            width: 100%;
            max-height: 220px;
            object-fit: contain;
        }

    .nf-preview-clear {
        position: absolute;
        top: 8px;
        right: 8px;
        width: 28px;
        height: 28px;
        border-radius: 50%;
        background: rgba(0,0,0,.65);
        border: none;
        color: #fff;
        display: flex;
        align-items: center;
        justify-content: center;
        cursor: pointer;
        font-size: .9rem;
        transition: background .2s;
    }

        .nf-preview-clear:hover {
            background: var(--nf-red);
        }

    .nf-embed-preview {
        margin-top: 10px;
        border-radius: 6px;
        overflow: hidden;
        display: none;
        position: relative;
        padding-bottom: 56.25%;
        height: 0;
    }

        .nf-embed-preview iframe {
            position: absolute;
            top: 0;
            left: 0;
            width: 100%;
            height: 100%;
            border: none;
            border-radius: 6px;
        }

    /* Upload file input */
    .nf-file-input-wrap {
        margin-top: 10px;
        padding: 10px 13px;
        background: var(--nf-input);
        border: 1px dashed var(--nf-border);
        border-radius: 5px;
        color: var(--nf-lgray);
        font-size: .88rem;
        cursor: pointer;
        transition: border-color .2s;
    }

        .nf-file-input-wrap:hover {
            border-color: var(--nf-red);
        }

        .nf-file-input-wrap input[type=file] {
            display: block;
            width: 100%;
            color: var(--nf-lgray);
            background: transparent;
            border: none;
            outline: none;
            font-family: inherit;
            font-size: .88rem;
            cursor: pointer;
        }

            .nf-file-input-wrap input[type=file]::file-selector-button {
                background: var(--nf-red);
                color: #fff;
                border: none;
                padding: 6px 14px;
                border-radius: 4px;
                font-size: .82rem;
                font-weight: 600;
                cursor: pointer;
                margin-right: 10px;
                transition: background .2s;
            }

                .nf-file-input-wrap input[type=file]::file-selector-button:hover {
                    background: var(--nf-red2);
                }

    .nf-upload-or-divider {
        display: flex;
        align-items: center;
        gap: 10px;
        margin: 10px 0;
        color: var(--nf-gray);
        font-size: .78rem;
        text-transform: uppercase;
        letter-spacing: .5px;
    }

        .nf-upload-or-divider::before, .nf-upload-or-divider::after {
            content: '';
            flex: 1;
            height: 1px;
            background: var(--nf-border);
        }

    /* Tag Picker (Thêm từ bên Create qua) */
    .nf-tag-search-box {
        display: flex;
        gap: 6px;
        align-items: center;
        margin-bottom: 8px;
    }

        .nf-tag-search-box input {
            flex: 1;
            padding: 8px 12px;
            background: var(--nf-input);
            border: 1px solid var(--nf-border);
            border-radius: 5px;
            color: var(--nf-white);
            font-size: .88rem;
            outline: none;
            font-family: inherit;
        }

            .nf-tag-search-box input:focus {
                border-color: var(--nf-red);
            }

            .nf-tag-search-box input::placeholder {
                color: var(--nf-gray);
            }

    .nf-tag-dropdown {
        max-height: 170px;
        overflow-y: auto;
        background: var(--nf-input);
        border: 1px solid var(--nf-border);
        border-radius: 5px;
        margin-bottom: 8px;
    }

        .nf-tag-dropdown::-webkit-scrollbar {
            width: 5px;
        }

        .nf-tag-dropdown::-webkit-scrollbar-track {
            background: var(--nf-darker);
        }

        .nf-tag-dropdown::-webkit-scrollbar-thumb {
            background: var(--nf-border);
            border-radius: 3px;
        }

    .nf-tag-option {
        padding: 8px 12px;
        font-size: .88rem;
        color: var(--nf-lgray);
        cursor: pointer;
        transition: background .15s;
        user-select: none;
        display: flex;
        align-items: center;
        gap: 8px;
    }

        .nf-tag-option:hover {
            background: rgba(229,9,20,.1);
            color: var(--nf-white);
        }

        .nf-tag-option.selected {
            color: var(--nf-red);
        }

            .nf-tag-option.selected::before {
                content: '✓ ';
                font-weight: 700;
            }

    .nf-tag-chips {
        display: flex;
        flex-wrap: wrap;
        gap: 6px;
        min-height: 32px;
        padding: 6px 8px;
        background: var(--nf-darker);
        border: 1px solid var(--nf-border);
        border-radius: 5px;
    }

    .nf-tag-chip {
        display: inline-flex;
        align-items: center;
        gap: 5px;
        background: rgba(229,9,20,.15);
        border: 1px solid rgba(229,9,20,.4);
        color: var(--nf-white);
        padding: 3px 10px;
        border-radius: 20px;
        font-size: .78rem;
        font-weight: 600;
    }

        .nf-tag-chip button {
            background: none;
            border: none;
            color: var(--nf-lgray);
            padding: 0;
            cursor: pointer;
            font-size: .85rem;
            line-height: 1;
            transition: color .15s;
        }

            .nf-tag-chip button:hover {
                color: var(--nf-red);
            }

    .nf-tag-empty {
        color: var(--nf-gray);
        font-size: .8rem;
        font-style: italic;
        padding: 2px 4px;
    }

    /* Active toggle */
    .nf-toggle {
        display: flex;
        align-items: center;
        gap: 10px;
        padding: 12px 16px;
        background: var(--nf-input);
        border: 1px solid var(--nf-border);
        border-radius: 5px;
    }

        .nf-toggle input {
            width: 17px;
            height: 17px;
            accent-color: var(--nf-red);
            cursor: pointer;
        }

        .nf-toggle label {
            color: var(--nf-white);
            font-size: .92rem;
            cursor: pointer;
            margin: 0;
        }

    .nf-val-banner {
        background: rgba(229,9,20,.1);
        border: 1px solid rgba(229,9,20,.4);
        border-radius: 6px;
        padding: 12px 16px;
        margin-bottom: 20px;
        color: #ff6b6b;
        font-size: .85rem;
    }

        .nf-val-banner ul {
            margin: 6px 0 0;
            padding-left: 18px;
        }

    /* Buttons */
    .nf-btn {
        display: inline-flex;
        align-items: center;
        gap: 7px;
        padding: 10px 22px;
        font-size: .92rem;
        font-weight: 600;
        border-radius: 5px;
        border: none;
        cursor: pointer;
        transition: all .2s;
        text-decoration: none;
        font-family: inherit;
        line-height: 1.4;
    }

    .nf-btn-red {
        background: var(--nf-red);
        color: #fff;
    }

        .nf-btn-red:hover {
            background: var(--nf-red2);
            color: #fff;
            transform: translateY(-1px);
            box-shadow: 0 4px 12px rgba(229,9,20,.35);
        }

        .nf-btn-red:disabled {
            opacity: .55;
            cursor: not-allowed;
            transform: none;
            box-shadow: none;
        }

    .nf-btn-ghost {
        background: transparent;
        color: var(--nf-lgray);
        border: 1px solid var(--nf-border);
    }

        .nf-btn-ghost:hover {
            background: var(--nf-border);
            color: var(--nf-white);
        }

    .nf-form-actions {
        display: flex;
        gap: 12px;
        padding-top: 22px;
        border-top: 1px solid var(--nf-border);
        flex-wrap: wrap;
    }

    @@media(max-width:768px) {
        .nf-grid {
            grid-template-columns: 1fr;
        }

        .nf-gcol2 {
            grid-column: 1;
        }

        .nf-card-bd {
            padding: 16px;
        }

        .nf-form-actions {
            flex-direction: column;
        }

        .nf-btn {
            width: 100%;
            justify-content: center;
        }
    }
</style>

<div class="nf-page-header">
    <h1 class="nf-page-title">Edit <span>Movie</span></h1>
    <p class="nf-page-sub">Update the details for this movie</p>
</div>

<form asp-action="Edit" method="post" enctype="multipart/form-data" id="editForm">
    <input type="hidden" asp-for="Id" />

    @if (!ViewData.ModelState.IsValid)
    {
        <div class="nf-val-banner">
            <strong>Please fix the errors below:</strong>
            <ul>
                @foreach (var e in ViewData.ModelState.Values.SelectMany(v => v.Errors))
                {
                    <li>@e.ErrorMessage</li>
                }
            </ul>
        </div>
    }

    <div class="nf-card">
        <div class="nf-card-hd"><i class="zmdi zmdi-info"></i> Basic Information</div>
        <div class="nf-card-bd">
            <div class="nf-grid">
                <div class="nf-gcol2 nf-fgroup">
                    <label class="nf-label">Title <span class="req">*</span></label>
                    <input asp-for="Title" class="nf-ctrl" id="titleInput" placeholder="Movie title" />
                    <span asp-validation-for="Title" class="nf-err"></span>
                </div>
                <div class="nf-gcol2 nf-fgroup">
                    <label class="nf-label">Slug (URL)</label>
                    <input asp-for="Slug" class="nf-ctrl" id="slugInput" placeholder="auto-generated-from-title" />
                    <span class="nf-hint">URL identifier. Changing this might break existing links.</span>
                    <span asp-validation-for="Slug" class="nf-err"></span>
                </div>
                <div class="nf-gcol2 nf-fgroup">
                    <label class="nf-label">Description</label>
                    <textarea asp-for="Description" class="nf-ctrl" rows="4" placeholder="Movie description…"></textarea>
                    <span asp-validation-for="Description" class="nf-err"></span>
                </div>
                <div class="nf-fgroup">
                    <label class="nf-label">Release Year</label>
                    <input asp-for="ReleaseYear" class="nf-ctrl" type="number" placeholder="e.g. 2024" />
                    <span asp-validation-for="ReleaseYear" class="nf-err"></span>
                </div>
                <div class="nf-fgroup">
                    <label class="nf-label">Duration (minutes)</label>
                    <input asp-for="DurationMinutes" class="nf-ctrl" type="number" placeholder="e.g. 120" />
                    <span asp-validation-for="DurationMinutes" class="nf-err"></span>
                </div>
            </div>
        </div>
    </div>

    <div class="nf-card">
        <div class="nf-card-hd"><i class="zmdi zmdi-image"></i> Media</div>
        <div class="nf-card-bd">
            <div class="nf-grid">
                <div class="nf-gcol2 nf-fgroup">
                    <label class="nf-label">Poster Image</label>
                    <div class="nf-file-input-wrap" id="editPosterFileWrap">
                        <input type="file" name="posterFile" id="editPosterFileInput" accept=".jpg,.jpeg,.png,.webp" onchange="onEditPosterFileChange(this)" />
                        <span class="nf-hint">Choose new file to change poster (JPG, PNG, WEBP). Max 5MB.</span>
                    </div>
                    <div class="nf-upload-or-divider">or paste URL</div>
                    <div class="nf-url-group">
                        <input asp-for="PosterUrl" class="nf-ctrl" id="editPosterUrl" placeholder="https://example.com/poster.jpg" />
                        <button type="button" class="nf-url-preview-btn" onclick="editPreviewPoster()">Preview</button>
                        <button type="button" class="nf-url-preview-btn" onclick="editClearPoster()" style="color:var(--nf-gray);">Clear</button>
                    </div>
                    <span class="nf-hint">Paste a direct image link. Click Preview to verify.</span>
                    <span asp-validation-for="PosterUrl" class="nf-err"></span>

                    <div class="nf-img-preview-wrap" id="editPosterPreview">
                        <img src="" alt="Poster preview" id="editPosterPreviewImg" />
                        <button type="button" class="nf-preview-clear" onclick="editClearPoster()"><i class="zmdi zmdi-close"></i></button>
                    </div>
                </div>

                <div class="nf-gcol2 nf-fgroup">
                    <label class="nf-label">Trailer URL</label>
                    <div class="nf-url-group">
                        <input asp-for="TrailerUrl" class="nf-ctrl" id="editTrailerUrl" placeholder="https://youtube.com/watch?v=…" />
                        <button type="button" class="nf-url-preview-btn" onclick="editPreviewTrailer()">Preview</button>
                        <button type="button" class="nf-url-preview-btn" onclick="editClearTrailer()" style="color:var(--nf-gray);">Clear</button>
                    </div>
                    <span class="nf-hint">YouTube or Vimeo URL. Click Preview to embed.</span>
                    <span asp-validation-for="TrailerUrl" class="nf-err"></span>
                    <div class="nf-embed-preview" id="editTrailerPreview"></div>
                </div>
            </div>
        </div>
    </div>

    <div class="nf-card">
        <div class="nf-card-hd"><i class="zmdi zmdi-labels"></i> Classification</div>
        <div class="nf-card-bd">
            <div class="nf-grid">
                <div class="nf-fgroup">
                    <label class="nf-label">Movie Type <span class="req">*</span></label>
                    <select asp-for="Type" class="nf-ctrl" asp-items="Html.GetEnumSelectList<FinalCuongFilm.ApplicationCore.Entities.Enum.MovieType>()"></select>
                    <span asp-validation-for="Type" class="nf-err"></span>
                </div>
                <div class="nf-fgroup">
                    <label class="nf-label">Status <span class="req">*</span></label>
                    <select asp-for="Status" class="nf-ctrl" asp-items="Html.GetEnumSelectList<FinalCuongFilm.ApplicationCore.Entities.Enum.MovieStatus>()"></select>
                    <span asp-validation-for="Status" class="nf-err"></span>
                </div>
                <div class="nf-fgroup">
                    <label class="nf-label">Country <span class="req">*</span></label>
                    <select asp-for="CountryId" class="nf-ctrl" asp-items="ViewBag.Countries"></select>
                    <span asp-validation-for="CountryId" class="nf-err"></span>
                </div>
                <div class="nf-fgroup">
                    <label class="nf-label">Language <span class="req">*</span></label>
                    <select asp-for="LanguageId" class="nf-ctrl" asp-items="ViewBag.Languages"></select>
                    <span asp-validation-for="LanguageId" class="nf-err"></span>
                </div>
            </div>
        </div>
    </div>

    <div class="nf-card">
        <div class="nf-card-hd"><i class="zmdi zmdi-accounts"></i> Cast &amp; Genres</div>
        <div class="nf-card-bd">
            <div class="nf-grid">
                <div class="nf-fgroup">
                    <label class="nf-label">Actors</label>
                    <select asp-for="ActorIds" asp-items="ViewBag.Actors" multiple id="actorSelect" class="nf-ctrl" style="display:none"></select>
                    <div class="nf-tag-picker" id="actorPicker">
                        <div class="nf-tag-search-box">
                            <input type="text" id="actorSearch" placeholder="Search actors…" autocomplete="off" />
                        </div>
                        <div class="nf-tag-dropdown" id="actorDropdown"></div>
                        <div class="nf-tag-chips" id="actorChips">
                            <span class="nf-tag-empty">No actors selected</span>
                        </div>
                    </div>
                    <span asp-validation-for="ActorIds" class="nf-err"></span>
                </div>
                <div class="nf-fgroup">
                    <label class="nf-label">Genres</label>
                    <select asp-for="GenreIds" asp-items="ViewBag.Genres" multiple id="genreSelect" class="nf-ctrl" style="display:none"></select>
                    <div class="nf-tag-picker" id="genrePicker">
                        <div class="nf-tag-search-box">
                            <input type="text" id="genreSearch" placeholder="Search genres…" autocomplete="off" />
                        </div>
                        <div class="nf-tag-dropdown" id="genreDropdown"></div>
                        <div class="nf-tag-chips" id="genreChips">
                            <span class="nf-tag-empty">No genres selected</span>
                        </div>
                    </div>
                    <span asp-validation-for="GenreIds" class="nf-err"></span>
                </div>
            </div>
        </div>
    </div>

    <div class="nf-card">
        <div class="nf-card-hd"><i class="zmdi zmdi-eye"></i> Publish Settings</div>
        <div class="nf-card-bd">
            <div class="nf-toggle">
                <input asp-for="IsActive" type="checkbox" id="editActiveChk" />
                <label for="editActiveChk">Active — movie is visible to users</label>
            </div>
        </div>
    </div>

    <div class="nf-form-actions">
        <button type="submit" class="nf-btn nf-btn-red" id="submitBtn"><i class="zmdi zmdi-check"></i> Save Changes</button>
        <a asp-action="Index" class="nf-btn nf-btn-ghost"><i class="zmdi zmdi-arrow-left"></i> Cancel</a>
    </div>
</form>

@section Scripts {
    @{
        await Html.RenderPartialAsync("_ValidationScriptsPartial");
    }
    <script>
        document.addEventListener('DOMContentLoaded', function () {

            /* Slug Logic (Khóa sẵn để tránh vô tình đổi khi sửa tên) */
            const titleEl = document.getElementById('titleInput');
            const slugEl  = document.getElementById('slugInput');
            // Nếu slug đã có data thì locked = true, không tự nhảy theo title nữa
            let slugLocked = slugEl.value.trim().length > 0;
            const toSlug = t => t.toLowerCase().replace(/[^\w\s-]/g,'').replace(/\s+/g,'-').replace(/-+/g,'-').trim();
            titleEl.addEventListener('input', () => { if (!slugLocked) slugEl.value = toSlug(titleEl.value); });
            slugEl.addEventListener('input',  () => { slugLocked = slugEl.value.length > 0; });

            /* Tag Picker Factory (Hỗ trợ nạp sẵn dữ liệu) */
            function buildTagPicker(selectId, searchId, dropdownId, chipsId) {
                const sel      = document.getElementById(selectId);
                const search   = document.getElementById(searchId);
                const dropdown = document.getElementById(dropdownId);
                const chips    = document.getElementById(chipsId);

                const allOptions = Array.from(sel.options).map(o => ({ value: o.value, label: o.text }));

                // ĐIỂM KHÁC BIỆT CỦA EDIT: Lấy các giá trị đã được chọn (selected) từ Database
                let selected = Array.from(sel.selectedOptions).map(o => o.value);

                function renderDropdown(filter = '') {
                    dropdown.innerHTML = '';
                    allOptions.forEach(opt => {
                        if (filter && !opt.label.toLowerCase().includes(filter.toLowerCase())) return;
                        const div = document.createElement('div');
                        div.className = 'nf-tag-option' + (selected.includes(opt.value) ? ' selected' : '');
                        div.textContent = opt.label;
                        div.dataset.value = opt.value;
                        div.addEventListener('click', () => toggleItem(opt));
                        dropdown.appendChild(div);
                    });
                    if (!dropdown.children.length) {
                        dropdown.innerHTML = '<div style="padding:8px 12px;color:var(--nf-gray);font-size:.82rem;">No results</div>';
                    }
                }

                function renderChips() {
                    chips.innerHTML = '';
                    if (!selected.length) { chips.innerHTML = '<span class="nf-tag-empty">None selected</span>'; return; }
                    selected.forEach(val => {
                        const opt = allOptions.find(o => o.value === val);
                        if (!opt) return;
                        const chip = document.createElement('span');
                        chip.className = 'nf-tag-chip';
                        chip.innerHTML = `${opt.label}<button type="button" title="Remove">×</button>`;
                        chip.querySelector('button').addEventListener('click', () => toggleItem(opt));
                        chips.appendChild(chip);
                    });
                }

                function syncSelect() {
                    Array.from(sel.options).forEach(o => { o.selected = selected.includes(o.value); });
                }

                function toggleItem(opt) {
                    const idx = selected.indexOf(opt.value);
                    if (idx === -1) selected.push(opt.value); else selected.splice(idx, 1);
                    syncSelect();
                    renderDropdown(search.value);
                    renderChips();
                }

                search.addEventListener('input', () => renderDropdown(search.value));
                renderDropdown();
                renderChips();
            }

            buildTagPicker('actorSelect', 'actorSearch', 'actorDropdown', 'actorChips');
            buildTagPicker('genreSelect', 'genreSearch', 'genreDropdown', 'genreChips');

            /* Submit feedback */
            document.getElementById('editForm').addEventListener('submit', () => {
                const btn = document.getElementById('submitBtn');
                btn.innerHTML = '<i class="zmdi zmdi-hourglass-alt"></i> Saving…';
                btn.disabled = true;
            });

            /* Show existing poster and trailer on page load */
            const posterUrl = document.getElementById('editPosterUrl').value.trim();
            if (posterUrl) {
                const wrap = document.getElementById('editPosterPreview');
                const img  = document.getElementById('editPosterPreviewImg');
                img.onload = () => wrap.style.display = 'block';
                img.src = posterUrl;
            }

            const trailerUrl = document.getElementById('editTrailerUrl').value.trim();
            if (trailerUrl) {
                editPreviewTrailer();
            }
        });

        /* Poster File Upload Preview (Edit) */
        function onEditPosterFileChange(input) {
            const wrap     = document.getElementById('editPosterPreview');
            const img      = document.getElementById('editPosterPreviewImg');
            const urlInput = document.getElementById('editPosterUrl');

            if (input.files && input.files[0]) {
                const file = input.files[0];
                if (file.size > 5 * 1024 * 1024) {
                    alert('File too big. Please choose file smaller 5 Mb.');
                    input.value = '';
                    return;
                }
                const reader = new FileReader();
                reader.onload = function(e) {
                    img.src = e.target.result;
                    wrap.style.display = 'block';
                };
                reader.readAsDataURL(file);
                urlInput.value = '';
            }
        }

        /* Shared helpers */
        function getEmbedUrl(url) {
            const yt = url.match(/(?:youtube\.com\/(?:[^\/]+\/.+\/|(?:v|e(?:mbed)?)\/|.*[?&]v=)|youtu\.be\/)([^"&?\/\s]{11})/);
            if (yt) return `https://www.youtube.com/embed/${yt[1]}`;
            const vi = url.match(/vimeo\.com\/([0-9]+)/);
            if (vi) return `https://player.vimeo.com/video/${vi[1]}`;
            return null;
        }

        function editPreviewPoster() {
            const url  = document.getElementById('editPosterUrl').value.trim();
            const wrap = document.getElementById('editPosterPreview');
            const img  = document.getElementById('editPosterPreviewImg');
            if (!url) { alert('Please enter a poster URL first.'); return; }
            img.onload  = () => wrap.style.display = 'block';
            img.onerror = () => { alert('Could not load image. Check the URL.'); wrap.style.display = 'none'; };
            img.src = url;
            document.getElementById('editPosterFileInput').value = '';
        }

        function editClearPoster() {
            document.getElementById('editPosterUrl').value = '';
            document.getElementById('editPosterFileInput').value = '';
            document.getElementById('editPosterPreview').style.display = 'none';
            document.getElementById('editPosterPreviewImg').src = '';
        }

        function editPreviewTrailer() {
            const url  = document.getElementById('editTrailerUrl').value.trim();
            const wrap = document.getElementById('editTrailerPreview');
            if (!url) { alert('Please enter a trailer URL first.'); return; }
            const embed = getEmbedUrl(url);
            if (!embed) { alert('Unsupported URL. Use YouTube or Vimeo.'); return; }
            wrap.innerHTML = `<iframe src="${embed}" frameborder="0" allowfullscreen></iframe>`;
            wrap.style.display = 'block';
        }

        function editClearTrailer() {
            document.getElementById('editTrailerUrl').value = '';
            const wrap = document.getElementById('editTrailerPreview');
            wrap.style.display = 'none'; wrap.innerHTML = '';
        }
    </script>
}