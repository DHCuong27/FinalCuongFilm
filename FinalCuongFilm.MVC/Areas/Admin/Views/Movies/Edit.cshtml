@model FinalCuongFilm.Common.DTOs.MovieUpdateDto
@{
    ViewData["Title"] = "Edit Movie";
}

<style>
    :root {
        --nf-red: #e50914;
        --nf-red2: #f40612;
        --nf-bg: #141414;
        --nf-dark: #181818;
        --nf-darker: #0f0f0f;
        --nf-card: #1f1f1f;
        --nf-input: #2a2a2a;
        --nf-border: #333;
        --nf-gray: #808080;
        --nf-lgray: #b3b3b3;
        --nf-white: #fff;
        --nf-green: #2ecc71;
        --nf-blue: #3498db;
        --nf-yellow: #f39c12;
    }

    .nf-page-header {
        margin-bottom: 24px;
        padding-bottom: 16px;
        border-bottom: 2px solid var(--nf-border);
    }

    .nf-page-title {
        font-size: 1.75rem;
        font-weight: 700;
        color: var(--nf-white);
        margin: 0 0 4px;
    }

        .nf-page-title span {
            color: var(--nf-red);
        }

    .nf-page-sub {
        color: var(--nf-lgray);
        font-size: .9rem;
    }

    .nf-card {
        background: var(--nf-card);
        border: 1px solid var(--nf-border);
        border-radius: 8px;
        overflow: hidden;
        margin-bottom: 18px;
        box-shadow: 0 4px 20px rgba(0,0,0,.35);
    }

    .nf-card-hd {
        background: var(--nf-darker);
        padding: 12px 20px;
        border-bottom: 2px solid var(--nf-red);
        display: flex;
        align-items: center;
        gap: 9px;
        font-size: .72rem;
        font-weight: 700;
        color: var(--nf-white);
        text-transform: uppercase;
        letter-spacing: .8px;
    }

        .nf-card-hd i {
            color: var(--nf-red);
            font-size: 1.05rem;
        }

    .nf-card-bd {
        padding: 22px 24px;
    }

    .nf-grid {
        display: grid;
        grid-template-columns: repeat(2,1fr);
        gap: 18px;
    }

    .nf-gcol2 {
        grid-column: 1/-1;
    }

    .nf-label {
        display: block;
        font-size: .72rem;
        font-weight: 700;
        color: var(--nf-lgray);
        margin-bottom: 6px;
        text-transform: uppercase;
        letter-spacing: .7px;
    }

        .nf-label .req {
            color: var(--nf-red);
            margin-left: 2px;
        }

    .nf-ctrl {
        display: block;
        width: 100%;
        padding: 10px 13px;
        font-size: .95rem;
        color: var(--nf-white);
        background: var(--nf-input);
        border: 1px solid var(--nf-border);
        border-radius: 5px;
        outline: none;
        font-family: inherit;
        transition: border-color .2s, box-shadow .2s;
    }

        .nf-ctrl:focus {
            border-color: var(--nf-red);
            box-shadow: 0 0 0 2px rgba(229,9,20,.18);
            background: #2f2f2f;
        }

        .nf-ctrl::placeholder {
            color: var(--nf-gray);
        }

    textarea.nf-ctrl {
        min-height: 100px;
        resize: vertical;
    }

    select.nf-ctrl[multiple] {
        min-height: 130px;
    }

    .nf-hint {
        font-size: .75rem;
        color: var(--nf-gray);
        margin-top: 4px;
        display: block;
    }

    .nf-err {
        color: #ff4d4f;
        font-size: .78rem;
        margin-top: 3px;
        display: block;
    }
    /* Poster URL preview */
    .nf-url-group {
        display: flex;
        gap: 8px;
    }

        .nf-url-group .nf-ctrl {
            flex: 1;
        }

    .nf-url-preview-btn {
        flex-shrink: 0;
        padding: 0 14px;
        height: 42px;
        background: var(--nf-darker);
        border: 1px solid var(--nf-border);
        border-radius: 5px;
        color: var(--nf-lgray);
        font-size: .82rem;
        font-weight: 600;
        cursor: pointer;
        white-space: nowrap;
        transition: all .2s;
        font-family: inherit;
    }

        .nf-url-preview-btn:hover {
            border-color: var(--nf-red);
            color: var(--nf-red);
        }

    .nf-img-preview-wrap {
        margin-top: 10px;
        border-radius: 6px;
        overflow: hidden;
        background: var(--nf-darker);
        border: 1px solid var(--nf-border);
        display: none;
        position: relative;
    }

        .nf-img-preview-wrap img {
            display: block;
            width: 100%;
            max-height: 220px;
            object-fit: contain;
        }

    .nf-preview-clear {
        position: absolute;
        top: 8px;
        right: 8px;
        width: 28px;
        height: 28px;
        border-radius: 50%;
        background: rgba(0,0,0,.65);
        border: none;
        color: #fff;
        display: flex;
        align-items: center;
        justify-content: center;
        cursor: pointer;
        font-size: .9rem;
        transition: background .2s;
    }

        .nf-preview-clear:hover {
            background: var(--nf-red);
        }

    .nf-embed-preview {
        margin-top: 10px;
        border-radius: 6px;
        overflow: hidden;
        display: none;
        position: relative;
        padding-bottom: 56.25%;
        height: 0;
    }

        .nf-embed-preview iframe {
            position: absolute;
            top: 0;
            left: 0;
            width: 100%;
            height: 100%;
            border: none;
            border-radius: 6px;
        }

    /* ── Upload file input ── */
    .nf-file-input-wrap {
        margin-top: 10px;
        padding: 10px 13px;
        background: var(--nf-input);
        border: 1px dashed var(--nf-border);
        border-radius: 5px;
        color: var(--nf-lgray);
        font-size: .88rem;
        cursor: pointer;
        transition: border-color .2s;
    }

        .nf-file-input-wrap:hover {
            border-color: var(--nf-red);
        }

        .nf-file-input-wrap input[type=file] {
            display: block;
            width: 100%;
            color: var(--nf-lgray);
            background: transparent;
            border: none;
            outline: none;
            font-family: inherit;
            font-size: .88rem;
            cursor: pointer;
        }

            .nf-file-input-wrap input[type=file]::file-selector-button {
                background: var(--nf-red);
                color: #fff;
                border: none;
                padding: 6px 14px;
                border-radius: 4px;
                font-size: .82rem;
                font-weight: 600;
                cursor: pointer;
                margin-right: 10px;
                transition: background .2s;
            }

                .nf-file-input-wrap input[type=file]::file-selector-button:hover {
                    background: var(--nf-red2);
                }

    .nf-upload-or-divider {
        display: flex;
        align-items: center;
        gap: 10px;
        margin: 10px 0;
        color: var(--nf-gray);
        font-size: .78rem;
        text-transform: uppercase;
        letter-spacing: .5px;
    }

        .nf-upload-or-divider::before,
        .nf-upload-or-divider::after {
            content: '';
            flex: 1;
            height: 1px;
            background: var(--nf-border);
        }

    .nf-toggle {
        display: flex;
        align-items: center;
        gap: 10px;
        padding: 12px 16px;
        background: var(--nf-input);
        border: 1px solid var(--nf-border);
        border-radius: 5px;
    }

        .nf-toggle input {
            width: 17px;
            height: 17px;
            accent-color: var(--nf-red);
            cursor: pointer;
        }

        .nf-toggle label {
            color: var(--nf-white);
            font-size: .92rem;
            cursor: pointer;
            margin: 0;
        }

    .nf-val-banner {
        background: rgba(229,9,20,.1);
        border: 1px solid rgba(229,9,20,.4);
        border-radius: 6px;
        padding: 12px 16px;
        margin-bottom: 20px;
        color: #ff6b6b;
        font-size: .85rem;
    }

        .nf-val-banner ul {
            margin: 6px 0 0;
            padding-left: 18px;
        }

    .nf-btn {
        display: inline-flex;
        align-items: center;
        gap: 7px;
        padding: 10px 22px;
        font-size: .92rem;
        font-weight: 600;
        border-radius: 5px;
        border: none;
        cursor: pointer;
        transition: all .2s;
        text-decoration: none;
        font-family: inherit;
        line-height: 1.4;
    }

    .nf-btn-red {
        background: var(--nf-red);
        color: #fff;
    }

        .nf-btn-red:hover {
            background: var(--nf-red2);
            color: #fff;
            transform: translateY(-1px);
            box-shadow: 0 4px 12px rgba(229,9,20,.35);
        }

    .nf-btn-ghost {
        background: transparent;
        color: var(--nf-lgray);
        border: 1px solid var(--nf-border);
    }

        .nf-btn-ghost:hover {
            background: var(--nf-border);
            color: var(--nf-white);
        }

    .nf-form-actions {
        display: flex;
        gap: 12px;
        padding-top: 22px;
        border-top: 1px solid var(--nf-border);
        flex-wrap: wrap;
    }

    @@media(max-width:768px) {
        .nf-grid {
            grid-template-columns: 1fr;
        }

        .nf-gcol2 {
            grid-column: 1;
        }

        .nf-card-bd {
            padding: 16px;
        }

        .nf-form-actions {
            flex-direction: column;
        }

        .nf-btn {
            width: 100%;
            justify-content: center;
        }
    }
</style>

<div class="nf-page-header">
    <h1 class="nf-page-title">Edit <span>Movie</span></h1>
    <p class="nf-page-sub">Update the details for this movie</p>
</div>

{{!-- ✅ FIX: thêm enctype="multipart/form-data" để hỗ trợ upload file poster --}}
<form asp-action="Edit" method="post" enctype="multipart/form-data" id="editForm">
    <input type="hidden" asp-for="Id" />

    @if (!ViewData.ModelState.IsValid)
    {
        <div class="nf-val-banner">
            <strong>Please fix the errors below:</strong>
            <ul>
                @foreach (var e in ViewData.ModelState.Values.SelectMany(v => v.Errors))
                {
                    <li>@e.ErrorMessage</li>
                }
            </ul>
        </div>
    }

    <!-- §1 Basic Info -->
    <div class="nf-card">
        <div class="nf-card-hd"><i class="zmdi zmdi-info"></i> Basic Information</div>
        <div class="nf-card-bd">
            <div class="nf-grid">
                <div class="nf-gcol2">
                    <label class="nf-label">Title <span class="req">*</span></label>
                    <input asp-for="Title" class="nf-ctrl" placeholder="Movie title" />
                    <span asp-validation-for="Title" class="nf-err"></span>
                </div>
                <div class="nf-gcol2">
                    <label class="nf-label">Description</label>
                    <textarea asp-for="Description" class="nf-ctrl" rows="4" placeholder="Movie description…"></textarea>
                    <span asp-validation-for="Description" class="nf-err"></span>
                </div>
                <div>
                    <label class="nf-label">Release Year</label>
                    <input asp-for="ReleaseYear" class="nf-ctrl" type="number" placeholder="e.g. 2024" />
                    <span asp-validation-for="ReleaseYear" class="nf-err"></span>
                </div>
                <div>
                    <label class="nf-label">Duration (minutes)</label>
                    <input asp-for="DurationMinutes" class="nf-ctrl" type="number" placeholder="e.g. 120" />
                    <span asp-validation-for="DurationMinutes" class="nf-err"></span>
                </div>
            </div>
        </div>
    </div>

    <!-- §2 Media -->
    <div class="nf-card">
        <div class="nf-card-hd"><i class="zmdi zmdi-image"></i> Media</div>
        <div class="nf-card-bd">
            <div class="nf-grid">
                <!-- Poster -->
                <div class="nf-gcol2">
                    <label class="nf-label">Poster Image</label>

                    {{!-- ✅ Upload file poster trực tiếp --}}
                    <div class="nf-file-input-wrap" id="editPosterFileWrap">
                        <input type="file" name="posterFile" id="editPosterFileInput"
                               accept=".jpg,.jpeg,.png,.webp"
                               onchange="onEditPosterFileChange(this)" />
                        <span class="nf-hint">Chọn file ảnh mới để thay poster (JPG, PNG, WEBP). Tối đa 5MB.</span>
                    </div>

                    <div class="nf-upload-or-divider">hoặc dán URL</div>

                    <div class="nf-url-group">
                        <input asp-for="PosterUrl" class="nf-ctrl" id="editPosterUrl" placeholder="https://example.com/poster.jpg" />
                        <button type="button" class="nf-url-preview-btn" onclick="editPreviewPoster()">Preview</button>
                        <button type="button" class="nf-url-preview-btn" onclick="editClearPoster()" style="color:var(--nf-gray);">Clear</button>
                    </div>
                    <span class="nf-hint">Paste a direct image link. Click Preview to verify.</span>
                    <span asp-validation-for="PosterUrl" class="nf-err"></span>
                    <div class="nf-img-preview-wrap" id="editPosterPreview">
                        <img src="" alt="Poster preview" id="editPosterPreviewImg" />
                        <button type="button" class="nf-preview-clear" onclick="editClearPoster()"><i class="zmdi zmdi-close"></i></button>
                    </div>
                </div>
                <!-- Trailer URL -->
                <div class="nf-gcol2">
                    <label class="nf-label">Trailer URL</label>
                    <div class="nf-url-group">
                        <input asp-for="TrailerUrl" class="nf-ctrl" id="editTrailerUrl" placeholder="https://youtube.com/watch?v=…" />
                        <button type="button" class="nf-url-preview-btn" onclick="editPreviewTrailer()">Preview</button>
                        <button type="button" class="nf-url-preview-btn" onclick="editClearTrailer()" style="color:var(--nf-gray);">Clear</button>
                    </div>
                    <span class="nf-hint">YouTube or Vimeo URL. Click Preview to embed.</span>
                    <span asp-validation-for="TrailerUrl" class="nf-err"></span>
                    <div class="nf-embed-preview" id="editTrailerPreview"></div>
                </div>
            </div>
        </div>
    </div>

    <!-- §3 Classification -->
    <div class="nf-card">
        <div class="nf-card-hd"><i class="zmdi zmdi-labels"></i> Classification</div>
        <div class="nf-card-bd">
            <div class="nf-grid">
                <div>
                    <label class="nf-label">Movie Type</label>
                    <select asp-for="Type" class="nf-ctrl"
                            asp-items="Html.GetEnumSelectList<FinalCuongFilm.ApplicationCore.Entities.Enum.MovieType>()">
                    </select>
                    <span asp-validation-for="Type" class="nf-err"></span>
                </div>
                <div>
                    <label class="nf-label">Status</label>
                    <select asp-for="Status" class="nf-ctrl"
                            asp-items="Html.GetEnumSelectList<FinalCuongFilm.ApplicationCore.Entities.Enum.MovieStatus>()">
                    </select>
                    <span asp-validation-for="Status" class="nf-err"></span>
                </div>
                <div>
                    <label class="nf-label">Country</label>
                    <select asp-for="CountryId" class="nf-ctrl" asp-items="ViewBag.Countries"></select>
                    <span asp-validation-for="CountryId" class="nf-err"></span>
                </div>
                <div>
                    <label class="nf-label">Language</label>
                    <select asp-for="LanguageId" class="nf-ctrl" asp-items="ViewBag.Languages"></select>
                    <span asp-validation-for="LanguageId" class="nf-err"></span>
                </div>
            </div>
        </div>
    </div>

    <!-- §4 Cast & Genres -->
    <div class="nf-card">
        <div class="nf-card-hd"><i class="zmdi zmdi-accounts"></i> Cast &amp; Genres</div>
        <div class="nf-card-bd">
            <div class="nf-grid">
                <div>
                    <label class="nf-label">Actors</label>
                    <select asp-for="ActorIds" class="nf-ctrl" asp-items="ViewBag.Actors" multiple></select>
                    <span class="nf-hint">Hold Ctrl (Cmd on Mac) to select multiple</span>
                    <span asp-validation-for="ActorIds" class="nf-err"></span>
                </div>
                <div>
                    <label class="nf-label">Genres</label>
                    <select asp-for="GenreIds" class="nf-ctrl" asp-items="ViewBag.Genres" multiple></select>
                    <span class="nf-hint">Hold Ctrl (Cmd on Mac) to select multiple</span>
                    <span asp-validation-for="GenreIds" class="nf-err"></span>
                </div>
            </div>
        </div>
    </div>

    <!-- §5 Publish -->
    <div class="nf-card">
        <div class="nf-card-hd"><i class="zmdi zmdi-eye"></i> Publish Settings</div>
        <div class="nf-card-bd">
            <div class="nf-toggle">
                <input asp-for="IsActive" type="checkbox" id="editActiveChk" />
                <label for="editActiveChk">Active — movie is visible to users</label>
            </div>
        </div>
    </div>

    <div class="nf-form-actions">
        <button type="submit" class="nf-btn nf-btn-red"><i class="zmdi zmdi-check"></i> Save Changes</button>
        <a asp-action="Index" class="nf-btn nf-btn-ghost"><i class="zmdi zmdi-arrow-left"></i> Cancel</a>
    </div>
</form>

@section Scripts {
    @{
        await Html.RenderPartialAsync("_ValidationScriptsPartial");
    }
    <script>
        /* ── Poster File Upload Preview (Edit) ── */
        function onEditPosterFileChange(input) {
            const wrap     = document.getElementById('editPosterPreview');
            const img      = document.getElementById('editPosterPreviewImg');
            const urlInput = document.getElementById('editPosterUrl');

            if (input.files && input.files[0]) {
                const file = input.files[0];
                if (file.size > 5 * 1024 * 1024) {
                    alert('File quá lớn. Vui lòng chọn ảnh nhỏ hơn 5MB.');
                    input.value = '';
                    return;
                }
                const reader = new FileReader();
                reader.onload = function(e) {
                    img.src = e.target.result;
                    wrap.style.display = 'block';
                };
                reader.readAsDataURL(file);
                // Khi chọn file mới, xóa URL cũ để tránh conflict
                urlInput.value = '';
            }
        }

        /* Shared helpers */
        function getEmbedUrl(url) {
            const yt = url.match(/(?:youtube\.com\/(?:[^\/]+\/.+\/|(?:v|e(?:mbed)?)\/|.*[?&]v=)|youtu\.be\/)([^"&?\/\s]{11})/);
            if (yt) return `https://www.youtube.com/embed/${yt[1]}`;
            const vi = url.match(/vimeo\.com\/([0-9]+)/);
            if (vi) return `https://player.vimeo.com/video/${vi[1]}`;
            return null;
        }
        function editPreviewPoster() {
            const url  = document.getElementById('editPosterUrl').value.trim();
            const wrap = document.getElementById('editPosterPreview');
            const img  = document.getElementById('editPosterPreviewImg');
            if (!url) { alert('Please enter a poster URL first.'); return; }
            img.onload  = () => wrap.style.display = 'block';
            img.onerror = () => { alert('Could not load image. Check the URL.'); wrap.style.display = 'none'; };
            img.src = url;
            // Khi nhập URL thì xóa file input
            document.getElementById('editPosterFileInput').value = '';
        }
        function editClearPoster() {
            document.getElementById('editPosterUrl').value = '';
            document.getElementById('editPosterFileInput').value = '';
            document.getElementById('editPosterPreview').style.display = 'none';
            document.getElementById('editPosterPreviewImg').src = '';
        }
        function editPreviewTrailer() {
            const url  = document.getElementById('editTrailerUrl').value.trim();
            const wrap = document.getElementById('editTrailerPreview');
            if (!url) { alert('Please enter a trailer URL first.'); return; }
            const embed = getEmbedUrl(url);
            if (!embed) { alert('Unsupported URL. Use YouTube or Vimeo.'); return; }
            wrap.innerHTML = `<iframe src="${embed}" frameborder="0" allowfullscreen></iframe>`;
            wrap.style.display = 'block';
        }
        function editClearTrailer() {
            document.getElementById('editTrailerUrl').value = '';
            const wrap = document.getElementById('editTrailerPreview');
            wrap.style.display = 'none'; wrap.innerHTML = '';
        }
        // Show existing poster on page load
        document.addEventListener('DOMContentLoaded', () => {
            const url = document.getElementById('editPosterUrl').value.trim();
            if (url) {
                const wrap = document.getElementById('editPosterPreview');
                const img  = document.getElementById('editPosterPreviewImg');
                img.onload = () => wrap.style.display = 'block';
                img.src = url;
            }
        });
    </script>
}