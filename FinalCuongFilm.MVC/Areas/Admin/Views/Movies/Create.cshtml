@model FinalCuongFilm.Common.DTOs.MovieCreateDto
@using FinalCuongFilm.ApplicationCore

@{
    ViewData["Title"] = "Thêm Phim Mới";
}

<style>
    :root {
        --primary-blue: #0d6efd;
        --dark-blue: #084298;
        --light-blue: #e7f1ff;
        --bg-main: #f4f6f9;
        --card-bg: #ffffff;
        --input-bg: #ffffff;
        --text-primary: #212529;
        --text-secondary: #6c757d;
        --border-color: #dee2e6;
        --success-color: #198754;
        --shadow-lg: 0 12px 30px rgba(13, 110, 253, 0.12);
        --shadow-md: 0 6px 16px rgba(0, 0, 0, 0.08);
    }

    body {
        background: var(--bg-main);
        color: var(--text-primary);
        font-family: 'Inter', 'Segoe UI', sans-serif;
        min-height: 100vh;
    }

    /* Container */
    .movie-create-container {
        max-width: 1000px;
        margin: auto;
        padding: 32px 20px;
    }

    /* Header */
    .page-title {
        font-size: 34px;
        font-weight: 800;
        color: var(--primary-blue);
    }

    .page-subtitle {
        color: var(--text-secondary);
    }

    /* Card */
    .movie-form-card {
        background: var(--card-bg);
        border-radius: 14px;
        padding: 40px;
        box-shadow: var(--shadow-lg);
        border: 1px solid var(--border-color);
        animation: fadeInUp 0.4s ease-out;
    }

        .movie-form-card::before {
            content: '';
            display: block;
            height: 4px;
            background: linear-gradient(90deg, var(--primary-blue), var(--dark-blue));
            margin: -40px -40px 30px -40px;
            border-radius: 14px 14px 0 0;
        }

    /* Section */
    .section-title {
        font-size: 18px;
        font-weight: 600;
        color: var(--primary-blue);
        border-bottom: 2px solid var(--border-color);
        padding-bottom: 10px;
        margin: 30px 0 20px;
        display: flex;
        align-items: center;
        gap: 8px;
    }

    /* Grid */
    .form-grid {
        display: grid;
        grid-template-columns: repeat(2, 1fr);
        gap: 22px;
    }

    .form-grid-full {
        grid-column: 1 / -1;
    }

    /* Label */
    .form-label {
        font-size: 14px;
        font-weight: 600;
        color: var(--text-primary);
    }

        .form-label .required {
            color: #dc3545;
        }

    /* Input */
    .form-control {
        height: 46px;
        background: var(--input-bg);
        border: 1.5px solid var(--border-color);
        border-radius: 8px;
        padding: 10px 14px;
        font-size: 14px;
        transition: all 0.2s ease;
    }

        .form-control:focus {
            border-color: var(--primary-blue);
            box-shadow: 0 0 0 3px rgba(13, 110, 253, 0.15);
            outline: none;
        }

    textarea.form-control {
        height: 120px;
    }

    .form-text {
        font-size: 12px;
        color: var(--text-secondary);
    }

    /* Validation */
    .text-danger {
        font-size: 12px;
    }

    /* Select Tags */
    .select-tag {
        background: var(--light-blue);
        color: var(--primary-blue);
        padding: 5px 12px;
        border-radius: 20px;
        font-size: 12px;
        font-weight: 500;
    }

    /* Checkbox */
    .checkbox-mark {
        border-radius: 4px;
    }

    .custom-checkbox input:checked ~ .checkbox-mark {
        background: var(--primary-blue);
        border-color: var(--primary-blue);
    }

    /* Buttons */
    .form-actions {
        margin-top: 40px;
        display: flex;
        gap: 16px;
        border-top: 1px solid var(--border-color);
        padding-top: 30px;
    }

    .btn {
        padding: 12px 28px;
        font-size: 14px;
        border-radius: 8px;
        font-weight: 600;
    }

    .btn-primary {
        background: linear-gradient(135deg, var(--primary-blue), var(--dark-blue));
        color: #fff;
    }

        .btn-primary:hover {
            box-shadow: 0 8px 20px rgba(13, 110, 253, 0.3);
            transform: translateY(-1px);
        }

    .btn-secondary {
        background: #ffffff;
        border: 1.5px solid var(--border-color);
        color: var(--text-secondary);
    }

        .btn-secondary:hover {
            background: var(--light-blue);
            color: var(--primary-blue);
        }

    /* Validation summary */
    .validation-summary {
        background: #f8d7da;
        border: 1px solid #f5c2c7;
        border-radius: 8px;
        padding: 16px;
    }
</style>

<div class="movie-create-container">
    <div class="page-header">
        <h1 class="page-title">@ViewData["Title"]</h1>
        <p class="page-subtitle">Nhập thông tin chi tiết về bộ phim mới</p>
    </div>

    <div class="movie-form-card">
        @if (!ViewData.ModelState.IsValid)
        {
            <div class="validation-summary" role="alert">
                <ul>
                    @foreach (var error in ViewData.ModelState.Values.SelectMany(v => v.Errors))
                    {
                        <li>@error.ErrorMessage</li>
                    }
                </ul>
            </div>
        }

        <form asp-action="Create" method="post">
            <div class="section-title">
                <i class="bi bi-film"></i>
                Thông tin cơ bản
            </div>

            <div class="form-grid">
                <div class="form-grid-full">
                    <div class="form-group">
                        <label class="form-label">
                            Tiêu đề <span class="required">*</span>
                        </label>
                        <input asp-for="Title" class="form-control" placeholder="Nhập tên phim..." />
                        <span asp-validation-for="Title" class="text-danger"></span>
                    </div>
                </div>

                <div class="form-grid-full">
                    <div class="form-group">
                        <label class="form-label">Mô tả</label>
                        <textarea asp-for="Description" class="form-control" placeholder="Nhập mô tả phim..."></textarea>
                        <span asp-validation-for="Description" class="text-danger"></span>
                    </div>
                </div>

                <div class="form-group">
                    <label class="form-label">Năm phát hành</label>
                    <input asp-for="ReleaseYear" class="form-control" type="number" min="1900" max="2100" placeholder="2024" />
                    <span asp-validation-for="ReleaseYear" class="text-danger"></span>
                </div>

                <div class="form-group">
                    <label class="form-label">Thời lượng (phút)</label>
                    <input asp-for="DurationMinutes" class="form-control" type="number" min="1" placeholder="120" />
                    <span asp-validation-for="DurationMinutes" class="text-danger"></span>
                </div>
            </div>

            <div class="section-title">
                <i class="bi bi-link"></i>
                Liên kết phương tiện
            </div>

            <div class="form-grid">
                <div class="form-group">
                    <label class="form-label">URL Poster</label>
                    <input asp-for="PosterUrl" class="form-control" placeholder="https://example.com/poster.jpg" />
                    <span asp-validation-for="PosterUrl" class="text-danger"></span>
                    <small class="form-text">Đường dẫn hình ảnh poster phim</small>
                </div>

                <div class="form-group">
                    <label class="form-label">URL Trailer</label>
                    <input asp-for="TrailerUrl" class="form-control" placeholder="https://youtube.com/..." />
                    <span asp-validation-for="TrailerUrl" class="text-danger"></span>
                    <small class="form-text">Đường dẫn video trailer</small>
                </div>
            </div>

            <div class="section-title">
                <i class="bi bi-gear"></i>
                Phân loại
            </div>

            <div class="form-grid">
                <div class="form-group">
                    <label class="form-label">
                        Loại phim <span class="required">*</span>
                    </label>
                     <select asp-for="Type" class="form-control" asp-items="Html.GetEnumSelectList<FinalCuongFilm.ApplicationCore.Entities.Enum.MovieType>()">
                        <option value="">-- Chọn loại phim --</option>
                    </select> 
                    <span asp-validation-for="Type" class="text-danger"></span>
                </div>

                <div class="form-group">
                    <label class="form-label">
                        Trạng thái <span class="required">*</span>
                    </label>
                     <select asp-for="Status" class="form-control" asp-items="Html.GetEnumSelectList<FinalCuongFilm.ApplicationCore.Entities.Enum.MovieStatus>()">
                        <option value="">-- Chọn trạng thái --</option>
                    </select> *
                    <span asp-validation-for="Status" class="text-danger"></span>
                </div>

                <div class="form-group">
                    <label class="form-label">
                        Quốc gia <span class="required">*</span>
                    </label>
                    <div class="custom-select-wrapper">
                        <select asp-for="CountryId" class="form-control" asp-items="ViewBag.Countries">
                            <option value="">-- Chọn quốc gia --</option>
                        </select>
                    </div>
                    <span asp-validation-for="CountryId" class="text-danger"></span>
                </div>

                 <div class="form-group">
                    <label class="form-label">
                        Ngôn ngữ <span class="required">*</span>
                    </label>
                    <div class="custom-select-wrapper">
                        <select asp-for="LanguageId" class="form-control" asp-items="ViewBag.Languages">
                            <option value="">-- Chọn ngôn ngữ --</option>
                        </select>
                    </div>
                    <span asp-validation-for="LanguageId" class="text-danger"></span>
                </div> 
            </div>

            <div class="section-title">
                <i class="bi bi-people"></i>
                Thành phần phim
            </div>

            <div class="form-grid">
                <div class="form-group">
                    <label class="form-label">Diễn viên</label>
                    <select asp-for="ActorIds" class="form-control" asp-items="ViewBag.Actors" multiple>
                    </select>
                    <small class="form-text">Nhấn Ctrl/Cmd + Click để chọn nhiều</small>
                    <div class="select-tags" id="actorTags"></div>
                    <span asp-validation-for="ActorIds" class="text-danger"></span>
                </div>

                <div class="form-group">
                    <label class="form-label">Thể loại</label>
                    <select asp-for="GenreIds" class="form-control" asp-items="ViewBag.Genres" multiple>
                    </select>
                    <small class="form-text">Nhấn Ctrl/Cmd + Click để chọn nhiều</small>
                    <div class="select-tags" id="genreTags"></div>
                    <span asp-validation-for="GenreIds" class="text-danger"></span>
                </div>
            </div>

            <div class="checkbox-group">
                <label class="custom-checkbox">
                    <input asp-for="IsActive" type="checkbox" checked />
                    <span class="checkbox-mark"></span>
                </label>
                <label class="checkbox-label">Kích hoạt ngay</label>
            </div>

            <div class="form-actions">
                <button type="submit" class="btn btn-primary">
                    <i class="bi bi-check-lg"></i>
                    Lưu phim
                </button>
                <a asp-action="Index" class="btn btn-secondary">
                    <i class="bi bi-arrow-left"></i>
                    Quay lại
                </a>
            </div>
        </form>
    </div>
</div>

@section Scripts {
    @{
        await Html.RenderPartialAsync("_ValidationScriptsPartial");
    }
    
    <script>
        document.addEventListener('DOMContentLoaded', function() {
            // Update multi-select tags display
            function updateSelectTags(selectId, tagContainerId) {
                const select = document.getElementById(selectId);
                const tagContainer = document.getElementById(tagContainerId);
                
                if (!select || !tagContainer) return;
                
                function updateTags() {
                    tagContainer.innerHTML = '';
                    const selectedOptions = Array.from(select.selectedOptions);
                    
                    selectedOptions.forEach(option => {
                        const tag = document.createElement('div');
                        tag.className = 'select-tag';
                        tag.innerHTML = `
                            ${option.text}
                            <span class="select-tag-remove" data-value="${option.value}">×</span>
                        `;
                        tagContainer.appendChild(tag);
                    });
                }
                
                // Initial update
                updateTags();
                
                // Update on change
                select.addEventListener('change', updateTags);
                
                // Handle tag removal
                tagContainer.addEventListener('click', function(e) {
                    if (e.target.classList.contains('select-tag-remove')) {
                        const value = e.target.getAttribute('data-value');
                        const option = select.querySelector(`option[value="${value}"]`);
                        if (option) {
                            option.selected = false;
                            updateTags();
                        }
                    }
                });
            }
            
            // Initialize tag displays
            updateSelectTags('ActorIds', 'actorTags');
            updateSelectTags('GenreIds', 'genreTags');
            
            // Add custom styles to selects
            const selects = document.querySelectorAll('select');
            selects.forEach(select => {
                // Add hover effect
                select.addEventListener('mouseenter', function() {
                    this.style.borderColor = 'var(--text-secondary)';
                });
                
                select.addEventListener('mouseleave', function() {
                    if (!this.matches(':focus')) {
                        this.style.borderColor = 'var(--border-color)';
                    }
                });
            });
            
            // Form submission feedback
            const form = document.querySelector('form');
            form.addEventListener('submit', function(e) {
                const submitBtn = this.querySelector('button[type="submit"]');
                if (submitBtn) {
                    submitBtn.innerHTML = '<i class="bi bi-hourglass-split"></i> Đang xử lý...';
                    submitBtn.disabled = true;
                }
            });
        });
    </script>
}