@model FinalCuongFilm.Common.DTOs.PagedResult<FinalCuongFilm.Common.DTOs.MovieDto>

@{
    ViewData["Title"] = "Movie Management";
}

<style>
    :root {
        --nf-red: #e50914;
        --nf-red2: #f40612;
        --nf-bg: #141414;
        --nf-dark: #181818;
        --nf-darker: #0f0f0f;
        --nf-card: #1f1f1f;
        --nf-input: #2a2a2a;
        --nf-border: #333;
        --nf-gray: #808080;
        --nf-lgray: #b3b3b3;
        --nf-white: #fff;
        --nf-green: #2ecc71;
        --nf-blue: #3498db;
        --nf-yellow: #f39c12;
    }

    /* ── Page Header ── */
    .nf-page-header {
        display: flex;
        align-items: center;
        justify-content: space-between;
        margin-bottom: 24px;
        padding-bottom: 16px;
        border-bottom: 2px solid var(--nf-border);
        flex-wrap: wrap;
        gap: 12px;
    }

    .nf-page-title {
        font-size: 1.75rem;
        font-weight: 700;
        color: var(--nf-white);
        margin: 0;
    }

        .nf-page-title span {
            color: var(--nf-red);
        }

    /* ── Buttons ── */
    .nf-btn {
        display: inline-flex;
        align-items: center;
        gap: 7px;
        padding: 9px 20px;
        font-size: .9rem;
        font-weight: 600;
        border-radius: 5px;
        border: none;
        cursor: pointer;
        transition: all .2s;
        text-decoration: none;
        font-family: inherit;
        line-height: 1.4;
    }

    .nf-btn-red {
        background: var(--nf-red);
        color: #fff;
    }

        .nf-btn-red:hover {
            background: var(--nf-red2);
            color: #fff;
            transform: translateY(-1px);
            box-shadow: 0 4px 12px rgba(229,9,20,.35);
        }

    .nf-btn-blue {
        background: var(--nf-blue);
        color: #fff;
    }

    /* Icon Buttons */
    .nf-btn-icon {
        position: relative;
        width: 40px;
        height: 40px;
        border-radius: 50%;
        display: flex;
        align-items: center;
        justify-content: center;
        color: white;
        text-decoration: none;
        transition: all 0.3s ease;
        background: #2a2a2a;
        border: 2px solid #404040;
    }

        .nf-btn-icon:hover {
            transform: translateY(-3px);
        }

        .nf-btn-icon.view:hover {
            background: #3498db;
            border-color: #3498db;
            box-shadow: 0 5px 15px rgba(52, 152, 219, 0.3);
        }

        .nf-btn-icon.edit:hover {
            background: #f5c518;
            border-color: #f5c518;
            box-shadow: 0 5px 15px rgba(245, 197, 24, 0.3);
        }

        .nf-btn-icon.del:hover {
            background: #e50914;
            border-color: #e50914;
            box-shadow: 0 5px 15px rgba(229, 9, 20, 0.3);
        }

    /* ── Container & Table ── */
    .nf-table-container {
        background: linear-gradient(145deg, #1f1f1f 0%, #141414 100%);
        border-radius: 16px;
        padding: 1.5rem;
        box-shadow: 0 25px 50px -12px rgba(0, 0, 0, 0.5);
        border: 1px solid #2a2a2a;
        margin: 1rem 0;
    }

    .nf-table-header {
        display: flex;
        justify-content: space-between;
        align-items: center;
        margin-bottom: 2rem;
        flex-wrap: wrap;
        gap: 1rem;
    }

    .nf-table-title {
        display: flex;
        align-items: center;
        gap: 0.75rem;
        color: white;
        font-weight: 600;
        font-size: 1.2rem;
    }

        .nf-table-title i {
            color: var(--nf-red);
            font-size: 1.5rem;
        }

    .nf-count-badge {
        background: #2a2a2a;
        padding: 0.25rem 0.75rem;
        border-radius: 20px;
        font-size: 0.85rem;
        color: #b3b3b3;
        font-weight: 500;
    }

    .nf-table-responsive {
        overflow-x: auto;
        border-radius: 12px;
        background: #1a1a1a;
    }

    .nf-table {
        width: 100%;
        border-collapse: collapse;
        min-width: 900px;
        color: var(--nf-white);
    }

        .nf-table thead tr {
            background: linear-gradient(145deg, #2a2a2a 0%, #1f1f1f 100%);
            border-bottom: 2px solid var(--nf-red);
        }

        .nf-table thead th {
            padding: 1.2rem 1rem;
            font-weight: 600;
            font-size: 0.9rem;
            text-transform: uppercase;
            letter-spacing: 0.5px;
            white-space: nowrap;
        }

        .nf-table tbody tr {
            border-bottom: 1px solid #2a2a2a;
            transition: all 0.3s ease;
        }

            .nf-table tbody tr:hover {
                background: #2a2a2a;
                transform: scale(1.002);
                box-shadow: 0 5px 15px rgba(0, 0, 0, 0.3);
            }

        .nf-table tbody td {
            padding: 1.2rem 1rem;
            color: #b3b3b3;
            vertical-align: middle;
        }

    /* ── Search Box ── */
    .nf-search-box {
        position: relative;
        display: flex;
        align-items: center;
    }

        .nf-search-box i {
            position: absolute;
            left: 1rem;
            color: #808080;
            font-size: 1.1rem;
        }

        .nf-search-box input {
            background: #2a2a2a;
            border: 2px solid #404040;
            border-radius: 30px;
            padding: 0.75rem 1rem 0.75rem 2.8rem;
            color: white;
            font-size: 0.9rem;
            width: 250px;
            transition: all 0.3s ease;
        }

            .nf-search-box input:focus {
                outline: none;
                border-color: var(--nf-red);
                background: #333;
                width: 300px;
            }

    /* ── Poster ── */
    .nf-poster-wrapper {
        position: relative;
        width: 60px;
        height: 80px;
        border-radius: 8px;
        overflow: hidden;
        cursor: pointer;
        box-shadow: 0 5px 10px rgba(0, 0, 0, 0.3);
        transition: all 0.3s ease;
    }

        .nf-poster-wrapper:hover {
            transform: scale(1.1);
            box-shadow: 0 10px 20px rgba(229, 9, 20, 0.3);
        }

    .nf-poster {
        width: 100%;
        height: 100%;
        object-fit: cover;
    }

    .nf-poster-empty {
        width: 60px;
        height: 80px;
        background: linear-gradient(145deg, #2a2a2a 0%, #1f1f1f 100%);
        border-radius: 8px;
        display: flex;
        align-items: center;
        justify-content: center;
        border: 2px dashed #404040;
        color: #808080;
        font-size: 1.5rem;
    }

    /* ── Text & Badges ── */
    .nf-title-wrapper {
        display: flex;
        flex-direction: column;
        gap: 0.25rem;
    }

    .nf-title {
        color: white;
        font-weight: 600;
        font-size: 1rem;
    }

    .nf-slug {
        color: #808080;
        font-size: 0.85rem;
    }

    .nf-badge {
        display: inline-flex;
        align-items: center;
        gap: 0.25rem;
        padding: 0.4rem 0.8rem;
        border-radius: 30px;
        font-size: 0.8rem;
        font-weight: 600;
        text-transform: uppercase;
        white-space: nowrap;
    }

    .nf-badge-yellow {
        background: rgba(245, 197, 24, 0.15);
        color: #f5c518;
        border: 1px solid rgba(245, 197, 24, 0.3);
    }

    .nf-badge-green {
        background: rgba(46, 204, 113, 0.15);
        color: #2ecc71;
        border: 1px solid rgba(46, 204, 113, 0.3);
    }

    .nf-badge-blue {
        background: rgba(52, 152, 219, 0.15);
        color: #3498db;
        border: 1px solid rgba(52, 152, 219, 0.3);
    }

    .nf-badge-gray {
        background: rgba(128, 128, 128, 0.15);
        color: #808080;
        border: 1px solid rgba(128, 128, 128, 0.3);
    }

    .nf-country, .nf-year {
        display: flex;
        align-items: center;
        gap: 0.5rem;
        color: #b3b3b3;
    }

    .nf-status-group {
        display: flex;
        flex-direction: column;
        gap: 0.5rem;
    }

    .nf-actions {
        display: flex;
        gap: 0.75rem;
        justify-content: center;
    }

    /* ── Pagination ── */
    .nf-table-footer {
        margin-top: 2rem;
        display: flex;
        justify-content: center;
    }

    .nf-pagination {
        display: flex;
        align-items: center;
        gap: 1rem;
        background: #1a1a1a;
        padding: 0.5rem;
        border-radius: 40px;
        border: 1px solid #2a2a2a;
    }

    .nf-pagination-btn {
        width: 40px;
        height: 40px;
        border-radius: 50%;
        border: none;
        background: #2a2a2a;
        color: white;
        text-decoration: none;
        display: flex;
        align-items: center;
        justify-content: center;
        transition: all 0.3s ease;
    }

        .nf-pagination-btn:hover:not(.disabled) {
            background: var(--nf-red);
            transform: scale(1.1);
            color: white;
        }

        .nf-pagination-btn.disabled {
            opacity: 0.3;
            cursor: not-allowed;
            pointer-events: none;
        }

    .nf-pagination-info {
        color: #b3b3b3;
        font-size: 0.9rem;
        font-weight: 500;
    }

    /* ── Empty State ── */
    .nf-empty-state {
        text-align: center;
        padding: 4rem 2rem;
        background: linear-gradient(145deg, #1f1f1f 0%, #141414 100%);
        border-radius: 16px;
        border: 2px dashed #2a2a2a;
        margin-top: 20px;
    }

    .nf-empty-icon {
        width: 80px;
        height: 80px;
        background: #2a2a2a;
        border-radius: 50%;
        display: flex;
        align-items: center;
        justify-content: center;
        margin: 0 auto 1.5rem;
        color: var(--nf-red);
        font-size: 2.5rem;
    }

    .nf-empty-state h3 {
        color: white;
        font-weight: 600;
        margin-bottom: 0.5rem;
    }

    .nf-empty-state p {
        color: #808080;
        margin-bottom: 1.5rem;
    }

    /* ── Auto Import Section ── */
    .nf-import-section {
        background: var(--nf-card);
        border: 1px solid var(--nf-border);
        border-radius: 8px;
        padding: 18px 20px;
        margin-bottom: 24px;
        box-shadow: 0 4px 20px rgba(0,0,0,.4);
    }

    .nf-import-group {
        display: flex;
        gap: 12px;
        align-items: center;
    }

    .nf-import-input {
        flex-grow: 1;
        background: var(--nf-input);
        border: 1px solid var(--nf-border);
        color: var(--nf-white);
        padding: 10px 16px;
        border-radius: 5px;
        font-size: 0.95rem;
    }

        .nf-import-input:focus {
            outline: none;
            border-color: var(--nf-blue);
        }
</style>

<div class="nf-page-header">
    <h2 class="nf-page-title">Movie <span>Management</span></h2>
    <a asp-action="Create" class="nf-btn nf-btn-red">
        <i class="zmdi zmdi-plus"></i> Add New Movie
    </a>
</div>

<div class="nf-import-section">
    <div class="nf-import-group">
        <input type="text" id="movieTitle" class="nf-import-input" placeholder="Auto import movie from TMDB (Ex: Interstellar, Inception...)" />
        <button type="button" id="btnImport" class="nf-btn nf-btn-blue">
            <i class="zmdi zmdi-cloud-download"></i> Auto Import
        </button>
    </div>
    <div id="importStatus" class="mt-3" style="display: none; font-size: 0.9rem;">
        <span id="importSpinner" class="zmdi zmdi-spinner zmdi-hc-spin" style="color:var(--nf-blue); margin-right:5px; display:none;"></span>
        <span id="importMessage" style="color:var(--nf-lgray);">Pulling data...</span>
    </div>
</div>

<form id="antiforgeryForm">
    @Html.AntiForgeryToken()
</form>

@if (Model != null && Model.Items != null && Model.Items.Any())
{
    <div class="nf-table-container">
        <div class="nf-table-header">
            <div class="nf-table-title">
                <i class="zmdi zmdi-format-list-bulleted"></i>
                <span>Content List</span>
                <span class="nf-count-badge">Total: @Model.TotalCount items</span>
            </div>
            <div class="nf-table-filters">
                <div class="nf-search-box">
                    <i class="zmdi zmdi-search"></i>
                    <input type="text" placeholder="Search current page..." id="tableSearch" />
                </div>
            </div>
        </div>

        <div class="nf-table-responsive">
            <table class="nf-table">
                <thead>
                    <tr>
                        <th width="80">Poster</th>
                        <th>Title</th>
                        <th width="100">Type</th>
                        <th width="120">Country</th>
                        <th width="80">Year</th>
                        <th width="140">Status</th>
                        <th width="140" style="text-align:center;">Actions</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var item in Model.Items)
                    {
                        <tr class="nf-table-row">
                            <td>
                                @if (!string.IsNullOrEmpty(item.PosterUrl))
                                {
                                    <div class="nf-poster-wrapper">
                                        <img src="@item.PosterUrl" alt="@item.Title" class="nf-poster" />
                                    </div>
                                }
                                else
                                {
                                    <div class="nf-poster-empty">
                                        <i class="zmdi zmdi-image"></i>
                                    </div>
                                }
                            </td>
                            <td class="td-title">
                                <div class="nf-title-wrapper">
                                    <strong class="nf-title">@item.Title</strong>
                                    <span class="nf-slug">@item.Slug</span>
                                </div>
                            </td>
                            <td>
                                <span class="nf-badge nf-badge-yellow"><i class="zmdi zmdi-label"></i> @item.Type</span>
                            </td>
                            <td>
                                <span class="nf-country"><i class="zmdi zmdi-globe"></i> @item.CountryName</span>
                            </td>
                            <td>
                                <span class="nf-year">@item.ReleaseYear</span>
                            </td>
                            <td>
                                <div class="nf-status-group">
                                    @if (item.IsActive)
                                    {
                                        <span class="nf-badge nf-badge-green"><i class="zmdi zmdi-check-circle"></i> Active</span>
                                    }
                                    else
                                    {
                                        <span class="nf-badge nf-badge-gray"><i class="zmdi zmdi-eye-off"></i> Hidden</span>
                                    }
                                </div>
                            </td>
                            <td>
                                <div class="nf-actions">
                                    <a asp-action="Details" asp-route-id="@item.Id" class="nf-btn-icon view" title="View">
                                        <i class="zmdi zmdi-eye"></i>
                                    </a>
                                    <a asp-action="Edit" asp-route-id="@item.Id" class="nf-btn-icon edit" title="Edit">
                                        <i class="zmdi zmdi-edit"></i>
                                    </a>
                                    <a asp-action="Delete" asp-route-id="@item.Id" class="nf-btn-icon del" title="Delete" onclick="return confirm('Are you sure?')">
                                        <i class="zmdi zmdi-delete"></i>
                                    </a>
                                </div>
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>

        <div class="nf-table-footer">
            <div class="nf-pagination">
                <a href="@Url.Action("Index", new { page = Model.PageIndex - 1 })"
                   class="nf-pagination-btn @(!Model.HasPreviousPage ? "disabled" : "")">
                    <i class="zmdi zmdi-chevron-left"></i>
                </a>

                <span class="nf-pagination-info">Page @Model.PageIndex of @Model.TotalPages</span>

                <a href="@Url.Action("Index", new { page = Model.PageIndex + 1 })"
                   class="nf-pagination-btn @(!Model.HasNextPage ? "disabled" : "")">
                    <i class="zmdi zmdi-chevron-right"></i>
                </a>
            </div>
        </div>
    </div>
}
else
{
    <div class="nf-empty-state">
        <div class="nf-empty-icon">
            <i class="zmdi zmdi-alert-circle-o"></i>
        </div>
        <h3>No Items Found</h3>
        <p>There are no movies to display at the moment.</p>
        <a asp-action="Create" class="nf-btn nf-btn-red">
            <i class="zmdi zmdi-plus"></i> Add New Movie
        </a>
    </div>
}

@section Scripts {
    <script>
        // --- CHỨC NĂNG TÌM KIẾM Ở CLIENT ---
        document.getElementById('tableSearch')?.addEventListener('keyup', function() {
            const searchValue = this.value.toLowerCase();
            const rows = document.querySelectorAll('.nf-table tbody tr');

            rows.forEach(row => {
                const title = row.querySelector('.nf-title')?.textContent.toLowerCase();
                const type = row.querySelector('.nf-badge-yellow')?.textContent.toLowerCase();
                const country = row.querySelector('.nf-country')?.textContent.toLowerCase();

                if (title?.includes(searchValue) || type?.includes(searchValue) || country?.includes(searchValue)) {
                    row.style.display = '';
                } else {
                    row.style.display = 'none';
                }
            });
        });

        // --- CHỨC NĂNG IMPORT TỪ TMDB ---
        document.getElementById('btnImport').addEventListener('click', async function () {
            const titleInput = document.getElementById('movieTitle');
            const title = titleInput.value.trim();
            const btn = document.getElementById('btnImport');
            const statusBox = document.getElementById('importStatus');
            const spinner = document.getElementById('importSpinner');
            const msgSpan = document.getElementById('importMessage');

            if (!title) {
                alert('Please input movie title to Import!');
                titleInput.focus();
                return;
            }

            btn.disabled = true;
            statusBox.style.display = 'block';
            spinner.style.display = 'inline-block';
            msgSpan.style.color = 'var(--nf-lgray)';
            msgSpan.innerText = `Loading movie information "${title}" from TMDB...`;

            const token = document.querySelector('#antiforgeryForm input[name="__RequestVerificationToken"]').value;
            const formData = new FormData();
            formData.append('title', title);

            try {
                const response = await fetch('@Url.Action("ImportFromTmdb", "Movies", new { area = "Admin" })', {
                    method: 'POST',
                    headers: { 'RequestVerificationToken': token },
                    body: formData
                });

                const data = await response.json();

                if (data.success) {
                    spinner.style.display = 'none';
                    msgSpan.style.color = 'var(--nf-green)';
                    msgSpan.innerHTML = `<i class="zmdi zmdi-check-circle"></i> ${data.message} page will refresh...`;
                    titleInput.value = '';
                    setTimeout(() => window.location.reload(), 1500);
                } else {
                    spinner.style.display = 'none';
                    msgSpan.style.color = 'var(--nf-red)';
                    msgSpan.innerHTML = `<i class="zmdi zmdi-close-circle"></i> ${data.message}`;
                }
            } catch (error) {
                spinner.style.display = 'none';
                msgSpan.style.color = 'var(--nf-red)';
                msgSpan.innerHTML = `<i class="zmdi zmdi-alert-triangle"></i> Server connection error. Please try again.`;
            } finally {
                btn.disabled = false;
            }
        });

        document.getElementById('movieTitle').addEventListener('keypress', function (e) {
            if (e.key === 'Enter') {
                e.preventDefault();
                document.getElementById('btnImport').click();
            }
        });
    </script>
}