@model IEnumerable<FinalCuongFilm.Common.DTOs.MovieDto>

@{
    ViewData["Title"] = "Quản lý Phim";
}

<div class="row">
    <div class="col-md-12">
        <div class="overview-wrap">
            <h2 class="title-1">@ViewData["Title"]</h2>
            <a asp-action="Create" class="au-btn au-btn-icon au-btn--blue">
                <i class="zmdi zmdi-plus"></i>Thêm mới
            </a>
        </div>
    </div>
</div>

<div class="row m-t-30">
    <div class="col-md-12">
        <div class="table-responsive table--no-card m-b-40">
            <table class="table table-borderless table-striped table-earning">
                <thead>
                    <tr>
                        <th>Poster</th>
                        <th>Tiêu đề</th>
                        <th>Thể loại</th>
                        <th>Quốc gia</th>
                        <th>Năm</th>
                        <th>Trạng thái</th>
                        <th>Hành động</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var item in Model)
                    {
                        <tr>
                            <td>
                                @if (!string.IsNullOrEmpty(item.PosterUrl))
                                {
                                    <img src="@item.PosterUrl" alt="@item.Title" style="width: 50px; height: 70px; object-fit: cover;" />
                                }
                                else
                                {
                                    <img src="~/images/no-poster.jpg" alt="No poster" style="width: 50px; height: 70px; object-fit: cover;" />
                                }
                            </td>
                            <td>
                                <strong>@item.Title</strong><br />
                                <small class="text-muted">@item.Slug</small>
                            </td>
                            <td>@item.Type</td>
                            <td>@item.CountryName</td>
                            <td>@item.ReleaseYear</td>
                            <td>
                                @if (item.IsActive)
                                {
                                    <span class="badge badge-success">Hoạt động</span>
                                }
                                else
                                {
                                    <span class="badge badge-secondary">Tạm ẩn</span>
                                }
                                <br />
                                <span class="badge badge-info">@item.Status</span>
                            </td>
                            <td>
                                <div class="table-data-feature">
                                    <a asp-action="Details" asp-route-id="@item.Id" class="item" data-toggle="tooltip" title="Chi tiết">
                                        <i class="zmdi zmdi-eye"></i>
                                    </a>
                                    <a asp-action="Edit" asp-route-id="@item.Id" class="item" data-toggle="tooltip" title="Sửa">
                                        <i class="zmdi zmdi-edit"></i>
                                    </a>
                                    <a asp-action="Delete" asp-route-id="@item.Id" class="item" data-toggle="tooltip" title="Xóa">
                                        <i class="zmdi zmdi-delete"></i>
                                    </a>
                                </div>
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    </div>
</div>

@if (!Model.Any())
{
    <div class="row">
        <div class="col-md-12">
            <div class="alert alert-info">
                <strong>Thông báo:</strong> Chưa có phim nào. <a asp-action="Create">Thêm phim mới</a>
            </div>
        </div>
    </div>
}