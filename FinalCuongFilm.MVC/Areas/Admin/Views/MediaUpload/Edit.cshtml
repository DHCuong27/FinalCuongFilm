@model FinalCuongFilm.Common.DTOs.MediaFileUpdateDto

@{
    ViewData["Title"] = "Chỉnh sửa Media File";
}

<div class="row">
    <div class="col-md-12">
        <h2 class="title-1">@ViewData["Title"]</h2>
    </div>
</div>

<div class="row m-t-30">
    <div class="col-md-8">
        <div class="card">
            <div class="card-body">

                <form asp-action="Edit" method="post">
                    <div asp-validation-summary="ModelOnly" class="text-danger"></div>

                    <input type="hidden" asp-for="Id" />

                    <div class="form-group">
                        <label asp-for="FileName"></label>
                        <input asp-for="FileName" class="form-control" />
                        <span asp-validation-for="FileName" class="text-danger"></span>
                    </div>

                    <div class="form-group">
                        <label asp-for="FileType"></label>
                        <select asp-for="FileType" class="form-control">
                            <option value="Video">Video</option>
                            <option value="Subtitle">Subtitle</option>
                        </select>
                        <span asp-validation-for="FileType" class="text-danger"></span>
                    </div>

                    <div class="form-group">
                        <label asp-for="Quality"></label>
                        <input asp-for="Quality" class="form-control" placeholder="VD: 1080p, 720p" />
                        <span asp-validation-for="Quality" class="text-danger"></span>
                    </div>

                    <div class="form-group">
                        <label asp-for="Language"></label>
                        <input asp-for="Language" class="form-control" placeholder="VD: vi, en, jp" />
                        <span asp-validation-for="Language" class="text-danger"></span>
                    </div>

                    <hr />

                    <div class="form-group">
                        <label asp-for="MovieId">Phim</label>
                        <select asp-for="MovieId"
                                class="form-control"
                                asp-items="ViewBag.MovieId">
                            <option value="">-- Không chọn --</option>
                        </select>
                        <span asp-validation-for="MovieId" class="text-danger"></span>
                    </div>

                    <div class="form-group">
                        <label asp-for="EpisodeId">Tập phim</label>
                        <select asp-for="EpisodeId"
                                class="form-control"
                                asp-items="ViewBag.EpisodeId">
                            <option value="">-- Không chọn --</option>
                        </select>
                        <span asp-validation-for="EpisodeId" class="text-danger"></span>
                    </div>

                    <div class="alert alert-info m-t-20">
                        <i class="zmdi zmdi-info-outline"></i>
                        Media file chỉ nên gắn với <strong>phim</strong> hoặc <strong>tập phim</strong>.
                    </div>

                    <div class="m-t-30">
                        <button type="submit" class="btn btn-primary">
                            <i class="zmdi zmdi-save"></i> Lưu thay đổi
                        </button>

                        <a asp-action="Index" class="btn btn-secondary">
                            <i class="zmdi zmdi-arrow-left"></i> Quay lại
                        </a>
                    </div>

                </form>

            </div>
        </div>
    </div>
</div>
