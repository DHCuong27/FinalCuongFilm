@model FinalCuongFilm.Common.DTOs.MediaFileDto

@{
    ViewData["Title"] = "Delete Media File";
}

<div class="row">
    <div class="col-md-12">
        <h2 class="title-1 text-danger">
            <i class="zmdi zmdi-delete"></i> @ViewData["Title"]
        </h2>
    </div>
</div>

<div class="row m-t-30">
    <div class="col-md-8">
        <div class="card border-danger">
            <div class="card-body">

                <div class="alert alert-danger">
                    <strong>Cảnh báo!</strong> Hành động này không thể hoàn tác.
                </div>

                <dl class="row">

                    <dt class="col-sm-3">Tên file</dt>
                    <dd class="col-sm-9">@Model.FileName</dd>

                    <dt class="col-sm-3">Loại</dt>
                    <dd class="col-sm-9">
                        @if (Model.FileType == "Video")
                        {
                            <span class="role admin">Video</span>
                        }
                        else if (Model.FileType == "Subtitle")
                        {
                            <span class="role user">Subtitle</span>
                        }
                        else
                        {
                            <span class="role">@Model.FileType</span>
                        }
                    </dd>

                    <dt class="col-sm-3">Chất lượng</dt>
                    <dd class="col-sm-9">@Model.Quality</dd>

                    <dt class="col-sm-3">Ngôn ngữ</dt>
                    <dd class="col-sm-9">@Model.Language</dd>

                    <dt class="col-sm-3">Kích thước</dt>
                    <dd class="col-sm-9">@Model.FileSizeFormatted</dd>

                    <dt class="col-sm-3">Phim / Tập</dt>
                    <dd class="col-sm-9">
                        @if (Model.EpisodeId.HasValue)
                        {
                            <span>
                                Tập @Model.EpisodeNumber: @Model.EpisodeTitle
                            </span>
                        }
                        else if (Model.MovieId.HasValue)
                        {
                            <span>@Model.MovieTitle</span>
                        }
                    </dd>

                    <dt class="col-sm-3">Ngày upload</dt>
                    <dd class="col-sm-9">
                        @Model.UploadedAt.ToString("dd/MM/yyyy HH:mm")
                    </dd>

                </dl>

                <form asp-action="Delete" method="post">
                    <input type="hidden" asp-for="Id" />

                    <div class="m-t-30">
                        <button type="submit" class="btn btn-danger">
                            <i class="zmdi zmdi-delete"></i> Xác nhận xóa
                        </button>

                        <a asp-action="Index" class="btn btn-secondary">
                            <i class="zmdi zmdi-arrow-left"></i> Hủy
                        </a>
                    </div>
                </form>

            </div>
        </div>
    </div>

    <div class="col-md-4">
        <div class="card">
            <div class="card-body">
                <h5>File</h5>
                <a href="@Model.FileUrl" target="_blank">
                    @Model.FileUrl
                </a>

                @if (Model.FileType == "Video")
                {
                    <hr />
                    <video controls width="100%">
                        <source src="@Model.FileUrl" type="video/mp4" />
                    </video>
                }
            </div>
        </div>
    </div>
</div>
