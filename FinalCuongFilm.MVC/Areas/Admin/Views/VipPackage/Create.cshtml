@model FinalCuongFilm.ApplicationCore.Entities.VipPackage
@{
    ViewData["Title"] = "Create Premium Plan";
    Layout = "~/Areas/Admin/Views/Shared/_LayoutAdmin.cshtml";
}

<style>
    /* Form Styles */
    .form-card {
        background: var(--bg-white);
        border-radius: var(--radius-md);
        box-shadow: var(--shadow-sm);
        border: 1px solid var(--border-color);
        overflow: hidden;
    }

    .form-card-body {
        padding: 24px;
    }

    .form-group {
        margin-bottom: 20px;
    }

    .form-label {
        display: block;
        font-weight: 600;
        color: var(--text-dark);
        margin-bottom: 8px;
        font-size: 14px;
    }

    .form-control {
        width: 100%;
        padding: 10px 12px;
        border: 1px solid var(--border-color);
        border-radius: 6px;
        font-size: 14px;
        transition: all 0.2s;
        font-family: inherit;
    }

        .form-control:focus {
            outline: none;
            border-color: var(--primary-color);
            box-shadow: 0 0 0 3px rgba(37, 99, 235, 0.1);
        }

    textarea.form-control {
        resize: vertical;
        min-height: 100px;
    }

    /* Switch Toggle */
    .switch-container {
        background: var(--bg-light);
        padding: 16px;
        border-radius: 8px;
        border: 1px solid var(--border-color);
    }

    .custom-switch {
        display: flex;
        align-items: center;
        gap: 12px;
        cursor: pointer;
    }

        .custom-switch input {
            width: 44px;
            height: 24px;
            appearance: none;
            background: #cbd5e1;
            border-radius: 24px;
            position: relative;
            cursor: pointer;
            transition: all 0.2s;
        }

            .custom-switch input:checked {
                background: var(--success-color);
            }

            .custom-switch input::before {
                content: '';
                width: 20px;
                height: 20px;
                background: white;
                border-radius: 50%;
                position: absolute;
                top: 2px;
                left: 2px;
                transition: all 0.2s;
            }

            .custom-switch input:checked::before {
                left: 22px;
            }

    .switch-label {
        font-weight: 600;
        color: var(--success-color);
        margin: 0;
    }

    /* Form Actions */
    .form-actions {
        margin-top: 24px;
        padding-top: 24px;
        border-top: 1px solid var(--border-color);
        display: flex;
        gap: 12px;
    }

    /* Buttons Update */
    .btn-success {
        background: var(--success-color);
        color: white;
    }

        .btn-success:hover {
            background: #059669;
            color: white;
            box-shadow: 0 4px 12px rgba(16, 185, 129, 0.2);
        }

    .btn-secondary {
        background: var(--bg-light);
        color: var(--text-dark);
        border: 1px solid var(--border-color);
    }

        .btn-secondary:hover {
            background: #e2e8f0;
            color: var(--text-dark);
        }

    /* Grid Update */
    .form-row {
        display: grid;
        grid-template-columns: 1fr 1fr;
        gap: 24px;
    }

    .full-width {
        grid-column: 1 / -1; /* Ép phần tử chiếm toàn bộ chiều rộng của grid */
    }

    @@media (max-width: 768px) {
        .form-row

    {
        grid-template-columns: 1fr;
        gap: 16px;
    }

    .form-actions {
        flex-direction: column;
    }

        .form-actions .btn-custom {
            width: 100%;
            justify-content: center;
        }

    }
</style>

<div class="media-container">
    <div class="page-header">
        <div class="page-title">
            ➕ Create New Premium Plan
        </div>
    </div>

    <div class="form-card">
        <div class="form-card-body">
            <form asp-action="Create" method="post">
                <div class="form-row">
                    <div class="form-group">
                        <label class="form-label">Plan Name</label>
                        <input asp-for="Name" class="form-control" placeholder="e.g., 3-Month Plan" required />
                    </div>

                    <div class="form-group">
                        <label class="form-label">Price (VND)</label>
                        <input asp-for="Price" type="number" class="form-control" placeholder="e.g., 150000" required />
                    </div>

                    <div class="form-group full-width">
                        <label class="form-label">Duration (Days)</label>
                        <input asp-for="DurationInDays" type="number" class="form-control" placeholder="e.g., 90" required />
                    </div>

                    <div class="form-group full-width">
                        <label class="form-label">Benefits Description</label>
                        <textarea asp-for="Description" class="form-control" rows="4" placeholder="List the exclusive benefits of this plan..."></textarea>
                    </div>

                    <div class="form-group full-width">
                        <div class="switch-container">
                            <label class="custom-switch">
                                <input type="checkbox" asp-for="IsActive" value="true" checked />
                                <span class="switch-label">🎯 Publish and activate this plan immediately</span>
                            </label>
                        </div>
                    </div>
                </div>

                <div class="form-actions">
                    <button type="submit" class="btn-custom btn-success">💾 Save Plan</button>
                    <a asp-action="Index" class="btn-custom btn-secondary">← Back to List</a>
                </div>
            </form>
        </div>
    </div>
</div>