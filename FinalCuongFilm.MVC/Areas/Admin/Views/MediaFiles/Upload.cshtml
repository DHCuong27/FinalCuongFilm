@model FinalCuongFilm.Common.DTOs.MediaFileUploadDto

@{
    ViewData["Title"] = "Upload Media File";
}

<div class="row">
    <div class="col-md-12">
        <h2 class="title-1">@ViewData["Title"]</h2>
    </div>
</div>

<div class="row m-t-30">
    <div class="col-md-8">
        <div class="card">
            <div class="card-header">
                <strong>Upload file lên server</strong>
            </div>
            <div class="card-body card-block">
                <form asp-action="Upload" method="post" enctype="multipart/form-data">
                    <div asp-validation-summary="ModelOnly" class="text-danger"></div>

                    <div class="alert alert-warning">
                        <strong>Lưu ý:</strong>
                        <ul class="mb-0">
                            <li>Dung lượng tối đa: 2GB</li>
                            <li>Định dạng video: .mp4, .mkv, .avi, .mov, .webm</li>
                            <li>Định dạng subtitle: .srt, .vtt</li>
                        </ul>
                    </div>

                    <div class="form-group">
                        <label asp-for="MovieId" class="form-control-label">Phim</label>
                        <select asp-for="MovieId" class="form-control" asp-items="ViewBag.Movies" id="movieSelect">
                            <option value="">-- Chọn phim (nếu không chọn tập) --</option>
                        </select>
                        <span asp-validation-for="MovieId" class="text-danger"></span>
                    </div>

                    <div class="form-group">
                        <label asp-for="EpisodeId" class="form-control-label">Tập phim</label>
                        <select asp-for="EpisodeId" class="form-control" asp-items="ViewBag.Episodes" id="episodeSelect">
                            <option value="">-- Chọn tập (nếu có) --</option>
                        </select>
                        <span asp-validation-for="EpisodeId" class="text-danger"></span>
                    </div>

                    <div class="form-group">
                        <label asp-for="File" class="form-control-label">Chọn file <span class="text-danger">*</span></label>
                        <input asp-for="File" type="file" class="form-control-file" accept="video/*,.srt,.vtt" />
                        <span asp-validation-for="File" class="text-danger"></span>
                    </div>

                    <div class="row">
                        <div class="col-md-6">
                            <div class="form-group">
                                <label asp-for="FileType" class="form-control-label">Loại file</label>
                                <select asp-for="FileType" class="form-control" asp-items="ViewBag.FileTypes">
                                </select>
                                <span asp-validation-for="FileType" class="text-danger"></span>
                            </div>
                        </div>
                        <div class="col-md-6">
                            <div class="form-group">
                                <label asp-for="Quality" class="form-control-label">Chất lượng (cho video)</label>
                                <select asp-for="Quality" class="form-control" asp-items="ViewBag.Qualities">
                                    <option value="">-- Chọn chất lượng --</option>
                                </select>
                                <span asp-validation-for="Quality" class="text-danger"></span>
                            </div>
                        </div>
                    </div>

                    <div class="form-group">
                        <label asp-for="Language" class="form-control-label">Ngôn ngữ (cho subtitle)</label>
                        <input asp-for="Language" class="form-control" placeholder="Ví dụ: Tiếng Việt, English..." />
                        <span asp-validation-for="Language" class="text-danger"></span>
                    </div>

                    <div class="form-actions form-group">
                        <button type="submit" class="btn btn-success btn-sm">
                            <i class="fa fa-upload"></i> Upload
                        </button>
                        <a asp-action="Index" asp-route-movieId="@Model.MovieId" asp-route-episodeId="@Model.EpisodeId" class="btn btn-secondary btn-sm">
                            <i class="fa fa-times"></i> Hủy
                        </a>
                    </div>
                </form>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    @{
        await Html.RenderPartialAsync("_ValidationScriptsPartial");
    }
    <script>
        // Load episodes when movie is selected
        $('#movieSelect').change(function() {
            var movieId = $(this).val();
            if (movieId) {
                $.ajax({
                    url: '/Admin/Episodes/Index',
                    data: { movieId: movieId },
                    success: function(data) {
                        // Parse episodes from response and populate dropdown
                        // This is a simplified version - you may need to adjust based on your API
                    }
                });
            }
        });
    </script>
}